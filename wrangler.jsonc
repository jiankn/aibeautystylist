{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "aibeautystylist",
  "compatibility_date": "2026-04-20",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist"
  },
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "29f382b4bd0d41f187836f5b91c9dec7"
    },
    {
      "binding": "USAGE_LIMITS",
      "id": "b9b800faaf6e438ba7bf26115aa7d63d"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "aibeautystylist-db",
      "database_id": "74c8904c-b371-4fe5-a8a4-2b5604683823"
    }
  ],
  "r2_buckets": [
    {
      "binding": "USER_UPLOADS",
      "bucket_name": "aibeauty-assets"
    }
  ],
  "vars": {
    "APP_ENV": "production",
    "AI_PROVIDER": "gemini",
    "UPLOAD_PROVIDER": "r2",
    "GEMINI_MODEL": "gemini-3.5-flash",
    "GEMINI_TIMEOUT_MS": "45000",
    "GEMINI_THINKING_LEVEL": "medium"
    // 注意：GEMINI_API_KEY 应通过 wrangler secret put 设置，不要写在此文件中
    // 运行命令：npx wrangler secret put GEMINI_API_KEY
  }
}
