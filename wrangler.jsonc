{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "aibeauty",
  "compatibility_date": "2026-04-20",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist"
  },
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "replace-with-session-kv-id",
      "preview_id": "replace-with-session-kv-preview-id"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "aibeauty-db",
      "database_id": "replace-with-d1-database-id",
      "preview_database_id": "replace-with-d1-preview-database-id"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ASSETS",
      "bucket_name": "aibeauty-assets",
      "preview_bucket_name": "aibeauty-assets-preview"
    }
  ],
  "vars": {
    "APP_ENV": "development",
    "AI_PROVIDER": "gemini",
    "UPLOAD_PROVIDER": "mock"
    // 注意：GEMINI_API_KEY 应通过 wrangler secret put 设置，不要写在此文件中
    // 运行命令：npx wrangler secret put GEMINI_API_KEY
  }
}
