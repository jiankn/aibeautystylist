# AI 诊断模型 Provider（gemini / mock）
AI_PROVIDER=mock

# Gemini API Key（从 Google AI Studio 获取：https://aistudio.google.com/apikey）
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TIMEOUT_MS=45000
GEMINI_THINKING_LEVEL=medium

# Nano Banana Pro API 密钥 (用于生成带肌肤真实纹理的妆效图)
NANO_BANANA_PRO_API_KEY=

# Cloudflare 相关配置 (用于后续部署)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# 联盟营销配置 (用于 SKU 分销变现)
# AMAZON_AFFILIATE_TAG=
# SEPHORA_AFFILIATE_ID=

# ─── Evolink Z-Image-Turbo 生图 API ───
# 文档: https://evolink.ai/z-image-turbo
# 获取 API Key: https://evolink.ai/dashboard
# 用法: POST https://api.evolink.ai/v1/images/generations
#   Header: Authorization: Bearer <EVOLINK_API_KEY>
#   Body: { "model": "z-image-turbo", "prompt": "...", "size": "3:4" }
#   异步模式: 返回 task_id 后轮询 GET /v1/tasks/{task_id} 获取结果
EVOLINK_API_KEY=
EVOLINK_API_BASE=https://api.evolink.ai/v1
EVOLINK_IMAGE_MODEL=z-image-turbo
EVOLINK_IMAGE_SIZE=3:4
