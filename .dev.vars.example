# Application
APP_ENV=development
APP_PUBLIC_URL=http://localhost:4321

# AI
AI_PROVIDER=gemini
UPLOAD_PROVIDER=mock
# Keep mock locally to avoid accidental paid calls. Use gemini only with R2 uploads.
TRYON_PROVIDER=mock
# Makeup image provider: gemini (gemini-2.5-flash-image) or evolink (wan2.5-image-to-image).
IMAGE_PROVIDER=gemini
CLEANUP_SECRET=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FREE=gemini-2.5-flash-lite
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_PRIVATE_REFERENCE_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_TIMEOUT_MS=120000
GEMINI_IMAGE_TIMEOUT_MS=75000
GEMINI_THINKING_LEVEL=none
EVOLINK_API_KEY=
EVOLINK_IMAGE_MODEL=wan2.5-image-to-image
EVOLINK_IMAGE_SIZE=1280x1280
EVOLINK_IMAGE_QUALITY=low
EVOLINK_IMAGE_TIMEOUT_MS=75000

# Authentication
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# Email
POSTAL_API_URL=
POSTAL_API_KEY=
POSTAL_API_FROM_NAME=AI Beauty Stylist
SMTP_FROM=
SUPPORT_EMAIL=support@aibeautystylist.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_YEARLY=
STRIPE_PRICE_CREDITS_20=
STRIPE_PRICE_CREDITS_60=
STRIPE_PRICE_SINGLE_OCCASION=

# SEO research APIs (optional; never commit real values)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
DATAFORSEO_BASE_URL=https://api.dataforseo.com/v3
AISA_API_KEY=
AISA_BASE_URL=https://api.aisa.one/apis/v1
SEO_DEFAULT_LOCALE=en
SEO_DEFAULT_LOCATION_NAME=
SEO_DEFAULT_LANGUAGE_NAME=
SEO_RESEARCH_LOCALES=en,de,fr,ja,ko,zh-TW,es,pt-BR
