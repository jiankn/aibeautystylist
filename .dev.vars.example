# Application
APP_ENV=development
APP_PUBLIC_URL=http://localhost:4321

# AI
AI_PROVIDER=gemini
UPLOAD_PROVIDER=mock
# Keep mock locally to avoid accidental paid calls. Use gemini only with R2 uploads.
TRYON_PROVIDER=mock
# Makeup image provider: gemini (gemini-2.5-flash-image) or evolink (wan2.5-image-to-image).
IMAGE_PROVIDER=gemini
CLEANUP_SECRET=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FREE=gemini-2.5-flash-lite
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_TIMEOUT_MS=120000
GEMINI_IMAGE_TIMEOUT_MS=75000
GEMINI_THINKING_LEVEL=none
EVOLINK_API_KEY=
EVOLINK_IMAGE_MODEL=wan2.5-image-to-image
EVOLINK_IMAGE_SIZE=1280x1280
EVOLINK_IMAGE_QUALITY=low
EVOLINK_IMAGE_TIMEOUT_MS=75000

# Authentication
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# Email
POSTAL_API_URL=
POSTAL_API_KEY=
POSTAL_API_FROM_NAME=AI Beauty Stylist
SMTP_FROM=
SUPPORT_EMAIL=support@aibeautystylist.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_YEARLY=
STRIPE_PRICE_SINGLE_OCCASION=
