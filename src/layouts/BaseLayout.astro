---
import '../styles/global.css';
import UserAvatar from '../components/UserAvatar.astro';
import type { Locale } from '../lib/i18n';
import { getLocaleFromUrl, localePath, t, withoutLocalePrefix } from '../lib/i18n';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  robots?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  locale?: Locale;
}

const {
  title = 'AI Beauty Stylist — Find Your Perfect Look',
  description = 'Upload a bare-face selfie and get AI-powered shade diagnosis, personalized looks, and step-by-step tutorials you can actually follow.',
  ogImage = '/images/hero/hero-polished-elegant.webp',
  robots,
  structuredData,
  locale,
} = Astro.props;

const currentLocale = locale ?? getLocaleFromUrl(Astro.url);
const canonicalPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonicalUrl = new URL(canonicalPath, Astro.site ?? 'https://aibeautystylist.com');
const defaultLocalePath = withoutLocalePrefix(canonicalPath);
const zhAvailablePaths = new Set([
  '/',
  '/try-on/',
  '/tools/shade-finder/',
  '/tools/undertone-quiz/',
  '/tools/foundation-shade-finder-by-undertone/',
  '/makeup-guides/',
  '/lipstick-shades/',
  '/privacy/',
  '/terms/',
  '/discover/',
  '/membership/',
  '/about/',
  '/tutorial/',
  // P0 SEO 详情页：style guides
  '/styles/monolid-makeup/',
  '/styles/olive-skin-makeup/',
  '/styles/deep-skin-makeup/',
  '/styles/korean-dewy-makeup/',
  // P0 SEO 详情页：scenario guides
  '/scenarios/hooded-eyes-makeup/',
  '/scenarios/mature-skin-makeup/',
  '/scenarios/wedding-guest-makeup/',
  '/scenarios/everyday-natural-makeup/',
  // P0 SEO 详情页：lipstick shade guides
  '/lipstick-shades/warm-undertone-lipstick-shades/',
  '/lipstick-shades/cool-undertone-lipstick-shades/',
  '/lipstick-shades/neutral-undertone-lipstick-shades/',
  '/lipstick-shades/olive-skin-lipstick-shades/',
  '/lipstick-shades/deep-skin-lipstick-shades/',
  '/lipstick-shades/asian-skin-lipstick-shades/',
]);
const hasZhAlternate = zhAvailablePaths.has(defaultLocalePath);
const englishAlternateUrl = new URL(defaultLocalePath, Astro.site ?? 'https://aibeautystylist.com');
const zhAlternateUrl = new URL(localePath(defaultLocalePath, 'zh-CN'), Astro.site ?? 'https://aibeautystylist.com');
const zhSwitchUrl = hasZhAlternate ? zhAlternateUrl : new URL('/zh/', Astro.site ?? 'https://aibeautystylist.com');
// 给可见的语言切换器使用相对路径（保留本地环境可用），hreflang/canonical 仍用绝对 URL
const englishSwitchPath = defaultLocalePath;
const zhSwitchPath = hasZhAlternate ? localePath(defaultLocalePath, 'zh-CN') : '/zh/';
const ogImageUrl = new URL(ogImage, Astro.site ?? 'https://aibeautystylist.com');
const structuredDataItems = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
const navHrefs = currentLocale === 'zh-CN'
  ? {
      brand: '/zh/',
      discover: '/zh/discover/',
      tryOn: '/zh/try-on/',
      tutorials: '/zh/tutorial/',
      beautyKit: '/zh/tools/shade-finder/',
      membership: '/zh/membership/?from=nav_top',
    }
  : {
      brand: '/',
      discover: '/discover',
      tryOn: '/try-on',
      tutorials: '/tutorial',
      beautyKit: '/tools/shade-finder',
      membership: '/membership?from=nav_top',
    };
const footerHrefs = currentLocale === 'zh-CN'
  ? {
      discoverLooks: '/zh/discover/',
      aiTryOnStudio: '/zh/try-on/',
      shadeFinder: '/zh/tools/shade-finder/',
      makeupGuides: '/zh/makeup-guides/',
      lipstickShades: '/zh/lipstick-shades/',
      tutorials: '/zh/tutorial/',
      membership: '/zh/membership/?from=nav_footer',
      about: '/zh/about/',
      privacy: '/zh/privacy/',
      terms: '/zh/terms/',
    }
  : {
      discoverLooks: '/discover',
      aiTryOnStudio: '/try-on',
      shadeFinder: '/tools/shade-finder',
      makeupGuides: '/makeup-guides',
      lipstickShades: '/lipstick-shades',
      tutorials: '/tutorial',
      membership: '/membership?from=nav_footer',
      about: '/about',
      privacy: '/privacy',
      terms: '/terms',
    };
---

<!doctype html>
<html lang={currentLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <meta name="theme-color" content="#f7f3ef" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- i18n: hreflang (Phase 2 will add additional languages here) -->
    <link rel="alternate" hreflang="en" href={englishAlternateUrl} />
    {hasZhAlternate && <link rel="alternate" hreflang="zh-CN" href={zhAlternateUrl} />}
    <link rel="alternate" hreflang="x-default" href={englishAlternateUrl} />

    <!-- Favicon -->
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>💄</text></svg>" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="AI Beauty Stylist" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {structuredDataItems.map((item) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="container nav-wrap">
          <a class="brand" href={navHrefs.brand}>
            <span class="brand-mark">AB</span>
            <span>AI Beauty Stylist</span>
          </a>
          <nav class="nav-links" id="main-nav">
            <a href={navHrefs.discover}>{t('nav.discover', currentLocale)}</a>
            <a href={navHrefs.tryOn}>{t('nav.tryOn', currentLocale)}</a>
            <a href={navHrefs.tutorials}>{t('nav.tutorials', currentLocale)}</a>
            <a href={navHrefs.beautyKit}>{t('nav.beautyKit', currentLocale)}</a>
            <a href={navHrefs.membership}>{t('nav.membership', currentLocale)}</a>
            <div class="language-switcher" data-language-switcher>
              <button
                type="button"
                class="language-switcher-trigger"
                data-language-trigger
                aria-haspopup="listbox"
                aria-expanded="false"
                aria-label="Select language"
              >
                <svg class="language-switcher-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="10" />
                  <line x1="2" y1="12" x2="22" y2="12" />
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                </svg>
                <span class="language-switcher-label">{currentLocale === 'zh-CN' ? '简体中文' : 'English'}</span>
                <svg class="language-switcher-caret" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </button>
              <ul class="language-switcher-menu" role="listbox" data-language-menu hidden>
                <li role="option" aria-selected={currentLocale === 'en'}>
                  <a href={englishSwitchPath} class:list={['language-switcher-item', { 'is-active': currentLocale === 'en' }]}>English</a>
                </li>
                <li role="option" aria-selected={currentLocale === 'zh-CN'}>
                  <a href={zhSwitchPath} class:list={['language-switcher-item', { 'is-active': currentLocale === 'zh-CN' }]}>简体中文</a>
                </li>
              </ul>
            </div>
          </nav>
          <UserAvatar />
          <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
            <span></span><span></span><span></span>
          </button>
        </div>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        <div class="container footer-grid">
          <div>
            <p class="footer-title">AI Beauty Stylist</p>
            <p class="footer-copy">
              {t('footer.description', currentLocale)}
            </p>
            <div class="footer-social">
              <a href="#" aria-label="Instagram" class="social-link">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              </a>
              <a href="#" aria-label="TikTok" class="social-link">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1 0-5.78 2.92 2.92 0 0 1 .88.13V9a6.34 6.34 0 1 0 5.45 6.29V9.41a8.16 8.16 0 0 0 4.77 1.52V7.49a4.85 4.85 0 0 1-1-.8z"/></svg>
              </a>
              <a href="#" aria-label="YouTube" class="social-link">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.13C5.12 19.56 12 19.56 12 19.56s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.43z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/></svg>
              </a>
            </div>
          </div>
          <div class="footer-nav-col">
            <div>
              <p class="footer-title">{t('footer.explore', currentLocale)}</p>
              <ul class="footer-list">
                <li><a href={footerHrefs.discoverLooks}>{t('footer.discoverLooks', currentLocale)}</a></li>
                <li><a href={footerHrefs.aiTryOnStudio}>{t('footer.aiTryOnStudio', currentLocale)}</a></li>
                <li><a href={footerHrefs.shadeFinder}>{t('footer.shadeFinder', currentLocale)}</a></li>
                <li><a href={footerHrefs.makeupGuides}>{t('footer.makeupGuides', currentLocale)}</a></li>
                <li><a href={footerHrefs.lipstickShades}>{t('footer.lipstickShades', currentLocale)}</a></li>
                <li><a href={footerHrefs.tutorials}>{t('footer.tutorials', currentLocale)}</a></li>
                <li><a href={footerHrefs.membership}>{t('footer.membership', currentLocale)}</a></li>
              </ul>
            </div>
            <div>
              <p class="footer-title">{t('footer.company', currentLocale)}</p>
              <ul class="footer-list">
                <li><a href={footerHrefs.about}>{t('footer.about', currentLocale)}</a></li>
                <li><a href={footerHrefs.privacy}>{t('footer.privacy', currentLocale)}</a></li>
                <li><a href={footerHrefs.terms}>{t('footer.terms', currentLocale)}</a></li>
              </ul>
            </div>
          </div>
        </div>
        <p class="footer-legal container">{t('footer.legal', currentLocale)}</p>
      </footer>
    </div>
    <script>
      // 汉堡菜单交互
      const toggle = document.getElementById('nav-toggle');
      const nav = document.getElementById('main-nav');
      const closeMobileNav = () => {
        if (!nav || !toggle) return;
        nav.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.classList.remove('is-active');
      };
      toggle?.addEventListener('click', (event) => {
        event.stopPropagation();
        const open = nav?.classList.toggle('is-open');
        toggle.setAttribute('aria-expanded', String(!!open));
        toggle.classList.toggle('is-active', !!open);
      });
      // 点击导航外部 / ESC 自动收起移动端汉堡菜单
      document.addEventListener('click', (event) => {
        if (!nav || !toggle) return;
        if (!nav.classList.contains('is-open')) return;
        const target = event.target as Node;
        if (nav.contains(target) || toggle.contains(target)) return;
        closeMobileNav();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeMobileNav();
      });

      // 语言切换器下拉
      const langSwitcher = document.querySelector('[data-language-switcher]');
      const langTrigger = langSwitcher?.querySelector('[data-language-trigger]') as HTMLButtonElement | null;
      const langMenu = langSwitcher?.querySelector('[data-language-menu]') as HTMLElement | null;
      const closeLangMenu = () => {
        if (!langMenu || !langTrigger) return;
        langMenu.hidden = true;
        langSwitcher?.classList.remove('is-open');
        langTrigger.setAttribute('aria-expanded', 'false');
      };
      const openLangMenu = () => {
        if (!langMenu || !langTrigger) return;
        langMenu.hidden = false;
        langSwitcher?.classList.add('is-open');
        langTrigger.setAttribute('aria-expanded', 'true');
      };
      langTrigger?.addEventListener('click', (event) => {
        event.stopPropagation();
        if (langMenu?.hidden) openLangMenu();
        else closeLangMenu();
      });
      document.addEventListener('click', (event) => {
        if (!langSwitcher) return;
        if (!langSwitcher.contains(event.target as Node)) closeLangMenu();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeLangMenu();
      });

      // 滚动入场动画 (IntersectionObserver)
      document.addEventListener('DOMContentLoaded', () => {
        const targets = document.querySelectorAll(
          '.section-copy, .card, .look-card, .hero-visuals, .hero-copy, .trust-panel, .plans-panel, .pricing-card, .footer-grid'
        );
        targets.forEach((el) => {
          el.setAttribute('data-reveal', '');
          const parent = el.parentElement;
          if (parent && (parent.classList.contains('grid-cards') || parent.classList.contains('grid-cards-3') || parent.classList.contains('grid-cards-2') || parent.classList.contains('plan-stack'))) {
            const siblings = Array.from(parent.children);
            const idx = siblings.indexOf(el);
            if (idx > 0) el.setAttribute('data-reveal-delay', String(Math.min(idx, 5)));
          }
        });

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

        document.querySelectorAll('[data-reveal]').forEach(el => observer.observe(el));
      });

      // Look conversion analytics: collect once, score server-side.
      (() => {
        const sessionKey = 'aibeauty_analytics_session_id';
        const anonymousKey = 'aibeauty_analytics_anonymous_id';
        const attributionKey = 'aibeauty_look_attribution';

        type AnalyticsPayload = {
          lookSlug?: string;
          styleSlug?: string;
          source?: string;
          position?: string | number;
          route?: string;
          referrer?: string;
          metadata?: Record<string, unknown>;
          [key: string]: unknown;
        };

        type AnalyticsWindow = Window & typeof globalThis & {
          aiBeautyAnalytics?: {
            track: (name: string, data?: AnalyticsPayload) => void;
            getAttribution: () => AnalyticsPayload;
            setAttribution: (input: AnalyticsPayload) => AnalyticsPayload;
          };
        };

        const analyticsWindow = window as AnalyticsWindow;

        function createId(prefix: string) {
          const random = globalThis.crypto?.randomUUID?.() ?? `${Date.now()}-${Math.random().toString(36).slice(2)}`;
          return `${prefix}_${random}`;
        }

        function readStorage(storage: Storage, key: string) {
          try {
            return storage.getItem(key);
          } catch {
            return null;
          }
        }

        function writeStorage(storage: Storage, key: string, value: string) {
          try {
            storage.setItem(key, value);
          } catch {
            // Storage can be blocked in privacy modes; analytics should never break UX.
          }
        }

        function getStableId(storage: Storage, key: string, prefix: string) {
          const existing = readStorage(storage, key);
          if (existing) return existing;
          const next = createId(prefix);
          writeStorage(storage, key, next);
          return next;
        }

        function cleanAttr(value: unknown) {
          return typeof value === 'string' && value.trim() ? value.trim() : undefined;
        }

        function readAttributionFromUrl() {
          const params = new URLSearchParams(window.location.search);
          return {
            lookSlug: cleanAttr(params.get('look') || undefined),
            styleSlug: cleanAttr(params.get('style') || undefined),
            source: cleanAttr(params.get('source') || undefined),
            position: cleanAttr(params.get('position') || undefined),
          };
        }

        function readAttributionFromElement(element: Element | null) {
          const dataset = element instanceof HTMLElement ? element.dataset : {};
          return {
            lookSlug: cleanAttr(dataset.analyticsLookSlug),
            styleSlug: cleanAttr(dataset.analyticsStyleSlug),
            source: cleanAttr(dataset.analyticsSource),
            position: cleanAttr(dataset.analyticsPosition),
          };
        }

        function getStoredAttribution(): AnalyticsPayload {
          try {
            return JSON.parse(readStorage(sessionStorage, attributionKey) || '{}') || {};
          } catch {
            return {};
          }
        }

        function storeAttribution(input: AnalyticsPayload) {
          const previous = getStoredAttribution();
          const next = {
            ...previous,
            ...Object.fromEntries(Object.entries(input).filter(([, value]) => value !== undefined && value !== null && value !== '')),
          };
          if (next.lookSlug || next.styleSlug) {
            writeStorage(sessionStorage, attributionKey, JSON.stringify(next));
          }
          return next;
        }

        function normalizePayload(input: AnalyticsPayload = {}) {
          const stored = getStoredAttribution();
          const url = readAttributionFromUrl();
          const merged = {
            ...stored,
            ...Object.fromEntries(Object.entries(url).filter(([, value]) => value)),
            ...Object.fromEntries(Object.entries(input).filter(([, value]) => value !== undefined && value !== null && value !== '')),
          };
          return {
            ...merged,
            position: merged.position ? Number(merged.position) : undefined,
            sessionId: getStableId(sessionStorage, sessionKey, 'session'),
            anonymousId: getStableId(localStorage, anonymousKey, 'anon'),
            route: window.location.pathname + window.location.search,
            referrer: document.referrer || undefined,
          };
        }

        function trackLookEvent(eventName: string, input: AnalyticsPayload = {}) {
          const payload = normalizePayload(input);
          if (!payload.lookSlug && !payload.styleSlug && ![
            'membership_click',
            'upgrade_click',
            'register_success',
            'checkout_started',
            'checkout_success',
            'share_click',
            'save_click',
            'save_look',
            'save_look_remove',
            'set_my_style',
            'clear_my_style',
            'find_style_filter',
            'find_style_view_all',
            'find_style_view_guide',
          ].includes(eventName)) return;
          const body = JSON.stringify({ eventName, ...payload });
          const url = '/api/analytics/look-event';
          if (navigator.sendBeacon) {
            const sent = navigator.sendBeacon(url, new Blob([body], { type: 'application/json' }));
            if (sent) return;
          }
          fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body,
            keepalive: true,
          }).catch(() => {});
        }

        analyticsWindow.aiBeautyAnalytics = {
          track: trackLookEvent,
          getAttribution: getStoredAttribution,
          setAttribution: storeAttribution,
        };

        storeAttribution(readAttributionFromUrl());

        document.addEventListener('click', (event) => {
          const target = event.target instanceof Element ? event.target : null;
          if (!target) return;

          const lookElement = target.closest('[data-analytics-look]');
          if (lookElement instanceof HTMLElement) {
            const attribution = storeAttribution(readAttributionFromElement(lookElement));
            trackLookEvent('look_click', attribution);
          }

          const eventElement = target.closest('[data-analytics-event]');
          if (eventElement instanceof HTMLElement) {
            trackLookEvent(eventElement.dataset.analyticsEvent || '', readAttributionFromElement(eventElement));
          }

          const link = target.closest('a[href]');
          if (link instanceof HTMLAnchorElement) {
            const href = link.getAttribute('href') || '';
            if (href.startsWith('/membership') || href.includes('/membership?')) {
              // P1 — 透传 ?from= 作为 source 便于 analytics 区分入口
              let source: string | undefined;
              try {
                const url = new URL(href, window.location.origin);
                source = url.searchParams.get('from') || undefined;
              } catch {
                source = undefined;
              }
              trackLookEvent('membership_click', source ? { source } : {});
            }
          }
        });

        document.addEventListener('DOMContentLoaded', () => {
          const elements = Array.from(document.querySelectorAll('[data-analytics-look]'));
          if (!elements.length) return;
          const seen = new WeakSet();
          const impressionObserver = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting || seen.has(entry.target)) return;
              seen.add(entry.target);
              if (entry.target instanceof HTMLElement) {
                trackLookEvent('look_impression', readAttributionFromElement(entry.target));
              }
              impressionObserver.unobserve(entry.target);
            });
          }, { threshold: 0.5 });
          elements.forEach((element) => impressionObserver.observe(element));
        });
      })();
    </script>
  </body>
</html>
