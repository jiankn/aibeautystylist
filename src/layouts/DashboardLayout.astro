---
/**
 * DashboardLayout — 账户中心专用布局
 *
 * 在 BaseLayout 基础上加上：
 *  - 左侧导航（Overview / Subscription / History / Privacy）
 *  - 主区容器（slot）
 *  - 客户端守卫脚本：未登录时自动跳转 /login
 */
import BaseLayout from './BaseLayout.astro';

interface Props {
  title?: string;
  pageKey: 'overview' | 'subscription' | 'history' | 'privacy';
  pageHeading: string;
  pageDescription?: string;
}

const { title, pageKey, pageHeading, pageDescription } = Astro.props;

const navItems: Array<{
  key: Props['pageKey'];
  href: string;
  label: string;
  icon: string;
  description: string;
}> = [
  {
    key: 'overview',
    href: '/dashboard',
    label: 'Overview',
    icon: 'M3 12h2v8H3zM9 8h2v12H9zM15 4h2v16h-2zM21 14h-2v6h2z',
    description: 'Plan, usage, recent try-ons',
  },
  {
    key: 'subscription',
    href: '/dashboard/subscription',
    label: 'Subscription',
    icon: 'M21 4H3a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h18a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zM1 10h22',
    description: 'Plan, billing, invoices',
  },
  {
    key: 'history',
    href: '/dashboard/history',
    label: 'Try-On History',
    icon: 'M12 8v4l3 3M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z',
    description: 'All your past sessions',
  },
  {
    key: 'privacy',
    href: '/dashboard/privacy',
    label: 'Privacy & Data',
    icon: 'M12 2L3 7v6c0 5 3.5 9 9 11 5.5-2 9-6 9-11V7l-9-5z',
    description: 'Delete data, account',
  },
];
---

<BaseLayout title={title ?? `${pageHeading} — Dashboard`} robots="noindex,nofollow">
  <section class="dashboard-shell">
    <div class="container dashboard-grid">
      <aside class="dashboard-side" aria-label="Account navigation">
        <p class="dashboard-side-eyebrow">My Account</p>
        <nav class="dashboard-nav">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={['dashboard-nav-item', { 'is-active': item.key === pageKey }]}
              aria-current={item.key === pageKey ? 'page' : undefined}
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={item.icon} />
              </svg>
              <span class="dashboard-nav-text">
                <strong>{item.label}</strong>
                <small>{item.description}</small>
              </span>
            </a>
          ))}
        </nav>
        <form action="/api/auth/logout" method="POST" class="dashboard-signout-form">
          <button type="submit" class="dashboard-signout">Sign out</button>
        </form>
      </aside>

      <main class="dashboard-main" aria-labelledby="dashboard-heading">
        <header class="dashboard-page-header">
          <h1 id="dashboard-heading">{pageHeading}</h1>
          {pageDescription && <p>{pageDescription}</p>}
        </header>
        <div class="dashboard-content">
          <slot />
        </div>
      </main>
    </div>
  </section>
</BaseLayout>

<script>
  // 客户端守卫：检查是否登录，未登录则跳转 OAuth
  (async () => {
    try {
      const resp = await fetch('/api/auth/me');
      const data = await resp.json();
      if (!data.authenticated) {
        const next = encodeURIComponent(window.location.pathname);
        window.location.replace(`/login?next=${next}`);
      }
    } catch {
      // 网络故障时不强制跳转，避免死循环
    }
  })();
</script>
