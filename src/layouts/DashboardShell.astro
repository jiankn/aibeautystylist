---
/**
 * DashboardShell — 账户中心 V2 骨架（Editorial Concierge × Operational Strip）
 *
 * 三层结构：
 *   1) Hero        左 identity + 右 hero-aside slot（每页不同）
 *   2) Strip       4 个紧凑指标 chip（slot="strip"）
 *   3) Split       主列 slot="main" + 副列 slot="aside"（桌面 ≥ 1024px 双列）
 *
 * 左侧 floating glass nav：桌面 ≥ 1024px 显示；移动端收为 hero 下方横向 chip nav。
 * 客户端守卫：未登录跳 /login？next=...
 */
import BaseLayout from './BaseLayout.astro';

interface Props {
  title?: string;
  pageKey: 'overview' | 'subscription' | 'history' | 'privacy';
  pageHeading: string;
  pageDescription?: string;
}

const { title, pageKey, pageHeading, pageDescription } = Astro.props;

const navItems: Array<{
  key: Props['pageKey'];
  href: string;
  label: string;
  icon: string;
  description: string;
}> = [
  {
    key: 'overview',
    href: '/dashboard',
    label: 'Overview',
    icon: 'M3 12h2v8H3zM9 8h2v12H9zM15 4h2v16h-2zM21 14h-2v6h2z',
    description: 'Plan, usage, recent try-ons',
  },
  {
    key: 'subscription',
    href: '/dashboard/subscription',
    label: 'Subscription',
    icon: 'M21 4H3a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h18a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zM1 10h22',
    description: 'Plan, billing, invoices',
  },
  {
    key: 'history',
    href: '/dashboard/history',
    label: 'Try-On History',
    icon: 'M12 8v4l3 3M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z',
    description: 'All your past sessions',
  },
  {
    key: 'privacy',
    href: '/dashboard/privacy',
    label: 'Privacy & Data',
    icon: 'M12 2L3 7v6c0 5 3.5 9 9 11 5.5-2 9-6 9-11V7l-9-5z',
    description: 'Delete data, account',
  },
];
---

<BaseLayout title={title ?? `${pageHeading} — Dashboard`} robots="noindex,nofollow">
  <section class="db-shell">
    <div class="container db-grid">
      <!-- ── Sidebar (desktop floating glass rail) ────────────────────── -->
      <aside class="db-sidebar" aria-label="Account navigation">
        <div class="db-sidebar-card">
          <p class="db-sidebar-eyebrow">My Account</p>
          <nav class="db-nav">
            {navItems.map((item) => (
              <a
                href={item.href}
                class:list={['db-nav-item', { 'is-active': item.key === pageKey }]}
                aria-current={item.key === pageKey ? 'page' : undefined}
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={item.icon} />
                </svg>
                <span class="db-nav-text">
                  <strong>{item.label}</strong>
                  <small>{item.description}</small>
                </span>
              </a>
            ))}
          </nav>
          <form action="/api/auth/logout" method="POST" class="db-signout-form">
            <button type="submit" class="db-signout">Sign out</button>
          </form>
        </div>
      </aside>

      <!-- ── Main column ──────────────────────────────────────────────── -->
      <main class="db-main" aria-labelledby="db-heading">
        <!-- Hero -->
        <header class="db-hero">
          <div class="db-hero-identity">
            <p class="db-hero-eyebrow" data-db-eyebrow>My account</p>
            <h1 id="db-heading" class="db-hero-title">{pageHeading}</h1>
            {pageDescription && <p class="db-hero-description">{pageDescription}</p>}
            <slot name="hero-actions" />
          </div>
          <div class="db-hero-aside">
            <slot name="hero-aside">
              <div class="db-hero-aside-placeholder" aria-hidden="true" />
            </slot>
          </div>
        </header>

        <!-- Mobile chip nav (≤ 1023px) -->
        <nav class="db-mobile-nav" aria-label="Account navigation (mobile)">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={['db-mobile-chip', { 'is-active': item.key === pageKey }]}
              aria-current={item.key === pageKey ? 'page' : undefined}
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={item.icon} />
              </svg>
              <span>{item.label}</span>
            </a>
          ))}
        </nav>

        <!-- Stat strip -->
        <section class="db-strip" aria-label="At a glance">
          <slot name="strip" />
        </section>

        <!-- Split: main + aside -->
        <div class="db-split">
          <div class="db-main-col">
            <slot name="main" />
            <slot />
          </div>
          <aside class="db-aside-col" aria-label="Suggestions">
            <slot name="aside" />
          </aside>
        </div>
      </main>
    </div>
  </section>
</BaseLayout>

<script>
  // 客户端守卫：未登录则跳 /login
  (async () => {
    try {
      const resp = await fetch('/api/auth/me');
      const data = await resp.json();
      if (!data.authenticated) {
        const next = encodeURIComponent(window.location.pathname);
        window.location.replace(`/login?next=${next}`);
      }
    } catch {
      // 网络故障时不强制跳转，避免死循环
    }
  })();
</script>
