---
/**
 * DashboardShell — 账户中心 V3 骨架（Vogue Editorial Magazine）
 *
 * 结构：
 *   1) Hero        横排 portrait + identity + hero-aside slot（杀手锁）
 *   2) Sub-nav     一行 editorial 下划线 nav（Overview/Subscription/History/Privacy）+ 右侧 Sign out
 *   3) Strip       slot="strip" 細线分隔 serif 数字
 *   4) Split       slot="main" + slot="aside"
 *
 * 客户端守卫：未登录跳 /login？next=...
 */
import BaseLayout from './BaseLayout.astro';
import type { Locale } from '../lib/i18n';
import { getLocaleFromUrl, localePath } from '../lib/i18n';

interface Props {
  title?: string;
  locale?: Locale;
  pageKey: 'overview' | 'subscription' | 'history' | 'privacy';
  pageHeading: string;
  pageDescription?: string;
}

const { title, locale, pageKey, pageHeading, pageDescription } = Astro.props;
const currentLocale = locale ?? getLocaleFromUrl(Astro.url);
const isZh = currentLocale === 'zh-CN';

const shellText = isZh
  ? {
      titleSuffix: '账户中心',
      accountNavLabel: '账户导航',
      welcomeBack: '欢迎回来',
      beautyPass: 'Beauty Pass',
      featured: '重点推荐',
      atAGlance: '快速概览',
      suggestions: '建议',
      nav: {
        overview: ['总览', '总览'],
        subscription: ['订阅与账单', '订阅'],
        history: ['试妆历史', '历史'],
        privacy: ['隐私与数据', '隐私'],
      },
    }
  : {
      titleSuffix: 'Dashboard',
      accountNavLabel: 'Account navigation',
      welcomeBack: 'Welcome back',
      beautyPass: 'Beauty Pass',
      featured: 'Featured',
      atAGlance: 'At a glance',
      suggestions: 'Suggestions',
      nav: {
        overview: ['Overview', 'Overview'],
        subscription: ['Subscription', 'Plan'],
        history: ['Try-On History', 'History'],
        privacy: ['Privacy & Data', 'Privacy'],
      },
    };

const navItems: Array<{
  key: Props['pageKey'];
  href: string;
  label: string;
  shortLabel: string;
}> = [
  { key: 'overview', href: localePath('/dashboard', currentLocale), label: shellText.nav.overview[0], shortLabel: shellText.nav.overview[1] },
  { key: 'subscription', href: localePath('/dashboard/subscription', currentLocale), label: shellText.nav.subscription[0], shortLabel: shellText.nav.subscription[1] },
  { key: 'history', href: localePath('/dashboard/history', currentLocale), label: shellText.nav.history[0], shortLabel: shellText.nav.history[1] },
  { key: 'privacy', href: localePath('/dashboard/privacy', currentLocale), label: shellText.nav.privacy[0], shortLabel: shellText.nav.privacy[1] },
];
---

<BaseLayout locale={currentLocale} title={title ?? `${pageHeading} — ${shellText.titleSuffix}`} robots="noindex,nofollow">
  <section class="db-shell">
    <div class="container">
      <main class="db-main" aria-labelledby="db-heading">
        <h1 id="db-heading" class="sr-only">{pageHeading}</h1>

        <!-- ── Nameplate + Sub-nav (一行集成) ──────────────────── -->
        <nav class="db-subnav" aria-label={shellText.accountNavLabel}>
          <div class="db-nameplate">
            <span class="db-nameplate-portrait" aria-hidden="true" data-db-portrait>A</span>
            <span class="db-nameplate-text">
              <strong data-db-greeting>{shellText.welcomeBack}</strong>
              <small data-db-eyebrow>{shellText.beautyPass}</small>
            </span>
          </div>
          <div class="db-subnav-inner">
            {navItems.map((item) => (
              <a
                href={item.href}
                class:list={['db-subnav-item', { 'is-active': item.key === pageKey }]}
                aria-current={item.key === pageKey ? 'page' : undefined}
              >
                <span class="db-subnav-full">{item.label}</span>
                <span class="db-subnav-short">{item.shortLabel}</span>
              </a>
            ))}
          </div>
        </nav>

        <!-- ── Page intro (description + 主 CTA) ──────────────────── -->
        {pageDescription && (
          <p class="db-page-description">{pageDescription}</p>
        )}
        <slot name="hero-actions" />

        <!-- ── Feature block (原 hero-aside 升级为主块) ──────────── -->
        <section class="db-feature" aria-label={shellText.featured}>
          <slot name="hero-aside" />
        </section>

        <!-- ── Stat strip ─────────────────────────────────────────── -->
        <section class="db-strip" aria-label={shellText.atAGlance}>
          <slot name="strip" />
        </section>

        <!-- ── Split: main + aside ────────────────────────────────── -->
        <div class="db-split">
          <div class="db-main-col">
            <slot name="main" />
            <slot />
          </div>
          <aside class="db-aside-col" aria-label={shellText.suggestions}>
            <slot name="aside" />
          </aside>
        </div>
      </main>
    </div>
  </section>
</BaseLayout>

<script>
  // 客户端守卫：未登录则跳 /login
  (async () => {
    try {
      const resp = await fetch('/api/auth/me');
      const data = await resp.json();
      if (!data.authenticated) {
        const next = encodeURIComponent(window.location.pathname);
        window.location.replace(`/login?next=${next}`);
      }
    } catch {
      // 网络故障时不强制跳转，避免死循环
    }
  })();

  // Nameplate 填充（portrait 首字母 + 问候 + plan）
  const DB_LOCALE = document.documentElement.lang;
  const DB_COPY = DB_LOCALE === 'zh-CN'
    ? {
        freeExplorer: '免费体验版',
        fallbackName: '你',
        greeting: (name: string) => `${name}，欢迎回来`,
      }
    : {
        freeExplorer: 'Free Explorer',
        fallbackName: 'there',
        greeting: (name: string) => `Hi, ${name}`,
      };

  type NameplateUser = { name: string | null; email: string | null; tier: string };
  type NameplateOverview = {
    user: NameplateUser;
    subscription: null | { planName: string };
  };

  function tierLabel(tier: string): string {
    if (tier === 'pro') return 'Beauty Pass Pro';
    if (tier === 'premium') return 'Premium';
    return DB_COPY.freeExplorer;
  }

  function firstNameOf(user: NameplateUser): string {
    if (user.name && user.name.trim().length > 0) return user.name.trim().split(/\s+/)[0];
    if (user.email) return user.email.split('@')[0];
    return DB_COPY.fallbackName;
  }

  (async () => {
    try {
      const resp = await fetch('/api/account/overview');
      if (!resp.ok) return;
      const data = (await resp.json()) as NameplateOverview;
      const name = firstNameOf(data.user);
      const plan = data.subscription?.planName ?? tierLabel(data.user.tier);
      const initial = (name.charAt(0) || 'A').toUpperCase();

      const portrait = document.querySelector<HTMLElement>('[data-db-portrait]');
      if (portrait) portrait.textContent = initial;
      const greeting = document.querySelector<HTMLElement>('[data-db-greeting]');
      if (greeting) greeting.textContent = DB_COPY.greeting(name);
      const eyebrow = document.querySelector<HTMLElement>('[data-db-eyebrow]');
      if (eyebrow) eyebrow.textContent = plan;
    } catch {
      // 静默失败：保持默认占位
    }
  })();
</script>
