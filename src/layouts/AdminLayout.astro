---
/**
 * 管理后台专用布局。
 * 提供独立于用户端的后台导航、顶部工具栏与简体中文/英文文案。
 */
type AdminNavId =
  | "overview"
  | "users"
  | "revenue"
  | "ai-costs"
  | "support"
  | "settings";

interface Props {
  title: string;
  activeNav?: AdminNavId;
}

const { title, activeNav = "overview" } = Astro.props as Props;
const currentLang =
  Astro.url.searchParams.get("lang") === "en" ? "en" : "zh-cn";

const adminCopy = {
  "zh-cn": {
    htmlLang: "zh-CN",
    console: "Admin",
    returnSite: "返回网站",
    logout: "退出",
    loggingOut: "退出中",
    menu: "打开后台菜单",
    adminRole: "超级管理员",
    search: "搜索用户、工单、功能...",
    searchLabel: "后台搜索",
    dateRange: "最近 14 天",
    refresh: "刷新",
    live: "系统正常",
    breadcrumb: "管理后台",
    language: "语言",
    nav: {
      overview: "总览",
      users: "用户",
      revenue: "收入",
      "ai-costs": "AI 成本",
      support: "工单",
      settings: "设置",
    },
  },
  en: {
    htmlLang: "en",
    console: "Admin",
    returnSite: "Back to site",
    logout: "Sign out",
    loggingOut: "Signing out",
    menu: "Open admin menu",
    adminRole: "Super admin",
    search: "Search users, tickets, features...",
    searchLabel: "Admin search",
    dateRange: "Last 14 days",
    refresh: "Refresh",
    live: "System healthy",
    breadcrumb: "Admin",
    language: "Language",
    nav: {
      overview: "Overview",
      users: "Users",
      revenue: "Revenue",
      "ai-costs": "AI costs",
      support: "Support",
      settings: "Settings",
    },
  },
} as const;

const copy = adminCopy[currentLang];

const withLang = (href: string) => {
  const url = new URL(href, Astro.url.origin);
  if (currentLang === "en") {
    url.searchParams.set("lang", "en");
  } else {
    url.searchParams.delete("lang");
  }
  return `${url.pathname}${url.search}${url.hash}`;
};

const langHref = (lang: "zh-cn" | "en") => {
  const url = new URL(Astro.url);
  if (lang === "en") {
    url.searchParams.set("lang", "en");
  } else {
    url.searchParams.delete("lang");
  }
  return `${url.pathname}${url.search}${url.hash}`;
};

const navItems: Array<{ id: AdminNavId; href: string; icon: string }> = [
  { id: "overview", href: "/admin", icon: "chart" },
  { id: "users", href: "/admin/users", icon: "users" },
  { id: "revenue", href: "/admin/revenue", icon: "dollar" },
  { id: "ai-costs", href: "/admin/ai-costs", icon: "cpu" },
  { id: "support", href: "/admin/support", icon: "ticket" },
  { id: "settings", href: "/admin?panel=settings", icon: "settings" },
];

const fontStylesheet =
  currentLang === "zh-cn"
    ? "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+SC:wght@400;500;600;700;800&display=swap"
    : "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap";

const now = new Date();
const rangeStart = new Date(now.getTime() - 13 * 24 * 60 * 60 * 1000);
const formatRangeDate = (date: Date) => {
  const month = String(date.getMonth() + 1).padStart(2, "0");
  const day = String(date.getDate()).padStart(2, "0");
  return `${date.getFullYear()}-${month}-${day}`;
};
const dateRangeLabel = `${formatRangeDate(rangeStart)} ~ ${formatRangeDate(now)}`;
---

<!doctype html>
<html lang={copy.htmlLang} data-admin-lang={currentLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{title} - AI Beauty Stylist Admin</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={fontStylesheet} rel="stylesheet" />
    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      :root {
        --admin-bg: #f8f7fa;
        --admin-bg-strong: #f4f0f4;
        --admin-sidebar: #ffffff;
        --admin-sidebar-2: #fdfbfc;
        --admin-surface: #ffffff;
        --admin-surface-soft: #fbf8fb;
        --admin-surface-hover: #f8eff4;
        --admin-border: #e8e2e8;
        --admin-border-strong: #d7cbd6;
        --admin-text: #17112b;
        --admin-text-muted: #615b70;
        --admin-text-dim: #8f8799;
        --admin-primary: #b8326b;
        --admin-primary-strong: #8b1f4d;
        --admin-primary-soft: #fae8f1;
        --admin-plum: #4b2447;
        --admin-teal: #0f8b83;
        --admin-blue: #2563eb;
        --admin-amber: #b76a00;
        --admin-red: #c6284c;
        --admin-green: #11805d;
        --admin-shadow: 0 16px 36px rgba(42, 27, 46, 0.08);
        --admin-sidebar-w: 220px;
        --admin-topbar-h: 56px;
        --admin-radius: 8px;
        --admin-radius-sm: 6px;
        --admin-font:
          "Inter", "Noto Sans SC", system-ui, -apple-system, sans-serif;
        --admin-mono: "SFMono-Regular", Consolas, "Liberation Mono", monospace;
      }

      html,
      body {
        min-height: 100vh;
        margin: 0;
        background: var(--admin-bg);
        color: var(--admin-text);
        font-family: var(--admin-font);
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
      }

      a,
      button,
      input,
      select {
        font: inherit;
      }

      a:focus-visible,
      button:focus-visible,
      input:focus-visible,
      select:focus-visible {
        outline: 3px solid rgba(184, 50, 107, 0.28);
        outline-offset: 2px;
      }

      button {
        color: inherit;
      }

      [hidden] {
        display: none !important;
      }

      .admin-shell {
        display: grid;
        grid-template-columns: var(--admin-sidebar-w) minmax(0, 1fr);
        grid-template-rows: var(--admin-topbar-h) minmax(0, 1fr);
        min-height: 100vh;
      }

      .admin-sidebar {
        position: sticky;
        top: 0;
        z-index: 60;
        grid-row: 1 / -1;
        display: flex;
        height: 100vh;
        flex-direction: column;
        border-right: 1px solid var(--admin-border);
        background: var(--admin-sidebar);
        color: var(--admin-text);
      }

      .sidebar-brand {
        display: flex;
        min-height: 86px;
        align-items: center;
        padding: 20px 22px 16px;
        border-bottom: 1px solid var(--admin-border);
        color: inherit;
        text-decoration: none;
      }

      .sidebar-brand-icon {
        display: grid;
        width: 34px;
        height: 34px;
        flex: 0 0 auto;
        place-items: center;
        border: 1px solid rgba(184, 50, 107, 0.14);
        border-radius: 999px;
        background: linear-gradient(135deg, #b8326b, #8b1f4d);
        color: #fff;
        font-size: 12px;
        font-weight: 800;
      }

      .sidebar-brand-text {
        min-width: 0;
        color: var(--admin-primary-strong);
        font-size: 20px;
        font-weight: 800;
        letter-spacing: -0.02em;
        line-height: 1.12;
      }

      .sidebar-brand-text small {
        display: block;
        margin-top: 5px;
        color: var(--admin-text);
        font-size: 15px;
        font-weight: 500;
        letter-spacing: 0;
        text-transform: none;
      }

      .sidebar-nav {
        display: grid;
        align-content: start;
        gap: 12px;
        padding: 16px 16px;
      }

      .sidebar-nav a {
        position: relative;
        display: flex;
        min-height: 44px;
        align-items: center;
        gap: 14px;
        padding: 10px 14px;
        border-radius: var(--admin-radius);
        color: var(--admin-text);
        font-size: 15px;
        font-weight: 600;
        text-decoration: none;
        transition:
          background-color 180ms ease,
          color 180ms ease;
      }

      .sidebar-nav a:hover {
        background: var(--admin-surface-hover);
        color: var(--admin-primary-strong);
      }

      .sidebar-nav a.active {
        background: var(--admin-primary-soft);
        color: var(--admin-primary-strong);
        box-shadow: none;
      }

      .nav-icon {
        display: grid;
        width: 20px;
        height: 20px;
        flex: 0 0 auto;
        place-items: center;
      }

      .nav-icon svg {
        width: 18px;
        height: 18px;
        fill: none;
        stroke: currentColor;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-width: 1.9;
      }

      .sidebar-footer {
        display: grid;
        gap: 8px;
        margin-top: auto;
        padding: 12px 8px 10px;
        border-top: 1px solid var(--admin-border);
      }

      .sidebar-account {
        display: grid;
        min-width: 0;
        grid-template-columns: 36px minmax(0, 1fr) 18px;
        gap: 10px;
        align-items: center;
        width: 100%;
        border: 1px solid var(--admin-border);
        border-radius: var(--admin-radius);
        background: #fff;
        padding: 9px 10px;
        text-align: left;
      }

      .sidebar-account b,
      .sidebar-account span {
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .sidebar-account b {
        color: var(--admin-text);
        font-size: 13px;
      }

      .sidebar-account span {
        color: var(--admin-text-muted);
        font-size: 12px;
      }

      .sidebar-account-chevron {
        width: 16px;
        height: 16px;
        color: var(--admin-text-muted);
      }

      .sidebar-footer-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
      }

      .admin-topbar {
        position: sticky;
        top: 0;
        z-index: 50;
        display: grid;
        grid-template-columns: minmax(190px, 1fr) minmax(260px, 440px) auto;
        gap: 14px;
        align-items: center;
        border-bottom: 1px solid var(--admin-border);
        background: rgba(255, 255, 255, 0.92);
        padding: 0 22px 0 26px;
        box-shadow: 0 2px 12px rgba(31, 22, 36, 0.05);
        backdrop-filter: blur(14px);
      }

      .topbar-left {
        display: flex;
        min-width: 0;
        align-items: center;
        gap: 12px;
      }

      .topbar-kicker {
        display: inline-flex;
        min-width: 0;
        align-items: center;
        gap: 12px;
        color: var(--admin-text-muted);
        font-size: 14px;
        font-weight: 500;
      }

      .topbar-kicker b {
        color: var(--admin-text);
        font-weight: 700;
      }

      .topbar-kicker i {
        color: var(--admin-text-dim);
        font-style: normal;
      }

      .topbar-title {
        display: none;
      }

      .admin-search {
        position: relative;
        min-width: 0;
      }

      .admin-search svg {
        position: absolute;
        top: 50%;
        left: 13px;
        width: 16px;
        height: 16px;
        transform: translateY(-50%);
        color: var(--admin-text-dim);
      }

      .admin-search input {
        width: 100%;
        min-height: 36px;
        border: 1px solid var(--admin-border);
        border-radius: var(--admin-radius);
        background: #fff;
        color: var(--admin-text);
        padding: 7px 12px 7px 38px;
        font-size: 13px;
        outline: none;
      }

      .admin-search input:focus {
        border-color: rgba(184, 50, 107, 0.45);
        box-shadow: 0 0 0 4px rgba(184, 50, 107, 0.12);
      }

      .topbar-right {
        display: flex;
        min-width: 0;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
      }

      .topbar-pill,
      .admin-lang-switch a,
      .admin-lang-switch span {
        display: inline-flex;
        min-height: 36px;
        align-items: center;
        border: 1px solid var(--admin-border);
        border-radius: var(--admin-radius-sm);
        background: #fff;
        color: var(--admin-text-muted);
        font-size: 12px;
        font-weight: 800;
        text-decoration: none;
      }

      .topbar-pill {
        gap: 7px;
        padding: 0 12px;
      }

      .topbar-pill.live {
        border-color: #ccebdc;
        background: #effaf4;
        color: var(--admin-green);
      }

      .admin-live-dot {
        width: 7px;
        height: 7px;
        border-radius: 999px;
        background: currentColor;
      }

      .admin-lang-switch {
        display: inline-flex;
        overflow: hidden;
        border: 1px solid var(--admin-border);
        border-radius: var(--admin-radius-sm);
        background: #fff;
      }

      .admin-lang-switch a,
      .admin-lang-switch span {
        min-height: 34px;
        border: 0;
        border-radius: 0;
        background: transparent;
        padding: 0 9px;
      }

      .admin-lang-switch span {
        background: var(--admin-primary-soft);
        color: var(--admin-primary-strong);
      }

      .admin-main {
        min-width: 0;
        padding: 24px 26px 32px;
      }

      .admin-page-header {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 16px;
        align-items: end;
        margin-bottom: 18px;
      }

      .admin-page-kicker {
        color: var(--admin-primary);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .admin-page-title {
        margin: 0;
        color: var(--admin-text);
        font-size: clamp(25px, 2.3vw, 30px);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.08;
      }

      .admin-page-description {
        max-width: 760px;
        margin: 8px 0 0;
        color: var(--admin-text-muted);
        font-size: 14px;
      }

      .admin-meta-row,
      .admin-toolbar,
      .admin-toolbar-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
      }

      .admin-meta-row {
        margin-bottom: 16px;
        color: var(--admin-text-dim);
        font-size: 12px;
      }

      .admin-toolbar {
        justify-content: space-between;
        margin-bottom: 16px;
      }

      .admin-last-updated {
        color: var(--admin-text-muted);
      }

      .admin-status-banner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 16px;
        padding: 12px 14px;
        border: 1px solid var(--admin-border);
        border-radius: var(--admin-radius);
        background: #fff;
        color: var(--admin-text-muted);
        font-size: 13px;
        box-shadow: 0 8px 18px rgba(60, 28, 55, 0.04);
      }

      .admin-status-banner[hidden] {
        display: none;
      }

      .admin-status-banner.loading {
        border-color: rgba(37, 99, 235, 0.2);
        background: #eff6ff;
        color: var(--admin-blue);
      }

      .admin-status-banner.success {
        border-color: rgba(17, 128, 93, 0.22);
        background: #edf9f4;
        color: var(--admin-green);
      }

      .admin-status-banner.warning {
        border-color: rgba(183, 106, 0, 0.22);
        background: #fff7e8;
        color: var(--admin-amber);
      }

      .admin-status-banner.error {
        border-color: rgba(198, 40, 76, 0.24);
        background: #fff0f3;
        color: var(--admin-red);
      }

      .admin-card {
        min-width: 0;
        border: 1px solid var(--admin-border);
        border-radius: var(--admin-radius);
        background: var(--admin-surface);
        box-shadow: 0 1px 2px rgba(31, 22, 36, 0.04);
      }

      .admin-card.padded,
      .admin-card:not(:has(.admin-table)) {
        padding: 18px;
      }

      .admin-card:hover {
        border-color: var(--admin-border-strong);
      }

      .admin-card-title {
        margin: 0 0 10px;
        color: var(--admin-text);
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0;
        text-transform: none;
      }

      .admin-section {
        margin-bottom: 16px;
      }

      .admin-section-title {
        margin: 0 0 12px;
        color: var(--admin-text);
        font-size: 16px;
        font-weight: 800;
      }

      .admin-grid-2 {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 16px;
      }

      .kpi-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 18px;
        margin-bottom: 16px;
      }

      .kpi-card {
        position: relative;
        display: grid;
        min-height: 154px;
        align-content: space-between;
        gap: 8px;
        overflow: hidden;
        border: 1px solid var(--admin-border);
        border-radius: var(--admin-radius);
        background: var(--admin-surface);
        padding: 18px 18px 14px;
        box-shadow: 0 1px 2px rgba(31, 22, 36, 0.04);
      }

      button.kpi-card {
        width: 100%;
        cursor: pointer;
        text-align: left;
      }

      .kpi-label {
        color: var(--admin-text-muted);
        font-size: 14px;
        font-weight: 600;
      }

      .kpi-value {
        color: var(--admin-text);
        font-variant-numeric: tabular-nums;
        font-size: clamp(21px, 2vw, 24px);
        font-weight: 800;
        letter-spacing: -0.02em;
        line-height: 1;
      }

      .kpi-change {
        display: inline-flex;
        width: fit-content;
        min-height: 24px;
        align-items: center;
        gap: 5px;
        border-radius: 5px;
        background: var(--admin-bg-strong);
        color: var(--admin-text-muted);
        padding: 2px 8px;
        font-size: 12px;
        font-weight: 800;
        text-decoration: none;
      }

      .kpi-change.up {
        background: #edf9f4;
        color: var(--admin-green);
      }

      .kpi-change.down {
        background: #fff0f3;
        color: var(--admin-red);
      }

      .kpi-change.neutral {
        background: var(--admin-bg-strong);
        color: var(--admin-text-muted);
      }

      .kpi-spark {
        width: 132px;
        height: 46px;
        justify-self: end;
      }

      .admin-btn {
        display: inline-flex;
        min-height: 38px;
        align-items: center;
        justify-content: center;
        gap: 7px;
        border: 1px solid var(--admin-border);
        border-radius: var(--admin-radius-sm);
        background: #fff;
        color: var(--admin-text);
        padding: 8px 13px;
        cursor: pointer;
        font-size: 13px;
        font-weight: 800;
        text-decoration: none;
        transition:
          background-color 180ms ease,
          border-color 180ms ease,
          color 180ms ease;
      }

      .admin-btn:hover {
        border-color: var(--admin-border-strong);
        background: var(--admin-surface-hover);
      }

      .admin-btn:disabled {
        cursor: not-allowed;
        opacity: 0.62;
      }

      .admin-btn-primary {
        border-color: var(--admin-primary);
        background: var(--admin-primary);
        color: #fff;
      }

      .admin-btn-primary:hover {
        border-color: var(--admin-primary-strong);
        background: var(--admin-primary-strong);
      }

      .admin-btn-sm {
        min-height: 34px;
        padding: 6px 10px;
        font-size: 12px;
      }

      .admin-btn-danger {
        border-color: rgba(198, 40, 76, 0.28);
        color: var(--admin-red);
      }

      .admin-input,
      .admin-select {
        min-height: 40px;
        border: 1px solid var(--admin-border);
        border-radius: var(--admin-radius-sm);
        background: #fff;
        color: var(--admin-text);
        padding: 8px 12px;
        font-size: 13px;
        outline: none;
      }

      .admin-input:focus,
      .admin-select:focus {
        border-color: rgba(184, 50, 107, 0.45);
        box-shadow: 0 0 0 4px rgba(184, 50, 107, 0.12);
      }

      .admin-select {
        padding-right: 30px;
      }

      .admin-table-wrap {
        overflow-x: auto;
      }

      .admin-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
      }

      .admin-table th,
      .admin-table td {
        padding: 10px 16px;
        border-bottom: 1px solid var(--admin-border);
        text-align: left;
        vertical-align: middle;
      }

      .admin-table th {
        background: transparent;
        color: var(--admin-text-muted);
        font-size: 12px;
        font-weight: 600;
        text-transform: none;
        white-space: nowrap;
      }

      .admin-table td {
        color: var(--admin-text);
      }

      .admin-table tbody tr:hover {
        background: var(--admin-surface-hover);
      }

      .admin-table tbody tr:last-child td {
        border-bottom: 0;
      }

      .badge {
        display: inline-flex;
        min-height: 24px;
        align-items: center;
        gap: 6px;
        border-radius: 999px;
        padding: 3px 9px;
        font-size: 11px;
        font-weight: 800;
      }

      .badge-dot {
        width: 6px;
        height: 6px;
        border-radius: 999px;
        background: currentColor;
      }

      .badge-green {
        background: #edf9f4;
        color: var(--admin-green);
      }

      .badge-amber {
        background: #fff7e8;
        color: var(--admin-amber);
      }

      .badge-red {
        background: #fff0f3;
        color: var(--admin-red);
      }

      .badge-blue {
        background: #eef4ff;
        color: var(--admin-blue);
      }

      .badge-purple {
        background: var(--admin-primary-soft);
        color: var(--admin-primary-strong);
      }

      .badge-gray {
        background: var(--admin-bg-strong);
        color: var(--admin-text-muted);
      }

      .chart-container {
        position: relative;
        width: 100%;
        height: 280px;
      }

      .chart-canvas {
        width: 100% !important;
        height: 100% !important;
      }

      .admin-loading {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 38px 16px;
        color: var(--admin-text-muted);
        font-size: 13px;
      }

      .admin-spinner {
        width: 18px;
        height: 18px;
        border: 2px solid var(--admin-border);
        border-top-color: var(--admin-primary);
        border-radius: 999px;
        animation: admin-spin 700ms linear infinite;
      }

      @keyframes admin-spin {
        to {
          transform: rotate(360deg);
        }
      }

      .admin-empty {
        padding: 30px 16px;
        color: var(--admin-text-muted);
        text-align: center;
        font-size: 13px;
      }

      .admin-empty strong {
        display: block;
        margin-bottom: 4px;
        color: var(--admin-text);
        font-size: 14px;
      }

      .admin-empty small {
        display: block;
        color: var(--admin-text-dim);
        font-size: 12px;
      }

      .admin-action-list {
        display: grid;
        gap: 10px;
      }

      .admin-action-item {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        gap: 12px;
        align-items: center;
        border: 1px solid var(--admin-border);
        border-radius: var(--admin-radius);
        background: var(--admin-surface-soft);
        padding: 12px;
      }

      .admin-action-dot {
        width: 9px;
        height: 40px;
        border-radius: 999px;
        background: var(--admin-green);
      }

      .admin-action-dot.warning {
        background: var(--admin-amber);
      }

      .admin-action-dot.danger {
        background: var(--admin-red);
      }

      .admin-action-title {
        color: var(--admin-text);
        font-size: 13px;
        font-weight: 800;
      }

      .admin-action-copy {
        margin-top: 2px;
        color: var(--admin-text-muted);
        font-size: 12px;
      }

      .admin-muted {
        color: var(--admin-text-muted);
      }

      .admin-code {
        color: var(--admin-primary-strong);
        font-family: var(--admin-mono);
        font-size: 12px;
      }

      .progress-bar {
        height: 7px;
        overflow: hidden;
        border-radius: 999px;
        background: var(--admin-bg-strong);
      }

      .progress-fill {
        height: 100%;
        border-radius: inherit;
        background: var(--admin-primary);
        transition: width 240ms ease;
      }

      .admin-pagination {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 14px 0;
        color: var(--admin-text-muted);
        font-size: 13px;
      }

      .admin-pagination-btns {
        display: flex;
        gap: 8px;
      }

      .admin-drawer-backdrop {
        position: fixed;
        inset: 0;
        z-index: 100;
        display: none;
        background: rgba(37, 19, 36, 0.42);
        backdrop-filter: blur(4px);
      }

      .admin-drawer-backdrop.open {
        display: block;
      }

      .admin-drawer {
        position: absolute;
        top: 0;
        right: 0;
        bottom: 0;
        width: min(520px, 100%);
        overflow-y: auto;
        border-left: 1px solid var(--admin-border);
        background: var(--admin-surface);
        box-shadow: -18px 0 44px rgba(60, 28, 55, 0.18);
      }

      .admin-drawer-header,
      .admin-drawer-body {
        padding: 20px;
      }

      .admin-drawer-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        border-bottom: 1px solid var(--admin-border);
      }

      .admin-drawer-title {
        font-size: 18px;
        font-weight: 800;
      }

      .admin-drawer-body {
        display: grid;
        gap: 16px;
      }

      .admin-detail-grid {
        display: grid;
        gap: 8px;
      }

      .admin-detail-row {
        display: grid;
        grid-template-columns: 128px minmax(0, 1fr);
        gap: 12px;
        border-bottom: 1px solid var(--admin-border);
        padding: 10px 0;
        font-size: 13px;
      }

      .admin-detail-row dt {
        color: var(--admin-text-muted);
      }

      .admin-detail-row dd {
        min-width: 0;
        margin: 0;
        color: var(--admin-text);
        word-break: break-word;
      }

      .mobile-menu-btn {
        display: none;
        width: 40px;
        height: 40px;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--admin-border);
        border-radius: var(--admin-radius-sm);
        background: #fff;
        cursor: pointer;
      }

      .mobile-menu-btn svg,
      .admin-btn svg,
      .topbar-pill svg {
        width: 16px;
        height: 16px;
      }

      ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
      }

      ::-webkit-scrollbar-thumb {
        border-radius: 999px;
        background: #cbb8c7;
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation-duration: 1ms !important;
          scroll-behavior: auto !important;
          transition-duration: 1ms !important;
        }
      }

      @media (max-width: 1180px) {
        .admin-topbar {
          grid-template-columns: auto minmax(180px, 1fr) auto;
        }

        .topbar-pill.range {
          display: none;
        }

        .kpi-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      @media (max-width: 900px) {
        .admin-shell {
          grid-template-columns: minmax(0, 1fr);
        }

        .admin-sidebar {
          position: fixed;
          left: 0;
          transform: translateX(-104%);
          width: var(--admin-sidebar-w);
          transition: transform 220ms ease;
        }

        .admin-sidebar.open {
          transform: translateX(0);
        }

        .admin-topbar {
          grid-template-columns: minmax(0, 1fr) auto;
          padding: 0 14px;
        }

        .admin-search {
          display: none;
        }

        .mobile-menu-btn {
          display: inline-flex;
        }

        .admin-main {
          padding: 16px;
        }

        .admin-page-header,
        .admin-toolbar,
        .admin-grid-2 {
          grid-template-columns: 1fr;
        }

        .topbar-kicker,
        .topbar-pill.live,
        .admin-lang-switch {
          display: none;
        }
      }

      @media (max-width: 620px) {
        .kpi-grid {
          grid-template-columns: 1fr;
        }

        .topbar-pill.refresh {
          display: none;
        }

        .admin-page-title {
          font-size: 28px;
        }

        .admin-action-item {
          grid-template-columns: auto minmax(0, 1fr);
        }

        .admin-action-item .admin-btn {
          grid-column: 2;
          width: fit-content;
        }
      }
    </style>
  </head>
  <body>
    <div class="admin-shell">
      <aside class="admin-sidebar" id="adminSidebar">
        <a href={withLang("/admin")} class="sidebar-brand">
          <span class="sidebar-brand-text">
            AI Beauty Stylist
            <small>{copy.console}</small>
          </span>
        </a>
        <nav class="sidebar-nav" aria-label={copy.console}>
          {
            navItems.map((item) => (
              <a
                href={withLang(item.href)}
                class:list={[{ active: activeNav === item.id }]}
                aria-current={activeNav === item.id ? "page" : undefined}
              >
                <span class="nav-icon">
                  {item.icon === "chart" && (
                    <svg viewBox="0 0 24 24">
                      <path d="M3 3v18h18" />
                      <path d="M18 17V9" />
                      <path d="M13 17V5" />
                      <path d="M8 17v-3" />
                    </svg>
                  )}
                  {item.icon === "users" && (
                    <svg viewBox="0 0 24 24">
                      <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                      <circle cx="9" cy="7" r="4" />
                      <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                      <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                  )}
                  {item.icon === "dollar" && (
                    <svg viewBox="0 0 24 24">
                      <line x1="12" y1="2" x2="12" y2="22" />
                      <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                    </svg>
                  )}
                  {item.icon === "cpu" && (
                    <svg viewBox="0 0 24 24">
                      <rect x="4" y="4" width="16" height="16" rx="2" />
                      <path d="M9 9h6v6H9z" />
                      <path d="M9 1v3" />
                      <path d="M15 1v3" />
                      <path d="M9 20v3" />
                      <path d="M15 20v3" />
                      <path d="M20 9h3" />
                      <path d="M20 14h3" />
                      <path d="M1 9h3" />
                      <path d="M1 14h3" />
                    </svg>
                  )}
                  {item.icon === "ticket" && (
                    <svg viewBox="0 0 24 24">
                      <path d="M2 12h2" />
                      <path d="M20 12h2" />
                      <path d="M4 6h16a2 2 0 0 1 2 2v2a2 2 0 0 0 0 4v2a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-2a2 2 0 0 0 0-4V8a2 2 0 0 1 2-2z" />
                    </svg>
                  )}
                  {item.icon === "settings" && (
                    <svg viewBox="0 0 24 24">
                      <path d="M12 15.5A3.5 3.5 0 1 0 12 8a3.5 3.5 0 0 0 0 7.5z" />
                      <path d="M19.4 15a1.8 1.8 0 0 0 .36 1.98l.04.04a2.1 2.1 0 1 1-2.97 2.97l-.04-.04a1.8 1.8 0 0 0-1.98-.36 1.8 1.8 0 0 0-1.1 1.66V21a2.1 2.1 0 1 1-4.2 0v-.06a1.8 1.8 0 0 0-1.1-1.66 1.8 1.8 0 0 0-1.98.36l-.04.04a2.1 2.1 0 1 1-2.97-2.97l.04-.04A1.8 1.8 0 0 0 4.6 15a1.8 1.8 0 0 0-1.66-1.1H3a2.1 2.1 0 1 1 0-4.2h.06A1.8 1.8 0 0 0 4.72 8.6a1.8 1.8 0 0 0-.36-1.98l-.04-.04a2.1 2.1 0 1 1 2.97-2.97l.04.04A1.8 1.8 0 0 0 9.3 4a1.8 1.8 0 0 0 1.1-1.66V2a2.1 2.1 0 1 1 4.2 0v.06A1.8 1.8 0 0 0 15.7 4a1.8 1.8 0 0 0 1.98-.36l.04-.04a2.1 2.1 0 1 1 2.97 2.97l-.04.04a1.8 1.8 0 0 0-.36 1.98 1.8 1.8 0 0 0 1.66 1.1H22a2.1 2.1 0 1 1 0 4.2h-.06A1.8 1.8 0 0 0 19.4 15z" />
                    </svg>
                  )}
                </span>
                {copy.nav[item.id]}
              </a>
            ))
          }
        </nav>
        <div class="sidebar-footer">
          <div class="sidebar-account" data-admin-account>
            <span class="sidebar-brand-icon" data-admin-avatar>A</span>
            <span>
              <b data-admin-email>admin</b>
              <span>{copy.adminRole}</span>
            </span>
            <svg
              class="sidebar-account-chevron"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m6 9 6 6 6-6"></path>
            </svg>
          </div>
          <div class="sidebar-footer-actions">
            <a href="/" class="admin-btn admin-btn-sm">{copy.returnSite}</a>
            <button
              class="admin-btn admin-btn-sm admin-btn-danger"
              id="adminLogout"
              type="button"
            >
              {copy.logout}
            </button>
          </div>
        </div>
      </aside>

      <header class="admin-topbar">
        <div class="topbar-left">
          <button
            class="mobile-menu-btn"
            id="mobileMenuBtn"
            type="button"
            aria-label={copy.menu}
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
          </button>
          <div>
            <div class="topbar-kicker">
              <span>{copy.breadcrumb}</span>
              <i>/</i>
              <b>{copy.nav[activeNav]}</b>
            </div>
            <h1 class="topbar-title">{title}</h1>
          </div>
        </div>

        <form class="admin-search" id="adminSearchForm" role="search">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
          <input
            id="adminSearchInput"
            type="search"
            aria-label={copy.searchLabel}
            placeholder={copy.search}
          />
        </form>

        <div class="topbar-right">
          <span class="topbar-pill range">
            {dateRangeLabel}
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M8 2v4"></path>
              <path d="M16 2v4"></path>
              <rect x="3" y="4" width="18" height="18" rx="2"></rect>
              <path d="M3 10h18"></path>
            </svg>
          </span>
          <button
            class="admin-btn admin-btn-sm topbar-pill refresh"
            id="adminGlobalRefresh"
            type="button"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M21 12a9 9 0 0 1-9 9 9.7 9.7 0 0 1-6.7-2.7"></path>
              <path d="M3 12a9 9 0 0 1 9-9 9.7 9.7 0 0 1 6.7 2.7"></path>
              <path d="M3 20v-6h6"></path>
              <path d="M21 4v6h-6"></path>
            </svg>
            {copy.refresh}
          </button>
          <span class="topbar-pill live"
            ><span class="admin-live-dot"></span>{copy.live}</span
          >
          <div class="admin-lang-switch" aria-label={copy.language}>
            {
              currentLang === "zh-cn" ? (
                <span>中</span>
              ) : (
                <a href={langHref("zh-cn")}>中</a>
              )
            }
            {
              currentLang === "en" ? (
                <span>EN</span>
              ) : (
                <a href={langHref("en")}>EN</a>
              )
            }
          </div>
        </div>
      </header>

      <main class="admin-main">
        <slot />
      </main>
    </div>

    <script
      is:inline
      define:vars={{ layoutLang: currentLang, layoutCopy: copy }}
    >
      (function () {
        var btn = document.getElementById("mobileMenuBtn");
        var sidebar = document.getElementById("adminSidebar");
        var logoutBtn = document.getElementById("adminLogout");
        var emailEls = document.querySelectorAll("[data-admin-email]");
        var avatarEl = document.querySelector("[data-admin-avatar]");
        var refreshBtn = document.getElementById("adminGlobalRefresh");
        var searchForm = document.getElementById("adminSearchForm");
        var searchInput = document.getElementById("adminSearchInput");

        if (btn && sidebar) {
          btn.addEventListener("click", function () {
            sidebar.classList.toggle("open");
          });
          document.addEventListener("click", function (event) {
            if (
              !sidebar.contains(event.target) &&
              !btn.contains(event.target)
            ) {
              sidebar.classList.remove("open");
            }
          });
        }

        fetch("/api/session")
          .then(function (response) {
            return response.json();
          })
          .then(function (body) {
            var email =
              body && body.data && body.data.user && body.data.user.email;
            if (!email) return;
            emailEls.forEach(function (el) {
              el.textContent = "admin";
              el.title = email;
            });
            if (avatarEl) avatarEl.textContent = "A";
          })
          .catch(function () {});

        if (refreshBtn) {
          refreshBtn.addEventListener("click", function () {
            var pageRefresh = document.querySelector(
              "[data-admin-page-refresh]",
            );
            if (pageRefresh instanceof HTMLButtonElement) {
              pageRefresh.click();
            } else {
              window.location.reload();
            }
          });
        }

        if (searchForm && searchInput) {
          searchForm.addEventListener("submit", function (event) {
            event.preventDefault();
            var query = searchInput.value.trim();
            if (!query) return;
            var target = new URL("/admin/users", window.location.origin);
            target.searchParams.set("search", query);
            if (layoutLang === "en") target.searchParams.set("lang", "en");
            window.location.href = target.pathname + target.search;
          });
        }

        if (logoutBtn) {
          logoutBtn.addEventListener("click", function () {
            logoutBtn.disabled = true;
            logoutBtn.textContent = layoutCopy.loggingOut;
            fetch("/api/auth/logout", { method: "POST" })
              .catch(function () {})
              .finally(function () {
                window.location.href =
                  "/login?next=" + encodeURIComponent(window.location.pathname);
              });
          });
        }
      })();
    </script>
  </body>
</html>
