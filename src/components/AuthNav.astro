---
// 全站登录状态入口：复用现有入口，缺失时再创建。
const initialLoggedIn = Boolean(Astro.locals.isLoggedIn);
---

<script is:inline define:vars={{ initialLoggedIn }}>
  (() => {
    const actions = document.querySelector(".nav-actions");
    if (!actions) return;
    const locale = String(
      window.__absLocale || document.documentElement.lang || "en",
    );
    const authCopy = {
      en: {
        cta: "Get Started",
        shortCta: "Sign up",
        dashboard: "Dashboard",
        signedIn: "Signed in",
        accountMenu: "Account menu",
        plan: "Plan",
        account: "Account settings",
        billing: "Subscription and quota",
        signOut: "Sign out",
        signingOut: "Signing out...",
        signOutFailed: "Could not sign out. Try again.",
      },
      "zh-CN": {
        cta: "开始使用",
        shortCta: "开始",
        dashboard: "工作台",
        signedIn: "已登录",
        accountMenu: "账户菜单",
        plan: "当前计划",
        account: "账户设置",
        billing: "订阅与额度",
        signOut: "退出登录",
        signingOut: "正在退出...",
        signOutFailed: "退出失败，请重试。",
      },
      "zh-TW": {
        cta: "開始使用",
        shortCta: "開始",
        dashboard: "工作台",
        signedIn: "已登入",
        accountMenu: "帳戶選單",
        plan: "目前方案",
        account: "帳戶設定",
        billing: "訂閱與額度",
        signOut: "登出",
        signingOut: "正在登出...",
        signOutFailed: "登出失敗，請重試。",
      },
      "de-DE": {
        cta: "Loslegen",
        shortCta: "Starten",
        dashboard: "Dashboard",
        signedIn: "Angemeldet",
        accountMenu: "Kontomenü",
        plan: "Tarif",
        account: "Kontoeinstellungen",
        billing: "Abo und Kontingent",
        signOut: "Abmelden",
        signingOut: "Abmelden...",
        signOutFailed: "Abmeldung fehlgeschlagen. Erneut versuchen.",
      },
      "fr-FR": {
        cta: "Commencer",
        shortCta: "Débuter",
        dashboard: "Tableau de bord",
        signedIn: "Connecté",
        accountMenu: "Menu du compte",
        plan: "Offre",
        account: "Paramètres du compte",
        billing: "Abonnement et quota",
        signOut: "Se déconnecter",
        signingOut: "Déconnexion...",
        signOutFailed: "Déconnexion impossible. Réessayez.",
      },
      "ja-JP": {
        cta: "始める",
        shortCta: "開始",
        dashboard: "ダッシュボード",
        signedIn: "ログイン中",
        accountMenu: "アカウントメニュー",
        plan: "プラン",
        account: "アカウント設定",
        billing: "サブスクと利用枠",
        signOut: "ログアウト",
        signingOut: "ログアウト中...",
        signOutFailed: "ログアウトできません。再試行してください。",
      },
      "ko-KR": {
        cta: "시작하기",
        shortCta: "시작",
        dashboard: "대시보드",
        signedIn: "로그인됨",
        accountMenu: "계정 메뉴",
        plan: "플랜",
        account: "계정 설정",
        billing: "구독 및 한도",
        signOut: "로그아웃",
        signingOut: "로그아웃 중...",
        signOutFailed: "로그아웃하지 못했습니다. 다시 시도하세요.",
      },
      "es-ES": {
        cta: "Comenzar",
        shortCta: "Empezar",
        dashboard: "Panel",
        signedIn: "Sesión iniciada",
        accountMenu: "Menú de cuenta",
        plan: "Plan",
        account: "Ajustes de cuenta",
        billing: "Suscripción y cuota",
        signOut: "Cerrar sesión",
        signingOut: "Cerrando sesión...",
        signOutFailed: "No se pudo cerrar sesión. Inténtalo de nuevo.",
      },
      "es-419": {
        cta: "Comenzar",
        shortCta: "Empezar",
        dashboard: "Panel",
        signedIn: "Sesión iniciada",
        accountMenu: "Menú de cuenta",
        plan: "Plan",
        account: "Ajustes de cuenta",
        billing: "Suscripción y cuota",
        signOut: "Cerrar sesión",
        signingOut: "Cerrando sesión...",
        signOutFailed: "No se pudo cerrar sesión. Inténtalo de nuevo.",
      },
      "pt-BR": {
        cta: "Começar",
        shortCta: "Iniciar",
        dashboard: "Painel",
        signedIn: "Conectado",
        accountMenu: "Menu da conta",
        plan: "Plano",
        account: "Configurações da conta",
        billing: "Assinatura e cota",
        signOut: "Sair",
        signingOut: "Saindo...",
        signOutFailed: "Não foi possível sair. Tente novamente.",
      },
    }[locale] || {
      cta: "Get Started",
      shortCta: "Start",
      dashboard: "Dashboard",
      signedIn: "Signed in",
      accountMenu: "Account menu",
      plan: "Plan",
      account: "Account settings",
      billing: "Subscription and quota",
      signOut: "Sign out",
      signingOut: "Signing out...",
      signOutFailed: "Could not sign out. Try again.",
    };
    const localePrefix =
      {
        "zh-CN": "/zh-cn",
        "zh-TW": "/zh-tw",
        "de-DE": "/de",
        "fr-FR": "/fr",
        "ja-JP": "/ja",
        "ko-KR": "/ko",
        "es-ES": "/es",
        "es-419": "/es",
        "pt-BR": "/pt-br",
      }[locale] || "";
    const routePathname =
      location.pathname.replace(
        /^\/(zh-cn|zh-tw|de|fr|ja|ko|es|pt-br)(?=\/|$)/i,
        "",
      ) || "/";

    function localized(path) {
      return `${localePrefix}${path}`;
    }

    let link = actions.querySelector("[data-auth-entry]");
    if (
      !link &&
      (routePathname === "/login" || routePathname === "/reset-password")
    ) {
      return;
    }
    if (!link) {
      link = document.createElement("a");
      link.setAttribute("data-auth-entry", "");
      link.className = "btn btn-primary auth-entry-btn keep-mobile";
      actions.insertBefore(link, actions.firstChild);
    }

    const authHref = link.dataset.authHref || localized("/login?mode=register");
    const accountHref = link.dataset.accountHref || localized("/dashboard");
    const authLabel = link.dataset.authLabel || authCopy.cta;
    const authShortLabel = link.dataset.authShortLabel || authCopy.shortCta;
    const planNames = { free: "Free", pro: "Pro", premium: "Premium" };
    const knownPlanCodes = new Set(Object.keys(planNames));
    const mobileAuthCtas = Array.from(
      document.querySelectorAll("[data-mobile-menu-auth-cta]"),
    );
    const mobileAccountSummaries = Array.from(
      document.querySelectorAll("[data-mobile-account-summary]"),
    );
    const mobileTopAccounts = Array.from(
      document.querySelectorAll("[data-mobile-top-account]"),
    );
    const checkoutSucceeded =
      new URLSearchParams(location.search).get("checkout") === "success";
    const delay = (ms) =>
      new Promise((resolve) => window.setTimeout(resolve, ms));
    let currentSession = null;

    function setAuthLabel(anchor) {
      const desktopLabel = anchor.querySelector(".auth-entry-label-desktop");
      const mobileLabel = anchor.querySelector(".auth-entry-label-mobile");
      if (desktopLabel || mobileLabel) {
        if (desktopLabel) desktopLabel.textContent = authLabel;
        if (mobileLabel) mobileLabel.textContent = authShortLabel;
      } else {
        anchor.textContent = authLabel;
      }
      anchor.setAttribute("aria-label", `${authLabel}. ${authShortLabel}`);
    }

    function fillTemplate(template, values) {
      return String(template || "").replace(/\{(\w+)\}/g, (_, key) =>
        values[key] == null ? "" : String(values[key]),
      );
    }

    function getPlanState(rawPlan) {
      const planCode = String(rawPlan || "free").toLowerCase();
      const normalizedPlan = knownPlanCodes.has(planCode) ? planCode : "free";
      return {
        code: normalizedPlan,
        label: planNames[normalizedPlan] || String(rawPlan || "Free"),
      };
    }

    function setAvatarContent(node, avatarUrl, fallback) {
      if (!node) return;
      node.replaceChildren();
      if (!avatarUrl) {
        node.textContent = fallback;
        return;
      }
      const image = document.createElement("img");
      image.className = "account-avatar-image";
      image.src = avatarUrl;
      image.alt = "";
      image.width = 64;
      image.height = 64;
      image.decoding = "async";
      image.addEventListener(
        "error",
        () => {
          node.replaceChildren();
          node.textContent = fallback;
        },
        { once: true },
      );
      node.append(image);
    }

    function createPlanBadge(planState) {
      const badge = document.createElement("span");
      badge.className = "account-plan-badge";
      badge.dataset.plan = planState.code;
      badge.textContent = planState.label;
      return badge;
    }

    function renderPlanLine(node, { label, planState, quotaText = "" }) {
      const labelNode = document.createElement("span");
      labelNode.className = "account-plan-label";
      labelNode.textContent = `${label}:`;

      node.dataset.plan = planState.code;
      node.setAttribute(
        "aria-label",
        quotaText
          ? `${label}: ${planState.label}, ${quotaText}`
          : `${label}: ${planState.label}`,
      );
      node.replaceChildren(labelNode, createPlanBadge(planState));

      if (quotaText) {
        const quotaNode = document.createElement("span");
        quotaNode.className = "account-plan-quota";
        quotaNode.textContent = quotaText;
        node.append(quotaNode);
      }
    }

    function setMobileAccountSummarySignedOut() {
      mobileAccountSummaries.forEach((summary) => {
        const avatar = summary.querySelector(
          "[data-mobile-account-summary-avatar]",
        );
        const title = summary.querySelector(
          "[data-mobile-account-summary-title]",
        );
        const note = summary.querySelector(
          "[data-mobile-account-summary-note]",
        );
        const action = summary.querySelector(
          "[data-mobile-account-summary-action]",
        );
        const nextTitle = summary.dataset.authTitle || authLabel;
        const nextNote = summary.dataset.authNote || "";
        const nextAction = summary.dataset.authAction || authShortLabel;
        summary.href = summary.dataset.authHref || authHref;
        if (avatar) avatar.textContent = "AI";
        if (title) title.textContent = nextTitle;
        if (note) {
          note.classList.remove("mobile-account-plan-line");
          delete note.dataset.plan;
          note.textContent = nextNote;
        }
        if (action) action.textContent = nextAction;
        summary.setAttribute("aria-label", `${nextTitle}. ${nextAction}`);
      });
    }

    function setMobileAccountSummarySignedIn(session) {
      const email = session?.user?.email || "";
      const planState = getPlanState(session?.plan);
      const plan = planState.label;
      const initial = (email.trim()[0] || "A").toUpperCase();
      const quota = session?.quota;
      mobileAccountSummaries.forEach((summary) => {
        const avatar = summary.querySelector(
          "[data-mobile-account-summary-avatar]",
        );
        const title = summary.querySelector(
          "[data-mobile-account-summary-title]",
        );
        const note = summary.querySelector(
          "[data-mobile-account-summary-note]",
        );
        const action = summary.querySelector(
          "[data-mobile-account-summary-action]",
        );
        const planLabel = summary.dataset.planLabel || authCopy.plan;
        const quotaTemplate = summary.dataset.quotaTemplate || "";
        const quotaText =
          Number.isFinite(Number(quota?.remaining)) &&
          Number.isFinite(Number(quota?.total))
            ? fillTemplate(quotaTemplate, {
                remaining: quota.remaining,
                total: quota.total,
              })
            : summary.dataset.quotaUnavailable || "";
        const noteText = quotaText
          ? `${planLabel}: ${plan} · ${quotaText}`
          : `${planLabel}: ${plan}`;
        summary.href = summary.dataset.accountHref || localized("/dashboard");
        setAvatarContent(avatar, session?.user?.avatarUrl, initial);
        if (title) title.textContent = email || authCopy.accountMenu;
        if (note) {
          note.classList.add("mobile-account-plan-line");
          renderPlanLine(note, { label: planLabel, planState, quotaText });
        }
        if (action) {
          action.textContent = summary.dataset.manageLabel || authCopy.account;
        }
        summary.setAttribute(
          "aria-label",
          `${authCopy.accountMenu}: ${email}. ${noteText}`,
        );
      });
    }

    function setMobileAuthSignedOut() {
      mobileAuthCtas.forEach((anchor) => {
        const label = anchor.querySelector("[data-mobile-menu-auth-label]");
        const avatar = anchor.querySelector("[data-mobile-menu-auth-avatar]");
        const nextLabel = anchor.dataset.authLabel || authLabel;
        const nextShortLabel = anchor.dataset.authShortLabel || authShortLabel;
        anchor.href = anchor.dataset.authHref || authHref;
        anchor.classList.remove("mobile-menu-auth-cta-account");
        if (label) label.textContent = nextLabel;
        else anchor.textContent = nextLabel;
        if (avatar) {
          avatar.textContent = "";
          avatar.setAttribute("hidden", "");
        }
        anchor.setAttribute("aria-label", `${nextLabel}. ${nextShortLabel}`);
      });
      setMobileAccountSummarySignedOut();
      mobileTopAccounts.forEach((anchor) => {
        const plan = anchor.querySelector("[data-mobile-top-plan]");
        const avatar = anchor.querySelector("[data-mobile-top-avatar]");
        anchor.href = anchor.dataset.authHref || authHref;
        if (plan) plan.textContent = authShortLabel;
        if (avatar) avatar.textContent = "AI";
        anchor.setAttribute("aria-label", `${authLabel}. ${authShortLabel}`);
      });
    }

    function setMobileAuthSignedIn(session) {
      const email = session?.user?.email || "";
      const planState = getPlanState(session?.plan);
      const plan = planState.label;
      const initial = (email.trim()[0] || "A").toUpperCase();
      mobileAuthCtas.forEach((anchor) => {
        const label = anchor.querySelector("[data-mobile-menu-auth-label]");
        const avatar = anchor.querySelector("[data-mobile-menu-auth-avatar]");
        anchor.href = anchor.dataset.accountHref || localized("/dashboard");
        anchor.classList.add("mobile-menu-auth-cta-account");
        if (label) label.textContent = plan;
        else anchor.textContent = plan;
        if (avatar) {
          setAvatarContent(avatar, session?.user?.avatarUrl, initial);
          avatar.removeAttribute("hidden");
        }
        anchor.setAttribute(
          "aria-label",
          `${authCopy.accountMenu}: ${email}. ${authCopy.plan}: ${plan}`,
        );
      });
      setMobileAccountSummarySignedIn(session);
      mobileTopAccounts.forEach((anchor) => {
        const label = anchor.querySelector("[data-mobile-top-plan]");
        const avatar = anchor.querySelector("[data-mobile-top-avatar]");
        anchor.href = anchor.dataset.accountHref || localized("/dashboard");
        if (label) label.textContent = plan;
        setAvatarContent(avatar, session?.user?.avatarUrl, initial);
        anchor.setAttribute(
          "aria-label",
          `${authCopy.accountMenu}: ${email}. ${authCopy.plan}: ${plan}`,
        );
      });
    }

    function closeAccountMenu(menu) {
      menu.classList.remove("open");
      menu
        .querySelector("[data-account-menu-trigger]")
        ?.setAttribute("aria-expanded", "false");
    }

    function closeLanguageMenu() {
      const dropdown = document.getElementById("lang-dropdown");
      const toggle = document.getElementById("lang-toggle");
      dropdown?.classList.remove("open");
      toggle?.setAttribute("aria-expanded", "false");
    }

    function createMenuItem({ href, label, isButton = false }) {
      const item = document.createElement(isButton ? "button" : "a");
      item.className = `account-menu-item${isButton ? " account-menu-logout" : ""}`;
      if (isButton) item.type = "button";
      else item.href = href;
      item.setAttribute("role", "menuitem");
      item.textContent = label;
      return item;
    }

    function renderAccountMenu(anchor, session) {
      const email = session?.user?.email || "";
      const planState = getPlanState(session?.plan);
      const initial = (email.trim()[0] || "A").toUpperCase();
      let menu = actions.querySelector("[data-account-menu]");

      if (!menu) {
        menu = document.createElement("div");
        menu.className = "account-menu";
        menu.setAttribute("data-account-menu", "");
        anchor.replaceWith(menu);
      }

      menu.replaceChildren();
      const trigger = document.createElement("button");
      trigger.className = "btn account-menu-trigger keep-mobile";
      trigger.type = "button";
      trigger.setAttribute("data-account-menu-trigger", "");
      trigger.setAttribute("aria-haspopup", "menu");
      trigger.setAttribute("aria-expanded", "false");
      trigger.setAttribute("aria-label", `${authCopy.accountMenu}: ${email}`);

      const avatar = document.createElement("span");
      avatar.className = "account-avatar";
      avatar.setAttribute("aria-hidden", "true");
      setAvatarContent(avatar, session?.user?.avatarUrl, initial);

      trigger.append(avatar);

      const panel = document.createElement("div");
      panel.className = "account-menu-panel";
      panel.setAttribute("data-account-menu-panel", "");
      panel.setAttribute("role", "menu");

      const identity = document.createElement("div");
      identity.className = "account-menu-identity";
      const signedIn = document.createElement("span");
      signedIn.textContent = authCopy.signedIn;
      const emailNode = document.createElement("strong");
      emailNode.textContent = email;
      const planNode = document.createElement("small");
      planNode.className = "account-plan-line";
      renderPlanLine(planNode, {
        label: authCopy.plan,
        planState,
      });
      identity.append(signedIn, emailNode, planNode);

      const list = document.createElement("div");
      list.className = "account-menu-list";
      const dashboard = createMenuItem({
        href: accountHref,
        label: authCopy.dashboard,
      });
      const account = createMenuItem({
        href: localized("/dashboard#account-panel"),
        label: authCopy.account,
      });
      const billing = createMenuItem({
        href: localized("/dashboard#billing-panel"),
        label: authCopy.billing,
      });
      const logout = createMenuItem({
        label: authCopy.signOut,
        isButton: true,
      });
      const status = document.createElement("p");
      status.className = "account-menu-status";
      status.setAttribute("role", "status");
      status.setAttribute("data-account-menu-status", "");
      list.append(dashboard, account, billing, logout, status);
      panel.append(identity, list);
      menu.append(trigger, panel);

      trigger.addEventListener("click", (event) => {
        event.stopPropagation();
        const nextOpen = !menu.classList.contains("open");
        document
          .querySelectorAll("[data-account-menu].open")
          .forEach((openMenu) => closeAccountMenu(openMenu));
        if (nextOpen) closeLanguageMenu();
        menu.classList.toggle("open", nextOpen);
        trigger.setAttribute("aria-expanded", String(nextOpen));
      });

      panel.addEventListener("click", (event) => event.stopPropagation());
      logout.addEventListener("click", async () => {
        logout.disabled = true;
        status.textContent = authCopy.signingOut;
        try {
          const response = await fetch("/api/auth/logout", { method: "POST" });
          if (!response.ok) throw new Error("LOGOUT_FAILED");
          window.location.href = localized("/");
        } catch {
          logout.disabled = false;
          status.textContent = authCopy.signOutFailed;
        }
      });
    }

    link.href = authHref;
    setAuthLabel(link);
    setMobileAuthSignedOut();

    document.addEventListener("click", () => {
      document
        .querySelectorAll("[data-account-menu].open")
        .forEach((menu) => closeAccountMenu(menu));
    });

    document.addEventListener("keydown", (event) => {
      if (event.key !== "Escape") return;
      document
        .querySelectorAll("[data-account-menu].open")
        .forEach((menu) => closeAccountMenu(menu));
    });

    async function fetchSessionWithCheckoutRefresh() {
      let body = await fetch("/api/session").then((res) => res.json());
      if (!checkoutSucceeded || body?.data?.plan !== "free") return body;

      for (let attempt = 0; attempt < 6; attempt += 1) {
        await delay(1500);
        body = await fetch("/api/session").then((res) => res.json());
        if (body?.data?.plan && body.data.plan !== "free") break;
      }
      return body;
    }

    const syncSession = () => {
      fetchSessionWithCheckoutRefresh()
        .then((body) => {
          const data = body?.data;
          const email = data?.user?.email;
          if (email) {
            currentSession = data;
            renderAccountMenu(link, data);
            setMobileAuthSignedIn(data);
          } else {
            link.href = authHref;
            setAuthLabel(link);
            setMobileAuthSignedOut();
          }
        })
        .catch(() => {});
    };

    document.addEventListener("profile-avatar-updated", (event) => {
      const avatarUrl = event.detail?.avatarUrl;
      if (!avatarUrl || !currentSession?.user) return;
      currentSession.user.avatarUrl = avatarUrl;
      const email = currentSession.user.email || "";
      const initial = (email.trim()[0] || "A").toUpperCase();
      document
        .querySelectorAll(
          ".account-avatar, [data-mobile-menu-auth-avatar], [data-mobile-account-summary-avatar], [data-mobile-top-avatar]",
        )
        .forEach((avatar) => setAvatarContent(avatar, avatarUrl, initial));
    });

    // SSR already knows whether this request has a valid session. Anonymous
    // pages do not need a second session lookup after load.
    if (checkoutSucceeded || initialLoggedIn) syncSession();
  })();
</script>
