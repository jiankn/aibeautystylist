---
import { t, type Locale } from '../lib/i18n';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const isZh = locale === 'zh-CN';

const primaryCtaHref = isZh ? '/zh/try-on/' : '/try-on';
const proHookHref = isZh ? '/zh/membership/?from=hero_weekly_drop' : '/membership?from=hero_weekly_drop';
const heroProLabel = isZh ? 'Pro 会员专属' : 'Pro drop';
const heroProHeadline = isZh ? '按你的风格档案，每周推荐新妆容' : 'Unlock weekly drop based on your style profile';

const imgLabels = isZh
  ? { glam: '精致妆感', glow: '光泽气色', clean: '清透妆感' }
  : { glam: 'Polished Glam', glow: 'Radiant Glow', clean: 'Clean Beauty' };

const heroTrustLabel = isZh ? '你会获得什么' : 'What you get';
const imgAlts = isZh
  ? {
      glam: '精致优雅妆容示意图',
      glow: '深肤色光泽妆容示意图',
      clean: '清透干净妆容示意图',
    }
  : {
      glam: 'Polished elegant makeup look',
      glow: 'Luminous glow makeup on deep skin',
      clean: 'Refined clean beauty makeup',
    };
---

<section class="hero section">
  <div class="container hero-grid">
    <div class="hero-copy">
      <span class="eyebrow">{t('hero.eyebrow', locale)}</span>
      <h1 data-hero-title>{t('hero.headline', locale)}</h1>
      <p class="lead" data-hero-lead>
        {t('hero.lead', locale)}
      </p>
      <div class="cta-row">
        <a class="btn" href={primaryCtaHref} data-hero-primary-cta>{t('hero.ctaPrimary', locale)}</a>
        <a class="btn btn-secondary" href="#try-a-style">{t('hero.ctaSecondary', locale)}</a>
      </div>
      <a class="hero-pro-hook" href={proHookHref} data-hero-pro-hook hidden>
        <span>{heroProLabel}</span>
        <strong>{heroProHeadline}</strong>
      </a>
      <ul class="hero-trust" aria-label={heroTrustLabel}>
        <li class="hero-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="20 6 9 17 4 12" />
          </svg>
          <strong>{t('hero.metric1Title', locale)}</strong>
          <span>{t('hero.metric1Detail', locale)}</span>
        </li>
        <li class="hero-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="6" width="18" height="13" rx="2" />
            <circle cx="12" cy="12.5" r="3.5" />
            <path d="M8 6V4h8v2" />
          </svg>
          <strong>{t('hero.metric2Title', locale)}</strong>
          <span>{t('hero.metric2Detail', locale)}</span>
        </li>
        <li class="hero-trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="11" width="18" height="11" rx="2" />
            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
          </svg>
          <strong>{t('hero.metric3Title', locale)}</strong>
          <span>{t('hero.metric3Detail', locale)}</span>
        </li>
      </ul>
    </div>

    <div class="hero-visuals">
      <div class="hero-img-stack">
        <div class="hero-img-main">
          <img src="/images/hero/hero-polished-elegant.webp" alt={imgAlts.glam} loading="eager" />
          <span class="hero-img-label">{imgLabels.glam}</span>
        </div>
        <div class="hero-img-secondary">
          <div class="hero-img-sm">
            <img src="/images/hero/hero-inclusive-glow.webp" alt={imgAlts.glow} loading="eager" />
            <span class="hero-img-label">{imgLabels.glow}</span>
          </div>
          <div class="hero-img-sm">
            <img src="/images/hero/hero-asian-refined.webp" alt={imgAlts.clean} loading="eager" />
            <span class="hero-img-label">{imgLabels.clean}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { getMyStyle } from '../lib/personalization';

  const myStyle = getMyStyle();
  if (myStyle) {
    const isZhPage = document.documentElement.lang === 'zh-CN' || window.location.pathname.startsWith('/zh/');
    const copy = isZhPage
      ? {
          title: (label: string) => `欢迎回来，要继续试试「${label}」吗？`,
          lead: '你保存的风格档案已经准备好。上传自拍，或继续预览上次选好的妆容方向。',
          cta: (label: string) => `试试「${label}」`,
          tryOnBase: '/zh/try-on/',
          membershipBase: '/zh/membership/',
        }
      : {
          title: (label: string) => `Welcome back, ready to try ${label} again?`,
          lead: 'Your saved style profile is ready. Upload a selfie or preview the look direction you already picked.',
          cta: (label: string) => `Try ${label}`,
          tryOnBase: '/try-on',
          membershipBase: '/membership',
        };
    const title = document.querySelector<HTMLElement>('[data-hero-title]');
    const lead = document.querySelector<HTMLElement>('[data-hero-lead]');
    const primaryCta = document.querySelector<HTMLAnchorElement>('[data-hero-primary-cta]');
    const proHook = document.querySelector<HTMLAnchorElement>('[data-hero-pro-hook]');
    const tryOnHref = `${copy.tryOnBase}?scenario=${encodeURIComponent(myStyle.scenario)}&style=${encodeURIComponent(myStyle.slug)}&look=${encodeURIComponent(myStyle.lookSlug)}&source=hero-my-style`;

    if (title) title.textContent = copy.title(myStyle.label);
    if (lead) lead.textContent = copy.lead;
    if (primaryCta) {
      primaryCta.href = tryOnHref;
      primaryCta.textContent = copy.cta(myStyle.label);
    }
    if (proHook) {
      proHook.href = `${copy.membershipBase}?from=hero_weekly_drop&style=${encodeURIComponent(myStyle.slug)}`;
      proHook.hidden = false;
    }
  }
</script>

<style>
  .hero-copy {
    max-width: 540px;
  }

  .hero-visuals {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-img-stack {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    max-width: 480px;
  }

  .hero-img-main {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    box-shadow: 0 20px 60px rgba(62, 39, 39, 0.12);
  }

  .hero-img-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 84% center;
    transition: transform 0.6s ease;
  }

  .hero-img-main:hover img {
    transform: scale(1.03);
  }

  .hero-img-secondary {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .hero-img-sm {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    box-shadow: 0 8px 30px rgba(62, 39, 39, 0.08);
    --img-scale: 1;
    --img-hover-scale: 1.05;
    --img-x: 0%;
  }

  .hero-img-sm img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: translateX(var(--img-x)) scale(var(--img-scale));
    transition: transform 0.6s ease;
  }

  .hero-img-sm:first-child {
    --img-scale: 1.16;
    --img-hover-scale: 1.2;
    --img-x: 5.5%;
  }

  .hero-img-sm:nth-child(2) {
    --img-scale: 1.16;
    --img-hover-scale: 1.2;
    --img-x: 0%;
  }

  .hero-img-sm:hover img {
    transform: translateX(var(--img-x)) scale(var(--img-hover-scale));
  }

  .hero-img-label {
    position: absolute;
    bottom: 12px;
    left: 12px;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(8px);
    padding: 5px 14px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: 0.02em;
  }

  .hero-pro-hook {
    display: inline-grid;
    gap: 3px;
    margin-top: 14px;
    padding: 12px 16px;
    border: 1px solid rgba(168, 102, 102, 0.24);
    border-radius: 16px;
    background: rgba(255, 248, 241, 0.78);
    color: var(--text);
    text-decoration: none;
    box-shadow: 0 10px 30px rgba(62, 39, 39, 0.06);
  }

  .hero-pro-hook[hidden] {
    display: none;
  }

  .hero-pro-hook span {
    color: var(--accent-deep);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-pro-hook strong {
    font-size: 0.94rem;
  }

  @media (max-width: 900px) {
    .hero-img-stack {
      max-width: 100%;
    }

    .hero-img-main {
      aspect-ratio: 4 / 3;
      border-radius: 16px;
    }

    .hero-img-sm {
      border-radius: 12px;
    }
  }

  @media (max-width: 640px) {
    .hero-copy,
    .hero-visuals,
    .hero-img-stack {
      width: 100%;
      max-width: 100%;
      min-width: 0;
    }

    .hero-copy h1 {
      font-size: 2.4rem;
      overflow-wrap: break-word;
    }

    .hero-copy .cta-row {
      width: 100%;
    }

    .hero-copy .cta-row .btn {
      width: 100%;
    }

    .hero-img-secondary {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
