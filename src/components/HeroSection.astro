<script>
  import { getMyStyle } from '../lib/personalization';

  const myStyle = getMyStyle();
  if (myStyle) {
    const title = document.querySelector<HTMLElement>('[data-hero-title]');
    const lead = document.querySelector<HTMLElement>('[data-hero-lead]');
    const primaryCta = document.querySelector<HTMLAnchorElement>('[data-hero-primary-cta]');
    const proHook = document.querySelector<HTMLAnchorElement>('[data-hero-pro-hook]');
    const tryOnHref = `/try-on?scenario=${encodeURIComponent(myStyle.scenario)}&style=${encodeURIComponent(myStyle.slug)}&look=${encodeURIComponent(myStyle.lookSlug)}&source=hero-my-style`;

    if (title) title.textContent = `Welcome back, ready to try ${myStyle.label} again?`;
    if (lead) lead.textContent = 'Your saved style profile is ready. Upload a selfie or preview the look direction you already picked.';
    if (primaryCta) {
      primaryCta.href = tryOnHref;
      primaryCta.textContent = `Try ${myStyle.label}`;
    }
    if (proHook) {
      proHook.href = `/membership?from=hero_weekly_drop&style=${encodeURIComponent(myStyle.slug)}`;
      proHook.hidden = false;
    }
  }
</script>

