---
import { languageConfigs } from "../i18n/config";
import {
  getLanguageSwitchPathname,
  getLocalizedAppHref,
  getLocalizedPathname,
  resolveLocaleRoute,
} from "../i18n/routing";
import { getCurrentLocale } from "../lib/i18n";

type RightAction = "account" | "search" | "help" | "settings" | "bell" | "none";
type ActionItem = Exclude<RightAction, "none"> | "language" | "theme" | "menu";
type SearchPill = {
  label: string;
  href?: string;
  ariaLabel?: string;
};
type TabItem = {
  label: string;
  href?: string;
  active?: boolean;
  filterGroup?: string;
  filterValue?: string;
  queryParam?: string;
  queryValue?: string;
};

interface Props {
  title?: string;
  brand?: boolean;
  backHref?: string;
  rightAction?: RightAction;
  rightHref?: string;
  tabs?: TabItem[];
  fitTabs?: boolean;
  tabOverflow?: TabItem[];
  tabOverflowLabel?: string;
  compact?: boolean;
  showMenu?: boolean;
  showSearch?: boolean;
  showLanguage?: boolean;
  showTheme?: boolean;
  searchControls?: string;
  searchPill?: SearchPill;
}

const {
  title,
  brand = true,
  backHref,
  rightAction = "none",
  rightHref,
  tabs = [],
  fitTabs = false,
  tabOverflow = [],
  tabOverflowLabel,
  compact = false,
  showMenu = true,
  showSearch = false,
  showLanguage = true,
  showTheme = true,
  searchControls,
  searchPill,
} = Astro.props as Props;

const locale = getCurrentLocale();
const currentPathname = Astro.originPathname || Astro.url.pathname;
const currentRoute =
  Astro.locals.localeRoute ?? resolveLocaleRoute(currentPathname);
const activeLanguageSlug = currentRoute.language.slug;
const localizeAppHref = (href: string) =>
  getLocalizedAppHref(href, currentRoute.language.slug);
const localizeHref = (href: string) =>
  getLocalizedPathname(href, currentRoute.language.slug);
const appRoutePathnames = new Set([
  "/tryon-free",
  "/discover",
  "/diagnosis",
  "/pricing",
  "/faq",
  "/history",
  "/login",
  "/dashboard",
  "/support",
  "/tryon-pro",
  "/tryon-premium",
]);
const languageSwitchHref = (languageSlug: string) => {
  if (appRoutePathnames.has(currentRoute.routePathname)) {
    return getLocalizedAppHref(
      `${currentRoute.routePathname}${Astro.url.search}${Astro.url.hash}`,
      languageSlug,
    );
  }
  return `${getLanguageSwitchPathname(currentPathname, languageSlug)}${Astro.url.search}${Astro.url.hash}`;
};
const languageOptions = languageConfigs
  .filter((language) => language.includeInLanguageSwitcher)
  .map((language) => ({
    ...language,
    active: language.slug === activeLanguageSlug,
    href: languageSwitchHref(language.slug),
  }));
const dashboardHref = localizeAppHref("/dashboard");
const accountSettingsHref = `${dashboardHref}#account-panel`;
const authTarget = localizeAppHref(
  `/login?mode=register&next=${encodeURIComponent(dashboardHref)}`,
);
const accountTarget = Astro.locals.isLoggedIn
  ? dashboardHref
  : localizeAppHref(
      `/login?mode=login&next=${encodeURIComponent(dashboardHref)}`,
    );
const resolvedRightHref =
  rightHref ??
  (rightAction === "account"
    ? accountTarget
    : rightAction === "help"
      ? localizeAppHref("/faq")
      : rightAction === "settings"
        ? accountSettingsHref
        : rightAction === "search"
          ? localizeAppHref("/discover")
          : rightAction === "bell"
            ? dashboardHref
            : undefined);
const resolvedBackHref = backHref ?? localizeHref("/");

const copy = {
  en: {
    account: "Account",
    back: "Back",
    bell: "Notifications",
    help: "Help",
    language: "Select language",
    menu: "More",
    search: "Search",
    settings: "Settings",
    theme: "Change display mode",
    pro: "Pro",
  },
  "zh-CN": {
    account: "我的",
    back: "返回",
    bell: "通知",
    help: "帮助",
    language: "选择语言",
    menu: "更多",
    search: "搜索",
    settings: "设置",
    theme: "切换显示模式",
    pro: "Pro",
  },
  "zh-TW": {
    account: "我的",
    back: "返回",
    bell: "通知",
    help: "幫助",
    language: "選擇語言",
    menu: "更多",
    search: "搜尋",
    settings: "設定",
    theme: "切換顯示模式",
    pro: "Pro",
  },
  "de-DE": {
    account: "Konto",
    back: "Zurück",
    bell: "Mitteilungen",
    help: "Hilfe",
    language: "Sprache wählen",
    menu: "Mehr",
    search: "Suchen",
    settings: "Einstellungen",
    theme: "Anzeige wechseln",
    pro: "Pro",
  },
  "fr-FR": {
    account: "Compte",
    back: "Retour",
    bell: "Notifications",
    help: "Aide",
    language: "Choisir la langue",
    menu: "Plus",
    search: "Rechercher",
    settings: "Réglages",
    theme: "Changer l'affichage",
    pro: "Pro",
  },
  "ja-JP": {
    account: "アカウント",
    back: "戻る",
    bell: "通知",
    help: "ヘルプ",
    language: "言語を選択",
    menu: "その他",
    search: "検索",
    settings: "設定",
    theme: "表示を切り替える",
    pro: "Pro",
  },
  "ko-KR": {
    account: "계정",
    back: "뒤로",
    bell: "알림",
    help: "도움말",
    language: "언어 선택",
    menu: "더보기",
    search: "검색",
    settings: "설정",
    theme: "화면 모드 변경",
    pro: "Pro",
  },
  "es-ES": {
    account: "Cuenta",
    back: "Volver",
    bell: "Notificaciones",
    help: "Ayuda",
    language: "Seleccionar idioma",
    menu: "Más",
    search: "Buscar",
    settings: "Ajustes",
    theme: "Cambiar modo de visualización",
    pro: "Pro",
  },
  "es-419": {
    account: "Cuenta",
    back: "Volver",
    bell: "Notificaciones",
    help: "Ayuda",
    language: "Seleccionar idioma",
    menu: "Más",
    search: "Buscar",
    settings: "Ajustes",
    theme: "Cambiar modo de visualización",
    pro: "Pro",
  },
  "pt-BR": {
    account: "Conta",
    back: "Voltar",
    bell: "Notificações",
    help: "Ajuda",
    language: "Selecionar idioma",
    menu: "Mais",
    search: "Buscar",
    settings: "Configurações",
    theme: "Alterar modo de exibição",
    pro: "Pro",
  },
}[locale] ?? {
  account: "Account",
  back: "Back",
  bell: "Notifications",
  help: "Help",
  language: "Select language",
  menu: "More",
  search: "Search",
  settings: "Settings",
  theme: "Change display mode",
  pro: "Pro",
};
const searchPillHref = searchPill?.href ?? localizeAppHref("/discover");
const searchPillLabel = searchPill?.label ?? copy.search;
const searchPillAriaLabel = searchPill?.ariaLabel ?? searchPillLabel;
const hasTabOverflow = tabOverflow.length > 0;
const hasFittedTabs = fitTabs || hasTabOverflow;
const tabOverflowButtonLabel = tabOverflowLabel ?? copy.menu;
const tabOverflowMenuId = "mobile-app-tab-overflow-menu";
const mobileTabsStyle = hasFittedTabs
  ? `--mobile-app-tabs-count: ${tabs.length + (hasTabOverflow ? 1 : 0)}`
  : undefined;

const actionItems: ActionItem[] = [];
if (rightAction !== "none") {
  actionItems.push(rightAction);
} else if (showSearch) {
  actionItems.push("search");
}
if (showLanguage) actionItems.push("language");
if (showTheme) actionItems.push("theme");
if (showMenu) actionItems.push("menu");

const uniqueActionItems = actionItems.filter(
  (item, index) => actionItems.indexOf(item) === index,
);

const getActionHref = (item: ActionItem) => {
  if (item === "account") return accountTarget;
  if (item === "help")
    return rightAction === "help" ? resolvedRightHref : localizeAppHref("/faq");
  if (item === "settings")
    return rightAction === "settings" ? resolvedRightHref : accountSettingsHref;
  if (item === "search")
    return rightAction === "search"
      ? resolvedRightHref
      : localizeAppHref("/discover");
  if (item === "bell") return dashboardHref;
  return undefined;
};

const getActionLabel = (item: ActionItem) => {
  if (item === "account") return copy.account;
  if (item === "help") return copy.help;
  if (item === "settings") return copy.settings;
  if (item === "bell") return copy.bell;
  if (item === "language") return copy.language;
  if (item === "theme") return copy.theme;
  if (item === "menu") return copy.menu;
  return copy.search;
};
---

<header
  class:list={["mobile-app-topbar", compact && "mobile-app-topbar-compact"]}
  data-mobile-app-topbar
>
  <div class="mobile-app-topbar-row">
    <div class="mobile-app-leading">
      {
        brand && (
          <a class="mobile-app-brand" href={localizeHref("/")}>
            <img src="/images/logo-ui.webp" alt="" width="30" height="30" />
          </a>
        )
      }
      {
        backHref ? (
          <a
            class="mobile-app-icon-btn"
            href={resolvedBackHref}
            aria-label={copy.back}
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="m15 5-7 7 7 7" />
            </svg>
          </a>
        ) : (
          <span aria-hidden="true" />
        )
      }
    </div>

    {
      searchPill ? (
        <a
          class="mobile-app-search-pill"
          href={searchPillHref}
          aria-label={searchPillAriaLabel}
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="10.8" cy="10.8" r="6.2" />
            <path d="m16 16 4.2 4.2" />
          </svg>
          <span>{searchPillLabel}</span>
        </a>
      ) : title ? (
        <div class="mobile-app-page-title">{title}</div>
      ) : (
        <span class="mobile-app-title-spacer" aria-hidden="true" />
      )
    }

    <div class="mobile-app-actions">
      {
        uniqueActionItems.map((item) =>
          item === "account" ? (
            <a
              class="mobile-app-account"
              href={accountTarget}
              aria-label={copy.account}
              data-mobile-top-account
              data-auth-href={authTarget}
              data-account-href={dashboardHref}
            >
              <span class="mobile-app-plan" data-mobile-top-plan>
                {Astro.locals.isLoggedIn ? "AI" : copy.account}
              </span>
              <span
                class="mobile-app-avatar"
                data-mobile-top-avatar
                aria-hidden="true"
              >
                A
              </span>
            </a>
          ) : item === "menu" ? (
            <button
              class="mobile-app-icon-btn mobile-app-menu-btn"
              type="button"
              aria-label={copy.menu}
              aria-controls="mobile-nav"
              aria-expanded="false"
              data-mobile-top-menu
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4.5 7h15" />
                <path d="M4.5 12h15" />
                <path d="M4.5 17h15" />
              </svg>
            </button>
          ) : item === "language" ? (
            <div class="mobile-app-lang-dropdown" data-mobile-top-lang>
              <button
                class="mobile-app-icon-btn mobile-app-lang-btn"
                type="button"
                aria-label={copy.language}
                aria-expanded="false"
                aria-haspopup="true"
                aria-controls="mobile-app-lang-menu"
                data-mobile-top-lang-toggle
              >
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="m5 8 6 6" />
                  <path d="m4 14 6-6 2-3" />
                  <path d="M2 5h12" />
                  <path d="M7 2h1" />
                  <path d="m22 22-5-10-5 10" />
                  <path d="M14 18h6" />
                </svg>
              </button>
              <div
                class="mobile-app-lang-menu"
                id="mobile-app-lang-menu"
                role="menu"
              >
                {languageOptions.map((language) => (
                  <button
                    class:list={[
                      "mobile-app-lang-option",
                      language.active && "active",
                    ]}
                    type="button"
                    data-locale={language.locale}
                    data-href={language.href}
                    role="menuitemradio"
                    aria-checked={language.active ? "true" : "false"}
                  >
                    <span>{language.nativeLabel}</span>
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                      <path d="m20 6-11 11-5-5" />
                    </svg>
                  </button>
                ))}
              </div>
            </div>
          ) : item === "theme" ? (
            <button
              class="mobile-app-icon-btn mobile-app-theme-btn"
              type="button"
              aria-label={copy.theme}
              data-mobile-top-theme-toggle
            >
              <svg
                class="mobile-theme-icon mobile-theme-icon-moon"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z" />
              </svg>
              <svg
                class="mobile-theme-icon mobile-theme-icon-sun"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="4" />
                <path d="M12 2v2" />
                <path d="M12 20v2" />
                <path d="m4.93 4.93 1.42 1.42" />
                <path d="m17.66 17.66 1.41 1.41" />
                <path d="M2 12h2" />
                <path d="M20 12h2" />
                <path d="m6.34 17.66-1.41 1.41" />
                <path d="m19.07 4.93-1.41 1.42" />
              </svg>
            </button>
          ) : item === "search" && searchControls ? (
            <button
              class="mobile-app-icon-btn"
              type="button"
              aria-label={getActionLabel(item)}
              aria-controls={searchControls}
              aria-expanded="false"
              data-mobile-search-toggle
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="10.8" cy="10.8" r="6.2" />
                <path d="m16 16 4.2 4.2" />
              </svg>
            </button>
          ) : getActionHref(item) ? (
            <a
              class="mobile-app-icon-btn"
              href={getActionHref(item)}
              aria-label={getActionLabel(item)}
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                {item === "search" && (
                  <>
                    <circle cx="10.8" cy="10.8" r="6.2" />
                    <path d="m16 16 4.2 4.2" />
                  </>
                )}
                {item === "help" && (
                  <>
                    <circle cx="12" cy="12" r="8.3" />
                    <path d="M9.8 9.4a2.4 2.4 0 0 1 4.4 1.4c0 1.8-2.2 2-2.2 3.4" />
                    <path d="M12 17.4h.01" />
                  </>
                )}
                {item === "settings" && (
                  <>
                    <circle cx="12" cy="12" r="3.2" />
                    <path d="M19.4 13.5a7.7 7.7 0 0 0 0-3l2-1.4-2-3.4-2.4 1a8.2 8.2 0 0 0-2.6-1.5L12 2.6H8l-.4 2.6A8.2 8.2 0 0 0 5 6.7l-2.4-1-2 3.4 2 1.4a7.7 7.7 0 0 0 0 3l-2 1.4 2 3.4 2.4-1a8.2 8.2 0 0 0 2.6 1.5L8 21.4h4l.4-2.6a8.2 8.2 0 0 0 2.6-1.5l2.4 1 2-3.4-2-1.4Z" />
                  </>
                )}
                {item === "bell" && (
                  <>
                    <path d="M18 9.8a6 6 0 0 0-12 0c0 7-2.1 6.2-2.1 8h16.2c0-1.8-2.1-1-2.1-8Z" />
                    <path d="M9.8 20a2.5 2.5 0 0 0 4.4 0" />
                  </>
                )}
              </svg>
            </a>
          ) : null,
        )
      }
    </div>
  </div>

  {
    tabs.length > 0 && (
      <nav
        class:list={[
          "mobile-app-tabs",
          hasFittedTabs && "mobile-app-tabs-condensed",
          fitTabs && "mobile-app-tabs-fit-all",
        ]}
        aria-label={title}
        style={mobileTabsStyle}
      >
        {tabs.map((tab) =>
          tab.href ? (
            <a
              class:list={[tab.active && "active"]}
              href={tab.href}
              aria-current={tab.active ? "page" : undefined}
              data-mobile-tab-filter-group={tab.filterGroup}
              data-mobile-tab-filter-value={tab.filterValue}
              data-mobile-tab-query-param={tab.queryParam}
              data-mobile-tab-query-value={tab.queryValue}
            >
              {tab.label}
            </a>
          ) : (
            <span
              class:list={[tab.active && "active"]}
              aria-current={tab.active ? "page" : undefined}
            >
              {tab.label}
            </span>
          ),
        )}
        {hasTabOverflow && (
          <div
            class:list={[
              "mobile-app-tab-overflow",
              tabOverflow.some((tab) => tab.active) && "active",
            ]}
            data-mobile-tab-overflow
          >
            <button
              class="mobile-app-tab-overflow-toggle"
              type="button"
              aria-label={tabOverflowButtonLabel}
              aria-haspopup="menu"
              aria-expanded="false"
              aria-controls={tabOverflowMenuId}
              data-mobile-tab-overflow-toggle
            >
              <span>{tabOverflowButtonLabel}</span>
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="m7 10 5 5 5-5" />
              </svg>
            </button>
            <div
              class="mobile-app-tab-overflow-menu"
              id={tabOverflowMenuId}
              role="menu"
            >
              {tabOverflow.map((tab) =>
                tab.href ? (
                  <a
                    class:list={[tab.active && "active"]}
                    href={tab.href}
                    aria-current={tab.active ? "page" : undefined}
                    data-mobile-tab-filter-group={tab.filterGroup}
                    data-mobile-tab-filter-value={tab.filterValue}
                    data-mobile-tab-query-param={tab.queryParam}
                    data-mobile-tab-query-value={tab.queryValue}
                    role="menuitem"
                  >
                    {tab.label}
                  </a>
                ) : (
                  <span
                    class:list={[tab.active && "active"]}
                    aria-current={tab.active ? "page" : undefined}
                    role="menuitem"
                  >
                    {tab.label}
                  </span>
                ),
              )}
            </div>
          </div>
        )}
      </nav>
    )
  }
</header>

<script is:inline>
  (() => {
    const menuButtons = document.querySelectorAll("[data-mobile-top-menu]");
    const siteToggle = document.querySelector("[data-mobile-toggle]");
    const nav = document.querySelector("[data-mobile-nav]");
    const themeButtons = document.querySelectorAll(
      "[data-mobile-top-theme-toggle]",
    );
    const langDropdowns = document.querySelectorAll("[data-mobile-top-lang]");
    const tabOverflowGroups = document.querySelectorAll(
      "[data-mobile-tab-overflow]",
    );

    function syncExpanded() {
      const isOpen = nav?.classList.contains("mobile-open") || false;
      menuButtons.forEach((button) => {
        button.setAttribute("aria-expanded", String(isOpen));
      });
    }

    if (menuButtons.length) {
      menuButtons.forEach((button) => {
        button.addEventListener("click", () => {
          siteToggle?.click();
          window.setTimeout(syncExpanded, 0);
        });
      });

      if (nav) {
        new MutationObserver(syncExpanded).observe(nav, {
          attributes: true,
          attributeFilter: ["class"],
        });
      }
      syncExpanded();
    }

    themeButtons.forEach((button) => {
      button.addEventListener("click", () => {
        document.getElementById("theme-toggle")?.click();
      });
    });

    function closeLanguageDropdowns(except) {
      langDropdowns.forEach((dropdown) => {
        if (dropdown === except) return;
        dropdown.classList.remove("open");
        dropdown
          .querySelector("[data-mobile-top-lang-toggle]")
          ?.setAttribute("aria-expanded", "false");
      });
    }

    function closeTabOverflowGroups(except) {
      tabOverflowGroups.forEach((group) => {
        if (group === except) return;
        group.classList.remove("open");
        group
          .querySelector("[data-mobile-tab-overflow-toggle]")
          ?.setAttribute("aria-expanded", "false");
      });
    }

    langDropdowns.forEach((dropdown) => {
      const toggle = dropdown.querySelector("[data-mobile-top-lang-toggle]");
      const options = dropdown.querySelectorAll("[data-href][data-locale]");
      toggle?.addEventListener("click", (event) => {
        event.stopPropagation();
        const nextOpen = !dropdown.classList.contains("open");
        closeLanguageDropdowns(dropdown);
        closeTabOverflowGroups();
        dropdown.classList.toggle("open", nextOpen);
        toggle.setAttribute("aria-expanded", String(nextOpen));
      });
      options.forEach((option) => {
        option.addEventListener("click", () => {
          const locale = option.getAttribute("data-locale");
          const href = option.getAttribute("data-href") || "/";
          if (locale) {
            document.cookie = `abs_locale=${encodeURIComponent(locale)};path=/;max-age=31536000;SameSite=Lax`;
          }
          window.location.assign(new URL(href, window.location.origin).href);
        });
      });
    });

    tabOverflowGroups.forEach((group) => {
      const toggle = group.querySelector("[data-mobile-tab-overflow-toggle]");
      const links = group.querySelectorAll("a");
      toggle?.addEventListener("click", (event) => {
        event.stopPropagation();
        const nextOpen = !group.classList.contains("open");
        closeTabOverflowGroups(group);
        closeLanguageDropdowns();
        group.classList.toggle("open", nextOpen);
        toggle.setAttribute("aria-expanded", String(nextOpen));
      });
      links.forEach((link) => {
        link.addEventListener("click", () => {
          closeTabOverflowGroups();
        });
      });
    });

    document.addEventListener("click", () => {
      closeLanguageDropdowns();
      closeTabOverflowGroups();
    });
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeLanguageDropdowns();
        closeTabOverflowGroups();
      }
    });
  })();
</script>

<style>
  .mobile-app-topbar {
    display: none;
  }
  @media (max-width: 767px) {
    .mobile-app-topbar {
      position: sticky;
      top: 0;
      z-index: 115;
      display: block;
      border-bottom: 1px solid color-mix(in srgb, var(--line) 82%, transparent);
      background: var(--bg-elevated);
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }
    .mobile-app-topbar-row {
      display: grid;
      min-height: 56px;
      grid-template-columns:
        minmax(44px, max-content) minmax(0, 1fr)
        max-content;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
    }
    .mobile-app-page-title {
      display: -webkit-box;
      width: 100%;
      min-width: 0;
      max-width: none;
      overflow: hidden;
      margin: 0;
      color: var(--navy);
      font-size: clamp(14px, 3.8vw, 16px);
      font-weight: 900;
      line-height: 1.12;
      text-align: center;
      text-wrap: balance;
      white-space: normal;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
    }
    .mobile-app-leading,
    .mobile-app-actions {
