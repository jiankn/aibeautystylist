---
import { scenarioPages } from '../data/scenarioPages';

const scenarios = scenarioPages.slice(0, 6).map((page) => ({
  title: page.eyebrow,
  copy: page.description,
  href: `/scenarios/${page.slug}`,
}));
---

<section class="section" id="scenarios">
  <div class="container">
    <div class="section-copy">
      <span class="eyebrow">Start from Your Goal</span>
      <h2>Different scenes need different strategies. Pick yours.</h2>
      <p>Each scenario gets a tailored AI recommendation — low effort, high impact looks that actually work for you.</p>
      <a class="text-link" href="/makeup-guides">Browse all makeup guides</a>
    </div>

    <div class="grid-cards grid-cards-3">
      {scenarios.map((scenario, index) => (
        <a class="card scenario-card" href={scenario.href}>
          <span class="scenario-index">0{index + 1}</span>
          <h3>{scenario.title}</h3>
          <p>{scenario.copy}</p>
          <span class="text-link">Open guide</span>
        </a>
      ))}
    </div>
  </div>
</section>
