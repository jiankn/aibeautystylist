---
const scenarios = [
  {
    title: '10-min commute glow',
    copy: 'A fast polished routine for office light, video calls, and everyday structure.',
    href: '/scenarios/office-makeup',
  },
  {
    title: 'Interview-ready polish',
    copy: 'Controlled definition, calmer color, and a look that reads capable in person.',
    href: '/scenarios/interview-makeup',
  },
  {
    title: 'Soft date-night mood',
    copy: 'Romantic color harmony with close-up friendly skin and softly defined edges.',
    href: '/scenarios/date-night-makeup',
  },
  {
    title: 'Bridal soft glam',
    copy: 'Long-wear glow, camera balance, and a tutorial path for high-stakes days.',
    href: '/scenarios/bridal-makeup',
  },
  {
    title: 'First-timer basics',
    copy: 'A beginner-safe path that keeps the step count low and the result repeatable.',
    href: '/try-on?scenario=office',
  },
];
---

<section class="section" id="scenarios">
  <div class="container">
    <div class="section-copy">
      <span class="eyebrow">Start from Your Goal</span>
      <h2>Different scenes need different strategies. Pick yours.</h2>
      <p>Each scenario gets a tailored AI recommendation — low effort, high impact looks that actually work for you.</p>
    </div>

    <div class="grid-cards grid-cards-3">
      {scenarios.map((scenario, index) => (
        <a class="card scenario-card" href={scenario.href}>
          <span class="scenario-index">0{index + 1}</span>
          <h3>{scenario.title}</h3>
          <p>{scenario.copy}</p>
          <span class="text-link">Open guide</span>
        </a>
      ))}
    </div>
  </div>
</section>
