  const setUploadState = (nextState: UploadState, statusText?: string) => {
    uploadState = nextState;
    dropzone?.classList.toggle('is-uploading', nextState === 'reading' || nextState === 'compressing');
    dropzone?.classList.toggle('has-file', Boolean(preparedPhotoBase64 && selectedPhotoFile));
    dropzone?.classList.toggle('has-error', nextState === 'error');
    uploadIdleCopy?.classList.toggle('is-hidden', Boolean(preparedPhotoBase64 && selectedPhotoFile) || nextState === 'reading' || nextState === 'compressing');
    uploadReadyCopy?.classList.toggle('is-hidden', !(preparedPhotoBase64 && selectedPhotoFile) || nextState === 'reading' || nextState === 'compressing');
    uploadPreview?.classList.toggle('is-hidden', !(preparedPhotoBase64 && selectedPhotoFile));

    if (nextState !== 'reading' && nextState !== 'compressing') {
      uploadProgress?.classList.add('is-hidden');
      uploadProgress?.setAttribute('aria-hidden', 'true');
    }

    if (uploadStatus && statusText) uploadStatus.textContent = statusText;
    setGenerateButtonState();
  };

  const showUploadError = (message: string) => {
    if (uploadError) {
      uploadError.textContent = message;
      uploadError.classList.remove('is-hidden');
    }
    preparedPhotoBase64 = null;
    selectedPhotoFile = null;
    if (photoInput) photoInput.value = '';
    updatePreviewImage(undefined);
    setUploadState('error', TX.uploadNeedsAttention);
    setLive(message);
  };

  const validatePhotoFile = (file: File) => {
    const hasAllowedType = ALLOWED_UPLOAD_TYPES.includes(file.type);
    const hasAllowedExtension = /\.(jpe?g|png|webp)$/i.test(file.name);
    if (!hasAllowedType && !hasAllowedExtension) {
      return TX.uploadErrorType;
    }
    if (file.size <= 0) {
      return TX.uploadErrorEmpty;
    }
    if (file.size > MAX_UPLOAD_BYTES) {
      return `${TX.uploadErrorTooLargePrefix}${formatFileSize(file.size)}${TX.uploadErrorTooLargeSuffix}`;
    }
    return '';
  };

  const updateUploadPreview = (file: File, prepared: PreparedPhoto) => {
    if (uploadThumb) {
      uploadThumb.src = prepared.previewUrl;
      uploadThumb.alt = `${file.name} thumbnail`;
    }
    if (uploadFileName) uploadFileName.textContent = file.name || TX.uploadFileName;
    if (uploadFileMeta) {
      uploadFileMeta.textContent = `${formatFileSize(file.size)} ${TX.metaOriginal} · ${prepared.width}×${prepared.height} ${TX.metaAiReady} · ${formatFileSize(prepared.byteSize)} ${TX.metaOptimized}`;
    }
    if (uploadStatus) uploadStatus.textContent = TX.uploadReadyForDiagnosis;
  };

  const resetUpload = () => {
    uploadPreparationToken += 1;
    selectedPhotoFile = null;
    preparedPhotoBase64 = null;
    currentPhotoBase64 = null;
    currentLandmarks = null;
    currentUploadKey = null;
    renderedAfterImages.clear();
    if (photoInput) photoInput.value = '';
    if (uploadThumb) {
      uploadThumb.removeAttribute('src');
      uploadThumb.alt = 'Uploaded selfie thumbnail';
    }
    if (uploadFileName) uploadFileName.textContent = TX.uploadFileName;
    if (uploadFileMeta) uploadFileMeta.textContent = TX.uploadFileMeta;
    clearUploadError();
    updatePreviewImage(undefined);
    setUploadState('idle', TX.uploadContinue);
  };

  const compressPhoto = (
    file: File,
    onProgress?: (stage: UploadState, percent: number, detail: string) => void,
  ): Promise<PreparedPhoto> => {
    return new Promise((resolve, reject) => {
      const img = new Image();
      const reader = new FileReader();
      reader.onprogress = (event) => {
        if (!event.lengthComputable) {
          onProgress?.('reading', 28, 'Reading your image locally.');
          return;
        }
        const readPercent = 8 + (event.loaded / event.total) * 44;
        onProgress?.('reading', readPercent, `Reading ${formatFileSize(event.loaded)} of ${formatFileSize(event.total)}.`);
      };
      reader.onload = () => {
        const source = reader.result;
        if (typeof source !== 'string') {
          reject(new Error('Unable to read uploaded image.'));
          return;
        }
        onProgress?.('compressing', 58, 'Optimizing image for faster AI analysis.');
        img.onload = () => {
          const MAX_DIM = 768;
          let { width, height } = img;
          if (width > MAX_DIM || height > MAX_DIM) {
            const ratio = Math.min(MAX_DIM / width, MAX_DIM / height);
            width = Math.round(width * ratio);
            height = Math.round(height * ratio);
          }
          const canvas = document.createElement('canvas');
          canvas.width = width;
          canvas.height = height;
          const ctx = canvas.getContext('2d');
          ctx?.drawImage(img, 0, 0, width, height);
          onProgress?.('compressing', 84, 'Creating an AI-ready preview.');
          const dataUrl = canvas.toDataURL('image/jpeg', 0.7);
          resolve({
            dataUrl,
            previewUrl: dataUrl,
            width,
            height,
            byteSize: getDataUrlByteSize(dataUrl),
          });
        };
        img.onerror = () => reject(new Error('Unable to load uploaded image.'));
        img.src = source;
      };
      reader.onerror = () => reject(new Error('Unable to read uploaded image.'));
      reader.readAsDataURL(file);
    });
  };

  const preparePhoto = async (file: File) => {
    clearUploadError();
    const validationError = validatePhotoFile(file);
    if (validationError) {
      showUploadError(validationError);
      return;
    }

    const token = ++uploadPreparationToken;
    selectedPhotoFile = file;
    preparedPhotoBase64 = null;
    currentPhotoBase64 = null;
    currentLandmarks = null;
    currentUploadKey = null;
    renderedAfterImages.clear();
    updatePreviewImage(undefined);
    setUploadProgress(TX.uploadProgressLabel, 6, TX.uploadProgressDetail);
    setUploadState('reading', TX.uploadProgressLabel);

    try {
      const prepared = await compressPhoto(file, (stage, percent, detail) => {
        if (token !== uploadPreparationToken) return;
        setUploadState(stage, TX.uploadProgressLabel);
        setUploadProgress(TX.uploadProgressLabel, percent, detail);
      });
      if (token !== uploadPreparationToken) return;
      preparedPhotoBase64 = prepared.dataUrl;
      updateUploadPreview(file, prepared);
      updatePreviewImage(prepared.previewUrl);
      setUploadProgress(TX.uploadReadyForDiagnosis, 100, TX.uploadReadyForDiagnosis);
      window.setTimeout(() => {
        if (token === uploadPreparationToken) setUploadState('ready', TX.uploadReadyForDiagnosis);
      }, 180);
      setLive(TX.selfieUploadSuccess);
    } catch (error) {
      if (token !== uploadPreparationToken) return;
      console.warn('[TryOnStudio] Photo preparation failed:', error);
      showUploadError('Unable to prepare this image. Please try a different JPG, PNG, or WebP selfie.');
    }
  };

  const initMediaPipe = async () => {
    if (faceLandmarkerInstance) return faceLandmarkerInstance;
    try {
      const { initFaceLandmarker } = await import('../lib/faceColorEngine');
      faceLandmarkerInstance = await initFaceLandmarker();
      return faceLandmarkerInstance;
    } catch (error) {
      console.warn('[TryOnStudio] MediaPipe load failed; falling back to color swatch preview:', error);
      return null;
    }
  };

  const applyLipColorToCanvas = async (lipColorData: LipColorParams) => {
    if (!afterCanvas || !beforeImage || !lipColorData) return;
    const imgEl = beforeImage;
    if (!imgEl.naturalWidth) return;
    afterImage?.classList.add('is-hidden');

    if (currentLandmarks) {
      try {
        const { applyLipColor } = await import('../lib/faceColorEngine');
        applyLipColor(afterCanvas, imgEl, currentLandmarks, lipColorData);
        afterCanvas.classList.remove('is-hidden');
        afterPlaceholder?.classList.add('is-hidden');
        lipSwatch?.classList.add('is-hidden');
        return;
      } catch (error) {
        console.warn('[TryOnStudio] Canvas lip color failed:', error);
      }
    }
    try {
      const { renderColorSwatch } = await import('../lib/faceColorEngine');
      if (lipSwatch) {
        renderColorSwatch(lipSwatch, lipColorData);
        lipSwatch.classList.remove('is-hidden');
        afterPlaceholder?.classList.add('is-hidden');
      }
    } catch (error) {
      console.warn('[TryOnStudio] Color swatch fallback failed:', error);
    }
  };

  const setStep = (nextStep: 'input' | 'loading' | 'result') => {
    tryonShell?.setAttribute('data-tryon-current-step', nextStep);
    steps.forEach((element) => {
      const isNext = element.dataset.tryonStep === nextStep;
      if (isNext) {
        element.classList.remove('is-hidden', 'is-step-exit');
        element.classList.add('is-step-enter');
        window.requestAnimationFrame(() => {
          element.classList.add('is-step-active');
          window.setTimeout(() => element.classList.remove('is-step-enter'), 220);
        });
        return;
      }

      if (!element.classList.contains('is-hidden')) {
        element.classList.remove('is-step-active', 'is-step-enter');
        element.classList.add('is-step-exit');
        window.setTimeout(() => {
          if (element.dataset.tryonStep !== nextStep) {
            element.classList.add('is-hidden');
            element.classList.remove('is-step-exit');
          }
        }, 180);
        return;
      }

      element.classList.remove('is-step-active', 'is-step-enter', 'is-step-exit');
      element.classList.add('is-hidden');
    });
  };

  const fillList = (container: HTMLElement | null, items: string[] = []) => {
    if (!container) return;
    container.innerHTML = '';
    items.forEach((item) => {
      const li = document.createElement('li');
      li.textContent = item;
      container.appendChild(li);
    });
  };

  const renderTags = (container: HTMLElement | null, items: string[] = []) => {
    if (!container) return;
    container.innerHTML = '';
    items.forEach((item) => {
      const span = document.createElement('span');
      span.className = 'share-tag';
      span.textContent = item;
      container.appendChild(span);
    });
  };

  const renderStepPreview = (container: HTMLElement | null, items: TryOnStepClient[] = []) => {
    if (!container) return;
    container.innerHTML = '';
    const lang = (document.documentElement.lang || 'en').toLowerCase();
    const selfLabel = TX.selfCheckLabel;
    items.slice(0, 3).forEach((item, index) => {
      const article = document.createElement('article');
      article.className = 'mini-step-card';
      const idx = document.createElement('span');
      idx.className = 'mini-step-index';
      idx.textContent = String(index + 1).padStart(2, '0');
      const body = document.createElement('div');
      const h5 = document.createElement('h5');
      h5.textContent = item.title;
      const p = document.createElement('p');
      p.textContent = item.detail;
      const small = document.createElement('small');
      small.style.color = 'var(--muted)';
      small.textContent = `${selfLabel}${item.selfCheck}`;
      body.append(h5, p, small);
      article.append(idx, body);
      container.appendChild(article);
    });
  };

  const renderProductGroup = (container: HTMLElement | null, items: TryOnProductClient[] = []) => {
    if (!container) return;
    container.innerHTML = '';
    items.forEach((item) => {
      const article = document.createElement('article');
      article.className = 'product-card';
      const head = document.createElement('div');
      head.className = 'product-card-head';
      const meta = document.createElement('p');
      meta.className = 'product-meta';
      meta.textContent = `${item.category} · ${item.shade}`;
      const price = document.createElement('span');
      price.className = 'product-price';
      price.textContent = item.price;
      head.append(meta, price);
      const h5 = document.createElement('h5');
      h5.textContent = item.name;
      const why = document.createElement('p');
      why.className = 'product-reason';
      why.textContent = item.why;
      article.append(head, h5, why);
      container.appendChild(article);
    });
  };

  const getSelectedLook = (): TryOnLookClient | undefined =>
    currentLooks.find((item) => item.id === selectedLookId);

  const showAfterPlaceholder = (message = 'Selected look preview') => {
    afterImage?.classList.add('is-hidden');
    afterImage?.removeAttribute('src');
    afterCanvas?.classList.add('is-hidden');
    lipSwatch?.classList.add('is-hidden');
    if (afterPlaceholder) {
      afterPlaceholder.textContent = message;
      afterPlaceholder.classList.remove('is-hidden');
    }
  };

  const showAfterImage = (look: TryOnLookClient, dataUrl: string) => {
    afterCanvas?.classList.add('is-hidden');
    lipSwatch?.classList.add('is-hidden');
    afterPlaceholder?.classList.add('is-hidden');
    if (afterImage) {
      afterImage.src = dataUrl;
      afterImage.alt = `${look.name} realistic makeup preview`;
      afterImage.classList.remove('is-hidden');
    }
  };

  const updateShareResultVisual = (dataUrl?: string, look?: TryOnLookClient) => {
    if (!shareResultVisual || !shareResultImage) return;
    if (!dataUrl) {
      shareResultVisual.classList.add('is-hidden');
      shareResultImage.removeAttribute('src');
      return;
    }
    shareResultImage.src = dataUrl;
    shareResultImage.alt = look ? `${TX.shareAfterAlt}: ${look.name}` : TX.shareAfterAlt;
    shareResultVisual.classList.remove('is-hidden');
  };

  const fallbackToCanvasPreview = (lookId: string) => {
    if (currentLipColors && currentLipColors[lookId]) {
      applyLipColorToCanvas(currentLipColors[lookId]);
      return;
    }
    showAfterPlaceholder('Full-face preview is not available for this look yet.');
  };

  const renderRealMakeupPreview = async (look: TryOnLookClient) => {
    if (!currentPhotoBase64 || currentIsDemo) {
      fallbackToCanvasPreview(look.id);
      return;
    }
    if (currentGatedInfo?.isFreeTier && currentGatedInfo.lockedFeatures.includes('makeup_preview')) {
      fallbackToCanvasPreview(look.id);
      return;
    }

    const cached = renderedAfterImages.get(look.id);
    if (cached) {
      showAfterImage(look, cached);
      setUploadState('ready', 'Ready for AI diagnosis');
      return;
    }

    const sequence = ++renderSequence;
    showAfterPlaceholder('Generating realistic full-face makeup preview...');
    setUploadState('rendering', 'Rendering makeup preview');

    try {
      const response = await fetch('/api/try-on-render', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          photoBase64: currentPhotoBase64,
          locale: (document.documentElement.lang || 'en').toLowerCase().startsWith('zh') ? 'zh' : 'en',
          look: {
            id: look.id,
            name: look.name,
            reason: look.reason,
            scenario: look.scenario,
            focus: look.focus,
            finish: look.finish,
            tutorialHeadline: look.tutorialHeadline,
          },
        }),
      });
      const data = await response.json() as TryOnRenderResponse;
      const dataUrl = data._render?.image?.dataUrl;
      if (sequence !== renderSequence || selectedLookId !== look.id) return;

      if (response.ok && dataUrl && !data._render?.fallback) {
        renderedAfterImages.set(look.id, dataUrl);
        showAfterImage(look, dataUrl);
        setUploadState('ready', 'Preview generated');
        setLive('Realistic makeup preview generated.');
        return;
      }

      console.warn('[TryOnStudio] Full-face render fallback:', data._render?.fallbackReason);
      fallbackToCanvasPreview(look.id);
      setUploadState('ready', 'Preview fallback shown');
    } catch (error) {
      if (sequence !== renderSequence || selectedLookId !== look.id) return;
      console.warn('[TryOnStudio] Full-face render request failed:', error);
      fallbackToCanvasPreview(look.id);
      setUploadState('ready', 'Preview fallback shown');
    }
  };

  const renderLookCards = () => {
    if (!lookList) return;
    lookList.innerHTML = '';
    if (!currentLooks.length) {
      const empty = document.createElement('div');
      empty.className = 'empty-state';
      empty.innerHTML = `
        <span class="empty-state-mark" aria-hidden="true"></span>
        <strong>No looks available yet</strong>
        <p>Upload a selfie or choose a sample look to generate personalized recommendations.</p>
      `;
      lookList.appendChild(empty);
      if (looksProgressTotal) looksProgressTotal.textContent = '0';
      if (looksProgressCurrent) looksProgressCurrent.textContent = '0';
      return;
    }

    currentLooks.forEach((look) => {
      const button = document.createElement('button');
      button.type = 'button';
      button.className = `look-option-card${look.id === selectedLookId ? ' is-active' : ''}`;
      button.setAttribute('aria-label', `Select ${look.name}. ${look.minutes} look focused on ${look.focus}.`);
      button.setAttribute('aria-pressed', String(look.id === selectedLookId));
      const pill = document.createElement('span');
      pill.className = 'pill';
      pill.textContent = look.scenario;
      const h4 = document.createElement('h4');
      h4.textContent = look.name;
      const p = document.createElement('p');
      p.textContent = look.reason;
      const meta = document.createElement('div');
      meta.className = 'look-option-meta';
      [look.difficulty, look.minutes, look.focus].forEach((text) => {
        const s = document.createElement('span');
        s.textContent = text;
        meta.appendChild(s);
      });
      // 唇色色块（如果有唇色数据）
      const lipSwatchContainer = document.createElement('div');
      lipSwatchContainer.className = 'look-card-lip-swatch';
      if (currentLipColors && currentLipColors[look.id]) {
        import('../lib/faceColorEngine').then(({ renderInlineSwatch }) => {
          renderInlineSwatch(lipSwatchContainer, currentLipColors![look.id]);
        }).catch(() => {});
      }
      const previewBtn = document.createElement('button');
      previewBtn.type = 'button';
      const isFreeTier = currentGatedInfo?.isFreeTier ?? false;
      const previewLocked = isFreeTier && currentGatedInfo?.lockedFeatures.includes('makeup_preview');
      previewBtn.className = `btn btn-secondary look-preview-btn${previewLocked ? ' is-locked' : ''}`;
      previewBtn.innerHTML = previewLocked ? TX.previewMakeupLocked : TX.previewMakeup;
      previewBtn.dataset.lookId = look.id;
      previewBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        triggerMakeupPreview(look);
      });
      button.append(pill, h4, p, meta, lipSwatchContainer, previewBtn);
      button.addEventListener('click', () => selectLook(look.id));
      lookList.appendChild(button);
    });

    if (currentGatedInfo?.isFreeTier && currentLooks.length < 3) {
      const remaining = 3 - currentLooks.length;
      const ghost = document.createElement('a');
      ghost.className = 'look-option-card look-option-ghost';
      ghost.href = '/membership?from=tryon_ghost_card';
      ghost.setAttribute('aria-label', `${remaining}${TX.ghostCardSuffix}`);
      ghost.innerHTML = `
        <span class="look-ghost-icon" aria-hidden="true">🔒</span>
        <h4>${remaining}${TX.ghostCardSuffix}</h4>
        <p>${TX.ghostCardDetail}</p>
        <span class="look-ghost-cta">${TX.ghostCardCta}</span>
      `;
      ghost.addEventListener('click', () => {
        trackLookEvent('upgrade_click', { source: 'tryon_ghost_card' });
      });
      lookList.appendChild(ghost);
    }

    // P2.10: refresh progress total + observe new cards for current chip
    if (looksProgressTotal) looksProgressTotal.textContent = String(currentLooks.length);
    setupLooksProgress();
  };

  // P2.10: 横滑进度跟踪
  let looksProgressObserver: IntersectionObserver | null = null;
  const setupLooksProgress = () => {
    if (!lookList || !looksProgressEl) return;
    looksProgressObserver?.disconnect();
    const cards = Array.from(lookList.querySelectorAll<HTMLElement>('.look-option-card:not(.look-option-ghost)'));
    if (!cards.length) return;
    const observer = new IntersectionObserver(
      (entries: IntersectionObserverEntry[]) => {
        // Pick the entry with the largest intersectionRatio
        let best = entries[0];
        if (!best) return;
        for (const entry of entries) {
          if (entry.intersectionRatio > best.intersectionRatio) best = entry;
        }
        if (best.isIntersecting) {
          const idx = cards.indexOf(best.target as HTMLElement);
          if (idx >= 0 && looksProgressCurrent) {
            looksProgressCurrent.textContent = String(idx + 1);
          }
        }
      },
      { root: lookList, threshold: [0.5, 0.75, 1] },
    );
    looksProgressObserver = observer;
    cards.forEach((c) => observer.observe(c));
  };

  const selectLook = (lookId: string) => {
    const look = currentLooks.find((item) => item.id === lookId);
    if (!look) return;

    selectedLookId = lookId;
    if (selectedLookName) selectedLookName.textContent = look.name;
    if (selectedLookFinish) selectedLookFinish.textContent = look.finish;
    if (selectedLookFocus) selectedLookFocus.textContent = look.focus;
    if (selectedLookTime) selectedLookTime.textContent = look.minutes;
    if (selectedLookReason) selectedLookReason.textContent = look.reason;
    if (selectedLookHeading) selectedLookHeading.textContent = look.name;
    if (selectedLookHeadline) selectedLookHeadline.textContent = look.tutorialHeadline;

    const tutorialHref = `/tutorials/${look.id}`;
    if (tutorialLink) tutorialLink.setAttribute('href', tutorialHref);
    if (finalTutorialLink) finalTutorialLink.setAttribute('href', tutorialHref);
    if (continueLink) continueLink.setAttribute('href', tutorialHref);

    renderStepPreview(selectedSteps, look.tutorialSteps ?? []);
    fillList(selectedSelfChecks, look.selfChecks ?? []);
    renderProductGroup(kitMust, look.kit?.mustHave ?? []);
    renderProductGroup(kitOptional, look.kit?.optional ?? []);
    renderProductGroup(kitUpgrade, look.kit?.upgrade ?? []);

    if (shareLook) shareLook.textContent = `${look.name} · ${look.finish}`;
    updateShareResultVisual(renderedAfterImages.get(look.id), look);
    renderLookCards();

    // P0 — 同步教程锁卡显示状态
    syncTutorialLock(look);

    fallbackToCanvasPreview(look.id);
  };

  const updatePreviewImage = (source?: string) => {
    if (!source) {
      beforeImage?.classList.add('is-hidden');
      beforeImage?.removeAttribute('src');
      beforePlaceholder?.classList.remove('is-hidden');
      afterImage?.classList.add('is-hidden');
      afterImage?.removeAttribute('src');
      afterCanvas?.classList.add('is-hidden');
      lipSwatch?.classList.add('is-hidden');
      afterPlaceholder?.classList.remove('is-hidden');
      return;
    }
    if (beforeImage) {
      beforeImage.setAttribute('src', source);
      beforeImage.setAttribute('alt', 'Your selfie');
      beforeImage.classList.remove('is-hidden');
    }
    beforePlaceholder?.classList.add('is-hidden');
  };

  const setShareStatus = (message: string) => {
    if (shareStatus) shareStatus.textContent = message;
  };

  const setLive = (message: string) => {
    if (liveRegion) liveRegion.textContent = message;
  };

  // P0.A6: 提交后 scroll + focus 到结果标题
  const focusResult = () => {
    const heading = document.getElementById('tryon-section-diagnosis');
    if (!heading) return;
    requestAnimationFrame(() => {
      heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
      // 在动画结束后获取焦点（避免 smooth scroll 被打断）
      setTimeout(() => heading.focus({ preventScroll: true }), 250);
    });
  };

  // P0 — 应用会员门控信息：显示/隐藏升级横幅 + 教程被裁锁卡
  const featureLabelMap: Record<string, string> = {
    makeup_preview: 'HD Makeup Preview on your face',
    full_tutorial: 'Full step-by-step tutorial (all steps)',
    product_recommendations: 'Curated product recommendations',
    saved_looks: 'Save & revisit your look plans',
    look_history: 'Unlimited look history',
  };

  const syncRemainingBadge = (
    tier: 'free' | 'pro' | 'premium',
    remaining?: number,
    limit?: number,
    windowType?: 'daily' | 'monthly',
    hasPhoto = false,
  ) => {
    if (!remainingBadge || typeof remaining !== 'number' || !hasPhoto) {
      remainingBadge?.classList.add('is-hidden');
      return;
    }

    const label = tier === 'free'
      ? TX.remainingBadge
      : tier === 'premium'
        ? TX.remainingBadgePremium
        : TX.remainingBadgeMonthly;
    if (remainingLabel) remainingLabel.textContent = label;
    if (remainingCount) remainingCount.textContent = String(remaining);

    const resolvedLimit = typeof limit === 'number' && Number.isFinite(limit) ? limit : undefined;
    if (remainingTotal) {
      remainingTotal.textContent = resolvedLimit ? `/${resolvedLimit}` : '';
      remainingTotal.classList.toggle('is-hidden', !resolvedLimit);
    }

    remainingBadge.dataset.quotaTier = tier;
    remainingBadge.dataset.quotaWindow = windowType || (tier === 'free' ? 'daily' : 'monthly');
    remainingBadge.classList.remove('is-hidden');
  };

  const applyGatedInfo = (gated?: GatedInfo) => {
    currentGatedInfo = gated;
    currentTier = gated?.tier ?? currentTier;
    const isFreeTier = Boolean(gated?.isFreeTier);
    looksUpgradeCta?.classList.toggle('is-hidden', !isFreeTier);
    if (!gated || !gated.isFreeTier) {
      gatedBanner?.classList.add('is-hidden');
      tutorialLock?.classList.add('is-hidden');
      upgradeCompare?.classList.add('is-hidden');
      return;
    }

    // P1 — 结果页底部升级对比卡（仅免费用户）
    if (upgradeCompare) {
      upgradeCompare.classList.remove('is-hidden');
      const lookCount = currentLooks.length;
      if (upgradeCompareFreeLooks) {
        upgradeCompareFreeLooks.textContent = `${lookCount || 2} look${(lookCount || 2) > 1 ? 's' : ''}`;
      }
      if (upgradeCompareCtaPro && !upgradeCompareCtaPro.dataset.bound) {
        upgradeCompareCtaPro.dataset.bound = '1';
        upgradeCompareCtaPro.addEventListener('click', () => {
          trackLookEvent('upgrade_click', { source: 'tryon_compare_pro' });
        });
      }
      if (upgradeCompareCtaPremium && !upgradeCompareCtaPremium.dataset.bound) {
        upgradeCompareCtaPremium.dataset.bound = '1';
        upgradeCompareCtaPremium.addEventListener('click', () => {
          trackLookEvent('upgrade_click', { source: 'tryon_compare_premium' });
        });
      }
    }

    // 顶部升级横幅（仅免费用户）
    if (gatedBanner) {
      gatedBanner.classList.remove('is-hidden');
      if (gatedMessage && gated.upgradeMessage) gatedMessage.textContent = gated.upgradeMessage;
      const upgradeHref = `${gated.upgradeUrl || '/membership'}?from=tryon_result`;
      if (gatedCta) {
        gatedCta.textContent = gated.upgradeCta || 'Upgrade to Pro';
        gatedCta.setAttribute('href', upgradeHref);
        gatedCta.addEventListener('click', () => {
          trackLookEvent('upgrade_click', { source: 'tryon_gated_banner' });
        }, { once: true });
      }
      // 根据 looks 实际数量动态生成详情文案
      const lookCount = currentLooks.length;
      const hasGatedTutorial = currentLooks.some((l) => l._tutorialGated);
      const detailParts: string[] = [];
      if (lookCount > 0) detailParts.push(`You're seeing ${lookCount} of 3 looks`);
      if (hasGatedTutorial) detailParts.push('the first 3 tutorial steps');
      if (gatedDetail) {
        gatedDetail.textContent = detailParts.length
          ? `${detailParts.join(' and ')}. Upgrade to see everything.`
          : 'Sign in and upgrade to unlock the full experience.';
      }
      if (gatedFeaturesList && gated.lockedFeatures.length > 0) {
        gatedFeaturesList.innerHTML = gated.lockedFeatures
          .map((f) => `<li>${featureLabelMap[f] || f}</li>`)
          .join('');
        gatedFeaturesList.classList.remove('is-hidden');
      }
    }
  };

  // 在切换 look 时同步更新教程锁卡（必须依赖 selectLook 已更新 currentLook 的 _tutorialGated 状态）
  const syncTutorialLock = (look: TryOnLookClient | undefined) => {
    if (!tutorialLock) return;
    if (look?._tutorialGated) {
      tutorialLock.classList.remove('is-hidden');
      const visibleSteps = look.tutorialSteps?.length ?? 3;
      const totalSteps = look._totalSteps ?? visibleSteps + 5;
      if (tutorialLockTitle) {
        tutorialLockTitle.textContent = `You're seeing steps 1–${visibleSteps} of ${totalSteps}`;
      }
      if (tutorialLockDetail) {
        const nextTitle = look._nextStepTitle;
        tutorialLockDetail.textContent = nextTitle
          ? `Next up: "${nextTitle}" — upgrade to Pro to unlock every step with tips and product picks.`
          : `Pro unlocks all ${totalSteps} steps with error alerts, self-checks, and curated product picks.`;
      }
      if (tutorialLockCta) {
        tutorialLockCta.setAttribute('href', '/membership?from=tutorial_lock');
        tutorialLockCta.addEventListener('click', () => {
          trackLookEvent('upgrade_click', { source: 'tutorial_lock' });
        }, { once: true });
      }
    } else {
      tutorialLock.classList.add('is-hidden');
    }
  };

  // P1.A10: Demo 模式独立视觉身份  + P0.2: demo 隐藏 compare + P2.14 banner
  const setMode = (isDemo: boolean) => {
    currentIsDemo = isDemo;
    if (resultStep) resultStep.setAttribute('data-tryon-mode', isDemo ? 'demo' : 'real');
    if (modeChip) {
      if (isDemo) {
        modeChip.textContent = TX.modeChipDemo;
        modeChip.classList.remove('is-real');
        modeChip.classList.add('is-demo');
      } else {
        modeChip.textContent = TX.modeChipReal;
        modeChip.classList.remove('is-demo');
        modeChip.classList.add('is-real');
      }
    }

    // P0.2: demo 隐藏 Step 2（包括 sub-nav 对应链接）
    if (compareSection) compareSection.classList.toggle('is-hidden', isDemo);
    if (subnavCompareLink) subnavCompareLink.classList.toggle('is-hidden', isDemo);

    // P2.14: demo banner 显示
    demoBanner?.classList.toggle('is-hidden', !isDemo);
    if (demoBannerTitle && demoBannerCopy) {
      if (isDemo && selectedInspirationLook) {
        demoBannerTitle.textContent = `Sample preview: ${selectedInspirationLook.title}`;
        demoBannerCopy.textContent = `Upload a selfie to adapt this ${selectedInspirationLook.tone.toLowerCase()} look to your face, undertone, and features.`;
      } else {
        demoBannerTitle.textContent = "You're previewing a sample profile.";
        demoBannerCopy.textContent = 'Upload a selfie above to get a real AI diagnosis with custom shades.';
      }
    }

    // P2.11: Re-analyze 按钮文案随模式切换
    if (rerunButton) rerunButton.textContent = isDemo ? TX.rerunButtonDemo : TX.rerunButton;
    if (deleteButton) deleteButton.classList.toggle('is-hidden', isDemo);
  };

  photoInput?.addEventListener('change', (event) => {
    const input = event.currentTarget;
    const file = input instanceof HTMLInputElement ? input.files?.[0] : undefined;
    if (file) {
      preparePhoto(file);
    } else {
      resetUpload();
    }
  });

  uploadChangeButton?.addEventListener('click', () => {
    photoInput?.click();
  });

  uploadRemoveButton?.addEventListener('click', () => {
    resetUpload();
    setLive('Selfie removed.');
  });

  // ─── 提交主流程 ───
  const runDiagnosis = async (
    { presetScenario, presetLookSlug, forceDemo }: { presetScenario?: string; presetLookSlug?: string; forceDemo?: boolean } = {},
  ) => {
    if (!form) return;
    const formData = new FormData(form);
    const photo = !forceDemo && selectedPhotoFile && preparedPhotoBase64 ? selectedPhotoFile : undefined;

    if (!forceDemo && !photo) {
      showUploadError('Upload a selfie first, or choose one of the sample looks.');
      photoInput?.focus();
      return;
    }

    let photoBase64: string | undefined;
    if (photo) {
      photoBase64 = preparedPhotoBase64 ?? undefined;
    }
    currentPhotoBase64 = photoBase64 ?? null;
    renderedAfterImages.clear();

    const scenario = presetScenario ?? String(formData.get('scenario') || 'office');
    const experience = String(formData.get('experience') || 'beginner');
    const lookSlug = presetLookSlug ?? selectedInspirationLook?.slug ?? lookParam;

    const payload = {
      scenario,
      experience,
      lookSlug: lookSlug || undefined,
      hasPhoto: Boolean(photo),
      photoBase64,
      // P0.1: send locale so service & AI prompt return matching language
      locale: (document.documentElement.lang || 'en').toLowerCase().startsWith('zh') ? 'zh' : 'en',
    };

    setStep('loading');
    startLoadingTimer(photo ? 45 : 8);
    if (photo) setUploadState('analyzing', 'Analyzing face and color profile');
    setLive('Analyzing. Please wait.');

    const apiPromise: Promise<TryOnApiResponse> = fetch('/api/try-on-plan', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    }).then(async (r) => {
      if (r.status === 429) {
        const data = await r.json() as TryOnApiResponse;
        return { ...data, _rateLimited: true };
      }
      return r.json();
    });

    const mediaPipePromise = photo
      ? (async () => {
          const mp = await initMediaPipe();
          if (mp && beforeImage && beforeImage.naturalWidth) {
            currentLandmarks = mp.detect(beforeImage);
          }
        })()
      : Promise.resolve();

    let result: TryOnApiResponse;
    try {
      const [r] = await Promise.all([apiPromise, mediaPipePromise]);
      result = r;
    } catch (error) {
      console.error('[TryOnStudio] Diagnosis request failed:', error);
      stopLoadingTimer();
      setStep('input');
      if (photo) setUploadState('ready', 'Ready for AI diagnosis');
      setLive('Sorry, something went wrong. Please try again.');
      alert('Sorry, the diagnosis request failed. Please try again.');
      return;
    }

    if (result?._rateLimited) {
      stopLoadingTimer();
      setStep('input');
      if (photo) setUploadState('ready', 'Ready for AI diagnosis');
      setLive('Daily free quota reached.');
      alert(result.message || "You've used your free diagnosis today.");
      return;
    }

    if (!result.diagnosis || !result.shareCard || !Array.isArray(result.looks)) {
      stopLoadingTimer();
      setStep('input');
      if (photo) setUploadState('ready', 'Ready for AI diagnosis');
      setLive('Diagnosis response was incomplete.');
      alert('Sorry, the diagnosis response was incomplete. Please try again.');
      return;
    }

    if (photo) {
      trackLookEvent('selfie_upload_success', { lookSlug: lookSlug || undefined });
    }
    trackLookEvent('tryon_result_view', { lookSlug: lookSlug || undefined, metadata: { demo: !photo } });

    currentLooks = result.looks;
    currentShareCard = result.shareCard;
    currentLipColors = result._lipColors ?? null;
    currentUploadKey = result._upload?.stored && result._upload.key ? result._upload.key : null;
    selectedLookId = currentLooks[0]?.id || '';
    currentTier = result._tier ?? result._gated?.tier ?? currentTier;

    const isDemo = Boolean(forceDemo) || Boolean(result?.meta?.fallback) || !photo;
    setMode(isDemo);

    // P0 — 渲染会员门控信息
    applyGatedInfo(result._gated);

    syncRemainingBadge(currentTier, result._remaining, result._quotaLimit, result._quotaWindow, Boolean(photo));

    if (diagnosisTitle) diagnosisTitle.textContent = result.diagnosis.title;
    if (diagnosisSummary) diagnosisSummary.textContent = result.diagnosis.summary;
    if (shareTitle) shareTitle.textContent = result.shareCard.title;
    if (shareSubtitle) shareSubtitle.textContent = result.shareCard.subtitle;
    if (shareBadge) shareBadge.textContent = result.shareCard.badge;
    if (shareCta) shareCta.textContent = result.shareCard.cta;
    renderTags(shareTags, result.shareCard.hashtags || []);
    fillList(faceNotes, result.diagnosis.faceNotes || []);

    if (selectedLookId) selectLook(selectedLookId);

    setShareStatus(TX.shareExport);
    window.setTimeout(() => {
      stopLoadingTimer();
      setStep('result');
      focusResult();
      setLive(isDemo ? 'Demo profile ready.' : 'Diagnosis ready.');
    }, 600);
  };

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    runDiagnosis();
  });

  // P0.A2: Demo 缩略图触发
  qsa<HTMLElement>('[data-tryon-demo]').forEach((thumb) => {
    thumb.addEventListener('click', () => {
      const scenario = thumb.getAttribute('data-tryon-demo') || 'office';
      const look = setSelectedInspirationFromTrigger(thumb, true);
      // 同步 select 值，方便用户后续微调
      const scenarioSelect = qs<HTMLSelectElement>('select[name="scenario"]');
      if (scenarioSelect) scenarioSelect.value = scenario;
      closeLookDrawer();
      runDiagnosis({ presetScenario: scenario, presetLookSlug: look?.slug, forceDemo: true });
    });
  });

  // P1.A11: 重新分析（保留照片）
  rerunButton?.addEventListener('click', () => {
    const hasPhoto = Boolean(selectedPhotoFile && preparedPhotoBase64);
    runDiagnosis({ forceDemo: !hasPhoto });
  });

  // P1.A11: 删除我的照片（兑现 deletable 承诺）
  deleteButton?.addEventListener('click', () => {
    if (!confirm('Delete the photo from this session and reset the diagnosis?')) return;
    if (currentUploadKey) {
      fetch('/api/try-on-photo', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ key: currentUploadKey }),
      }).catch((error) => {
        console.warn('[TryOnStudio] Remote photo deletion failed:', error);
      });
    }
    if (form) form.reset();
    currentLooks = [];
    currentShareCard = null;
    currentLipColors = null;
    currentGatedInfo = undefined;
    currentTier = 'free';
    resetUpload();
    renderedAfterImages.clear();
    updateShareResultVisual(undefined);
    selectedLookId = '';
    setShareStatus(TX.shareExport);
    remainingBadge?.classList.add('is-hidden');
    setMode(false);
    setStep('input');
    setLive('Photo and diagnosis deleted.');
    document.getElementById('tryon-heading')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  shareExportButton?.addEventListener('click', async () => {
    const look = getSelectedLook();
    if (!look || !currentShareCard) return;
    trackLookEvent('share_click', { metadata: { action: 'copy_text', selectedLookId: look.id } });

    const shareText = [
      currentShareCard.title,
      currentShareCard.subtitle,
      `${look.name} · ${look.finish}`,
      `Focus: ${look.focus} · ${look.minutes}`,
      `Why it works: ${look.reason}`,
      (currentShareCard.hashtags || []).join(' '),
      `${TX.shareUrlLabel} ${getDisplaySiteUrl()}`,
    ].join('\n');

    try {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(shareText);
        setShareStatus(TX.shareStatusCopied);
      } else {
        setShareStatus('Clipboard not supported');
      }
    } catch (error) {
      setShareStatus('Copy failed — please copy manually');
    }
    window.setTimeout(() => setShareStatus(TX.shareExport), 1800);
  });

  continueLink?.addEventListener('click', () => {
    const look = getSelectedLook();
    trackLookEvent('tutorial_continue', { metadata: { selectedLookId: look?.id } });
  });

  // P2.14: demo banner Upload CTA → 滚回 dropzone
  demoBannerCta?.addEventListener('click', () => {
    setStep('input');
    qs<HTMLElement>('.upload-dropzone')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    setLive('Upload your selfie to get a real diagnosis.');
  });

  // P2.A12: 移动端 sub-nav 高亮当前 section
  if (subnav) {
    const sections = ['diagnosis', 'compare', 'looks', 'tutorial', 'share']
      .map((key) => document.getElementById(`tryon-section-${key}`))
      .filter((section): section is HTMLElement => section instanceof HTMLElement);
    const links = subnav.querySelectorAll<HTMLAnchorElement>('a');
    const linkByHash = new Map(Array.from(links).map((a) => [a.getAttribute('href'), a]));
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          // Skip if section is hidden (e.g. compare in demo mode)
          if (entry.target.classList.contains('is-hidden')) return;
          const id = entry.target.id;
          links.forEach((a) => a.classList.remove('is-active'));
          linkByHash.get(`#${id}`)?.classList.add('is-active');
        });
      },
      { rootMargin: '-30% 0px -60% 0px', threshold: 0 },
    );
    sections.forEach((s) => observer.observe(s));
  }

  // ─── 妆效预览功能 ─────────────────────────────────────────
  const makeupModal = document.getElementById('makeup-preview-modal');
  const makeupLoading = document.getElementById('makeup-preview-loading');
  const makeupResult = document.getElementById('makeup-preview-result');
  const makeupError = document.getElementById('makeup-preview-error');
  const makeupErrorMsg = document.getElementById('makeup-preview-error-msg');
  const makeupLookName = document.getElementById('makeup-preview-look-name');
  const makeupTitle = document.getElementById('makeup-preview-title');
  const makeupBefore = document.getElementById('makeup-preview-before') as HTMLImageElement | null;
  const makeupAfter = document.getElementById('makeup-preview-after') as HTMLImageElement | null;
  const makeupElapsed = document.getElementById('makeup-preview-elapsed');
  const makeupDownload = document.getElementById('makeup-preview-download');

  const showMakeupModal = () => {
    makeupModal?.classList.remove('is-hidden');
    document.body.classList.add('is-makeup-modal-open');
  };
  const hideMakeupModal = () => {
    makeupModal?.classList.add('is-hidden');
    document.body.classList.remove('is-makeup-modal-open');
  };

  const getPreviewEngineLabel = (tier?: string) =>
    tier === 'pro' || tier === 'premium' ? TX.previewEnginePro : TX.previewEngineBasic;

  const formatPreviewElapsed = (elapsed: string, tier?: string) =>
    TX.previewGeneratedWith
      .replace('{elapsed}', elapsed)
      .replace('{engine}', getPreviewEngineLabel(tier));

  const requestMakeupPreviewImage = async (look: TryOnLookClient) => {
    const photoData = currentPhotoBase64 || preparedPhotoBase64;
    if (!photoData) {
      throw new Error(TX.uploadSelfieFirst);
    }

    const resp = await fetch('/api/makeup-preview', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        photoBase64: photoData,
        look: {
          id: look.id,
          name: look.name,
          reason: look.reason,
          scenario: look.scenario,
          focus: look.focus,
          finish: look.finish,
          tutorialHeadline: look.tutorialHeadline,
        },
        locale: (document.documentElement.lang || 'en').toLowerCase().startsWith('zh') ? 'zh' : 'en',
      }),
    });

    const data = await resp.json() as MakeupPreviewResponse;
    if (!resp.ok || data.error || !data.image?.dataUrl) {
      throw new Error(data.message || TX.previewError);
    }
    return {
      dataUrl: data.image.dataUrl,
      tier: data._tier ?? currentTier,
    };
  };

  const ensureShareMakeupResult = async (look: TryOnLookClient) => {
    const cached = renderedAfterImages.get(look.id);
    if (cached) return cached;

    const visibleAfter = selectedLookId === look.id && afterImage && !afterImage.classList.contains('is-hidden') && afterImage.src
      ? afterImage.src
      : '';
    if (visibleAfter) {
      renderedAfterImages.set(look.id, visibleAfter);
      updateShareResultVisual(visibleAfter, look);
      return visibleAfter;
    }

    if (currentIsDemo || (!currentPhotoBase64 && !preparedPhotoBase64)) {
      return undefined;
    }
    if (currentGatedInfo?.isFreeTier && currentGatedInfo.lockedFeatures.includes('makeup_preview')) {
      return undefined;
    }

    const preview = await requestMakeupPreviewImage(look);
    renderedAfterImages.set(look.id, preview.dataUrl);
    updateShareResultVisual(preview.dataUrl, look);
    if (selectedLookId === look.id) showAfterImage(look, preview.dataUrl);
    return preview.dataUrl;
  };

  // 关闭按钮
  document.querySelectorAll('[data-makeup-close]').forEach((btn) => {
    btn.addEventListener('click', hideMakeupModal);
  });
  // ESC 关闭
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !makeupModal?.classList.contains('is-hidden')) {
      hideMakeupModal();
    }
  });

  const triggerMakeupPreview = async (look: TryOnLookClient) => {
    if (currentGatedInfo?.isFreeTier && currentGatedInfo.lockedFeatures.includes('makeup_preview')) {
      makeupLoading?.classList.add('is-hidden');
      makeupResult?.classList.add('is-hidden');
      makeupError?.classList.remove('is-hidden');
      if (makeupErrorMsg) {
        // P1 — 锁态加 before/after 视觉示例：让 free 用户直接看到"升级后大概是什么样子"
        const safeLookName = look.name.replace(/"/g, '&quot;');
        makeupErrorMsg.innerHTML = `<div class="makeup-upsell">
          <div class="makeup-upsell-visual" aria-hidden="true">
            <figure class="makeup-upsell-frame makeup-upsell-frame-before">
              <span class="makeup-upsell-frame-pill">Your selfie</span>
              <div class="makeup-upsell-frame-placeholder">📷</div>
            </figure>
            <span class="makeup-upsell-arrow">→</span>
            <figure class="makeup-upsell-frame makeup-upsell-frame-after">
              <span class="makeup-upsell-frame-pill makeup-upsell-frame-pill-after">AI Preview · Pro</span>
              <img src="/images/hero/look-warm-nude-daily.webp" alt="" loading="lazy" />
              <span class="makeup-upsell-frame-blur" aria-hidden="true"></span>
              <span class="makeup-upsell-frame-lock" aria-hidden="true">🔒</span>
            </figure>
          </div>
          <span class="makeup-upsell-icon" aria-hidden="true">✨</span>
          <strong>See "${safeLookName}" on your own face</strong>
          <p>Pro renders this look as a realistic AI preview on your selfie in under 30 seconds — try as many looks as you want, 30 per month.</p>
          <a class="btn" href="/membership?from=makeup_preview" data-makeup-upsell-cta>Upgrade to Pro · $19.99/mo</a>
        </div>`;
        makeupErrorMsg.querySelector<HTMLAnchorElement>('[data-makeup-upsell-cta]')?.addEventListener('click', () => {
          trackLookEvent('upgrade_click', { source: 'makeup_preview_upsell' });
        }, { once: true });
      }
      if (makeupLookName) makeupLookName.textContent = look.name;
      showMakeupModal();
      return;
    }

    if (!currentPhotoBase64 && !preparedPhotoBase64) {
      alert('Please upload a selfie first to generate a makeup preview.');
      return;
    }

    // 显示 modal loading
    makeupLoading?.classList.remove('is-hidden');
    makeupResult?.classList.add('is-hidden');
    makeupError?.classList.add('is-hidden');
    if (makeupLookName) makeupLookName.textContent = look.name;
    showMakeupModal();

    const photoData = currentPhotoBase64 || preparedPhotoBase64;

    try {
      const startTime = Date.now();
      const preview = await requestMakeupPreviewImage(look);
      const elapsed = ((Date.now() - startTime) / 1000).toFixed(1);
      renderedAfterImages.set(look.id, preview.dataUrl);
      updateShareResultVisual(preview.dataUrl, look);
      if (selectedLookId === look.id) showAfterImage(look, preview.dataUrl);

      // 显示结果
      makeupLoading?.classList.add('is-hidden');
      makeupResult?.classList.remove('is-hidden');
      if (makeupTitle) makeupTitle.textContent = `${look.name} — AI Makeup Preview`;
      if (makeupBefore && photoData) makeupBefore.src = photoData;
      if (makeupAfter) makeupAfter.src = preview.dataUrl;
      if (makeupElapsed) makeupElapsed.textContent = formatPreviewElapsed(elapsed, preview.tier);

      // 下载按钮
      makeupDownload?.addEventListener('click', () => {
        const a = document.createElement('a');
        a.href = preview.dataUrl;
        a.download = `makeup-preview-${look.id}.png`;
        a.click();
      }, { once: true });

    } catch (err) {
      makeupLoading?.classList.add('is-hidden');
      makeupError?.classList.remove('is-hidden');
      if (makeupErrorMsg) {
        makeupErrorMsg.textContent = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
      }
    }
  };

  const saveLookBtn = qs<HTMLButtonElement>('[data-save-look]');
  const saveLookStatus = qs<HTMLElement>('[data-save-status]');

  const showSaveStatus = (msg: string, isError = false) => {
    if (!saveLookStatus) return;
    saveLookStatus.textContent = msg;
    saveLookStatus.classList.remove('is-hidden');
    saveLookStatus.classList.toggle('is-error', isError);
  };

  saveLookBtn?.addEventListener('click', async () => {
    const look = getSelectedLook();
    if (!look) return;
    saveLookBtn.disabled = true;
    const originalText = saveLookBtn.textContent ?? '💾 Save my look plan';
    saveLookBtn.textContent = '⏳ Checking…';
    try {
      const meResp = await fetch('/api/auth/me');
      const meData = (await meResp.json()) as { authenticated?: boolean };
      if (!meData.authenticated) {
        // 未登录 → 引导注册/登录
        trackLookEvent('save_click', { metadata: { result: 'redirect_login', selectedLookId: look.id } });
        const next = encodeURIComponent(`/try-on?look=${look.id}`);
        window.location.href = `/login?next=${next}&intent=save_look`;
        return;
      }
      // 已登录：诊断结果由 try-on-plan 自动写入 tryon_jobs，提示用户去 history 查看
      trackLookEvent('save_click', { metadata: { result: 'already_saved', selectedLookId: look.id } });
      showSaveStatus('✓ Saved automatically. View in your dashboard history.');
      saveLookBtn.textContent = '✓ Saved to history';
      // 转换成 history 链接
      saveLookBtn.disabled = false;
      saveLookBtn.addEventListener('click', () => {
        window.location.href = '/dashboard/history';
      }, { once: true });
    } catch {
      saveLookBtn.disabled = false;
      saveLookBtn.textContent = originalText;
      showSaveStatus('Could not check sign-in status. Try again.', true);
    }
  });

  // ─── 分享卡下载功能 ─────────────────────────────────────────
  const shareDownloadBtn = qs<HTMLButtonElement>('[data-share-download]');
  const shareCardPreview = qs<HTMLElement>('[data-share-card-preview]');
  const shareCardImage = qs<HTMLImageElement>('[data-share-card-image]');

  shareDownloadBtn?.addEventListener('click', async () => {
    const look = getSelectedLook();
    if (!look) return;
    trackLookEvent('share_click', { metadata: { action: 'download_card', selectedLookId: look.id } });

    shareDownloadBtn.disabled = true;
    shareDownloadBtn.textContent = TX.shareGeneratingAfter;
    setShareStatus(TX.shareGeneratingAfter);

    try {
      const { generateShareCard, downloadShareCard } = await import('../lib/shareCardGenerator');

      const diagTitle = diagnosisTitle?.textContent || 'Your Personalized Beauty Profile';
      const lipHex = currentLipColors?.[look.id]?.hex;
      const makeupResultUrl = await ensureShareMakeupResult(look);
      shareDownloadBtn.textContent = TX.sharePreparingCard;
      setShareStatus(TX.sharePreparingCard);

      const dataUrl = await generateShareCard({
        diagnosisTitle: diagTitle,
        lookName: look.name,
        lookFinish: look.finish,
        scenario: look.scenario,
        lipColorHex: lipHex,
        makeupResultUrl,
        hashtags: currentShareCard?.hashtags,
        siteUrl: getDisplaySiteUrl(),
      });

      // 显示预览
      if (shareCardImage && shareCardPreview) {
        shareCardImage.src = dataUrl;
        shareCardPreview.classList.remove('is-hidden');
      }

      // 触发下载
      downloadShareCard(dataUrl, look.name);

      shareDownloadBtn.textContent = TX.shareDownloadDone;
      setShareStatus(TX.shareDownloadDone);
      setTimeout(() => {
        shareDownloadBtn.textContent = TX.shareDownload;
        setShareStatus(TX.shareExport);
        shareDownloadBtn.disabled = false;
      }, 2000);

    } catch (err) {
      console.error('[ShareCard] Generation failed:', err);
      shareDownloadBtn.textContent = TX.shareDownloadFailed;
      setShareStatus(err instanceof Error ? err.message : TX.shareDownloadFailed);
      setTimeout(() => {
        shareDownloadBtn.textContent = TX.shareDownload;
        setShareStatus(TX.shareExport);
        shareDownloadBtn.disabled = false;
      }, 2000);
    }
  });
</script>
