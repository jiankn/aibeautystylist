    if (loadingProgressBar) {
      loadingProgressBar.style.width = `${Math.max(0, Math.min(100, Math.round(percent)))}%`;
    }
  };

  const updateLoadingTimer = () => {
    const elapsed = Math.floor((Date.now() - loadingStartedAt) / 1000);
    const remaining = Math.max(0, loadingEstimateSeconds - elapsed);
    const progress = remaining > 0
      ? Math.min(94, (elapsed / loadingEstimateSeconds) * 94)
      : 96;
    const activeIndex = remaining === 0
      ? loadingPhaseItems.length - 1
      : Math.min(loadingPhaseItems.length - 1, Math.floor((elapsed / loadingEstimateSeconds) * loadingPhaseItems.length));

    if (loadingCountdown) loadingCountdown.textContent = String(remaining);
    if (loadingCountdownLabel) {
      loadingCountdownLabel.textContent = remaining > 0 ? TX.loadingCountdownLabel : TX.loadingFinalizingLabel;
    }
    setLoadingProgress(progress);
    loadingPhaseItems.forEach((item, index) => {
      item.classList.toggle('is-active', index === activeIndex);
      item.classList.toggle('is-complete', index < activeIndex);
    });
  };

  const startLoadingTimer = (seconds: number) => {
    if (loadingTimerId !== undefined) window.clearInterval(loadingTimerId);
    loadingEstimateSeconds = Math.max(6, seconds);
    loadingStartedAt = Date.now();
    setLoadingProgress(0);
    updateLoadingTimer();
    loadingTimerId = window.setInterval(updateLoadingTimer, 1000);
  };

  const stopLoadingTimer = () => {
    if (loadingTimerId !== undefined) {
      window.clearInterval(loadingTimerId);
      loadingTimerId = undefined;
    }
    setLoadingProgress(100);
  };

  const getDataUrlByteSize = (dataUrl: string) => {
    const base64 = dataUrl.split(',')[1] || '';
    return Math.round((base64.length * 3) / 4);
  };

  const setGenerateButtonState = () => {
    if (!generateSubmitButton) return;
    const busy = uploadState === 'reading' || uploadState === 'compressing' || uploadState === 'analyzing' || uploadState === 'rendering';
    const canSubmit = Boolean(preparedPhotoBase64 && selectedPhotoFile && uploadState === 'ready');
    generateSubmitButton.disabled = busy || !canSubmit;

    if (uploadState === 'reading' || uploadState === 'compressing') {
      generateSubmitButton.textContent = TX.btnPreparingPhoto;
      return;
    }
    if (uploadState === 'analyzing') {
      generateSubmitButton.textContent = TX.btnAnalyzing;
      return;
    }
    if (uploadState === 'rendering') {
      generateSubmitButton.textContent = TX.btnRenderingPreview;
      return;
    }
    if (uploadState === 'error') {
      generateSubmitButton.textContent = TX.btnFixUpload;
      return;
    }
    generateSubmitButton.textContent = canSubmit
      ? (generateSubmitButton.dataset.defaultLabel || TX.generateSubmitDefault)
      : TX.generateSubmitDisabled;
  };

  const setUploadProgress = (label: string, percent: number, detail: string) => {
    const safePercent = Math.max(0, Math.min(100, Math.round(percent)));
    uploadProgress?.classList.remove('is-hidden');
    uploadProgress?.setAttribute('aria-hidden', 'false');
    if (uploadProgressLabel) uploadProgressLabel.textContent = label;
    if (uploadProgressPercent) uploadProgressPercent.textContent = `${safePercent}%`;
    if (uploadProgressBar) uploadProgressBar.style.width = `${safePercent}%`;
    if (uploadProgressDetail) uploadProgressDetail.textContent = detail;
  };

  const clearUploadError = () => {
    if (!uploadError) return;
    uploadError.textContent = '';
    uploadError.classList.add('is-hidden');
