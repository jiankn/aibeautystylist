const tx = getTranslations(locale);
const tryOnStudioTranslationsJson = JSON.stringify(tx.tryOnStudio).replace(/</g, '\\u003c');
---

<section class="tool-shell card tryon-shell" data-tryon-shell data-tryon-current-step="input">
  <!-- 移动端粘性 sub-nav (在结果态内 IntersectionObserver 高亮) -->
  <nav class="tryon-subnav" data-tryon-subnav aria-label="Result sections">
    <div class="tryon-subnav-track">
      <a href="#tryon-section-diagnosis">{tx.tryOnStudio.diagnosisEyebrow}</a>
      <a href="#tryon-section-compare">{tx.tryOnStudio.compareEyebrow}</a>
      <a href="#tryon-section-looks">{tx.tryOnStudio.looksEyebrow}</a>
      <a href="#tryon-section-tutorial">{tx.tryOnStudio.tutorialEyebrow}</a>
      <a href="#tryon-section-share">{tx.tryOnStudio.shareEyebrow}</a>
    </div>
  </nav>

  <div class="tryon-live-region" data-tryon-live aria-live="polite" role="status"></div>

  <div class="tool-steps">
    <!-- ─────────── 输入态 ─────────── -->
    <section class="tool-step" data-tryon-step="input">
      <div class="tryon-intro-grid">
        <div class="tryon-intro-left">
          <header class="tryon-header">
            <div class="tryon-header-copy">
              <span class="eyebrow">{tx.tryOnStudio.stepLabel}</span>
              <h1 id="tryon-heading">{tx.tryOnStudio.heading}</h1>
              <p>{tx.tryOnStudio.subheading}</p>
            </div>
            <span class="tryon-trust-strip" aria-label="Privacy promise">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
              {tx.tryOnStudio.privacyStrip}
            </span>
          </header>
        <form class="tryon-form-stack" data-tryon-form>
          <label class="upload-field">
            <span class="sr-only">{tx.tryOnStudio.uploadLabel}</span>
            <div class="upload-dropzone" data-upload-dropzone>
              <input
                type="file"
                name="photo"
                accept="image/jpeg,image/png,image/webp"
                aria-describedby="tryon-upload-helper tryon-upload-status tryon-upload-error"
                data-photo-input
              />
              <div class="upload-dropzone-copy" data-upload-idle-copy>
                <span class="upload-dropzone-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                    <polyline points="17 8 12 3 7 8" />
                    <line x1="12" y1="3" x2="12" y2="15" />
                  </svg>
                </span>
                <strong>{tx.tryOnStudio.uploadIdle}</strong>
                <p id="tryon-upload-helper">{tx.tryOnStudio.uploadHelper}</p>
              </div>
              <div class="upload-dropzone-copy upload-ready-copy is-hidden" data-upload-ready-copy>
                <strong>{tx.tryOnStudio.uploadReady}</strong>
                <p>{tx.tryOnStudio.uploadReadyDetail}</p>
              </div>
              <div class="upload-progress is-hidden" data-upload-progress aria-hidden="true">
                <div class="upload-progress-head">
                  <strong data-upload-progress-label>{tx.tryOnStudio.uploadProgressLabel}</strong>
                  <span data-upload-progress-percent>0%</span>
                </div>
                <div class="upload-progress-track" aria-hidden="true">
                  <span data-upload-progress-bar></span>
                </div>
                <p data-upload-progress-detail>{tx.tryOnStudio.uploadProgressDetail}</p>
              </div>
            </div>
          </label>

          <div class="upload-preview-summary is-hidden" data-upload-preview>
            <img src="" alt="Uploaded selfie thumbnail" data-upload-thumb loading="lazy" />
            <div class="upload-preview-copy">
              <strong data-upload-file-name>{tx.tryOnStudio.uploadFileName}</strong>
              <span data-upload-file-meta>{tx.tryOnStudio.uploadFileMeta}</span>
              <span id="tryon-upload-status" class="upload-preview-status" data-upload-status>{tx.tryOnStudio.uploadStatusReady}</span>
            </div>
            <div class="upload-preview-actions">
              <button class="btn btn-secondary upload-action-btn" type="button" data-upload-change>{tx.tryOnStudio.uploadChange}</button>
              <button class="btn btn-secondary upload-action-btn" type="button" data-upload-remove>{tx.tryOnStudio.uploadRemove}</button>
            </div>
          </div>

          <p id="tryon-upload-error" class="upload-error is-hidden" data-upload-error role="alert"></p>

          <div class="tryon-cta-row">
            <label>
              <span>{tx.tryOnStudio.scenarioLabel}</span>
              <select name="scenario">
                <option value="office">{tx.tryOnStudio.scenarioOffice}</option>
                <option value="date">{tx.tryOnStudio.scenarioDate}</option>
                <option value="photo">{tx.tryOnStudio.scenarioPhoto}</option>
              </select>
            </label>
            <label>
              <span>{tx.tryOnStudio.experienceLabel}</span>
              <select name="experience">
                <option value="beginner">{tx.tryOnStudio.experienceBeginner}</option>
                <option value="intermediate">{tx.tryOnStudio.experienceIntermediate}</option>
              </select>
            </label>
            <button class="btn" type="submit" data-generate-submit data-default-label={tx.tryOnStudio.generateSubmitDefault} disabled>{tx.tryOnStudio.generateSubmitDisabled}</button>
          </div>

          <p class="tryon-form-meta">
            {tx.tryOnStudio.formMeta}
          </p>
        </form>
        </div>

        <!-- P0.A2: 未上传时右侧灵感/风格选择 -->
        <aside class="tryon-demo-card" aria-label="Makeup inspiration choices">
          <span class="tryon-demo-eyebrow">{tx.tryOnStudio.demoEyebrow}</span>
          <div class="tryon-demo-hero" data-tryon-demo-hero>
            <img
              src={quickLookItems[0].image}
              alt={quickLookItems[0].imageAlt}
              data-tryon-demo-hero-img
              loading="eager"
            />
            <div class="tryon-demo-hero-caption" data-tryon-demo-hero-caption>
              <strong data-tryon-demo-hero-title>{quickLookItems[0].title}</strong>
              <small data-tryon-demo-hero-tone>{quickLookItems[0].tone}</small>
            </div>
          </div>
          <div class="tryon-demo-actions">
            <button class="btn btn-secondary tryon-demo-action-btn" type="button" data-look-drawer-open>{tx.tryOnStudio.getMoreInspired}</button>
            <button class="btn btn-secondary tryon-demo-action-btn" type="button" data-style-drawer-open>{tx.tryOnStudio.tryMoreStyles}</button>
          </div>
        </aside>
      </div>
    </section>

    <!-- ─────────── 加载态 ─────────── -->
    <section class="tool-step is-hidden" data-tryon-step="loading" aria-live="polite">
      <div class="loading-state tryon-loading">
        <div class="spinner" aria-hidden="true"></div>
        <h3>{tx.tryOnStudio.loadingTitle}</h3>
        <p>{tx.tryOnStudio.loadingDetail}</p>
        <div class="tryon-loading-timer" data-loading-timer>
          <span class="tryon-loading-count" data-loading-countdown>45</span>
          <span class="tryon-loading-unit">{tx.tryOnStudio.loadingSecondsUnit}</span>
          <small data-loading-countdown-label>{tx.tryOnStudio.loadingCountdownLabel}</small>
        </div>
        <div class="tryon-loading-progress" aria-hidden="true">
          <span data-loading-progress-bar></span>
        </div>
        <ol class="tryon-loading-phases" aria-label="AI diagnosis progress">
          <li class="is-active" data-loading-phase>{tx.tryOnStudio.loadingStageScan}</li>
          <li data-loading-phase>{tx.tryOnStudio.loadingStageMatch}</li>
          <li data-loading-phase>{tx.tryOnStudio.loadingStagePlan}</li>
          <li data-loading-phase>{tx.tryOnStudio.loadingStageReady}</li>
        </ol>
      </div>
    </section>

    <!-- ─────────── 结果态 ─────────── -->
    <section class="tool-step is-hidden" data-tryon-step="result" data-tryon-mode="real">
      <div class="tryon-result-stack">
        <!-- 控制条：模式 chip + 剩余次数 + 删除/重诊断 -->
        <div class="tryon-result-controls">
          <div class="tryon-result-controls-meta">
            <span class="tryon-result-mode-chip is-real" data-tryon-mode-chip>{tx.tryOnStudio.modeChipReal}</span>
            <span class="is-hidden" data-remaining-badge>
              <span data-remaining-label>{tx.tryOnStudio.remainingBadge}</span><strong data-remaining-count>1</strong><span data-remaining-total>/1</span>
            </span>
          </div>
          <div class="tryon-result-controls-actions">
            <button class="btn btn-secondary tryon-control-btn" type="button" data-tryon-rerun>{tx.tryOnStudio.rerunButton}</button>
            <button class="btn btn-secondary tryon-control-btn" type="button" data-tryon-delete>{tx.tryOnStudio.deleteButton}</button>
          </div>
        </div>

        <!-- AI 免责声明 (PRD §15) -->
        <p class="tryon-ai-disclaimer" role="note">{tx.tryOnStudio.aiDisclaimer}</p>

        <!-- P2.A14: Demo 模式整宽提示横幅（chip 之外的明确入口） -->
        <aside class="tryon-demo-banner is-hidden" data-tryon-demo-banner role="note">
          <div class="tryon-demo-banner-copy">
            <strong data-tryon-demo-banner-title>{tx.tryOnStudio.demoBannerTitle}</strong>
            <span data-tryon-demo-banner-copy>{tx.tryOnStudio.demoBannerCopy}</span>
          </div>
          <button class="btn" type="button" data-tryon-demo-banner-cta>{tx.tryOnStudio.demoBannerCta}</button>
        </aside>

        <!-- P0 — 会员门控横幅：当后端返回 _gated.isFreeTier=true 时显示 -->
        <aside class="tryon-gated-banner is-hidden" data-tryon-gated-banner role="note">
          <div class="tryon-gated-banner-copy">
            <span class="pill tryon-gated-pill">{tx.tryOnStudio.gatedPill}</span>
            <strong data-tryon-gated-message>{tx.tryOnStudio.gatedMessage}</strong>
            <span data-tryon-gated-detail>{tx.tryOnStudio.gatedDetail}</span>
            <ul class="tryon-gated-features is-hidden" data-tryon-gated-features aria-label="Locked features"></ul>
          </div>
          <a class="btn" data-tryon-gated-cta href="/membership?from=tryon_gated_banner">{tx.tryOnStudio.gatedCta}</a>
        </aside>

        <!-- 1. Diagnosis 顶置整宽 -->
        <article class="tryon-diagnosis" id="tryon-section-diagnosis" tabindex="-1">
          <span class="tryon-diagnosis-eyebrow" data-tryon-section-eyebrow>{tx.tryOnStudio.diagnosisEyebrow}</span>
          <h2 data-diagnosis-title>Warm-neutral undertone · Soft definition fit</h2>
          <p class="tryon-diagnosis-summary" data-diagnosis-summary>Your features suit low-intensity, structured looks. Focus on enhancing complexion and definition.</p>
          <ul class="tryon-diagnosis-notes" data-face-notes>
            <li>Sheer, luminous base works best for you</li>
            <li>Brow and eye structure matters more than heavy color</li>
            <li>Matching lip and cheek tones creates a cleaner finish</li>
          </ul>
        </article>

        <!-- 2. Before / After (demo 模式下隐藏 — P0.2) -->
        <section id="tryon-section-compare" data-tryon-compare-section>
          <div class="result-section-head">
            <div>
              <span class="eyebrow">{tx.tryOnStudio.compareEyebrow}</span>
              <h3>{tx.tryOnStudio.compareHeading}</h3>
            </div>
          </div>
          <div class="tryon-compare">
            <article class="compare-frame">
              <span class="pill">{tx.tryOnStudio.compareBefore}</span>
              <div class="compare-image-shell">
                <img class="compare-image is-hidden" alt="" data-before-image />
                <div class="compare-placeholder" data-before-placeholder>{tx.tryOnStudio.comparePlaceholderBefore}</div>
              </div>
            </article>
            <article class="compare-frame compare-frame-after">
              <span class="pill">{tx.tryOnStudio.compareAfter}</span>
              <div class="compare-image-shell">
                <img class="compare-image is-hidden" alt="" data-after-image />
                <canvas class="compare-canvas is-hidden" data-after-canvas></canvas>
                <div class="lip-color-swatch is-hidden" data-lip-swatch></div>
                <div class="compare-placeholder" data-after-placeholder>{tx.tryOnStudio.comparePlaceholderAfter}</div>
              </div>
            </article>
          </div>
          <!-- P1.7: after-look-shell 移到 compare 下方独立 strip -->
          <div class="after-look-strip">
            <strong data-selected-look-name>Office Glow</strong>
            <p data-selected-look-finish>Soft matte nude</p>
            <div class="after-look-stats">
              <span data-selected-look-focus>Complexion, brow-eye clarity</span>
              <span data-selected-look-time>8 min</span>
            </div>
            <p class="after-look-copy" data-selected-look-reason>The quickest way to look polished — perfect for commuting and video calls.</p>
          </div>
        </section>

        <!-- 3. Looks -->
