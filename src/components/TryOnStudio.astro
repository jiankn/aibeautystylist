    loadingStageScan: t('tryOnStudio.loadingStageScan', currentLocale),
    loadingStageMatch: t('tryOnStudio.loadingStageMatch', currentLocale),
    loadingStagePlan: t('tryOnStudio.loadingStagePlan', currentLocale),
    loadingStageReady: t('tryOnStudio.loadingStageReady', currentLocale),
