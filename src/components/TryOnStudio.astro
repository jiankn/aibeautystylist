    looksUnlockCta: t('tryOnStudio.looksUnlockCta', currentLocale),
    tutorialEyebrow: t('tryOnStudio.tutorialEyebrow', currentLocale),
    tutorialHeading: t('tryOnStudio.tutorialHeading', currentLocale),
    tutorialHeadline: t('tryOnStudio.tutorialHeadline', currentLocale),
    tutorialContinue: t('tryOnStudio.tutorialContinue', currentLocale),
