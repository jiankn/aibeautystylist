---
import { buildLookTryOnHref, lookCatalogItems, lookFilters, quickTryOnLooks } from '../data/lookCatalog';
import { homeStyleItems } from '../data/stylePages';

const quickLookItems = quickTryOnLooks;

const styleShortcutItems = homeStyleItems.map((style) => ({
  label: style.label,
  href: `/try-on?scenario=${style.tryOnScenario}&style=${style.slug}&look=${style.lookSlug}`,
}));

const allLookItems = lookCatalogItems;
---

<section class="tool-shell card tryon-shell" data-tryon-shell data-tryon-current-step="input">
  <!-- 移动端粘性 sub-nav (在结果态内 IntersectionObserver 高亮) -->
  <nav class="tryon-subnav" data-tryon-subnav aria-label="Result sections">
    <div class="tryon-subnav-track">
      <a href="#tryon-section-diagnosis">Diagnosis</a>
      <a href="#tryon-section-compare">Before / After</a>
      <a href="#tryon-section-looks">Looks</a>
      <a href="#tryon-section-tutorial">Tutorial</a>
      <a href="#tryon-section-share">Share</a>
    </div>
  </nav>

  <div class="tryon-live-region" data-tryon-live aria-live="polite" role="status"></div>

  <div class="tool-steps">
    <!-- ─────────── 输入态 ─────────── -->
    <section class="tool-step" data-tryon-step="input">
      <div class="tryon-intro-grid">
        <div class="tryon-intro-left">
          <header class="tryon-header">
            <div class="tryon-header-copy">
              <span class="eyebrow">AI Try-On · Step 1</span>
              <h1 id="tryon-heading">Upload a selfie. Discover the looks made for you.</h1>
              <p>No filters. Real analysis of your skin tone and features, matched to looks and tutorials you can actually follow.</p>
            </div>
            <span class="tryon-trust-strip" aria-label="Privacy promise">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
              Used only for your recommendations · Deletable anytime
            </span>
          </header>
        <form class="tryon-form-stack" data-tryon-form>
          <label class="upload-field">
            <span class="sr-only">Upload bare-face selfie</span>
            <div class="upload-dropzone" data-upload-dropzone>
              <input
                type="file"
                name="photo"
                accept="image/jpeg,image/png,image/webp"
                aria-describedby="tryon-upload-helper tryon-upload-status tryon-upload-error"
                data-photo-input
              />
              <div class="upload-dropzone-copy" data-upload-idle-copy>
                <span class="upload-dropzone-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                    <polyline points="17 8 12 3 7 8" />
                    <line x1="12" y1="3" x2="12" y2="15" />
                  </svg>
                </span>
                <strong>Click or drag your selfie here</strong>
                <p id="tryon-upload-helper">JPG, PNG or WebP up to 8 MB · Best results: well-lit, front-facing</p>
              </div>
              <div class="upload-dropzone-copy upload-ready-copy is-hidden" data-upload-ready-copy>
                <strong>Photo ready</strong>
                <p>Click or drag another selfie here to replace it.</p>
              </div>
              <div class="upload-progress is-hidden" data-upload-progress aria-hidden="true">
                <div class="upload-progress-head">
                  <strong data-upload-progress-label>Preparing photo</strong>
                  <span data-upload-progress-percent>0%</span>
                </div>
                <div class="upload-progress-track" aria-hidden="true">
                  <span data-upload-progress-bar></span>
                </div>
                <p data-upload-progress-detail>Reading your image locally.</p>
              </div>
            </div>
          </label>

          <div class="upload-preview-summary is-hidden" data-upload-preview>
            <img src="" alt="Uploaded selfie thumbnail" data-upload-thumb loading="lazy" />
            <div class="upload-preview-copy">
              <strong data-upload-file-name>Selfie uploaded</strong>
              <span data-upload-file-meta>Ready for AI diagnosis</span>
              <span id="tryon-upload-status" class="upload-preview-status" data-upload-status>Ready</span>
            </div>
            <div class="upload-preview-actions">
              <button class="btn btn-secondary upload-action-btn" type="button" data-upload-change>Change</button>
              <button class="btn btn-secondary upload-action-btn" type="button" data-upload-remove>Remove</button>
            </div>
          </div>

          <p id="tryon-upload-error" class="upload-error is-hidden" data-upload-error role="alert"></p>

          <div class="tryon-cta-row">
            <label>
              <span>Scenario</span>
              <select name="scenario">
                <option value="office">Commute / Interview</option>
                <option value="date">Date Night</option>
                <option value="photo">Photo / On Camera</option>
              </select>
            </label>
            <label>
              <span>Experience</span>
              <select name="experience">
                <option value="beginner">Beginner</option>
                <option value="intermediate">Intermediate</option>
              </select>
            </label>
            <button class="btn" type="submit" data-generate-submit data-default-label="Generate My Looks" disabled>Upload Selfie First</button>
          </div>

          <p class="tryon-form-meta">
            <strong>1 free</strong> diagnosis/day · No selfie? Try a sample look on the right.
          </p>
        </form>
        </div>

        <!-- P0.A2: 未上传时右侧灵感/风格选择 -->
        <aside class="tryon-demo-card" aria-label="Makeup inspiration choices">
          <span class="tryon-demo-eyebrow">No selfie? Preview a sample</span>
          <div class="tryon-demo-hero" data-tryon-demo-hero>
            <img
              src={quickLookItems[0].image}
              alt={quickLookItems[0].imageAlt}
              data-tryon-demo-hero-img
              loading="eager"
            />
            <div class="tryon-demo-hero-caption" data-tryon-demo-hero-caption>
              <strong data-tryon-demo-hero-title>{quickLookItems[0].title}</strong>
              <small data-tryon-demo-hero-tone>{quickLookItems[0].tone}</small>
            </div>
          </div>
          <div class="tryon-demo-actions">
            <button class="btn btn-secondary tryon-demo-action-btn" type="button" data-look-drawer-open>Get More Inspired</button>
            <button class="btn btn-secondary tryon-demo-action-btn" type="button" data-style-drawer-open>Try More Styles</button>
          </div>
        </aside>
      </div>
    </section>

    <!-- ─────────── 加载态 ─────────── -->
    <section class="tool-step is-hidden" data-tryon-step="loading" aria-live="polite">
      <div class="loading-state tryon-loading">
        <div class="spinner" aria-hidden="true"></div>
        <h3>Analyzing your face & color profile…</h3>
        <p>Generating your diagnosis and curating 3 personalized looks.</p>
      </div>
    </section>

    <!-- ─────────── 结果态 ─────────── -->
    <section class="tool-step is-hidden" data-tryon-step="result" data-tryon-mode="real">
      <div class="tryon-result-stack">
        <!-- 控制条：模式 chip + 剩余次数 + 删除/重诊断 -->
        <div class="tryon-result-controls">
          <div class="tryon-result-controls-meta">
            <span class="tryon-result-mode-chip is-real" data-tryon-mode-chip>AI Diagnosis</span>
            <span class="is-hidden" data-remaining-badge>
              Free diagnoses left today: <strong data-remaining-count>1</strong>/1
            </span>
          </div>
          <div class="tryon-result-controls-actions">
            <button class="btn btn-secondary tryon-control-btn" type="button" data-tryon-rerun>Re-analyze</button>
            <button class="btn btn-secondary tryon-control-btn" type="button" data-tryon-delete>Delete my photo</button>
          </div>
        </div>

        <!-- AI 免责声明 (PRD §15) -->
        <p class="tryon-ai-disclaimer" role="note">Results are AI-generated suggestions for reference only. Individual results may vary.</p>

        <!-- P2.A14: Demo 模式整宽提示横幅（chip 之外的明确入口） -->
        <aside class="tryon-demo-banner is-hidden" data-tryon-demo-banner role="note">
          <div class="tryon-demo-banner-copy">
            <strong data-tryon-demo-banner-title>You're previewing a sample profile.</strong>
            <span data-tryon-demo-banner-copy>Upload a selfie above to get a real AI diagnosis with custom shades.</span>
          </div>
          <button class="btn" type="button" data-tryon-demo-banner-cta>Upload my photo</button>
        </aside>

        <!-- P0 — 会员门控横幅：当后端返回 _gated.isFreeTier=true 时显示 -->
        <aside class="tryon-gated-banner is-hidden" data-tryon-gated-banner role="note">
          <div class="tryon-gated-banner-copy">
            <span class="pill tryon-gated-pill">Free Preview</span>
            <strong data-tryon-gated-message>Unlock full tutorials, HD previews, and curated beauty kits with Pro</strong>
            <span data-tryon-gated-detail>You're seeing 2 of 3 looks and the first 3 tutorial steps. Upgrade to see everything.</span>
            <ul class="tryon-gated-features is-hidden" data-tryon-gated-features aria-label="Locked features"></ul>
          </div>
          <a class="btn" data-tryon-gated-cta href="/membership">Upgrade to Pro</a>
        </aside>

        <!-- 1. Diagnosis 顶置整宽 -->
        <article class="tryon-diagnosis" id="tryon-section-diagnosis" tabindex="-1">
          <span class="tryon-diagnosis-eyebrow" data-tryon-section-eyebrow>Diagnosis</span>
          <h2 data-diagnosis-title>Warm-neutral undertone · Soft definition fit</h2>
          <p class="tryon-diagnosis-summary" data-diagnosis-summary>Your features suit low-intensity, structured looks. Focus on enhancing complexion and definition.</p>
          <ul class="tryon-diagnosis-notes" data-face-notes>
            <li>Sheer, luminous base works best for you</li>
            <li>Brow and eye structure matters more than heavy color</li>
            <li>Matching lip and cheek tones creates a cleaner finish</li>
          </ul>
        </article>

        <!-- 2. Before / After (demo 模式下隐藏 — P0.2) -->
        <section id="tryon-section-compare" data-tryon-compare-section>
          <div class="result-section-head">
            <div>
              <span class="eyebrow">Preview</span>
              <h3>How this look maps to you</h3>
            </div>
          </div>
          <div class="tryon-compare">
            <article class="compare-frame">
              <span class="pill">Before</span>
              <div class="compare-image-shell">
                <img class="compare-image is-hidden" alt="" data-before-image />
                <div class="compare-placeholder" data-before-placeholder>Your photo will appear here when you upload one.</div>
              </div>
            </article>
            <article class="compare-frame compare-frame-after">
              <span class="pill">After</span>
              <div class="compare-image-shell">
                <img class="compare-image is-hidden" alt="" data-after-image />
                <canvas class="compare-canvas is-hidden" data-after-canvas></canvas>
                <div class="lip-color-swatch is-hidden" data-lip-swatch></div>
                <div class="compare-placeholder" data-after-placeholder>Selected look preview</div>
              </div>
            </article>
          </div>
          <!-- P1.7: after-look-shell 移到 compare 下方独立 strip -->
          <div class="after-look-strip">
            <strong data-selected-look-name>Office Glow</strong>
            <p data-selected-look-finish>Soft matte nude</p>
            <div class="after-look-stats">
              <span data-selected-look-focus>Complexion, brow-eye clarity</span>
              <span data-selected-look-time>8 min</span>
            </div>
            <p class="after-look-copy" data-selected-look-reason>The quickest way to look polished — perfect for commuting and video calls.</p>
          </div>
        </section>

        <!-- 3. Looks -->
        <section id="tryon-section-looks">
          <div class="result-section-head">
            <div>
              <span class="eyebrow">Choose your look</span>
              <h3>Pick the look you want to try first</h3>
            </div>
            <a class="btn btn-secondary" href="/membership">Unlock Full HD Try-On</a>
          </div>
          <div class="tryon-looks look-card-grid" data-look-list></div>
          <!-- P2.10: 横滑进度指示（移动端） -->
          <p class="tryon-looks-progress" data-tryon-looks-progress aria-hidden="true">
            <span data-tryon-looks-current>1</span> / <span data-tryon-looks-total>3</span>
          </p>
        </section>

        <!-- 4. Tutorial preview + Kit -->
        <section id="tryon-section-tutorial">
          <div class="result-section-head">
            <div>
              <span class="eyebrow">Tutorial preview</span>
              <!-- P1.6: 教程 H3 → result-label，并把当前 look 名作为 data point -->
              <h3>Walk-through for <span data-selected-look-heading>Office Glow</span></h3>
              <p class="selected-look-copy" data-selected-look-headline>An 8-minute commute look that instantly adds polish.</p>
            </div>
            <!-- P2.13: 教程 CTA 上移到 section-head -->
            <a class="btn" data-final-tutorial-link href="/tutorials/office-glow">Continue to Full Tutorial →</a>
          </div>
          <div class="step-preview-list" data-selected-steps></div>
          <ul class="check-list compact" data-selected-selfchecks></ul>

          <!-- P0 — 教程被裁断的解锁卡（仅免费用户教程被裁时显示） -->
          <aside class="tryon-tutorial-lock is-hidden" data-tryon-tutorial-lock role="note">
            <div class="tryon-tutorial-lock-icon" aria-hidden="true">🔒</div>
            <div class="tryon-tutorial-lock-copy">
              <strong data-tutorial-lock-title>The full tutorial is more steps</strong>
              <p data-tutorial-lock-detail>Pro unlocks every step with error alerts, self-check points, and curated product picks for each.</p>
            </div>
            <a class="btn" data-tutorial-lock-cta href="/membership">Unlock Full Tutorial</a>
          </aside>

          <details class="tryon-kit-details" data-tryon-kit>
            <!-- P2.12: summary-hint 独立类，不再借用 trust-strip -->
            <summary>
              <span class="tryon-kit-summary-label">Beauty kit picks</span>
              <span class="tryon-kit-summary-hint">Tap to expand</span>
            </summary>
            <div class="kit-columns">
              <div>
                <strong>Must-Have</strong>
                <div class="product-stack" data-kit-must></div>
              </div>
              <div>
                <strong>Swappable</strong>
                <div class="product-stack" data-kit-optional></div>
              </div>
              <div>
                <strong>Upgrade Pick</strong>
                <div class="product-stack" data-kit-upgrade></div>
              </div>
            </div>
          </details>

          <div class="tool-actions tutorial-cta-row top-gap">
            <a class="text-link" data-tutorial-link href="/tutorials/office-glow">See step details</a>
          </div>
        </section>

        <!-- 5. Share Card -->
        <section id="tryon-section-share">
          <div class="result-section-head">
            <div>
              <span class="eyebrow">Share</span>
              <h3>Save or share your plan</h3>
            </div>
          </div>
          <article class="share-card-mock">
            <div class="share-card-header">
              <span class="pill">Share Card</span>
              <span class="share-export-status" data-share-status>Copy to share</span>
            </div>
            <p class="share-badge" data-share-badge>Work-ready glow</p>
            <!-- P1.6: share-card 内嵌 H3 → H4 (避免与 section H3 同级) -->
            <h4 class="share-card-title" data-share-title>My AI Office Makeup Plan</h4>
            <p data-share-subtitle>Less effort, more polished every day.</p>
            <p class="share-card-look" data-share-look>Office Glow · Soft matte nude</p>
            <div class="share-card-tags" data-share-tags></div>
            <p class="share-card-cta" data-share-cta>Copy your look summary to share with friends, or continue to the full tutorial.</p>
            <div class="share-card-actions">
              <button class="btn" type="button" data-share-download>📸 Download Share Card</button>
              <button class="btn btn-secondary" type="button" data-share-export>Copy Share Text</button>
              <button class="btn btn-secondary" type="button" data-save-look>💾 Save my look plan</button>
              <a class="text-link" data-continue-link href="/tutorials/office-glow">Continue to Tutorial →</a>
            </div>
            <p class="share-save-status is-hidden" data-save-status role="status" aria-live="polite"></p>
            <div class="share-card-preview is-hidden" data-share-card-preview>
              <img data-share-card-image alt="Your share card preview" />
            </div>
          </article>
        </section>
      </div>
    </section>
  </div>
</section>

<div class="look-drawer is-hidden" data-look-drawer role="dialog" aria-modal="true" aria-hidden="true" aria-labelledby="look-drawer-title">
  <button class="look-drawer-backdrop" type="button" data-look-drawer-close aria-label="Close all looks"></button>
  <div class="look-drawer-panel">
    <div class="look-drawer-head">
      <div>
        <span class="eyebrow">All Looks</span>
        <h3 id="look-drawer-title">Find the makeup mood you want to try.</h3>
      </div>
      <button class="look-drawer-close" type="button" data-look-drawer-close aria-label="Close all looks">&times;</button>
    </div>
    <div class="look-filter-tabs" aria-label="Filter makeup looks">
      {lookFilters.map((filter, index) => (
        <button type="button" class:list={['look-filter-chip', { 'is-active': index === 0 }]} data-look-filter={filter.value}>
          {filter.label}
        </button>
      ))}
    </div>
    <div class="look-drawer-grid" aria-label="All makeup looks">
      {allLookItems.map((look, index) => (
        <button
          type="button"
          class="look-drawer-item"
          data-look-item
          data-analytics-look
          data-analytics-source="tryon-drawer"
          data-analytics-position={index + 1}
          data-analytics-look-slug={look.slug}
          data-look-slug={look.slug}
          data-look-title={look.title}
          data-look-tone={look.tone}
          data-look-category={look.category}
          data-tryon-demo={look.scenario}
          data-look-href={buildLookTryOnHref(look)}
          data-look-image={look.image}
          data-look-image-alt={look.imageAlt}
          style={`background-image:url('${look.image}');`}
          aria-label={`Try ${look.title}`}
        >
          <span><strong>{look.title}</strong><small>{look.tone}</small></span>
        </button>
      ))}
    </div>
  </div>
</div>

<!-- 妆效预览浮层 -->
<div class="makeup-preview-modal is-hidden" id="makeup-preview-modal" role="dialog" aria-modal="true" aria-label="Makeup Preview">
  <div class="makeup-preview-backdrop" data-makeup-close></div>
  <div class="makeup-preview-content">
    <button class="makeup-preview-close" data-makeup-close aria-label="Close preview">&times;</button>
    <div class="makeup-preview-loading" id="makeup-preview-loading">
      <div class="spinner" aria-hidden="true"></div>
      <h3>Generating your makeup look...</h3>
      <p id="makeup-preview-look-name"></p>
      <p class="makeup-preview-hint">This usually takes 30-60 seconds</p>
    </div>
    <div class="makeup-preview-result is-hidden" id="makeup-preview-result">
      <h3 id="makeup-preview-title"></h3>
      <div class="makeup-preview-images">
        <div class="makeup-preview-frame">
          <span class="pill">Before</span>
          <img id="makeup-preview-before" src="" alt="Before makeup" />
        </div>
        <div class="makeup-preview-frame">
          <span class="pill">After (AI Generated)</span>
          <img id="makeup-preview-after" src="" alt="AI generated makeup preview" />
        </div>
      </div>
      <div class="makeup-preview-actions">
        <button class="btn" id="makeup-preview-download">Download After Image</button>
        <button class="btn btn-secondary" data-makeup-close>Close</button>
      </div>
      <p class="makeup-preview-elapsed" id="makeup-preview-elapsed"></p>
    </div>
    <div class="makeup-preview-error is-hidden" id="makeup-preview-error">
      <p id="makeup-preview-error-msg"></p>
      <button class="btn btn-secondary" data-makeup-close>Close</button>
    </div>
  </div>
</div>

<script>
  type LipColorParams = {
    hex: string;
    opacity: number;
    blendMode: 'multiply' | 'soft-light' | 'overlay';
  };

  type NormalizedLandmark = { x: number; y: number; z: number };
  type FaceLandmarkerHandle = {
    detect: (image: HTMLImageElement) => NormalizedLandmark[] | null;
  };

  type TryOnProductClient = {
    sku: string;
    name: string;
    category: string;
    shade: string;
    price: string;
    why: string;
  };

  type TryOnStepClient = {
    title: string;
    detail: string;
    avoid: string;
    selfCheck: string;
  };

  type TryOnLookClient = {
    id: string;
    name: string;
    reason: string;
    scenario: string;
    difficulty: string;
    minutes: string;
    focus: string;
    finish: string;
    tutorialHeadline: string;
    tutorialSteps?: TryOnStepClient[];
    commonMistakes?: string[];
    selfChecks?: string[];
    _tutorialGated?: boolean;
    _totalSteps?: number;
    _nextStepTitle?: string;
    kit?: {
      mustHave?: TryOnProductClient[];
      optional?: TryOnProductClient[];
      upgrade?: TryOnProductClient[];
    };
  };

  type TryOnRenderResponse = {
    _render?: {
      provider?: string;
      model?: string;
      fallback?: boolean;
      fallbackReason?: string;
      generatedAt?: string;
      image?: {
        mimeType?: string;
        dataUrl?: string;
      };
    };
  };

  type UploadState = 'idle' | 'reading' | 'compressing' | 'ready' | 'analyzing' | 'rendering' | 'error';

  type PreparedPhoto = {
    dataUrl: string;
    previewUrl: string;
    width: number;
    height: number;
    byteSize: number;
  };

  type ShareCardClient = {
    title: string;
    subtitle: string;
    badge: string;
    hashtags?: string[];
    cta: string;
  };

  type GatedInfo = {
    tier: 'free' | 'pro' | 'premium';
    isFreeTier: boolean;
    lockedFeatures: string[];
    upgradeMessage: string;
    upgradeCta: string;
    upgradeUrl: string;
  };

  type TryOnApiResponse = {
    diagnosis?: {
      title: string;
      summary: string;
      faceNotes?: string[];
    };
    looks?: TryOnLookClient[];
    shareCard?: ShareCardClient;
    _lipColors?: Record<string, LipColorParams>;
    _remaining?: number;
    _rateLimited?: boolean;
    _gated?: GatedInfo;
    _upload?: {
      provider?: string;
      stored?: boolean;
      key?: string;
      error?: string;
    };
    message?: string;
    meta?: {
      fallback?: boolean;
    };
  };

  const qs = <T extends Element = HTMLElement>(selector: string) =>
    document.querySelector(selector) as T | null;

  const qsa = <T extends Element = HTMLElement>(selector: string) =>
    Array.from(document.querySelectorAll(selector)) as T[];

  // ─── DOM 引用 ───
  const form = qs<HTMLFormElement>('[data-tryon-form]');
  const tryonShell = qs<HTMLElement>('[data-tryon-shell]');
  const photoInput = qs<HTMLInputElement>('[data-photo-input]');
  const uploadIdleCopy = qs<HTMLElement>('[data-upload-idle-copy]');
  const uploadReadyCopy = qs<HTMLElement>('[data-upload-ready-copy]');
  const uploadProgress = qs<HTMLElement>('[data-upload-progress]');
  const uploadProgressLabel = qs<HTMLElement>('[data-upload-progress-label]');
  const uploadProgressPercent = qs<HTMLElement>('[data-upload-progress-percent]');
  const uploadProgressBar = qs<HTMLElement>('[data-upload-progress-bar]');
  const uploadProgressDetail = qs<HTMLElement>('[data-upload-progress-detail]');
