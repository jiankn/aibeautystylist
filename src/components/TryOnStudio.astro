  const loadingCountdownLabel = qs<HTMLElement>('[data-loading-countdown-label]');
  const loadingProgressBar = qs<HTMLElement>('[data-loading-progress-bar]');
  const loadingPhaseItems = qsa<HTMLElement>('[data-loading-phase]');
