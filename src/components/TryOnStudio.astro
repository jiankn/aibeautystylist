  const lookDrawerCloseButtons = qsa<HTMLButtonElement>('[data-look-drawer-close]');
  const lookFilterButtons = qsa<HTMLButtonElement>('[data-look-filter]');
  const lookDrawerItems = qsa<HTMLElement>('[data-look-item]');
  // Style Drawer DOM 引用
  const styleDrawer = qs<HTMLElement>('[data-style-drawer]');
  const styleDrawerCloseButtons = qsa<HTMLButtonElement>('[data-style-drawer-close]');
  const styleFilterButtons = qsa<HTMLButtonElement>('[data-style-filter]');
  const styleDrawerItems = qsa<HTMLElement>('[data-style-item]');
  const selectedInspiration = qs<HTMLElement>('[data-selected-inspiration]');
  const selectedInspirationTitle = qs<HTMLElement>('[data-selected-inspiration-title]');
  const selectedInspirationTone = qs<HTMLElement>('[data-selected-inspiration-tone]');
  const demoHeroImg = qs<HTMLImageElement>('[data-tryon-demo-hero-img]');
  const demoHeroTitle = qs<HTMLElement>('[data-tryon-demo-hero-title]');
  const demoHeroTone = qs<HTMLElement>('[data-tryon-demo-hero-tone]');
  // P0 — 会员门控 UI 引用
  const gatedBanner = qs<HTMLElement>('[data-tryon-gated-banner]');
  const gatedMessage = qs<HTMLElement>('[data-tryon-gated-message]');
