<script id="tryon-studio-translations" type="application/json" set:html={tryOnStudioTranslationsJson}></script>

<script>
  const translationsElement = document.getElementById('tryon-studio-translations');
  const TX = translationsElement?.textContent ? JSON.parse(translationsElement.textContent) : {};

  type LipColorParams = {
    hex: string;
    opacity: number;
    blendMode: 'multiply' | 'soft-light' | 'overlay';
  };

  type NormalizedLandmark = { x: number; y: number; z: number };
  type FaceLandmarkerHandle = {
    detect: (image: HTMLImageElement) => NormalizedLandmark[] | null;
  };

  type TryOnProductClient = {
    sku: string;
    name: string;
    category: string;
    shade: string;
    price: string;
    why: string;
  };

  type TryOnStepClient = {
    title: string;
    detail: string;
    avoid: string;
    selfCheck: string;
  };

  type TryOnLookClient = {
    id: string;
    name: string;
    reason: string;
    scenario: string;
    difficulty: string;
    minutes: string;
    focus: string;
    finish: string;
    tutorialHeadline: string;
    tutorialSteps?: TryOnStepClient[];
    commonMistakes?: string[];
    selfChecks?: string[];
    _tutorialGated?: boolean;
    _totalSteps?: number;
    _nextStepTitle?: string;
    kit?: {
      mustHave?: TryOnProductClient[];
      optional?: TryOnProductClient[];
      upgrade?: TryOnProductClient[];
    };
  };

  type TryOnRenderResponse = {
    _render?: {
      provider?: string;
      model?: string;
      fallback?: boolean;
      fallbackReason?: string;
      generatedAt?: string;
      image?: {
        mimeType?: string;
        dataUrl?: string;
      };
    };
  };

  type MakeupPreviewResponse = {
    error?: string;
    message?: string;
    image?: {
      dataUrl?: string;
    };
    _tier?: 'free' | 'pro' | 'premium';
  };

  type UploadState = 'idle' | 'reading' | 'compressing' | 'ready' | 'analyzing' | 'rendering' | 'error';

  type PreparedPhoto = {
    dataUrl: string;
    previewUrl: string;
    width: number;
    height: number;
    byteSize: number;
  };

  type ShareCardClient = {
    title: string;
    subtitle: string;
    badge: string;
    hashtags?: string[];
    cta: string;
  };

  type GatedInfo = {
    tier: 'free' | 'pro' | 'premium';
    isFreeTier: boolean;
    lockedFeatures: string[];
    upgradeMessage: string;
    upgradeCta: string;
    upgradeUrl: string;
  };

  type TryOnApiResponse = {
    diagnosis?: {
      title: string;
      summary: string;
      faceNotes?: string[];
    };
    looks?: TryOnLookClient[];
    shareCard?: ShareCardClient;
    _lipColors?: Record<string, LipColorParams>;
    _remaining?: number;
    _quotaLimit?: number;
    _quotaWindow?: 'daily' | 'monthly';
    _tier?: 'free' | 'pro' | 'premium';
    _rateLimited?: boolean;
    _gated?: GatedInfo;
    _upload?: {
      provider?: string;
      stored?: boolean;
      key?: string;
      error?: string;
    };
    message?: string;
    meta?: {
      fallback?: boolean;
    };
  };

  const qs = <T extends Element = HTMLElement>(selector: string) =>
    document.querySelector(selector) as T | null;

  const qsa = <T extends Element = HTMLElement>(selector: string) =>
    Array.from(document.querySelectorAll(selector)) as T[];

  // ─── DOM 引用 ───
  const form = qs<HTMLFormElement>('[data-tryon-form]');
  const tryonShell = qs<HTMLElement>('[data-tryon-shell]');
  const photoInput = qs<HTMLInputElement>('[data-photo-input]');
  const uploadIdleCopy = qs<HTMLElement>('[data-upload-idle-copy]');
  const uploadReadyCopy = qs<HTMLElement>('[data-upload-ready-copy]');
  const uploadProgress = qs<HTMLElement>('[data-upload-progress]');
  const uploadProgressLabel = qs<HTMLElement>('[data-upload-progress-label]');
  const uploadProgressPercent = qs<HTMLElement>('[data-upload-progress-percent]');
  const uploadProgressBar = qs<HTMLElement>('[data-upload-progress-bar]');
  const uploadProgressDetail = qs<HTMLElement>('[data-upload-progress-detail]');
  const uploadPreview = qs<HTMLElement>('[data-upload-preview]');
  const uploadThumb = qs<HTMLImageElement>('[data-upload-thumb]');
  const uploadFileName = qs<HTMLElement>('[data-upload-file-name]');
  const uploadFileMeta = qs<HTMLElement>('[data-upload-file-meta]');
  const uploadStatus = qs<HTMLElement>('[data-upload-status]');
  const uploadError = qs<HTMLElement>('[data-upload-error]');
  const uploadChangeButton = qs<HTMLButtonElement>('[data-upload-change]');
  const uploadRemoveButton = qs<HTMLButtonElement>('[data-upload-remove]');
  const generateSubmitButton = qs<HTMLButtonElement>('[data-generate-submit]');
  const beforeImage = qs<HTMLImageElement>('[data-before-image]');
  const afterImage = qs<HTMLImageElement>('[data-after-image]');
  const beforePlaceholder = qs<HTMLElement>('[data-before-placeholder]');
  const afterPlaceholder = qs<HTMLElement>('[data-after-placeholder]');
  const lookList = qs<HTMLElement>('[data-look-list]');
  const afterCanvas = qs<HTMLCanvasElement>('[data-after-canvas]');
  const lipSwatch = qs<HTMLElement>('[data-lip-swatch]');
  const remainingBadge = qs<HTMLElement>('[data-remaining-badge]');
  const remainingLabel = qs<HTMLElement>('[data-remaining-label]');
  const remainingCount = qs<HTMLElement>('[data-remaining-count]');
  const remainingTotal = qs<HTMLElement>('[data-remaining-total]');
  const modeChip = qs<HTMLElement>('[data-tryon-mode-chip]');
  const liveRegion = qs<HTMLElement>('[data-tryon-live]');
