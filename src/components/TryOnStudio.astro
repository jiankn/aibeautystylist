  const validatePhotoFile = (file: File) => {
    const hasAllowedType = ALLOWED_UPLOAD_TYPES.includes(file.type);
    const hasAllowedExtension = /\.(jpe?g|png|webp)$/i.test(file.name);
    if (!hasAllowedType && !hasAllowedExtension) {
      return 'Please upload a JPG, PNG, or WebP selfie.';
    }
    if (file.size <= 0) {
      return 'This file looks empty. Please choose another selfie.';
    }
    if (file.size > MAX_UPLOAD_BYTES) {
      return `Your selfie is ${formatFileSize(file.size)}. Please upload an image under 8 MB.`;
    }
    return '';
