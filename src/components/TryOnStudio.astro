  const formatFileSize = (bytes: number) => {
    if (bytes < 1024) return `${bytes} B`;
    const kb = bytes / 1024;
    if (kb < 1024) return `${kb.toFixed(kb >= 100 ? 0 : 1)} KB`;
    const mb = kb / 1024;
    return `${mb.toFixed(mb >= 10 ? 1 : 2)} MB`;
  };

  const getDataUrlByteSize = (dataUrl: string) => {
    const base64 = dataUrl.split(',')[1] || '';
    return Math.round((base64.length * 3) / 4);
  };

  const setGenerateButtonState = () => {
    if (!generateSubmitButton) return;
    const busy = uploadState === 'reading' || uploadState === 'compressing' || uploadState === 'analyzing' || uploadState === 'rendering';
    const canSubmit = Boolean(preparedPhotoBase64 && selectedPhotoFile && uploadState === 'ready');
    generateSubmitButton.disabled = busy || !canSubmit;

    if (uploadState === 'reading' || uploadState === 'compressing') {
      generateSubmitButton.textContent = 'Preparing Photo...';
      return;
    }
    if (uploadState === 'analyzing') {
      generateSubmitButton.textContent = 'Analyzing...';
