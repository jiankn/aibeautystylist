    shareTitle: t('tryOnStudio.shareTitle', currentLocale),
    shareSubtitle: t('tryOnStudio.shareSubtitle', currentLocale),
    shareCta: t('tryOnStudio.shareCta', currentLocale),
    shareDownload: t('tryOnStudio.shareDownload', currentLocale),
    shareExport: t('tryOnStudio.shareExport', currentLocale),
    shareSave: t('tryOnStudio.shareSave', currentLocale),
    shareContinue: t('tryOnStudio.shareContinue', currentLocale),
    shareSiteLabel: t('tryOnStudio.shareSiteLabel', currentLocale),
    shareGeneratingAfter: t('tryOnStudio.shareGeneratingAfter', currentLocale),
    sharePreparingCard: t('tryOnStudio.sharePreparingCard', currentLocale),
    shareDownloadDone: t('tryOnStudio.shareDownloadDone', currentLocale),
    shareDownloadFailed: t('tryOnStudio.shareDownloadFailed', currentLocale),
    shareAfterAlt: t('tryOnStudio.shareAfterAlt', currentLocale),
    shareUrlLabel: t('tryOnStudio.shareUrlLabel', currentLocale),
    shareStatusCopied: t('tryOnStudio.shareStatusCopied', currentLocale),
    shareStatusSaved: t('tryOnStudio.shareStatusSaved', currentLocale),
    upgradeCompareEyebrow: t('tryOnStudio.upgradeCompareEyebrow', currentLocale),
    upgradeCompareHeading: t('tryOnStudio.upgradeCompareHeading', currentLocale),
    upgradeCompareSub: t('tryOnStudio.upgradeCompareSub', currentLocale),
    upgradeFreeLabel: t('tryOnStudio.upgradeFreeLabel', currentLocale),
    upgradeFreePrice: t('tryOnStudio.upgradeFreePrice', currentLocale),
    upgradeProLabel: t('tryOnStudio.upgradeProLabel', currentLocale),
    upgradeProPrice: t('tryOnStudio.upgradeProPrice', currentLocale),
    upgradePremiumLabel: t('tryOnStudio.upgradePremiumLabel', currentLocale),
    upgradePremiumPrice: t('tryOnStudio.upgradePremiumPrice', currentLocale),
    upgradeProCta: t('tryOnStudio.upgradeProCta', currentLocale),
    upgradePremiumCta: t('tryOnStudio.upgradePremiumCta', currentLocale),
    lookDrawerTitle: t('tryOnStudio.lookDrawerTitle', currentLocale),
    lookDrawerSubtitle: t('tryOnStudio.lookDrawerSubtitle', currentLocale),
    styleDrawerTitle: t('tryOnStudio.styleDrawerTitle', currentLocale),
    styleDrawerSubtitle: t('tryOnStudio.styleDrawerSubtitle', currentLocale),
    styleFilterAll: t('tryOnStudio.styleFilterAll', currentLocale),
    styleFilterOffice: t('tryOnStudio.styleFilterOffice', currentLocale),
    styleFilterDate: t('tryOnStudio.styleFilterDate', currentLocale),
    styleFilterPhoto: t('tryOnStudio.styleFilterPhoto', currentLocale),
    emptyStateTitle: t('tryOnStudio.emptyStateTitle', currentLocale),
    emptyStateDetail: t('tryOnStudio.emptyStateDetail', currentLocale),
    ghostCardTitle: t('tryOnStudio.ghostCardTitle', currentLocale),
    ghostCardDetail: t('tryOnStudio.ghostCardDetail', currentLocale),
    ghostCardCta: t('tryOnStudio.ghostCardCta', currentLocale),
    previewMakeup: t('tryOnStudio.previewMakeup', currentLocale),
    previewMakeupLocked: t('tryOnStudio.previewMakeupLocked', currentLocale),
    selfieUploadSuccess: t('tryOnStudio.selfieUploadSuccess', currentLocale),
    diagnosisReady: t('tryOnStudio.diagnosisReady', currentLocale),
    demoReady: t('tryOnStudio.demoReady', currentLocale),
    uploadNeedsAttention: t('tryOnStudio.uploadNeedsAttention', currentLocale),
    uploadSelfieFirst: t('tryOnStudio.uploadSelfieFirst', currentLocale),
    dailyQuotaReached: t('tryOnStudio.dailyQuotaReached', currentLocale),
    diagnosisIncomplete: t('tryOnStudio.diagnosisIncomplete', currentLocale),
    requestFailed: t('tryOnStudio.requestFailed', currentLocale),
    deletePhotoConfirm: t('tryOnStudio.deletePhotoConfirm', currentLocale),
    photoRemoved: t('tryOnStudio.photoRemoved', currentLocale),
    noLooksAvailable: t('tryOnStudio.noLooksAvailable', currentLocale),
    selfCheckLabel: t('tryOnStudio.selfCheckLabel', currentLocale),
    generatingPreview: t('tryOnStudio.generatingPreview', currentLocale),
    previewLookName: t('tryOnStudio.previewLookName', currentLocale),
    previewHint: t('tryOnStudio.previewHint', currentLocale),
    previewElapsed: t('tryOnStudio.previewElapsed', currentLocale),
    previewError: t('tryOnStudio.previewError', currentLocale),
    previewClose: t('tryOnStudio.previewClose', currentLocale),
    previewDownload: t('tryOnStudio.previewDownload', currentLocale),
    beforeLabel: t('tryOnStudio.beforeLabel', currentLocale),
    afterLabel: t('tryOnStudio.afterLabel', currentLocale),
    selectedLookPreview: t('tryOnStudio.selectedLookPreview', currentLocale),
    fullFacePreviewNotAvailable: t('tryOnStudio.fullFacePreviewNotAvailable', currentLocale),
    generatingFullFacePreview: t('tryOnStudio.generatingFullFacePreview', currentLocale),
    previewFallbackShown: t('tryOnStudio.previewFallbackShown', currentLocale),
    previewGenerated: t('tryOnStudio.previewGenerated', currentLocale),
    previewGeneratedWith: t('tryOnStudio.previewGeneratedWith', currentLocale),
    previewEngineBasic: t('tryOnStudio.previewEngineBasic', currentLocale),
    previewEnginePro: t('tryOnStudio.previewEnginePro', currentLocale),
    btnPreparingPhoto: t('tryOnStudio.btnPreparingPhoto', currentLocale),
    btnAnalyzing: t('tryOnStudio.btnAnalyzing', currentLocale),
    btnRenderingPreview: t('tryOnStudio.btnRenderingPreview', currentLocale),
    btnFixUpload: t('tryOnStudio.btnFixUpload', currentLocale),
    uploadReadyForDiagnosis: t('tryOnStudio.uploadReadyForDiagnosis', currentLocale),
    uploadContinue: t('tryOnStudio.uploadContinue', currentLocale),
    uploadErrorType: t('tryOnStudio.uploadErrorType', currentLocale),
    uploadErrorEmpty: t('tryOnStudio.uploadErrorEmpty', currentLocale),
    uploadErrorTooLargePrefix: t('tryOnStudio.uploadErrorTooLargePrefix', currentLocale),
    uploadErrorTooLargeSuffix: t('tryOnStudio.uploadErrorTooLargeSuffix', currentLocale),
    metaOriginal: t('tryOnStudio.metaOriginal', currentLocale),
    metaAiReady: t('tryOnStudio.metaAiReady', currentLocale),
    metaOptimized: t('tryOnStudio.metaOptimized', currentLocale),
