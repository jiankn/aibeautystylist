---
import type { ReferenceTryOnCopy } from "../data/referenceTryOnCopy";
import ReferenceTryOnHistoryDrawer from "./ReferenceTryOnHistoryDrawer.astro";

interface Props {
  copy: ReferenceTryOnCopy;
  hrefs: {
    login: string;
    pricing: string;
    history: string;
    privateHistory: string;
    resultBase: string;
    shareCard: string;
    credits: string;
  };
}

const { copy, hrefs } = Astro.props;
---

<section class="rt-workspace-head" aria-labelledby="reference-workspace-title">
  <div>
    <p>{copy.eyebrow}</p>
    <h1 id="reference-workspace-title">{copy.heading}</h1>
  </div>
  <div class="rt-workspace-meta">
    <span class="rt-meta-item rt-quota-item">
      <svg viewBox="0 0 24 24" aria-hidden="true"
        ><ellipse cx="12" cy="5" rx="8" ry="3"></ellipse><path
          d="M4 5v6c0 1.7 3.6 3 8 3s8-1.3 8-3V5"></path><path
          d="M4 11v6c0 1.7 3.6 3 8 3s8-1.3 8-3v-6"></path></svg
      >
      <b data-workspace-quota>--</b>
    </span>
    <span class="rt-meta-item">
      <svg viewBox="0 0 24 24" aria-hidden="true"
        ><rect x="5" y="10" width="14" height="10" rx="2"></rect><path
          d="M8 10V7a4 4 0 0 1 8 0v3"></path></svg
      >
      {copy.privacyTitle}
    </span>
    <button
      class="rt-history-trigger"
      type="button"
      data-reference-history-trigger
      aria-haspopup="dialog"
      aria-controls="reference-history-dialog"
      aria-expanded="false"
      aria-label={copy.historyDrawerTrigger}
      hidden
    >
      <svg viewBox="0 0 24 24" aria-hidden="true"
        ><path d="M3 12a9 9 0 1 0 3-6.7L3 8"></path><path d="M3 3v5h5"
        ></path><path d="M12 7v5l3 2"></path></svg
      >
      <span>{copy.historyDrawerTrigger}</span>
    </button>
  </div>
</section>

<section
  class="reference-state"
  data-loading-state
  role="status"
  aria-live="polite"
>
  <span class="rt-loader" data-loading-spinner aria-hidden="true"></span>
  <p data-loading-message>{copy.loadingAccount}</p>
  <button type="button" data-loading-retry hidden>{copy.retry}</button>
</section>

<section class="reference-gate" data-login-gate hidden>
  <span class="rt-gate-label">{copy.eyebrow}</span>
  <h2>{copy.loginTitle}</h2>
  <p>{copy.loginBody}</p>
  <a class="rt-primary-link" href={hrefs.login}>{copy.loginCta}</a>
</section>

<section class="reference-gate" data-premium-gate hidden>
  <span class="rt-gate-label">Premium</span>
  <h2>{copy.premiumTitle}</h2>
  <p>{copy.premiumBody}</p>
  <a class="rt-primary-link" href={hrefs.pricing}>{copy.premiumCta}</a>
  <div class="premium-template-manager" data-template-manager hidden>
    <h3>{copy.manageExisting}</h3>
    <div class="saved-reference-list" data-template-list></div>
    <p class="saved-reference-status" data-template-status role="status"></p>
  </div>
</section>

<div class="reference-workspace-grid">
  <form class="reference-workflow" data-reference-form hidden novalidate>
    <nav class="rt-stepper" aria-label={copy.heading}>
      <div class="rt-stepper-node rt-stepper-node--active" data-step-node="1">
        <span class="rt-stepper-dot">1</span>
        <span class="rt-stepper-label">{copy.stepReference}</span>
      </div>
      <span class="rt-stepper-line"><i class="rt-stepper-line-fill"></i></span>
      <div class="rt-stepper-node" data-step-node="2">
        <span class="rt-stepper-dot">2</span>
        <span class="rt-stepper-label">{copy.stepSelfie}</span>
      </div>
      <span class="rt-stepper-line"><i class="rt-stepper-line-fill"></i></span>
      <div class="rt-stepper-node" data-step-node="3">
        <span class="rt-stepper-dot">3</span>
        <span class="rt-stepper-label">{copy.stepGenerate}</span>
      </div>
    </nav>

    <aside class="rt-source-panel">
      <section class="rt-source-block reference-step">
        <div class="rt-source-heading">
          <div>
            <h2>{copy.referenceTitle}</h2>
            <p>{copy.referenceHelp}</p>
          </div>
          <span data-reference-ready hidden>{copy.ready}</span>
        </div>
        <label class="reference-dropzone">
          <input
            type="file"
            accept="image/jpeg,image/png,image/webp"
            aria-describedby="reference-file-help reference-file-error"
            data-reference-input
          />
          <img data-reference-preview alt="" hidden />
          <span class="rt-upload-placeholder">
            <svg viewBox="0 0 24 24" aria-hidden="true"
              ><path d="M12 16V4"></path><path d="m7 9 5-5 5 5"></path><path
                d="M5 20h14"></path></svg
            >
            <b>{copy.referenceLabel}</b>
            <small id="reference-file-help">{copy.referenceFormat}</small>
          </span>
        </label>
        <label class="reference-name">
          <span>{copy.templateName}</span>
          <input
            type="text"
            maxlength="60"
            placeholder={copy.templatePlaceholder}
            data-template-title
          />
        </label>
        <p id="reference-file-error" data-error="reference" role="alert" hidden>
        </p>
        <label class="reference-check compact-check">
          <input
            type="checkbox"
            aria-describedby="reference-rights-error"
            data-rights-check
          />
          <span>{copy.rights}</span>
        </label>
        <p id="reference-rights-error" data-error="rights" role="alert" hidden>
        </p>
        <details class="saved-reference-block">
          <summary>{copy.savedTitle}</summary>
          <div class="saved-reference-list" data-template-list>
            <p>{copy.noSaved}</p>
          </div>
          <p class="saved-reference-status" data-template-status role="status">
          </p>
        </details>
      </section>

      <section class="rt-source-block reference-step">
        <div class="rt-source-heading">
          <div>
            <h2>{copy.selfieTitle}</h2>
            <p>{copy.selfieHelp}</p>
          </div>
          <span data-selfie-ready hidden>{copy.ready}</span>
        </div>
        <label class="reference-dropzone reference-selfie">
          <input
            type="file"
            accept="image/jpeg,image/png,image/webp"
            aria-describedby="selfie-file-help selfie-file-error"
            data-selfie-input
            required
          />
          <img data-selfie-preview alt="" hidden />
          <span class="rt-upload-placeholder">
            <svg viewBox="0 0 24 24" aria-hidden="true"
              ><path d="M12 16V4"></path><path d="m7 9 5-5 5 5"></path><path
                d="M5 20h14"></path></svg
            >
            <b>{copy.selfieLabel}</b>
            <small id="selfie-file-help">{copy.selfieFormat}</small>
          </span>
        </label>
        <p id="selfie-file-error" data-error="selfie" role="alert" hidden></p>
        <label class="reference-check compact-check">
          <input
            type="checkbox"
            aria-describedby="selfie-consent-error"
            data-consent-check
            required
          />
          <span>{copy.consent}</span>
        </label>
        <p id="selfie-consent-error" data-error="consent" role="alert" hidden>
        </p>
      </section>
    </aside>

    <section class="rt-preview-panel" aria-labelledby="preview-title">
      <header>
        <div>
          <h2 id="preview-title">{copy.previewTitle}</h2>
          <p>{copy.intro}</p>
        </div>
        <span>{copy.privacyTitle}</span>
      </header>
      <div class="rt-preview-stage">
        <div class="rt-preview-empty" data-canvas-empty>
          <svg viewBox="0 0 24 24" aria-hidden="true"
            ><rect x="3" y="3" width="18" height="18" rx="3"></rect><circle
              cx="9"
              cy="9"
              r="2"></circle><path d="m21 15-5-5L5 21"></path></svg
          >
          <strong>{copy.previewEmptyTitle}</strong>
          <p>{copy.previewEmptyBody}</p>
        </div>
        <img data-canvas-image alt={copy.selfieTitle} hidden />
      </div>
      <div class="reference-submit">
        <div>
          <p class="reference-cost-note" data-cost-note>{copy.costNote}</p>
          <a href={hrefs.credits} data-credit-link hidden>{copy.buyCredits}</a>
          <p data-reference-status role="status"></p>
          <a href={hrefs.history} data-progress-link hidden
            >{copy.viewProgress}</a
          >
        </div>
        <button type="submit" data-generate>
          <svg viewBox="0 0 24 24" aria-hidden="true"
            ><path d="M12 3v3"></path><path d="M12 18v3"></path><path
              d="M3 12h3"></path><path d="M18 12h3"></path><path
              d="m5.6 5.6 2.1 2.1"></path><path d="m16.3 16.3 2.1 2.1"
            ></path><path d="m5.6 18.4 2.1-2.1"></path><path
              d="m16.3 7.7 2.1-2.1"></path><circle cx="12" cy="12" r="3"
            ></circle></svg
          >
          <span>{copy.generate}</span>
        </button>
      </div>
    </section>
  </form>

  <section class="reference-result" data-result hidden>
    <aside class="reference-result-info">
      <span>{copy.generatedLabel}</span>
      <h2>{copy.resultTitle}</h2>
      <p>{copy.resultNote}</p>
      <div class="reference-result-actions">
        <button type="button" data-again>{copy.again}</button>
        <a href={hrefs.shareCard} data-share-result>{copy.shareBtn}</a>
      </div>
    </aside>
    <figure class="reference-result-figure" data-result-compare>
      <img
        class="rt-compare-original"
        data-result-original
        alt={copy.originalLabel}
      />
      <div class="rt-compare-after">
        <img data-result-image alt={copy.generatedLabel} />
      </div>
      <span class="rt-compare-label rt-compare-label-before"
        >{copy.originalLabel}</span
      >
      <span class="rt-compare-label rt-compare-label-after"
        >{copy.generatedLabel}</span
      >
      <span class="rt-compare-divider" aria-hidden="true"><i>↔</i></span>
      <input
        type="range"
        min="10"
        max="90"
        value="50"
        aria-label={copy.compareLabel}
        data-compare-slider
      />
    </figure>
  </section>

  <ReferenceTryOnHistoryDrawer
    copy={{
      trigger: copy.historyDrawerTrigger,
      title: copy.historyDrawerTitle,
      subtitle: copy.historyDrawerSubtitle,
      close: copy.historyDrawerClose,
      loading: copy.historyDrawerLoading,
      emptyTitle: copy.historyDrawerEmptyTitle,
      emptyBody: copy.historyDrawerEmptyBody,
      loadFailed: copy.historyDrawerLoadFailed,
      retry: copy.historyDrawerRetry,
      viewAll: copy.historyDrawerViewAll,
      back: copy.historyDrawerBack,
      reuse: copy.historyDrawerReuse,
      openResult: copy.historyDrawerOpenResult,
      templateUnavailable: copy.historyDrawerTemplateUnavailable,
    }}
    historyHref={hrefs.privateHistory}
    resultBaseHref={hrefs.resultBase}
  />
</div>

<style>
  :global(body.reference-tryon-body .reference-tryon-main) {
    width: 100%;
    max-width: none;
    min-height: calc(100dvh - 64px);
    margin: 0;
    padding: 52px 0 0;
    overflow: visible;
  }
  :global(.reference-tryon-body) {
    --rt-bg: #f3f5f8;
    --rt-surface: #ffffff;
    --rt-surface-2: #eef1f5;
    --rt-panel: #f9fafb;
    --rt-border: #d7dde5;
    --rt-border-strong: #b9c2cf;
    --rt-text: #18202c;
    --rt-muted: #667085;
    --rt-accent: #d84e64;
    --rt-accent-strong: #bd354e;
    --rt-accent-soft: #fff0f3;
    --rt-success: #16866f;
    background: var(--rt-bg);
  }
  :global([data-theme="dark"] .reference-tryon-body) {
    --rt-bg: #0d141c;
    --rt-surface: #151e28;
    --rt-surface-2: #1b2531;
    --rt-panel: #111a23;
    --rt-border: #2d3845;
    --rt-border-strong: #465363;
    --rt-text: #f4f7fb;
    --rt-muted: #a8b1bd;
    --rt-accent: #ff6b78;
    --rt-accent-strong: #ff7f8b;
    --rt-accent-soft: #321d26;
    --rt-success: #62d0b6;
  }
  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme="light"]) .reference-tryon-body) {
      --rt-bg: #0d141c;
      --rt-surface: #151e28;
      --rt-surface-2: #1b2531;
      --rt-panel: #111a23;
      --rt-border: #2d3845;
      --rt-border-strong: #465363;
      --rt-text: #f4f7fb;
      --rt-muted: #a8b1bd;
      --rt-accent: #ff6b78;
      --rt-accent-strong: #ff7f8b;
      --rt-accent-soft: #321d26;
      --rt-success: #62d0b6;
    }
  }
  .rt-workspace-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 64px;
    padding: 10px clamp(16px, 2vw, 28px);
    border-bottom: 1px solid var(--rt-border);
    background: color-mix(in srgb, var(--rt-surface) 92%, transparent);
  }
  .rt-workspace-head h1,
  .rt-workspace-head p {
    margin: 0;
  }
  .rt-workspace-head h1 {
    color: var(--rt-text);
    font-size: clamp(1.15rem, 1.8vw, 1.45rem);
    line-height: 1.2;
  }
  .rt-workspace-head p {
    margin-bottom: 2px;
    color: var(--rt-accent);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .rt-workspace-meta {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .rt-meta-item,
  .rt-history-trigger {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0 12px;
    border: 1px solid var(--rt-border);
    border-radius: 10px;
    background: var(--rt-surface);
    color: var(--rt-muted);
    font: inherit;
    font-size: 0.82rem;
    white-space: nowrap;
  }
  .rt-history-trigger {
    color: var(--rt-text);
    cursor: pointer;
    font-weight: 750;
  }
  .rt-meta-item svg,
  .rt-history-trigger svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .reference-workspace-grid {
    min-height: calc(100dvh - 136px);
    display: grid;
    grid-template-columns: 76px minmax(250px, 310px) minmax(480px, 1fr) minmax(
        300px,
        360px
      );
    gap: 16px;
    padding: 16px;
  }
  .reference-workflow {
    display: contents;
  }
  .rt-stepper {
    grid-column: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 78px 0 24px;
  }
  .rt-stepper-node {
    display: grid;
    justify-items: center;
    gap: 8px;
    color: var(--rt-muted);
    text-align: center;
  }
  .rt-stepper-dot {
    width: 40px;
    height: 40px;
    display: grid;
    place-items: center;
    border: 2px solid var(--rt-border-strong);
    border-radius: 50%;
    background: var(--rt-bg);
    color: var(--rt-muted);
    font-weight: 800;
  }
  .rt-stepper-label {
    max-width: 70px;
    font-size: 0.78rem;
    line-height: 1.3;
  }
  .rt-stepper-node--active .rt-stepper-dot,
  .rt-stepper-node--done .rt-stepper-dot {
    border-color: var(--rt-accent);
    background: var(--rt-accent);
    color: #fff;
  }
  .rt-stepper-node--active .rt-stepper-label {
    color: var(--rt-accent);
    font-weight: 800;
  }
  .rt-stepper-line {
    width: 2px;
    height: 112px;
    display: block;
    margin: 8px 0;
    background: var(--rt-border);
    overflow: hidden;
  }
  .rt-stepper-line-fill {
    width: 100%;
    height: 0;
    display: block;
    background: var(--rt-accent);
    transition: height 200ms ease;
  }
  .rt-stepper-line--active .rt-stepper-line-fill {
    height: 100%;
  }
  .rt-source-panel {
    grid-column: 2;
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-width: 0;
  }
  .rt-source-block,
  .rt-preview-panel,
  .reference-result,
  .reference-state,
  .reference-gate {
    border: 1px solid var(--rt-border);
    border-radius: 14px;
    background: var(--rt-surface);
    box-shadow: 0 14px 34px color-mix(in srgb, #101828 7%, transparent);
  }
  .rt-source-block {
    display: grid;
    gap: 10px;
    padding: 14px;
  }
  .rt-source-heading {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
  }
  .rt-source-heading h2,
  .rt-source-heading p {
    margin: 0;
  }
  .rt-source-heading h2 {
    color: var(--rt-text);
    font-size: 0.98rem;
  }
  .rt-source-heading p {
    margin-top: 3px;
    color: var(--rt-muted);
    font-size: 0.72rem;
    line-height: 1.4;
  }
  .rt-source-heading > span {
    color: var(--rt-success);
    font-size: 0.72rem;
    font-weight: 800;
  }
  .reference-dropzone {
    position: relative;
    min-height: 136px;
    display: grid;
    place-items: center;
    overflow: hidden;
    border: 1px dashed var(--rt-border-strong);
    border-radius: 10px;
    background: var(--rt-panel);
    cursor: pointer;
  }
  .reference-dropzone:focus-within {
    border-color: var(--rt-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--rt-accent) 22%, transparent);
  }
  .reference-dropzone input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
  }
  .reference-dropzone img {
    width: 100%;
    height: 100%;
    min-height: 136px;
    max-height: 190px;
    display: block;
    object-fit: cover;
  }
  .reference-dropzone img:not([hidden]) + .rt-upload-placeholder {
    display: none;
  }
  .rt-upload-placeholder {
    display: grid;
    justify-items: center;
    gap: 5px;
    padding: 16px;
    color: var(--rt-muted);
    text-align: center;
  }
  .rt-upload-placeholder svg {
    width: 26px;
    height: 26px;
    fill: none;
    stroke: var(--rt-accent);
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .rt-upload-placeholder b {
    color: var(--rt-text);
    font-size: 0.86rem;
  }
  .rt-upload-placeholder small {
    font-size: 0.68rem;
    line-height: 1.35;
  }
  .reference-name {
    display: grid;
    gap: 5px;
    color: var(--rt-muted);
    font-size: 0.72rem;
  }
  .reference-name input {
    min-height: 42px;
    padding: 0 10px;
    border: 1px solid var(--rt-border);
    border-radius: 8px;
    background: var(--rt-panel);
    color: var(--rt-text);
    font: inherit;
    font-size: 0.82rem;
  }
  .reference-check {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    color: var(--rt-muted);
    font-size: 0.7rem;
    line-height: 1.4;
  }
  .reference-check input {
    width: 18px;
    height: 18px;
    flex: 0 0 auto;
    accent-color: var(--rt-accent);
  }
  [data-error] {
    margin: 0;
    color: #d92d20;
    font-size: 0.72rem;
  }
  .saved-reference-block {
    border-top: 1px solid var(--rt-border);
    padding-top: 8px;
  }
  .saved-reference-block summary {
    min-height: 36px;
    display: flex;
    align-items: center;
    color: var(--rt-text);
    cursor: pointer;
    font-size: 0.78rem;
    font-weight: 750;
  }
  .saved-reference-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
  }
  .saved-reference-list > p,
  .saved-reference-status {
    grid-column: 1 / -1;
    margin: 0;
    color: var(--rt-muted);
    font-size: 0.72rem;
  }
  .rt-preview-panel {
    grid-column: 3;
    min-width: 0;
    display: grid;
    grid-template-rows: auto minmax(360px, 1fr) auto;
    overflow: hidden;
  }
  .rt-preview-panel > header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 18px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--rt-border);
  }
  .rt-preview-panel h2,
  .rt-preview-panel p {
    margin: 0;
  }
  .rt-preview-panel h2 {
    color: var(--rt-text);
    font-size: 1rem;
  }
  .rt-preview-panel header p {
    max-width: 58ch;
    margin-top: 3px;
    color: var(--rt-muted);
    font-size: 0.72rem;
    line-height: 1.4;
  }
  .rt-preview-panel header > span {
    color: var(--rt-success);
    font-size: 0.72rem;
    font-weight: 800;
    white-space: nowrap;
  }
  .rt-preview-stage {
    position: relative;
    min-height: 360px;
    display: grid;
    place-items: center;
    overflow: hidden;
    background:
      linear-gradient(var(--rt-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--rt-border) 1px, transparent 1px),
      var(--rt-panel);
    background-size: 48px 48px;
  }
  .rt-preview-stage > img {
    width: 100%;
    height: 100%;
    max-height: calc(100dvh - 290px);
    display: block;
    object-fit: contain;
  }
  .rt-preview-empty {
    max-width: 360px;
    display: grid;
    justify-items: center;
    gap: 8px;
    padding: 24px;
    color: var(--rt-muted);
    text-align: center;
  }
  .rt-preview-empty svg {
    width: 46px;
    height: 46px;
    fill: none;
    stroke: var(--rt-border-strong);
    stroke-width: 1.4;
  }
  .rt-preview-empty strong {
    color: var(--rt-text);
  }
  .rt-preview-empty p {
    line-height: 1.5;
  }
  .reference-submit {
    display: grid;
    grid-template-columns: 1fr minmax(180px, 34%);
    align-items: center;
    gap: 14px;
