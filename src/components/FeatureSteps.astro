---
const steps = [
  {
    title: 'Upload a Selfie',
    description: 'Take a front-facing, bare-face photo. It\'s used only for generating your personalized plan — deletable anytime.',
  },
  {
    title: 'See What Suits You',
    description: 'AI analyzes your skin tone and facial features, then recommends the best matching looks with clear reasoning.',
  },
  {
    title: 'Get Tutorials & Product Picks',
    description: 'Every look comes with step-by-step instructions and real product recommendations so you can actually do it.',
  },
];
---

<section class="section section-soft">
  <div class="container">
    <div class="section-copy">
      <span class="eyebrow">How It Works</span>
      <h2>Three steps to your perfect look — and how to create it.</h2>
      <p>Upload a selfie → Get your AI diagnosis and looks → Follow the tutorial and shop the kit.</p>
    </div>

    <div class="grid-cards grid-cards-3">
      {steps.map((step, index) => (
        <article class="card step-card">
          <span class="scenario-index">0{index + 1}</span>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
