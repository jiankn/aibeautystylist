---
import { getLocalizedAppHref, resolveLocaleRoute } from "../i18n/routing";
import type { SupportedLocale } from "../lib/i18n";

const currentPathname = Astro.originPathname || Astro.url.pathname;
const currentRoute =
  Astro.locals.localeRoute ?? resolveLocaleRoute(currentPathname);
const localizeAppHref = (href: string) =>
  getLocalizedAppHref(href, currentRoute.language.slug);
const locale = currentRoute.language.locale;
const taskRoutes = {
  discover: localizeAppHref("/discover"),
  diagnosis: localizeAppHref("/diagnosis"),
  history: localizeAppHref("/history"),
  resultBase: localizeAppHref("/result"),
  shareBase: localizeAppHref("/share"),
  tryonFree: localizeAppHref("/tryon"),
};

type BackgroundTaskCopy = {
  collapse: string;
  dismiss: string;
  open: string;
  runningState: string;
  doneState: string;
  failedState: string;
  qualityFailedState?: string;
  tryonTitle: string;
  diagnosisTitle: string;
  tryonDone: string;
  diagnosisDone: string;
  tryonFailed: string;
  diagnosisFailed: string;
  viewProgress: string;
  viewResult: string;
  viewReport: string;
  queued: string;
  validating: string;
  tryonDiagnosis: string;
  tryonImage: string;
  diagnosisDiagnosis: string;
  diagnosisImage: string;
  failed: string;
  qualityFailed?: string;
};

