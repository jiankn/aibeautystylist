---

<aside
  class="background-task-tray"
  data-background-task-tray
  aria-live="polite"
  aria-atomic="true"
  hidden
>
  <button
    class="background-task-bubble"
    type="button"
    data-background-task-bubble
    hidden
  >
    <span class="background-task-bubble-mark" aria-hidden="true">
      <img
        src="/images/logo-ui.webp"
        alt=""
        width="30"
        height="30"
        decoding="async"
      />
    </span>
    <span data-background-task-bubble-text>1</span>
  </button>
  <section class="background-task-card" data-background-task-card>
    <div class="background-task-mark" aria-hidden="true">
      <img
        src="/images/logo-ui.webp"
        alt=""
        width="44"
        height="44"
        decoding="async"
      />
    </div>
    <div class="background-task-content">
      <div class="background-task-head">
        <strong data-background-task-title></strong>
        <span data-background-task-state></span>
      </div>
      <p data-background-task-stage></p>
      <div class="background-task-meter" aria-hidden="true">
        <i data-background-task-progress></i>
      </div>
      <div class="background-task-actions">
        <button type="button" data-background-task-collapse></button>
        <a href={taskRoutes.history} data-background-task-primary></a>
      </div>
    </div>
  </section>
</aside>

<script is:inline define:vars={{ copy, taskRoutes }}>
  (() => {
    const tray = document.querySelector("[data-background-task-tray]");
    if (!tray) return;

    const card = tray.querySelector("[data-background-task-card]");
    const bubble = tray.querySelector("[data-background-task-bubble]");
    const bubbleText = tray.querySelector("[data-background-task-bubble-text]");
    const title = tray.querySelector("[data-background-task-title]");
    const state = tray.querySelector("[data-background-task-state]");
    const stage = tray.querySelector("[data-background-task-stage]");
    const progress = tray.querySelector("[data-background-task-progress]");
    const collapse = tray.querySelector("[data-background-task-collapse]");
    const primary = tray.querySelector("[data-background-task-primary]");

    const storageKey = "abs:background-tasks:v1";
    const collapsedKey = "abs:background-tasks:collapsed";
    const runningStatuses = new Set([
      "created",
      "upload_validating",
      "diagnosis_running",
      "image_running",
      "running",
    ]);
    const failedStatuses = new Set(["failed", "cancelled", "timed_out"]);
    let tasks = loadTasks();
    let collapsed = localStorage.getItem(collapsedKey) === "true";
    let pollTimer;

    function loadTasks() {
      try {
        const parsed = JSON.parse(localStorage.getItem(storageKey) || "[]");
        const cutoff = Date.now() - 24 * 60 * 60 * 1000;
        return Array.isArray(parsed)
          ? parsed.filter((task) => Number(task.updatedAt || 0) > cutoff)
          : [];
      } catch {
        return [];
      }
    }

    function saveTasks() {
      const persisted = tasks
        .filter((task) => task.persist !== false)
        .slice(0, 4);
      try {
        localStorage.setItem(storageKey, JSON.stringify(persisted));
      } catch {
        /* ignore private storage failures */
      }
    }

    function normalizeTask(task) {
      const now = Date.now();
      const type = task.type === "diagnosis" ? "diagnosis" : "tryon";
      const href =
        task.href ||
        (type === "diagnosis" ? taskRoutes.diagnosis : taskRoutes.tryonFree);
      const fallbackResultHref =
        type === "diagnosis"
          ? taskRoutes.diagnosis
          : task.id || task.jobId
            ? `${taskRoutes.resultBase}/${encodeURIComponent(task.id || task.jobId)}`
            : taskRoutes.history;
      const resultHref = task.resultHref || fallbackResultHref;
      return {
        id: String(task.id || task.jobId || crypto.randomUUID()),
        type,
        status: task.status || "running",
        errorCode: task.errorCode || "",
        title:
          task.title ||
          (type === "diagnosis" ? copy.diagnosisTitle : copy.tryonTitle),
        stage: task.stage || "",
        progress: Number.isFinite(Number(task.progress))
          ? Math.max(0, Math.min(100, Number(task.progress)))
          : 8,
        href,
        resultHref,
        persist: task.persist !== false,
        notified: Boolean(task.notified),
        createdAt: task.createdAt || now,
        updatedAt: now,
      };
    }

    function statusToProgress(status) {
      if (status === "created") return 34;
      if (status === "upload_validating") return 46;
      if (status === "diagnosis_running") return 68;
      if (status === "image_running") return 88;
      if (status === "succeeded") return 100;
      if (failedStatuses.has(status)) return 0;
      return 24;
    }

    function statusToStage(task, status) {
      if (status === "created") return copy.queued;
      if (status === "upload_validating") return copy.validating;
      if (status === "diagnosis_running") {
        return task.type === "diagnosis"
          ? copy.diagnosisDiagnosis
          : copy.tryonDiagnosis;
      }
      if (status === "image_running") {
        return task.type === "diagnosis"
          ? copy.diagnosisImage
          : copy.tryonImage;
      }
      if (status === "succeeded") {
        return task.type === "diagnosis" ? copy.diagnosisDone : copy.tryonDone;
      }
      if (
        failedStatuses.has(status) &&
        task.errorCode === "MAKEUP_TRANSFER_QUALITY_FAILED"
      ) {
        return copy.qualityFailed || copy.failed;
      }
      if (failedStatuses.has(status)) return copy.failed;
      return task.stage || copy.queued;
    }

    function mergeTask(nextTask) {
      const normalized = normalizeTask(nextTask);
      const index = tasks.findIndex((task) => task.id === normalized.id);
      if (index >= 0) {
        tasks[index] = {
          ...tasks[index],
          ...normalized,
          notified: normalized.notified || tasks[index].notified,
          createdAt: tasks[index].createdAt || normalized.createdAt,
        };
      } else {
        tasks.unshift(normalized);
      }
      tasks.sort((a, b) => Number(b.updatedAt) - Number(a.updatedAt));
      saveTasks();
      render();
      ensurePolling();
      return normalized;
    }

    function removeTask(id) {
      tasks = tasks.filter((task) => task.id !== id);
      saveTasks();
      render();
      ensurePolling();
    }

    function getActiveTask() {
      return (
        tasks.find((task) => runningStatuses.has(task.status)) ||
        tasks[0] ||
        null
      );
    }

    function render() {
      const active = getActiveTask();
      if (!active) {
        tray.hidden = true;
        return;
      }

      const runningCount = tasks.filter((task) =>
        runningStatuses.has(task.status),
      ).length;
      const isDone = active.status === "succeeded";
      const isFailed = failedStatuses.has(active.status);
      const actionHref = isDone ? active.resultHref : active.href;

      tray.hidden = false;
      tray.dataset.state = isDone ? "success" : isFailed ? "error" : "running";
      if (title) {
        title.textContent = isDone
          ? active.type === "diagnosis"
            ? copy.diagnosisDone
            : copy.tryonDone
          : isFailed
            ? active.type === "diagnosis"
              ? copy.diagnosisFailed
              : copy.tryonFailed
            : active.title;
      }
      if (state) {
        state.textContent = isDone
          ? copy.doneState
          : isFailed
            ? active.errorCode === "MAKEUP_TRANSFER_QUALITY_FAILED"
              ? copy.qualityFailedState || copy.failedState
              : copy.failedState
            : copy.runningState;
      }
      if (stage)
        stage.textContent =
          active.stage || statusToStage(active, active.status);
      if (progress) progress.style.width = `${active.progress || 0}%`;
      if (collapse) {
        collapse.textContent =
          isDone || isFailed ? copy.dismiss : copy.collapse;
      }
      if (primary) {
        primary.href = actionHref;
        primary.textContent = isDone
          ? active.type === "diagnosis"
            ? copy.viewReport
            : copy.viewResult
          : copy.viewProgress;
      }
      if (bubbleText) {
        bubbleText.textContent =
          runningCount > 1
            ? `${runningCount}`
            : isDone
              ? copy.doneState
              : copy.open;
      }
      if (card) card.hidden = collapsed;
      if (bubble) bubble.hidden = !collapsed;
    }

    async function pollTask(task) {
      try {
        const response = await fetch(
          `/api/tryon-jobs/${encodeURIComponent(task.id)}`,
        );
        const payload = await response.json().catch(() => null);
        if (!response.ok || !payload?.ok || !payload.data) return;
        const job = payload.data;
        const taskWithError = { ...task, errorCode: job.errorCode || "" };
        const next = {
          ...taskWithError,
          status: job.status,
          progress: statusToProgress(job.status),
          stage: statusToStage(taskWithError, job.status),
          resultHref:
            task.type === "diagnosis"
              ? taskRoutes.diagnosis
              : `${taskRoutes.resultBase}/${encodeURIComponent(job.id)}`,
        };
        const wasRunning = runningStatuses.has(task.status);
        mergeTask(next);
        if (wasRunning && job.status === "succeeded" && !task.notified) {
          const message =
            task.type === "diagnosis" ? copy.diagnosisDone : copy.tryonDone;
          window.showToast?.(message);
          mergeTask({ ...next, notified: true });
        }
      } catch {
        /* network hiccups should not remove the task */
      }
    }

    function ensurePolling() {
      window.clearInterval(pollTimer);
      const pollable = tasks.filter((task) => runningStatuses.has(task.status));
      if (!pollable.length) return;
      pollTimer = window.setInterval(() => {
        tasks
          .filter((task) => runningStatuses.has(task.status))
          .forEach((task) => pollTask(task));
      }, 2500);
    }

    collapse?.addEventListener("click", () => {
      const active = getActiveTask();
      if (active && !runningStatuses.has(active.status)) {
        removeTask(active.id);
        return;
      }
      collapsed = true;
      localStorage.setItem(collapsedKey, "true");
      render();
    });

    bubble?.addEventListener("click", () => {
      collapsed = false;
      localStorage.setItem(collapsedKey, "false");
      render();
    });

    document.addEventListener("abs:background-task", (event) => {
      const detail = event.detail || {};
      if (detail.action === "remove" && detail.id) {
        removeTask(String(detail.id));
        return;
      }
      if (detail.task) mergeTask(detail.task);
    });

    window.__absBackgroundTasks = {
      upsert: mergeTask,
      remove: removeTask,
      getAll: () => tasks.slice(),
      routes: taskRoutes,
    };

    render();
    ensurePolling();
    tasks
      .filter((task) => runningStatuses.has(task.status))
      .forEach((task) => pollTask(task));
  })();
</script>

