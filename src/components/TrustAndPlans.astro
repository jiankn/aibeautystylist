---
import { t, type Locale } from '../lib/i18n';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
---

<section class="section">
  <div class="container split-grid">
    <div class="card trust-panel">
      <span class="eyebrow">{t('trustPlans.trustEyebrow', locale)}</span>
      <h2>{t('trustPlans.trustHeading', locale)}</h2>
      <ul class="check-list">
        <li>{t('trustPlans.trust1', locale)}</li>
        <li>{t('trustPlans.trust2', locale)}</li>
        <li>{t('trustPlans.trust3', locale)}</li>
      </ul>
    </div>

    <div class="card plans-panel">
      <span class="eyebrow">{t('trustPlans.plansEyebrow', locale)}</span>
      <h2>{t('trustPlans.plansHeading', locale)}</h2>
      <div class="plan-stack">
        <div>
          <strong>{t('trustPlans.freeLabel', locale)}</strong>
          <p>{t('trustPlans.freeCopy', locale)}</p>
        </div>
        <div>
          <strong>{t('trustPlans.proLabel', locale)}</strong>
          <p>{t('trustPlans.proCopy', locale)}</p>
        </div>
        <div>
          <strong>{t('trustPlans.premiumLabel', locale)}</strong>
          <p>{t('trustPlans.premiumCopy', locale)}</p>
        </div>
      </div>
    </div>
  </div>
</section>
