---
/**
 * 产品推荐面板：展示平价/标准/进阶三档工具包 + "不建议买什么"。
 */
import type { ProductKit, ProductSku } from "../data/products";
import { t } from "../lib/i18n";

interface Props {
  kits: ProductKit[];
  notRecommended?: ProductSku[];
}

const { kits, notRecommended = [] } = Astro.props;

const tierLabels: Record<string, string> = {
  budget: t("productRecommend", "tierBudget"),
  standard: t("productRecommend", "tierStandard"),
  premium: t("productRecommend", "tierPremium"),
};

const tierColors: Record<string, string> = {
  budget: "pill-teal",
  standard: "pill-rose",
  premium: "pill-gold",
};

const categoryLabels: Record<string, string> = {
  base: t("productRecommend", "categoryBase"),
  eyes: t("productRecommend", "categoryEyes"),
  brows: t("productRecommend", "categoryBrows"),
  cheeks: t("productRecommend", "categoryCheeks"),
  lips: t("productRecommend", "categoryLips"),
  tools: t("productRecommend", "categoryTools"),
};

const kitTitleLabels: Record<string, string> = {
  "kit-commute-budget": t("productRecommend", "kitCommuteBudget"),
  "kit-commute-standard": t("productRecommend", "kitCommuteStandard"),
};

const productNameLabels: Record<string, string> = {
  p1: t("productRecommend", "productLightCushion"),
  p2: t("productRecommend", "productBrowPencil"),
  p3: t("productRecommend", "productFourColorEyeshadow"),
  p4: t("productRecommend", "productLongwearFoundation"),
  p5: t("productRecommend", "productPrecisionBrowPencil"),
  p6: t("productRecommend", "productMatteEyeshadow"),
  nr1: t("productRecommend", "avoidFullCoverageFoundation"),
  nr2: t("productRecommend", "avoidChunkyGlitterEyeshadow"),
};

const notRecommendedReasonLabels: Record<string, string> = {
  nr1: t("productRecommend", "avoidFullCoverageFoundationReason"),
  nr2: t("productRecommend", "avoidChunkyGlitterEyeshadowReason"),
};
---

<section class="product-recommend-panel">
  <h2 class="panel-title">{t("productRecommend", "title")}</h2>
  <p class="panel-subtitle">
    {t("productRecommend", "subtitle")}
  </p>

  {
    kits.length === 0 ? (
      <p class="muted" style="text-align:center;padding:20px">
        {t("productRecommend", "empty")}
      </p>
    ) : (
      <div class="kit-tabs">
        {kits.map((kit) => (
          <div class="kit-card">
            <div class="kit-header">
              <span class:list={["pill", tierColors[kit.tier] || "pill-teal"]}>
                {tierLabels[kit.tier] || kit.tier}
              </span>
              <span class="kit-price">{kit.totalPriceRange}</span>
            </div>
            <h3>{kitTitleLabels[kit.id] || kit.title}</h3>
            <ul class="kit-products">
              {kit.products.map((product) => (
                <li class="kit-product-item">
                  <span class="kit-product-cat">
                    {categoryLabels[product.category] || product.category}
                  </span>
                  <div>
                    <b>{productNameLabels[product.id] || product.name}</b>
                    <span class="small muted">
                      {product.brand} · {product.priceRange}
                    </span>
                  </div>
                  {product.affiliateUrl ? (
                    <a
                      class="btn btn-sm"
                      href={product.affiliateUrl}
                      target="_blank"
                      rel="noopener"
                    >
                      {t("productRecommend", "view")}
                    </a>
                  ) : (
                    <span class="small muted">
                      {t("productRecommend", "purchaseLinkComing")}
                    </span>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    )
  }

  {
    notRecommended.length > 0 && (
      <div class="not-recommended">
        <h3>{t("productRecommend", "avoidTitle")}</h3>
        <ul>
          {notRecommended.map((item) => (
            <li>
              <b>{productNameLabels[item.id] || item.name}</b>
              {item.notRecommendedReason && (
                <span>
                  :{" "}
                  {notRecommendedReasonLabels[item.id] ||
                    item.notRecommendedReason}
                </span>
              )}
            </li>
          ))}
        </ul>
      </div>
    )
  }
</section>

<style>
  .product-recommend-panel {
    padding: 24px;
  }
  .kit-tabs {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
    margin-top: 20px;
  }
  .kit-card {
    padding: 20px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }
  .kit-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }
  .kit-price {
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--teal);
  }
  .kit-card h3 {
    margin: 0 0 12px;
    font-size: 15px;
  }
  .kit-products {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 10px;
  }
  .kit-product-item {
    display: grid;
    grid-template-columns: 50px 1fr auto;
    gap: 10px;
    align-items: center;
    padding: 8px;
    border: 1px solid var(--line);
    border-radius: 8px;
  }
  .kit-product-cat {
    font-size: 11px;
    font-weight: 700;
    text-align: center;
    color: var(--muted);
  }
  .kit-product-item b {
    display: block;
    font-size: 13px;
  }
  .btn-sm {
    font-size: 0.8rem;
    padding: 4px 10px;
    min-height: 32px;
  }
  .not-recommended {
    margin-top: 20px;
    padding: 16px;
    border: 1px solid var(--rose-soft);
    border-radius: var(--radius);
    background: var(--rose-soft);
  }
  .not-recommended h3 {
    margin: 0 0 10px;
    font-size: 15px;
    color: var(--rose);
  }
  .not-recommended ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .not-recommended li {
    padding: 6px 0;
    font-size: 13px;
    color: var(--muted);
  }
  .not-recommended li b {
    color: var(--text);
  }
</style>
