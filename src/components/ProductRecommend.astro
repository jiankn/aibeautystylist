---
/**
 * 产品推荐面板：展示平价/标准/进阶三档工具包 + "不建议买什么"。
 */
import type { ProductKit, ProductSku } from "../data/products";

interface Props {
  kits: ProductKit[];
  notRecommended?: ProductSku[];
}

const { kits, notRecommended = [] } = Astro.props;

const tierLabels: Record<string, string> = {
  budget: "平价参考",
  standard: "标准参考",
  premium: "进阶参考",
};

const tierColors: Record<string, string> = {
  budget: "pill-teal",
  standard: "pill-rose",
  premium: "pill-gold",
};

const categoryLabels: Record<string, string> = {
  base: "底妆",
  eyes: "眼妆",
  brows: "眉部",
  cheeks: "腮红",
  lips: "唇妆",
  tools: "工具",
};
---

<section class="product-recommend-panel">
  <h2 class="panel-title">产品参考</h2>
  <p class="panel-subtitle">
    根据妆容特点整理的产品类型参考，可按预算选择相近产品
  </p>

  {
    kits.length === 0 ? (
      <p class="muted" style="text-align:center;padding:20px">
        产品参考还在整理中，当前可先按教程里的产品类型准备。
      </p>
    ) : (
      <div class="kit-tabs">
        {kits.map((kit) => (
          <div class="kit-card">
            <div class="kit-header">
              <span class:list={["pill", tierColors[kit.tier] || "pill-teal"]}>
                {tierLabels[kit.tier] || kit.tier}
              </span>
              <span class="kit-price">{kit.totalPriceRange}</span>
            </div>
            <h3>{kit.title}</h3>
            <ul class="kit-products">
              {kit.products.map((product) => (
                <li class="kit-product-item">
                  <span class="kit-product-cat">
                    {categoryLabels[product.category] || product.category}
                  </span>
                  <div>
                    <b>{product.name}</b>
                    <span class="small muted">
                      {product.brand} · {product.priceRange}
                    </span>
                  </div>
                  {product.affiliateUrl ? (
                    <a
                      class="btn btn-sm"
                      href={product.affiliateUrl}
                      target="_blank"
                      rel="noopener"
                    >
                      查看
                    </a>
                  ) : (
                    <span class="small muted">暂未接入</span>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    )
  }

  {
    notRecommended.length > 0 && (
      <div class="not-recommended">
        <h3>当前妆容可先避开的产品</h3>
        <ul>
          {notRecommended.map((item) => (
            <li>
              <b>{item.name}</b>
              {item.notRecommendedReason && (
                <span> — {item.notRecommendedReason}</span>
              )}
            </li>
          ))}
        </ul>
      </div>
    )
  }
</section>

<style>
  .product-recommend-panel {
    padding: 24px;
  }
  .kit-tabs {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
    margin-top: 20px;
  }
  .kit-card {
    padding: 20px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }
  .kit-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }
  .kit-price {
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--teal);
  }
  .kit-card h3 {
    margin: 0 0 12px;
    font-size: 15px;
  }
  .kit-products {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 10px;
  }
  .kit-product-item {
    display: grid;
    grid-template-columns: 50px 1fr auto;
    gap: 10px;
    align-items: center;
    padding: 8px;
    border: 1px solid var(--line);
    border-radius: 8px;
  }
  .kit-product-cat {
    font-size: 11px;
    font-weight: 700;
    text-align: center;
    color: var(--muted);
  }
  .kit-product-item b {
    display: block;
    font-size: 13px;
  }
  .btn-sm {
    font-size: 0.8rem;
    padding: 4px 10px;
    min-height: 32px;
  }
  .not-recommended {
    margin-top: 20px;
    padding: 16px;
    border: 1px solid var(--rose-soft);
    border-radius: var(--radius);
    background: var(--rose-soft);
  }
  .not-recommended h3 {
    margin: 0 0 10px;
    font-size: 15px;
    color: var(--rose);
  }
  .not-recommended ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .not-recommended li {
    padding: 6px 0;
    font-size: 13px;
    color: var(--muted);
  }
  .not-recommended li b {
    color: var(--text);
  }
</style>
