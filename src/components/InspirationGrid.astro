---
import { buildLookTryOnHref, homeInspirationLooks, LOOK_LIBRARY_TARGET_COUNT } from '../data/lookCatalog';

const looks = homeInspirationLooks.map((look, index) => ({
  ...look,
  tryOnHref: `${buildLookTryOnHref(look)}&source=get-inspired&position=${index + 1}`,
  position: index + 1,
}));

const galleryLooks = looks;
---

<section class="section section-soft home-inspiration" id="get-inspired">
  <div class="container">
    <div class="inspiration-head">
      <div class="section-copy inspiration-head-copy">
        <h2>Get Inspired</h2>
        <p>
          Browse a curated edit first. Open the full library when you want all {LOOK_LIBRARY_TARGET_COUNT} looks.
        </p>
      </div>
      <a class="btn btn-secondary inspiration-head-action" href="/discover#look-library">View all looks</a>
    </div>

    <div class="inspiration-grid" aria-label="Makeup inspiration looks">
      {galleryLooks.map((look, index) => (
        <a
          class="look-tile"
          href={look.tryOnHref}
          aria-label={`Try ${look.title}`}
          style={`--look-focus: ${look.focus};`}
          data-analytics-look
          data-analytics-source="get-inspired"
          data-analytics-look-slug={look.slug}
          data-analytics-position={look.position}
        >
          <img src={look.image} alt={look.imageAlt} loading={index < 4 ? 'eager' : 'lazy'} />
          <span class="look-tile-shade" aria-hidden="true"></span>
          <span class="look-tile-caption">
            <span>{look.tone}</span>
            <h3>{look.title}</h3>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .home-inspiration {
    scroll-margin-top: 88px;
    background: linear-gradient(180deg, #fcf8f5 0%, #f7f2ee 100%);
    color: #2a2323;
    padding-block: 76px;
  }

  .home-inspiration .container {
    max-width: 1100px;
  }

  .inspiration-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    max-width: 960px;
    margin: 0 auto 42px;
  }

  .inspiration-head-copy {
    max-width: 620px;
    margin: 0;
  }

  .inspiration-head h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.05;
  }

  .inspiration-head p {
    max-width: 520px;
    margin: 14px 0 0;
    font-size: 0.98rem;
  }

  .inspiration-head-action {
    flex-shrink: 0;
  }

  .inspiration-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    max-width: 960px;
    margin: 0 auto;
  }

  .look-tile {
    position: relative;
    display: block;
    overflow: hidden;
    aspect-ratio: 2 / 3;
    border-radius: 8px;
    color: inherit;
    background: rgba(255, 248, 241, 0.08);
    text-decoration: none;
    transition: transform 0.24s ease, filter 0.24s ease;
  }

  .look-tile img {
    position: relative;
    z-index: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--look-focus, center);
    transform: scale(1.001);
    transition: transform 0.45s ease;
  }

  .look-tile-shade {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg, rgba(20, 14, 14, 0) 38%, rgba(20, 14, 14, 0.72) 100%);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.24s ease;
  }

  .look-tile-caption {
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 14px;
    z-index: 2;
    display: grid;
    gap: 4px;
    color: white;
    opacity: 0;
    pointer-events: none;
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.38);
    transform: translateY(10px);
    transition: opacity 0.24s ease, transform 0.24s ease;
  }

  .look-tile-caption span {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .look-tile-caption h3 {
    margin: 0;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.05rem, 1.45vw, 1.4rem);
    line-height: 1.05;
  }

  .look-tile:hover,
  .look-tile:focus-visible {
    filter: brightness(1.06);
    transform: translateY(-3px);
  }

  .look-tile:hover img,
  .look-tile:focus-visible img {
    transform: scale(1.045);
  }

  .look-tile:hover .look-tile-shade,
  .look-tile:focus-visible .look-tile-shade,
  .look-tile:hover .look-tile-caption,
  .look-tile:focus-visible .look-tile-caption {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 900px) {
    .inspiration-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      max-width: 720px;
    }
  }

  @media (max-width: 640px) {
    .home-inspiration {
      padding-block: 56px;
    }

    .inspiration-head {
      align-items: flex-start;
      flex-direction: column;
      gap: 18px;
    }

    .inspiration-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }
  }
</style>
