---
import BrandWordmark from "./BrandWordmark.astro";
import AppIconBadge from "./AppIconBadge.astro";
import {
  buildAccountMobileMenu,
  getAccountCenterCopy,
} from "../data/accountCenterContent";
import { languageConfigs } from "../i18n/config";
import { getLocalizedPathForRoute } from "../i18n/localizedSeoPages";
import {
  addLocalePrefix,
  getLanguageSwitchPathname,
  getLocalizedAppHref,
  getLocalizedPathname,
  resolveLocaleRoute,
} from "../i18n/routing";
import { t, type SupportedLocale } from "../lib/i18n";

const currentPathname = Astro.originPathname || Astro.url.pathname;
const currentRoute =
  Astro.locals.localeRoute ?? resolveLocaleRoute(currentPathname);
const activeLanguageSlug = currentRoute.language.slug;
const localizeHref = (href: string) =>
  getLocalizedPathname(href, currentRoute.language.slug);
const localizeAppHref = (href: string) =>
  getLocalizedAppHref(href, currentRoute.language.slug);
const localizeSeoHref = (href: string) => {
  if (currentRoute.language.slug === "en") return href;
  const localizedPath = getLocalizedPathForRoute(
    "en",
    href,
    currentRoute.language.slug,
  );
  return localizedPath
    ? addLocalePrefix(localizedPath, currentRoute.language.slug)
    : href;
};
const appRoutePathnames = new Set([
  "/tryon-free",
  "/discover",
  "/diagnosis",
  "/pricing",
  "/faq",
  "/history",
  "/login",
  "/account",
  "/dashboard",
  "/support",
  "/tryon-pro",
  "/tryon-premium",
]);
const languageSwitchHref = (languageSlug: string) => {
  if (appRoutePathnames.has(currentRoute.routePathname)) {
    return getLocalizedAppHref(
      `${currentRoute.routePathname}${Astro.url.search}${Astro.url.hash}`,
      languageSlug,
    );
  }
  return getLanguageSwitchPathname(currentPathname, languageSlug);
};

type MobileMenuItem = {
  href?: string;
  label: string;
  icon?: string;
  action?: "logout";
  pendingLabel?: string;
  failedLabel?: string;
};

type MobileMenuSection = {
  label: string;
  items: MobileMenuItem[];
};

interface Props {
  active?:
    | "tryOn"
    | "discover"
    | "blog"
    | "diagnosis"
    | "pricing"
    | "dashboard";
  mark?: string;
  markClass?: string;
  showAuth?: boolean;
  userLabel?: string;
  minimal?: boolean;
  mobileMenuSection?: MobileMenuSection;
  mobileSmartHide?: boolean;
  mobileHidden?: boolean;
}

const {
  active,
  mark = "",
  markClass = "",
  showAuth = true,
  userLabel,
  minimal = false,
  mobileMenuSection,
  mobileSmartHide = false,
  mobileHidden = false,
} = Astro.props as Props;

const links = [
  {
    id: "tryOn",
    href: localizeAppHref("/tryon-free"),
    label: t("navigation", "tryOn"),
  },
  {
    id: "discover",
    href: localizeAppHref("/discover"),
    label: t("navigation", "discover"),
  },
  {
    id: "diagnosis",
    href: localizeAppHref("/diagnosis"),
    label: t("navigation", "diagnosis"),
  },
  {
    id: "pricing",
    href: localizeAppHref("/pricing"),
    label: t("navigation", "pricing"),
  },
] as const;

const guideEntries = [
  {
    href: localizeHref("/blog"),
    label: t("navigation", "blog"),
    description: t("navigation", "guideBeautyNotesDesc"),
  },
  {
    href: localizeSeoHref("/looks/soft-glam"),
    label: t("footer", "makeupStyles"),
    description: t("navigation", "guideStylesDesc"),
  },
  {
    href: localizeSeoHref("/scenarios/office"),
    label: t("footer", "scenarios"),
    description: t("navigation", "guideScenariosDesc"),
  },
  {
    href: localizeSeoHref("/for/hooded-eyes"),
    label: t("footer", "featureGuides"),
    description: t("navigation", "guideFeaturesDesc"),
  },
  {
    href: localizeSeoHref("/guides/beginner-tutorial"),
    label: t("footer", "beginnerGuide"),
    description: t("navigation", "guideBeginnerDesc"),
  },
  {
    href: localizeSeoHref("/guides/makeup-essentials"),
    label: t("footer", "makeupEssentials"),
    description: t("navigation", "guideEssentialsDesc"),
  },
] as const;

const featuredGuide = {
  href: localizeHref("/blog/ai-tryon-vs-beauty-filters"),
  image: "/images/article-ai-tryon-comparison.webp",
  title: t("navigation", "guideFeaturedTitle"),
};
const mobileGuidesSummary = [
  t("footer", "makeupStyles"),
  t("footer", "scenarios"),
  t("footer", "featureGuides"),
].join(" / ");

const authEntryHref = localizeAppHref("/login?mode=register");
const authAccountHref = localizeAppHref("/dashboard");
const mobileAccountHref = localizeAppHref("/account");
const authEntryLabel = t("navigation", "login");
const authEntryShortLabel = t("navigation", "loginShort");
const mobileDiagnosisHref = localizeAppHref("/diagnosis");
const mobilePricingHref = localizeAppHref("/pricing");
const mobileFaqHref = localizeAppHref("/faq");
const mobileHistoryHref = localizeAppHref("/history");
const mobileWorkspaceHref = localizeAppHref("/tryon-free");
const mobileDashboardHref = localizeAppHref("/dashboard");
const accountMenuCopy = getAccountCenterCopy(
  currentRoute.language.locale as SupportedLocale,
);

const languageOptions = languageConfigs
  .filter((language) => language.includeInLanguageSwitcher)
  .map((language) => ({
    ...language,
    active: language.slug === activeLanguageSlug,
    href: languageSwitchHref(language.slug),
  }));

const defaultMobileMenuSection = Astro.locals.isLoggedIn
  ? buildAccountMobileMenu(
      accountMenuCopy,
      {
        account: mobileAccountHref,
        dashboard: mobileDashboardHref,
        diagnosis: mobileDiagnosisHref,
        faq: mobileFaqHref,
        history: mobileHistoryHref,
        home: localizeHref("/"),
        pricing: mobilePricingHref,
        workspace: mobileWorkspaceHref,
      },
      "workspace",
    )
  : {
      label: accountMenuCopy.menuLabel,
      items: [
        {
          href: mobileDiagnosisHref,
          icon: "diagnosis",
          label: t("navigation", "diagnosis"),
        },
        {
          href: mobilePricingHref,
          icon: "membership",
          label: accountMenuCopy.memberCenter,
        },
        {
          href: mobileFaqHref,
          icon: "help",
          label: accountMenuCopy.helpCenter,
        },
      ],
    };
const baseMobileMenuSection = mobileMenuSection ?? defaultMobileMenuSection;
const hasDiagnosisMobileItem = baseMobileMenuSection.items.some(
  (item) => item.href === mobileDiagnosisHref,
);
const resolvedMobileMenuSection = {
  ...baseMobileMenuSection,
  items: hasDiagnosisMobileItem
    ? baseMobileMenuSection.items
    : [
        {
          href: mobileDiagnosisHref,
          icon: "diagnosis",
          label: t("navigation", "diagnosis"),
        },
        ...baseMobileMenuSection.items,
      ],
};
---

<header
  class:list={[
    "site-header",
    {
      "site-header-minimal": minimal,
      "site-header-smart": mobileSmartHide,
      "site-header-mobile-hidden": mobileHidden,
    },
  ]}
  data-smart-hide={mobileSmartHide ? "" : undefined}
>
  <nav class="site-nav shell" aria-label={t("navigation", "mainNav")}>
    <a class="brand" href={localizeHref("/")} aria-label={t("brand", "name")}>
      {
        mark ? (
          <span
            class:list={["brand-mark", markClass, "brand-mark-custom"]}
            aria-hidden="true"
          >
            <span class="brand-symbol">{mark}</span>
          </span>
        ) : (
          <img
            class="brand-logo-img"
            src="/images/logo-ui.webp"
            alt=""
            aria-hidden="true"
          />
        )
      }
      <BrandWordmark variant="header" />
    </a>
    {
      !minimal && (
        <>
          <div class="nav-links">
            {links.slice(0, 2).map((link) => (
              <a class:list={{ active: active === link.id }} href={link.href}>
                {link.label}
              </a>
            ))}
            <details class="guides-menu" data-guides-menu>
              <summary class:list={{ active: active === "blog" }}>
                <span>{t("navigation", "guides")}</span>
                <span class="guides-chevron" aria-hidden="true" />
              </summary>
              <div class="guides-mega">
                <section class="guides-directory">
                  <p class="guides-eyebrow">
                    {t("navigation", "guideMenuEyebrow")}
                  </p>
                  <nav
                    class="guides-entry-grid"
                    aria-label={t("navigation", "guideMenuEyebrow")}
                  >
                    {guideEntries.map((entry) => (
                      <a class="guide-entry" href={entry.href}>
                        <strong>{entry.label}</strong>
                        <span>{entry.description}</span>
                      </a>
                    ))}
                  </nav>
                </section>
                <aside class="guides-feature">
                  <p class="guides-eyebrow">
                    {t("navigation", "guideFeatured")}
                  </p>
                  <a class="guide-feature-link" href={featuredGuide.href}>
                    <img
                      src={featuredGuide.image}
                      alt=""
                      width="640"
                      height="360"
                      loading="eager"
                    />
                    <strong>{featuredGuide.title}</strong>
                    <span>
                      {t("navigation", "guideFeaturedAction")}
                      <i aria-hidden="true">→</i>
                    </span>
                  </a>
                </aside>
              </div>
            </details>
            {links.slice(2).map((link) => (
              <a class:list={{ active: active === link.id }} href={link.href}>
                {link.label}
              </a>
            ))}
          </div>
          <button
            class="mobile-menu-toggle keep-mobile"
            type="button"
            data-mobile-toggle
            aria-label={t("navigation", "openMenu")}
            aria-expanded="false"
            aria-controls="mobile-nav"
          >
            <span class="hamburger-icon" aria-hidden="true" />
          </button>
        </>
      )
    }
    <div class="nav-actions">
      <button
        class="btn nav-control keep-mobile"
        id="theme-toggle"
        type="button"
        aria-label={t("navigation", "toggleTheme")}
        title={t("navigation", "toggleTheme")}
        data-dark-label={t("navigation", "switchToDark")}
        data-light-label={t("navigation", "switchToLight")}
      >
        <span class="nav-control-icon theme-icons" aria-hidden="true">
          <svg
            class="theme-icon theme-icon-moon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.1"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
          </svg>
          <svg
            class="theme-icon theme-icon-sun"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.1"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2"></path>
            <path d="M12 20v2"></path>
            <path d="m4.93 4.93 1.42 1.42"></path>
            <path d="m17.66 17.66 1.41 1.41"></path>
            <path d="M2 12h2"></path>
            <path d="M20 12h2"></path>
            <path d="m6.34 17.66-1.41 1.41"></path>
            <path d="m19.07 4.93-1.41 1.42"></path>
          </svg>
        </span>
      </button>
      <div class="lang-dropdown" id="lang-dropdown">
        <button
          class="btn nav-control keep-mobile"
          id="lang-toggle"
          type="button"
          aria-label={t("navigation", "language")}
          title={t("navigation", "language")}
          aria-expanded="false"
          aria-haspopup="true"
          aria-controls="lang-menu"
        >
          <svg
            class="nav-control-icon language-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.1"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m5 8 6 6"></path>
            <path d="m4 14 6-6 2-3"></path>
            <path d="M2 5h12"></path>
            <path d="M7 2h1"></path>
            <path d="m22 22-5-10-5 10"></path>
            <path d="M14 18h6"></path>
          </svg>
        </button>
        <ul class="lang-menu" id="lang-menu" role="menu">
          {
            languageOptions.map((language) => (
              <li role="none">
                <button
                  class:list={["lang-option", { active: language.active }]}
                  type="button"
                  data-locale={language.locale}
                  data-href={language.href}
                  role="menuitemradio"
                  aria-checked={language.active}
                >
                  <span>{language.nativeLabel}</span>
                  <svg
                    class="lang-check"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="m20 6-11 11-5-5" />
                  </svg>
                </button>
              </li>
            ))
          }
        </ul>
      </div>
      {
        userLabel ? (
          <span class="avatar">{userLabel}</span>
        ) : showAuth ? (
          <a
            class="btn btn-primary auth-entry-btn keep-mobile"
            href={authEntryHref}
            data-auth-entry
            data-auth-href={authEntryHref}
            data-account-href={authAccountHref}
            data-auth-label={authEntryLabel}
            data-auth-short-label={authEntryShortLabel}
            aria-label={authEntryLabel}
          >
            <svg
              class="auth-entry-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="12" cy="8" r="3.5" />
              <path d="M5.5 20c.8-4 3-6 6.5-6s5.7 2 6.5 6" />
            </svg>
            <span class="auth-entry-label-desktop" aria-hidden="true">
              {authEntryLabel}
            </span>
            <span class="auth-entry-label-mobile" aria-hidden="true">
              {authEntryShortLabel}
            </span>
          </a>
        ) : null
      }
    </div>
  </nav>
</header>
{
  !minimal && (
    <>
      <div
        class="mobile-nav-backdrop"
        data-mobile-backdrop
        aria-hidden="true"
      />
      <div class="mobile-nav-panel" id="mobile-nav" data-mobile-nav>
        <div class="mobile-nav-track">
          <div class="mobile-nav-page mobile-nav-root" data-mobile-root>
            <div class="mobile-root-header">
              <a
                class="mobile-root-brand"
                href={localizeHref("/")}
                aria-label={t("brand", "name")}
              >
                <img
                  src="/images/logo-ui.webp"
                  alt=""
                  width="29"
                  height="29"
                  aria-hidden="true"
                />
                <span class="mobile-root-title">
                  {t("navigation", "mainNav")}
                </span>
              </a>
              <div class="mobile-root-actions">
                <button
                  class="mobile-subnav-close"
                  type="button"
                  data-mobile-root-close
                  aria-label={t("navigation", "closeMenu")}
                >
                  <span aria-hidden="true" />
                </button>
              </div>
            </div>
            {showAuth ? (
              <a
                class="mobile-account-summary"
                href={authEntryHref}
                data-mobile-account-summary
                data-auth-href={authEntryHref}
                data-account-href={mobileAccountHref}
                data-auth-title={authEntryLabel}
                data-auth-note={t("brand", "tagline")}
                data-auth-action={authEntryShortLabel}
                data-plan-label={t("plans", "currentPlan")}
                data-quota-template={accountMenuCopy.memberQuota}
                data-quota-unavailable={accountMenuCopy.quotaUnavailable}
                data-manage-label={accountMenuCopy.profile}
              >
                <span
                  class="mobile-account-summary-avatar"
                  data-mobile-account-summary-avatar
                  aria-hidden="true"
                >
                  AI
                </span>
                <span class="mobile-account-summary-copy">
                  <b data-mobile-account-summary-title>{authEntryLabel}</b>
                  <small data-mobile-account-summary-note>
                    {t("brand", "tagline")}
                  </small>
                </span>
                <span
                  class="mobile-account-summary-action"
                  data-mobile-account-summary-action
                >
                  {authEntryShortLabel}
                </span>
              </a>
            ) : null}
            <section
              class="mobile-app-section mobile-account-section"
              aria-label={resolvedMobileMenuSection.label}
            >
              <button
                class:list={[
                  "mobile-guides-entry-card",
                  { active: active === "blog" },
                ]}
                type="button"
                data-mobile-guides-open
                aria-expanded="false"
                aria-controls="mobile-guides-page"
              >
                <AppIconBadge icon="guides" size="menu" />
                <span>
                  <strong>{t("navigation", "guides")}</strong>
                  <small>{mobileGuidesSummary}</small>
                </span>
                <i aria-hidden="true">→</i>
              </button>
              <p>{resolvedMobileMenuSection.label}</p>
              <div class="mobile-app-links">
                {resolvedMobileMenuSection.items.map((item) =>
                  item.action === "logout" ? (
                    <button
                      class="mobile-app-link mobile-app-link-danger"
                      type="button"
                      data-mobile-logout
                      data-logout-redirect={localizeHref("/")}
                      data-pending-label={item.pendingLabel}
                      data-failed-label={item.failedLabel}
                    >
                      {item.icon && (
                        <AppIconBadge icon={item.icon} size="menu" />
                      )}
                      <b>{item.label}</b>
                    </button>
                  ) : (
                    <a class="mobile-app-link" href={item.href || "#"}>
                      {item.icon && (
                        <AppIconBadge icon={item.icon} size="menu" />
                      )}
                      <b>{item.label}</b>
                    </a>
                  ),
                )}
                <button
                  class="mobile-app-link mobile-theme-link"
                  type="button"
                  data-mobile-theme-toggle
                >
                  <AppIconBadge icon="theme" size="menu" />
                  <b>{t("navigation", "toggleTheme")}</b>
                </button>
              </div>
              <span class="mobile-app-status" data-mobile-logout-status />
            </section>
          </div>
          <div
            class="mobile-nav-page mobile-guides-page"
            id="mobile-guides-page"
            data-mobile-guides-page
            aria-hidden="true"
            inert
          >
            <div class="mobile-subnav-header">
              <button
                class="mobile-subnav-back"
                type="button"
                data-mobile-guides-back
              >
                <span class="mobile-back-chevron" aria-hidden="true" />
                <span>{t("navigation", "back")}</span>
              </button>
              <div class="mobile-root-actions">
                <button
                  class="mobile-subnav-close"
                  type="button"
                  data-mobile-guides-close
                  aria-label={t("navigation", "closeMenu")}
                >
                  <span aria-hidden="true" />
                </button>
              </div>
            </div>
            <p class="mobile-guides-eyebrow">
              {t("navigation", "guideMenuEyebrow")}
            </p>
            <nav
              class="mobile-guide-list"
              aria-label={t("navigation", "guideMenuEyebrow")}
            >
              {guideEntries.map((entry) => (
                <a href={entry.href}>
                  <strong>{entry.label}</strong>
                  <span>{entry.description}</span>
                </a>
              ))}
            </nav>
            <aside class="mobile-guide-feature">
              <p>{t("navigation", "guideFeatured")}</p>
              <a href={featuredGuide.href}>
                <img
                  src={featuredGuide.image}
                  alt=""
                  width="640"
                  height="360"
                  loading="lazy"
                />
                <strong>{featuredGuide.title}</strong>
                <span>
                  {t("navigation", "guideFeaturedAction")}
                  <i aria-hidden="true">→</i>
                </span>
              </a>
            </aside>
          </div>
        </div>
      </div>
    </>
  )
}

<script is:inline>
  (() => {
    const toggle = document.getElementById("lang-toggle");
    const menu = document.getElementById("lang-menu");
    const dropdown = document.getElementById("lang-dropdown");
    if (!toggle || !menu || !dropdown) return;

    const options = [...menu.querySelectorAll(".lang-option")];

    const closeAccountMenus = () => {
      document.querySelectorAll("[data-account-menu].open").forEach((menu) => {
        menu.classList.remove("open");
        menu
          .querySelector("[data-account-menu-trigger]")
          ?.setAttribute("aria-expanded", "false");
      });
    };

    const setOpen = (open, focusOption = false) => {
      if (open) closeAccountMenus();
      dropdown.classList.toggle("open", open);
      toggle.setAttribute("aria-expanded", String(open));
      if (open && focusOption) {
        (menu.querySelector(".lang-option.active") || options[0])?.focus();
      }
    };

    toggle.addEventListener("click", (e) => {
      e.stopPropagation();
      setOpen(!dropdown.classList.contains("open"));
    });

    toggle.addEventListener("keydown", (event) => {
      if (event.key === "ArrowDown" || event.key === "ArrowUp") {
        event.preventDefault();
        setOpen(true, true);
      }
    });

    options.forEach((btn) => {
      btn.addEventListener("click", () => {
        if (btn.classList.contains("active")) {
          setOpen(false);
          toggle.focus();
          return;
        }
        const locale = btn.getAttribute("data-locale");
        const href = btn.getAttribute("data-href") || "/";
        if (locale) {
          document.cookie = `abs_locale=${encodeURIComponent(locale)};path=/;max-age=31536000;SameSite=Lax`;
        }
        const target = new URL(href, window.location.origin);
        target.search = window.location.search;
        target.hash = window.location.hash;
        window.location.assign(target.href);
      });
    });

    menu.addEventListener("keydown", (event) => {
      const currentIndex = options.indexOf(document.activeElement);
      let nextIndex = currentIndex;
      if (event.key === "ArrowDown")
        nextIndex = (currentIndex + 1) % options.length;
      if (event.key === "ArrowUp")
        nextIndex = (currentIndex - 1 + options.length) % options.length;
      if (event.key === "Home") nextIndex = 0;
      if (event.key === "End") nextIndex = options.length - 1;
      if (nextIndex !== currentIndex) {
        event.preventDefault();
        options[nextIndex]?.focus();
      }
      if (event.key === "Escape") {
        event.preventDefault();
        setOpen(false);
        toggle.focus();
      }
    });

    document.addEventListener("click", (e) => {
      if (!dropdown.contains(e.target)) {
        setOpen(false);
      }
    });
  })();
</script>

<script is:inline>
  (() => {
    const details = document.querySelector("[data-guides-menu]");
    if (!details) return;

    details.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => details.removeAttribute("open"));
    });

    document.addEventListener("click", (event) => {
      if (!details.contains(event.target)) details.removeAttribute("open");
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && details.hasAttribute("open")) {
        details.removeAttribute("open");
        details.querySelector("summary")?.focus();
      }
    });
  })();
</script>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(
    "[data-mobile-toggle]",
  );
  const nav = document.querySelector<HTMLElement>("[data-mobile-nav]");
  const backdrop = document.querySelector<HTMLElement>(
    "[data-mobile-backdrop]",
  );
  const openGuides = document.querySelector<HTMLButtonElement>(
    "[data-mobile-guides-open]",
  );
  const backFromGuides = document.querySelector<HTMLButtonElement>(
    "[data-mobile-guides-back]",
  );
  const closeFromGuides = document.querySelector<HTMLButtonElement>(
    "[data-mobile-guides-close]",
  );
  const closeFromRoot = document.querySelector<HTMLButtonElement>(
    "[data-mobile-root-close]",
  );
  const rootPage = document.querySelector<HTMLElement>("[data-mobile-root]");
  const guidesPage = document.querySelector<HTMLElement>(
    "[data-mobile-guides-page]",
  );
  const mobileLogout = document.querySelector<HTMLButtonElement>(
    "[data-mobile-logout]",
  );
  const mobileLogoutStatus = document.querySelector<HTMLElement>(
    "[data-mobile-logout-status]",
  );
  const mobileThemeToggle = document.querySelector<HTMLButtonElement>(
    "[data-mobile-theme-toggle]",
  );

  if (toggle && nav) {
    const mobileToggle = toggle;
    const mobileNav = nav;
    const mobileQuery = window.matchMedia("(max-width: 1100px)");

    function setNavHidden(hidden: boolean) {
      if (hidden) {
        mobileNav.setAttribute("aria-hidden", "true");
        mobileNav.setAttribute("inert", "");
      } else {
        mobileNav.removeAttribute("aria-hidden");
        mobileNav.removeAttribute("inert");
      }
    }

    function setGuidesOpen(open: boolean, focusTarget = true) {
      mobileNav.classList.toggle("guides-open", open);
      openGuides?.setAttribute("aria-expanded", String(open));
      rootPage?.toggleAttribute("inert", open);
      rootPage?.setAttribute("aria-hidden", String(open));
      guidesPage?.toggleAttribute("inert", !open);
      guidesPage?.setAttribute("aria-hidden", String(!open));

      if (focusTarget) {
        if (open) backFromGuides?.focus();
        else openGuides?.focus();
      }
    }

    function openMenu() {
      setGuidesOpen(false, false);
      mobileNav.classList.add("mobile-open");
      setNavHidden(false);
      backdrop?.classList.add("visible");
      mobileToggle.setAttribute("aria-expanded", "true");
      mobileToggle.setAttribute(
        "aria-label",
        window.msg?.("closeMenu") || "Close",
      );
      document.body.style.overflow = "hidden";
    }

    function closeMenu() {
      mobileNav.classList.remove("mobile-open");
      setGuidesOpen(false, false);
      setNavHidden(mobileQuery.matches);
      backdrop?.classList.remove("visible");
      mobileToggle.setAttribute("aria-expanded", "false");
      mobileToggle.setAttribute(
        "aria-label",
        window.msg?.("openMenu") || "Menu",
      );
      document.body.style.overflow = "";
    }

    function isOpen() {
      return mobileNav.classList.contains("mobile-open");
    }

    setNavHidden(mobileQuery.matches);

    mobileToggle.addEventListener("click", () => {
      isOpen() ? closeMenu() : openMenu();
    });

    openGuides?.addEventListener("click", () => setGuidesOpen(true));
    backFromGuides?.addEventListener("click", () => setGuidesOpen(false));
    closeFromRoot?.addEventListener("click", closeMenu);
    closeFromGuides?.addEventListener("click", closeMenu);
    backdrop?.addEventListener("click", closeMenu);

    mobileNav.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    mobileThemeToggle?.addEventListener("click", () => {
      document.getElementById("theme-toggle")?.click();
    });

    mobileLogout?.addEventListener("click", async () => {
      const pendingLabel =
        mobileLogout.dataset.pendingLabel || mobileLogout.textContent || "";
      const failedLabel = mobileLogout.dataset.failedLabel || "";
      mobileLogout.disabled = true;
      if (mobileLogoutStatus) mobileLogoutStatus.textContent = pendingLabel;
      try {
        const response = await fetch("/api/auth/logout", { method: "POST" });
        if (!response.ok) throw new Error("LOGOUT_FAILED");
        window.location.href = mobileLogout.dataset.logoutRedirect || "/";
      } catch {
        mobileLogout.disabled = false;
        if (mobileLogoutStatus) mobileLogoutStatus.textContent = failedLabel;
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key !== "Escape" || !isOpen()) return;
      if (mobileNav.classList.contains("guides-open")) {
        setGuidesOpen(false);
        return;
      }
      closeMenu();
    });

    mobileQuery.addEventListener("change", (event) => {
      if (event.matches) {
        setNavHidden(!isOpen());
      } else {
        if (isOpen()) closeMenu();
        setNavHidden(false);
      }
    });
  }
</script>

<script is:inline>
  (() => {
    const header = document.querySelector("[data-smart-hide]");
    if (!header) return;

    const mobileQuery = window.matchMedia("(max-width: 767px)");
    let lastScrollY = window.scrollY;
    let ticking = false;

    const updateHeader = () => {
      ticking = false;
      if (!mobileQuery.matches || document.body.style.overflow === "hidden") {
        header.classList.remove("site-header-hidden");
        lastScrollY = window.scrollY;
        return;
      }

      const currentScrollY = window.scrollY;
      const shouldHide = currentScrollY > lastScrollY && currentScrollY > 80;
      header.classList.toggle("site-header-hidden", shouldHide);
      lastScrollY = Math.max(currentScrollY, 0);
    };

    window.addEventListener(
      "scroll",
      () => {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(updateHeader);
      },
      { passive: true },
    );
    mobileQuery.addEventListener("change", updateHeader);
    updateHeader();
  })();
</script>

