---
/**
 * UserAvatar — 导航栏用户头像/登录按钮
 * 
 * 使用客户端 JS 调用 /api/auth/me 获取用户状态，
 * 避免服务端渲染时的 Session 读取开销。
 */
import type { Locale } from '../lib/i18n';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const isZh = locale === 'zh-CN';

const copy = isZh
  ? {
      signIn: '登录',
      userMenu: '用户菜单',
      myAccount: '我的账户',
      subscription: '订阅管理',
      privacy: '隐私与数据',
      tryOn: 'AI 试妆',
      membership: '会员',
      signOut: '退出登录',
    }
  : {
      signIn: 'Sign In',
      userMenu: 'User menu',
      myAccount: 'My Account',
      subscription: 'Subscription',
      privacy: 'Privacy & Data',
      tryOn: 'Try On',
      membership: 'Membership',
      signOut: 'Sign Out',
    };

const authHrefs = isZh
  ? {
      dashboard: '/zh/dashboard/',
      subscription: '/zh/dashboard/subscription/',
      privacy: '/zh/dashboard/privacy/',
      tryOn: '/zh/try-on/',
      membership: '/zh/membership/?from=avatar_menu',
    }
  : {
      dashboard: '/dashboard',
      subscription: '/dashboard/subscription',
      privacy: '/dashboard/privacy',
      tryOn: '/try-on',
      membership: '/membership?from=avatar_menu',
    };
---

<div class="user-avatar-wrapper" id="user-avatar-wrapper" data-locale={locale}>
  <!-- 默认显示登录按钮（未加载状态） -->
  <a href="/login" class="auth-login-btn" id="auth-login-btn" title={copy.signIn}>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
      <circle cx="12" cy="7" r="4"></circle>
    </svg>
    <span>{copy.signIn}</span>
  </a>

  <!-- 已登录状态（默认隐藏） -->
  <div class="auth-user-menu" id="auth-user-menu" style="display:none;">
    <button class="avatar-btn" id="avatar-toggle" aria-label={copy.userMenu} aria-expanded="false">
      <img id="avatar-img" src="" alt="" class="avatar-img" />
      <span class="avatar-tier-badge" id="avatar-tier-badge"></span>
    </button>
    <div class="avatar-dropdown" id="avatar-dropdown">
      <div class="dropdown-user-info">
        <p class="dropdown-user-name" id="dropdown-user-name"></p>
        <p class="dropdown-user-email" id="dropdown-user-email"></p>
        <span class="dropdown-tier" id="dropdown-tier"></span>
      </div>
      <hr class="dropdown-divider" />
      <a href={authHrefs.dashboard} class="dropdown-item">📊 {copy.myAccount}</a>
      <a href={authHrefs.subscription} class="dropdown-item">💳 {copy.subscription}</a>
      <a href={authHrefs.privacy} class="dropdown-item">🔒 {copy.privacy}</a>
      <hr class="dropdown-divider" />
      <a href={authHrefs.tryOn} class="dropdown-item">🎨 {copy.tryOn}</a>
      <a href={authHrefs.membership} class="dropdown-item">💎 {copy.membership}</a>
      <hr class="dropdown-divider" />
      <form action="/api/auth/logout" method="POST" class="dropdown-logout">
        <button type="submit" class="dropdown-item logout-btn">{copy.signOut}</button>
      </form>
    </div>
  </div>
</div>

<style>
  .user-avatar-wrapper {
    position: relative;
    margin-left: 0.5rem;
  }

  /* ─── 登录按钮 ─── */
  .auth-login-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 1rem;
    border-radius: 100px;
    background: var(--accent, #b07f86);
    color: #fff;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
  }
  .auth-login-btn:hover {
    background: var(--accent-dark, #9a6b72);
    transform: translateY(-1px);
  }
  .auth-login-btn svg {
    flex-shrink: 0;
  }

  /* ─── 头像按钮 ─── */
  .avatar-btn {
    position: relative;
    display: flex;
    align-items: center;
    background: none;
    border: 2px solid transparent;
    border-radius: 50%;
    padding: 2px;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .avatar-btn:hover,
  .avatar-btn[aria-expanded="true"] {
    border-color: var(--accent, #b07f86);
  }

  .avatar-img {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    object-fit: cover;
  }

  .avatar-tier-badge {
    position: absolute;
    bottom: -2px;
    right: -2px;
    font-size: 0.6rem;
    padding: 1px 4px;
    border-radius: 6px;
    font-weight: 700;
    line-height: 1;
    display: none;
  }
  .avatar-tier-badge[data-tier="pro"] {
    display: block;
    background: linear-gradient(135deg, #ffa94d, #ff6b6b);
    color: #fff;
  }
  .avatar-tier-badge[data-tier="premium"] {
    display: block;
    background: linear-gradient(135deg, #b197fc, #845ef7);
    color: #fff;
  }

  /* ─── 下拉菜单 ─── */
  .avatar-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    width: 240px;
    background: var(--card-bg, #fff);
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12), 0 2px 8px rgba(0, 0, 0, 0.06);
    border: 1px solid var(--border, rgba(0,0,0,0.06));
    overflow: hidden;
    opacity: 0;
    transform: translateY(-8px) scale(0.96);
    pointer-events: none;
    transition: opacity 0.2s, transform 0.2s;
    z-index: 1000;
  }
  .avatar-dropdown.is-open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .dropdown-user-info {
    padding: 1rem;
  }
  .dropdown-user-name {
    font-weight: 600;
    font-size: 0.9rem;
    margin: 0;
    color: var(--text-primary, #1a1a1a);
  }
  .dropdown-user-email {
    font-size: 0.78rem;
    color: var(--text-secondary, #666);
    margin: 2px 0 6px;
  }
  .dropdown-tier {
    font-size: 0.7rem;
    padding: 2px 8px;
    border-radius: 100px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .dropdown-tier[data-tier="free"] {
    background: var(--bg-muted, #f5f0ee);
    color: var(--text-secondary, #666);
  }
  .dropdown-tier[data-tier="pro"] {
    background: linear-gradient(135deg, #fff3e0, #ffe0b2);
    color: #e65100;
  }
  .dropdown-tier[data-tier="premium"] {
    background: linear-gradient(135deg, #ede7f6, #d1c4e9);
    color: #4527a0;
  }

  .dropdown-divider {
    border: none;
    border-top: 1px solid var(--border, rgba(0,0,0,0.06));
    margin: 0;
  }

  .dropdown-item {
    display: block;
    padding: 0.65rem 1rem;
    font-size: 0.85rem;
    color: var(--text-primary, #1a1a1a);
    text-decoration: none;
    transition: background 0.15s;
  }
  .dropdown-item:hover {
    background: var(--bg-muted, #f5f0ee);
  }

  .dropdown-logout {
    margin: 0;
  }
  .logout-btn {
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    color: var(--text-secondary, #888);
  }
  .logout-btn:hover {
    color: #e53935;
    background: #fef2f2;
  }

  /* ─── 移动端适配 ─── */
  @media (max-width: 768px) {
    .auth-login-btn span { display: none; }
    .auth-login-btn { padding: 0.5rem; }
    .avatar-dropdown { right: -20px; }
  }
</style>

<script>
  // 获取用户状态并切换 UI
  async function initAuthUI() {
    try {
      const resp = await fetch('/api/auth/me');
      const data = await resp.json();

      const loginBtn = document.getElementById('auth-login-btn');
      const userMenu = document.getElementById('auth-user-menu');
      const wrapper = document.getElementById('user-avatar-wrapper');
      const isZhPage = wrapper?.dataset.locale === 'zh-CN' || document.documentElement.lang === 'zh-CN' || window.location.pathname.startsWith('/zh/');

      if (data.authenticated && data.user) {
        // 已登录：隐藏登录按钮，显示头像菜单
        if (loginBtn) loginBtn.style.display = 'none';
        if (userMenu) userMenu.style.display = 'block';

        const user = data.user;
        const avatarImg = document.getElementById('avatar-img') as HTMLImageElement;
        if (avatarImg && user.avatarUrl) {
          avatarImg.src = user.avatarUrl;
          avatarImg.alt = user.name || (isZhPage ? '用户头像' : 'User');
        }

        const badge = document.getElementById('avatar-tier-badge');
        if (badge && user.tier !== 'free') {
          badge.setAttribute('data-tier', user.tier);
          badge.textContent = user.tier === 'pro' ? 'PRO' : '★';
        }

        const nameEl = document.getElementById('dropdown-user-name');
        if (nameEl) nameEl.textContent = user.name || (isZhPage ? '用户' : 'User');

        const emailEl = document.getElementById('dropdown-user-email');
        if (emailEl) emailEl.textContent = user.email || '';

        const tierEl = document.getElementById('dropdown-tier');
        if (tierEl) {
          tierEl.setAttribute('data-tier', user.tier);
          tierEl.textContent = user.tier === 'free' ? (isZhPage ? '免费体验版' : 'Free Explorer') :
                               user.tier === 'pro' ? 'Beauty Pass Pro' : 'Premium';
        }

        // 下拉菜单交互
        const toggleBtn = document.getElementById('avatar-toggle');
        const dropdown = document.getElementById('avatar-dropdown');
        toggleBtn?.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = dropdown?.classList.toggle('is-open');
          toggleBtn.setAttribute('aria-expanded', String(!!isOpen));
        });

        // 点击外部关闭
        document.addEventListener('click', () => {
          dropdown?.classList.remove('is-open');
          toggleBtn?.setAttribute('aria-expanded', 'false');
        });
      }
    } catch {
      // Auth 服务不可用，保持默认登录按钮
    }
  }

  initAuthUI();
</script>
