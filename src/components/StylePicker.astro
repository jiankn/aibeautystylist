---
import { homeStyleItems } from '../data/stylePages';

const styles = homeStyleItems.map((style) => ({
  title: style.label,
  image: style.image,
  imageAlt: style.imageAlt,
  tryOnHref: `/try-on?scenario=${style.tryOnScenario}&style=${style.slug}&look=${style.lookSlug}`,
}));
---

<section class="section home-style-picker" id="try-a-style">
  <div class="container">
    <div class="style-picker-header">
      <div class="section-copy style-picker-head">
        <span class="eyebrow">Try a style</span>
        <h2>Choose a style direction and try it on your face.</h2>
        <p>
          Scan the finish first, then tap the style that feels closest to your occasion, features, or mood.
        </p>
      </div>
      <div class="style-picker-nav">
        <button class="style-nav-btn" data-dir="prev" aria-label="Previous styles">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button class="style-nav-btn" data-dir="next" aria-label="Next styles">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg>
        </button>
      </div>
    </div>

    <div class="style-picker-grid">
      {styles.map((style) => (
        <a class="style-card" href={style.tryOnHref} aria-label={`Try ${style.title}`}>
          <span class="style-card-image">
            <img src={style.image} alt={style.imageAlt} loading="lazy" />
          </span>
          <span class="style-card-title">{style.title}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  function initStylePicker() {
    const grid = document.querySelector('.style-picker-grid') as HTMLElement;
    const prevBtn = document.querySelector('.style-nav-btn[data-dir="prev"]') as HTMLButtonElement;
    const nextBtn = document.querySelector('.style-nav-btn[data-dir="next"]') as HTMLButtonElement;
    if (!grid || !prevBtn || !nextBtn) return;

    const getScrollAmount = () => {
      const card = grid.querySelector('.style-card') as HTMLElement;
      if (!card) return 300;
      return (card.offsetWidth + 14) * 3;
    };

    prevBtn.addEventListener('click', () => {
      grid.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
    });
    nextBtn.addEventListener('click', () => {
      grid.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
    });

    const updateButtons = () => {
      prevBtn.disabled = grid.scrollLeft <= 4;
      nextBtn.disabled = grid.scrollLeft + grid.clientWidth >= grid.scrollWidth - 4;
    };
    grid.addEventListener('scroll', updateButtons, { passive: true });
    updateButtons();
  }
  initStylePicker();
</script>

<style>
  .home-style-picker {
    scroll-margin-top: 88px;
  }

  .style-picker-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 28px;
  }

  .style-picker-head {
    max-width: 760px;
    margin-bottom: 0;
  }

  .style-picker-nav {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

  .style-nav-btn {
    display: inline-grid;
    place-items: center;
    width: 28px;
    height: 28px;
    padding: 0;
    border: none;
    border-radius: 0;
    background: none;
    color: var(--text-tertiary);
    cursor: pointer;
    transition: color 0.2s ease, opacity 0.2s ease;
  }

  .style-nav-btn:hover {
    color: var(--text);
  }

  .style-nav-btn:disabled {
    opacity: 0.25;
    cursor: default;
  }

  .style-picker-grid {
    display: flex;
    gap: 14px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .style-picker-grid::-webkit-scrollbar {
    display: none;
  }

  .style-card {
    flex: 0 0 calc((100% - 14px * 5) / 6);
    padding: 0;
    display: grid;
    gap: 8px;
    color: inherit;
    min-width: 0;
    scroll-snap-align: start;
  }

  .style-card-image {
    position: relative;
    display: block;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: var(--radius-sm);
    background: var(--accent-soft);
    box-shadow: 0 14px 34px rgba(62, 39, 39, 0.08);
  }

  .style-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.55s ease;
  }

  .style-card:hover .style-card-image img,
  .style-card:focus-visible .style-card-image img {
    transform: scale(1.05);
  }

  .style-card-title {
    display: block;
    color: var(--text);
    font-size: 0.84rem;
    font-weight: 600;
    line-height: 1.25;
    text-align: center;
  }

  @media (max-width: 900px) {
    .style-card {
      flex: 0 0 calc((100% - 14px * 3) / 4);
    }
  }

  @media (max-width: 640px) {
    .style-picker-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .style-picker-nav {
      align-self: flex-end;
      margin-top: -36px;
    }

    .style-picker-grid {
      margin: 0 -16px;
      padding: 0 16px 8px;
    }

    .style-card {
      flex: 0 0 124px;
    }

    .style-card-title {
      font-size: 0.84rem;
    }
  }
</style>
