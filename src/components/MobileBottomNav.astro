---
import {
  getLocalizedAppHref,
  getLocalizedPathname,
  resolveLocaleRoute,
} from "../i18n/routing";
import { getCurrentLocale } from "../lib/i18n";

type ActiveItem = "home" | "discover" | "tryon" | "history" | "account";

interface Props {
  active: ActiveItem;
}

const { active } = Astro.props as Props;
const locale = getCurrentLocale();
const currentPathname = Astro.originPathname || Astro.url.pathname;
const currentRoute =
  Astro.locals.localeRoute ?? resolveLocaleRoute(currentPathname);
const localizeAppHref = (href: string) =>
  getLocalizedAppHref(href, currentRoute.language.slug);
const localizeHref = (href: string) =>
  getLocalizedPathname(href, currentRoute.language.slug);
const isLoggedIn = Boolean(Astro.locals.isLoggedIn);
const dashboardHref = localizeAppHref("/dashboard");
const accountTarget = isLoggedIn
  ? dashboardHref
  : localizeAppHref(
      `/login?mode=login&next=${encodeURIComponent(dashboardHref)}`,
    );

const copy = {
  en: {
    nav: "Mobile primary navigation",
    home: "Home",
    tryon: "Try On",
    account: "Me",
  },
  "zh-CN": {
    nav: "移动端主导航",
    home: "首页",
    tryon: "试妆",
    account: "我的",
  },
  "zh-TW": {
    nav: "行動端主導覽",
    home: "首頁",
    tryon: "試妝",
    account: "我的",
  },
  "de-DE": {
    nav: "Primäre Mobilnavigation",
    home: "Start",
    tryon: "Testen",
    account: "Ich",
  },
  "fr-FR": {
    nav: "Navigation mobile principale",
    home: "Accueil",
    tryon: "Essayer",
    account: "Moi",
  },
  "ja-JP": {
    nav: "モバイル主ナビゲーション",
    home: "ホーム",
    tryon: "試す",
    account: "マイ",
  },
  "ko-KR": {
    nav: "모바일 기본 탐색",
    home: "홈",
    tryon: "시착",
    account: "내 정보",
  },
  "es-ES": {
    nav: "Navegación móvil principal",
    home: "Inicio",
    tryon: "Probar",
    account: "Yo",
  },
  "es-419": {
    nav: "Navegación móvil principal",
    home: "Inicio",
    tryon: "Probar",
    account: "Yo",
  },
  "pt-BR": {
    nav: "Navegação móvel principal",
    home: "Início",
    tryon: "Testar",
    account: "Eu",
  },
}[locale] ?? {
  nav: "Mobile primary navigation",
  home: "Home",
  tryon: "Try On",
  account: "Me",
};

const items = [
  {
    id: "home",
    href: localizeHref("/"),
    label: copy.home,
    icon: "home",
    primary: false,
  },
  {
    id: "tryon",
    href: localizeAppHref("/tryon-free"),
    label: copy.tryon,
    icon: "camera",
    primary: true,
  },
  {
    id: "account",
    href: accountTarget,
    label: copy.account,
    icon: "user",
    primary: false,
  },
] as const;

const isItemActive = (id: (typeof items)[number]["id"]) =>
  active === id || (id === "account" && active === "history");
---

<nav class="mobile-bottom-nav" aria-label={copy.nav} data-mobile-bottom-nav>
  <div
    class="mobile-bottom-nav-inner"
    style={`--mobile-bottom-nav-items: ${items.length}`}
  >
    {
      items.map((item) => (
        <a
          class:list={[
            "mobile-bottom-item",
            item.primary && "mobile-bottom-item-primary",
            isItemActive(item.id) && "active",
          ]}
          href={item.href}
          aria-current={isItemActive(item.id) ? "page" : undefined}
        >
          <span class="mobile-bottom-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              {item.icon === "home" && (
                <>
                  <path d="M3.5 11.2 12 4l8.5 7.2" />
                  <path d="M5.5 10.5V20h5v-5.2h3V20h5v-9.5" />
                </>
              )}
              {item.icon === "camera" && (
                <>
                  <path d="M7.2 8.2 8.8 6h6.4l1.6 2.2H20v10.3H4V8.2h3.2Z" />
                  <circle cx="12" cy="13.4" r="3.4" />
                  <path d="M18.2 5.2v2.1" />
                  <path d="M19.2 6.2h-2.1" />
                </>
              )}
              {item.icon === "user" && (
                <>
                  <circle cx="12" cy="8.2" r="3.3" />
                  <path d="M5.5 20c.8-4.2 3-6.2 6.5-6.2s5.7 2 6.5 6.2" />
                </>
              )}
            </svg>
          </span>
          <span>{item.label}</span>
        </a>
      ))
    }
  </div>
</nav>

<script is:inline>
  (() => {
    const body = document.body;
    body.classList.add("mobile-bottom-nav-ready");

    if (window.__absMobileBottomNavInit) return;
    window.__absMobileBottomNavInit = true;

    const suppressedReasons = new Set();
    window.absSetMobileBottomNavSuppressed = (reason, suppressed = true) => {
      const key = reason || "default";
      if (suppressed) suppressedReasons.add(key);
      else suppressedReasons.delete(key);
      body.classList.toggle(
        "mobile-bottom-nav-suppressed",
        suppressedReasons.size > 0,
      );
    };

    const keyboardSelector =
      "input:not([type='checkbox']):not([type='radio']):not([type='range']), textarea, select, [contenteditable='true']";
    const syncKeyboardState = () => {
      body.classList.toggle(
        "mobile-bottom-nav-keyboard",
        Boolean(document.activeElement?.matches?.(keyboardSelector)),
      );
    };
    document.addEventListener("focusin", syncKeyboardState);
    document.addEventListener("focusout", () =>
      requestAnimationFrame(syncKeyboardState),
    );

    const syncModalState = () => {
      const hasBlockingModal = Boolean(
        document.querySelector(
          "dialog[open], [aria-modal='true']:not([hidden])",
        ),
      );
      body.classList.toggle("mobile-bottom-nav-modal", hasBlockingModal);
    };
    new MutationObserver(syncModalState).observe(document.body, {
      attributes: true,
      childList: true,
      subtree: true,
      attributeFilter: ["open", "hidden", "aria-modal"],
    });
    syncKeyboardState();
    syncModalState();
  })();
</script>

<style>
  .mobile-bottom-nav {
    display: none;
  }
  @media (max-width: 767px) {
    :global(body.mobile-bottom-nav-ready) {
      padding-bottom: calc(60px + env(safe-area-inset-bottom));
    }
    .mobile-bottom-nav {
      position: fixed;
      right: 0;
      bottom: 0;
      left: 0;
      z-index: 130;
      display: block;
      padding: 5px 12px calc(5px + env(safe-area-inset-bottom));
      border-top: 1px solid color-mix(in srgb, var(--line) 86%, transparent);
      background: color-mix(in srgb, var(--bg-elevated) 96%, transparent);
      box-shadow: 0 -12px 34px rgba(18, 39, 66, 0.11);
      backdrop-filter: blur(18px) saturate(160%);
      -webkit-backdrop-filter: blur(18px) saturate(160%);
    }
    .mobile-bottom-nav-inner {
      display: grid;
      max-width: 460px;
      min-height: 46px;
      grid-template-columns: repeat(
        var(--mobile-bottom-nav-items, 3),
        minmax(0, 1fr)
      );
      align-items: end;
      gap: 6px;
      margin: 0 auto;
    }
    .mobile-bottom-item {
      display: inline-flex;
      min-width: 0;
      min-height: 42px;
      align-items: center;
      justify-content: center;
      gap: 5px;
      flex-direction: row;
      padding: 0 12px;
      border-radius: 999px;
      color: var(--muted);
      font-size: 11px;
      font-weight: 720;
      line-height: 1;
      text-decoration: none;
      touch-action: manipulation;
      transition:
        color 0.18s ease,
        background 0.18s ease,
        transform 0.18s ease;
    }
    .mobile-bottom-item:active {
      transform: scale(0.96);
    }
    .mobile-bottom-item span:last-child {
      flex-shrink: 0;
      white-space: nowrap;
    }
    .mobile-bottom-icon {
      display: grid;
      width: 20px;
      height: 20px;
      flex-shrink: 0;
      place-items: center;
    }
    .mobile-bottom-icon svg {
      display: block;
      width: 18px;
      height: 18px;
      fill: none;
      stroke: currentColor;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-width: 2.1;
    }
    .mobile-bottom-item.active {
      color: var(--rose);
      background: color-mix(in srgb, var(--rose-soft) 74%, transparent);
      padding: 0 14px;
    }
    /* CJK 语言优化：汉字较宽，缩小图标+增大文字间距 */
    :global(:lang(zh)) .mobile-bottom-item:not(.mobile-bottom-item-primary) {
      gap: 4px;
      font-size: 12px;
      letter-spacing: 0.02em;
    }
    :global(:lang(zh))
      .mobile-bottom-item:not(.mobile-bottom-item-primary)
      .mobile-bottom-icon {
      width: 18px;
      height: 18px;
    }
    :global(:lang(zh))
      .mobile-bottom-item:not(.mobile-bottom-item-primary)
      .mobile-bottom-icon
      svg {
      width: 16px;
      height: 16px;
    }
    .mobile-bottom-item-primary {
      position: relative;
      width: min(104px, 100%);
      min-height: 40px;
      color: #fff8fb;
      flex-direction: row;
      gap: 5px;
      justify-self: center;
      margin: 0 auto;
      border-radius: 999px;
      background: linear-gradient(135deg, #e13c72 0%, #bd245c 100%);
      font-weight: 850;
      box-shadow:
        0 12px 26px rgba(199, 49, 103, 0.24),
        inset 0 1px 0 rgba(255, 255, 255, 0.24);
    }
    .mobile-bottom-item-primary .mobile-bottom-icon {
      width: 24px;
      height: 24px;
    }
    .mobile-bottom-item-primary .mobile-bottom-icon svg {
      width: 22px;
      height: 22px;
      stroke-width: 2.25;
    }
    .mobile-bottom-item-primary span:last-child {
      color: #fff8fb;
      font-size: 12px;
      font-weight: 900;
    }
    .mobile-bottom-item-primary.active {
      background: linear-gradient(135deg, #f04c83 0%, #c71f61 100%);
    }
    .mobile-bottom-item-primary.active .mobile-bottom-icon svg {
      color: #fff;
      stroke-width: 2.35;
    }
    :global([data-theme="dark"]) .mobile-bottom-nav {
      border-top-color: rgba(255, 255, 255, 0.08);
      background: color-mix(in srgb, var(--bg-elevated) 94%, transparent);
      box-shadow: 0 -14px 34px rgba(0, 0, 0, 0.34);
    }
    :global([data-theme="dark"])
      .mobile-bottom-item.active:not(.mobile-bottom-item-primary) {
      background: color-mix(in srgb, var(--rose-soft) 45%, transparent);
    }
    :global([data-theme="dark"]) .mobile-bottom-item-primary {
      background: linear-gradient(135deg, #d94b76 0%, #9f2857 100%);
      box-shadow:
        0 12px 26px rgba(0, 0, 0, 0.38),
        inset 0 1px 0 rgba(255, 255, 255, 0.2);
    }
    @media (prefers-reduced-motion: reduce) {
      .mobile-bottom-item {
        transition: none;
      }
      .mobile-bottom-item:active {
        transform: none;
      }
    }
  }
</style>
