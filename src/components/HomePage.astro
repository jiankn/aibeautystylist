---
import SiteHeader from "../components/SiteHeader.astro";
import MobileAppTopBar from "../components/MobileAppTopBar.astro";
import MobileBottomNav from "../components/MobileBottomNav.astro";
import { resolveLookCatalog } from "../data/makeup/resolveCatalog";
import { resolvePageAssets } from "../data/makeup/resolvePageAssets";
import { getLocalizedAppHref, resolveLocaleRoute } from "../i18n/routing";
import { t } from "../lib/i18n";
import BaseLayout from "../layouts/BaseLayout.astro";

const currentPathname = Astro.originPathname || Astro.url.pathname;
const currentRoute =
  Astro.locals.localeRoute ?? resolveLocaleRoute(currentPathname);
const localizeAppHref = (href: string) =>
  getLocalizedAppHref(href, currentRoute.language.slug);
const audienceContext = Astro.locals.audienceContext;
const resolvedLooks = resolveLookCatalog(audienceContext);
const pageAssets = resolvePageAssets("home", audienceContext);
const heroImageAfter =
  pageAssets.heroImages?.light ?? "/images/home-hero-multicultural.webp";
const heroImageBefore = pageAssets.heroImagesBefore?.light ?? heroImageAfter;
const diagnosisPreviewImage =
  pageAssets.diagnosisPreviewImage ?? "/images/diagnosis-preview.webp";
const getLookThumbnail = (image: string) =>
  image.startsWith("/images/looks/")
    ? image.replace("/images/looks/", "/images/looks/thumbs/")
    : image;
const getLookPreviewImage = (image: string, width = 640) => {
  if (image.startsWith("/images/looks/")) {
    return image
      .replace("/images/looks/", "/images/look-card/looks/")
      .replace(/\.webp$/, `-${width}.webp`);
  }
  if (image.startsWith("/images/look-")) {
    return image
      .replace("/images/", "/images/look-card/")
      .replace(/\.webp$/, `-${width}.webp`);
  }
  return image;
};

const heroImageAttributes: Record<
  string,
  {
    srcset: string;
    sizes: string;
    width: number;
    height: number;
    mobileSrcset?: string;
    mobileSizes?: string;
    mobileHref?: string;
  }
> = {
  "/images/home-hero-global-commute-after.webp": {
    srcset:
      "/images/home-hero-global-commute-after-640.webp 640w, /images/home-hero-global-commute-after-960.webp 960w, /images/home-hero-global-commute-after.webp 1086w",
    sizes: "(max-width: 900px) calc(100vw - 72px), min(46vw, 612px)",
    width: 1086,
    height: 1448,
    mobileSrcset:
      "/images/home-hero-global-commute-after-mobile-480.webp 480w, /images/home-hero-global-commute-after-mobile-640.webp 640w",
    mobileSizes: "calc(100vw - 28px)",
    mobileHref: "/images/home-hero-global-commute-after-mobile-640.webp",
  },
  "/images/home-hero-global-commute-before.webp": {
    srcset:
      "/images/home-hero-global-commute-before-640.webp 640w, /images/home-hero-global-commute-before-960.webp 960w, /images/home-hero-global-commute-before.webp 1086w",
    sizes: "(max-width: 900px) calc(100vw - 72px), min(46vw, 612px)",
    width: 1086,
    height: 1448,
    mobileSrcset:
      "/images/home-hero-global-commute-before-mobile-480.webp 480w, /images/home-hero-global-commute-before-mobile-640.webp 640w",
    mobileSizes: "calc(100vw - 28px)",
    mobileHref: "/images/home-hero-global-commute-before-mobile-640.webp",
  },
  "/images/look-korean-dewy-makeup.webp": {
    srcset:
      "/images/look-korean-dewy-makeup-640.webp 640w, /images/look-korean-dewy-makeup.webp 1024w",
    sizes: "(max-width: 900px) calc(100vw - 72px), min(46vw, 612px)",
    width: 1024,
    height: 1024,
    mobileSrcset:
      "/images/look-korean-dewy-makeup-mobile-480.webp 480w, /images/look-korean-dewy-makeup-mobile-640.webp 640w",
    mobileSizes: "calc(100vw - 28px)",
    mobileHref: "/images/look-korean-dewy-makeup-mobile-640.webp",
  },
  "/images/look-korean-dewy-makeup-before.webp": {
    srcset:
      "/images/look-korean-dewy-makeup-before-640.webp 640w, /images/look-korean-dewy-makeup-before.webp 1024w",
    sizes: "(max-width: 900px) calc(100vw - 72px), min(46vw, 612px)",
    width: 1024,
    height: 1024,
    mobileSrcset:
      "/images/look-korean-dewy-makeup-before-mobile-480.webp 480w, /images/look-korean-dewy-makeup-before-mobile-640.webp 640w",
    mobileSizes: "calc(100vw - 28px)",
    mobileHref: "/images/look-korean-dewy-makeup-before-mobile-640.webp",
  },
};
const heroImageAfterAttrs = heroImageAttributes[heroImageAfter];
const heroImageBeforeAttrs = heroImageAttributes[heroImageBefore];
const heroPreloadImages = heroImageAfterAttrs?.mobileSrcset
  ? [
      {
        href: heroImageAfterAttrs.mobileHref ?? heroImageAfter,
        srcset: heroImageAfterAttrs.mobileSrcset,
        sizes: heroImageAfterAttrs.mobileSizes,
        media: "(max-width: 700px)",
        type: "image/webp",
        fetchpriority: "high" as const,
      },
      {
        href: heroImageAfter,
        srcset: heroImageAfterAttrs.srcset,
        sizes: heroImageAfterAttrs.sizes,
        media: "(min-width: 701px)",
        type: "image/webp",
        fetchpriority: "high" as const,
      },
    ]
  : [
      {
        href: heroImageAfter,
        srcset: heroImageAfterAttrs?.srcset,
        sizes: heroImageAfterAttrs?.sizes,
        type: "image/webp",
        fetchpriority: "high" as const,
      },
    ];

const featuredSlugs = [
  "commute",
  "no-makeup",
  "rose-milk-date",
  "photogenic",
  "wedding-guest",
];
const featuredLooks = featuredSlugs
  .map((slug) => resolvedLooks.find((look) => look.slug === slug))
  .filter(Boolean) as typeof resolvedLooks;

const scenarioHighlights = (
  t("homepage", "scenarioHighlights") as Array<{
    slug: string;
    label: string;
    moment: string;
    reason: string;
    scenario: string;
  }>
).map((item) => {
  const look = resolvedLooks.find((look) => look.slug === item.slug)!;
  const scenarioImage = pageAssets.scenarioImages?.[item.slug] ?? look.image;
  return {
    ...item,
    look,
    scenarioImage,
    href: localizeAppHref(
      `/tryon-free?look=${look.slug}&scenario=${encodeURIComponent(item.scenario)}&source=home_scenario`,
    ),
  };
});

const howSteps = t("homepage", "howSteps") as Array<{
  icon: string;
  title: string;
  copy: string;
}>;
const aiFeatures = t("homepage", "aiFeatures") as Array<{
  icon: string;
  title: string;
  copy: string;
}>;
const proofCases = (
  t("homepage", "proofCases") as Array<{
    slug: string;
    eyebrow: string;
    need: string;
    title: string;
    copy: string;
    outcome: string;
  }>
).map((item) => ({
  ...item,
  look: resolvedLooks.find((look) => look.slug === item.slug)!,
}));
const proofPrinciples = t("homepage", "proofPrinciples") as Array<{
  title: string;
  copy: string;
}>;
const uploadConcerns = t("homepage", "uploadConcerns") as Array<{
  index: string;
  title: string;
  copy: string;
}>;
const homepageMetaTitle = t("homepage", "metaTitle") as string;
const homepageMetaDescription = t("homepage", "metaDescription") as string;
const mobileExploreSearchCopy = {
  en: {
    label: "Explore looks, scenes, styles",
    ariaLabel: "Explore makeup looks, scenes, and styles",
  },
  "zh-CN": {
    label: "探索妆容、场景、风格",
    ariaLabel: "探索妆容、场景、风格",
  },
  "zh-TW": {
    label: "探索妝容、場景、風格",
    ariaLabel: "探索妝容、場景、風格",
  },
  "de-DE": {
    label: "Looks, Anlässe, Stile",
    ariaLabel: "Looks, Anlässe und Stile entdecken",
  },
  "fr-FR": {
    label: "Looks, occasions, styles",
    ariaLabel: "Explorer les looks, occasions et styles",
  },
  "ja-JP": {
    label: "メイク・シーン・スタイル",
    ariaLabel: "メイク、シーン、スタイルを探す",
  },
  "ko-KR": {
    label: "룩, 상황, 스타일 탐색",
    ariaLabel: "메이크업 룩, 상황, 스타일 탐색",
  },
  "es-ES": {
    label: "Looks, ocasiones, estilos",
    ariaLabel: "Explorar looks, ocasiones y estilos",
  },
  "es-419": {
    label: "Looks, ocasiones, estilos",
    ariaLabel: "Explorar looks, ocasiones y estilos",
  },
  "pt-BR": {
    label: "Looks, ocasiões, estilos",
    ariaLabel: "Explorar looks, ocasiões e estilos",
  },
}[currentRoute.language.locale] ?? {
  label: "Explore looks, scenes, styles",
  ariaLabel: "Explore makeup looks, scenes, and styles",
};

const origin = Astro.site ?? Astro.url.origin;
const homepageJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "@id": `${origin}/#webapp`,
      url: origin,
      name: "AI Beauty Stylist",
      applicationCategory: "BusinessApplication",
      operatingSystem: "All",
      description: t("homepage", "jsonLdDescription"),
      offers: {
        "@type": "Offer",
        price: "0.00",
        priceCurrency: "USD",
      },
    },
    {
      "@type": "Organization",
      "@id": `${origin}/#organization`,
      name: "AI Beauty Stylist",
      url: origin,
      logo: `${origin}/images/logo.png`,
    },
  ],
});
---

<BaseLayout
  title={homepageMetaTitle}
  description={homepageMetaDescription}
  bodyClass="home-main"
  jsonLd={homepageJsonLd}
  preloadImages={heroPreloadImages}
  appScriptStrategy="idle"
  analyticsScriptStrategy="idle"
>
  <SiteHeader active="tryOn" mobileHidden />
  <MobileAppTopBar
    brand
    showTheme={false}
    searchPill={{
      href: localizeAppHref("/discover"),
      label: mobileExploreSearchCopy.label,
      ariaLabel: mobileExploreSearchCopy.ariaLabel,
    }}
  />
  <main>
    <section class="home-hero shell" data-hero-copy-sync>
      <div class="home-copy">
        <div class="hero-kicker">
          <span class="pill pill-rose">{t("homepage", "heroKicker")}</span>
          <span>{t("homepage", "heroKickerSub")}</span>
        </div>
        <h1>
          {t("homepage", "heroTitle")}<br /><span
            >{t("homepage", "heroTitleSpan")}</span
          >
        </h1>
        <p>{t("homepage", "heroSubtitle")}</p>
        <div class="hero-actions">
          <a
            class="btn btn-primary"
            href={localizeAppHref("/tryon-free")}
            onclick="window.__track&&window.__track('home_start_tryon_click')"
            >{t("homepage", "startTryOn")}</a
          >
          <a class="btn" href="#how-it-works">{t("homepage", "howItWorks")}</a>
        </div>
        <p class="generation-note">
          {t("homepage", "pricingRule")}
        </p>
        <div class="hero-trust">
          <div class="trust-point">
            <span class="trust-icon trust-icon-natural" aria-hidden="true"
            ></span>
            <div>
              <b>{t("homepage", "trustNaturalTitle")}</b>
              <small>{t("homepage", "trustNaturalDesc")}</small>
            </div>
          </div>
          <div class="trust-point">
            <span class="trust-icon trust-icon-personal" aria-hidden="true"
            ></span>
            <div>
              <b>{t("homepage", "trustRecommendTitle")}</b>
              <small>{t("homepage", "trustRecommendDesc")}</small>
            </div>
          </div>
          <div class="trust-point">
            <span class="trust-icon trust-icon-private" aria-hidden="true"
            ></span>
            <div>
              <b>{t("homepage", "trustPrivacyTitle")}</b>
              <small>{t("homepage", "trustPrivacyDesc")}</small>
            </div>
          </div>
        </div>
      </div>
      <div class="home-visual" data-hero-visual>
        <div
          class="compare-hero home-compare"
          data-compare-slider
          data-home-original-image={heroImageBefore}
          aria-label={t("homepage", "dragSlider")}
        >
          <div class="compare-half right">
            <picture>
              {
                heroImageAfterAttrs?.mobileSrcset && (
                  <source
                    media="(max-width: 700px)"
                    srcset={heroImageAfterAttrs.mobileSrcset}
                    sizes={heroImageAfterAttrs.mobileSizes}
                    type="image/webp"
                  />
                )
              }
              <img
                src={heroImageAfter}
                srcset={heroImageAfterAttrs?.srcset}
                sizes={heroImageAfterAttrs?.sizes}
                width={heroImageAfterAttrs?.width}
                height={heroImageAfterAttrs?.height}
                alt={t("homepage", "heroImageAltAfter")}
                fetchpriority="high"
                decoding="async"
              />
            </picture>
          </div>
          <div class="compare-half left">
            <picture>
              {
                heroImageBeforeAttrs?.mobileSrcset && (
                  <source
                    media="(max-width: 700px)"
                    srcset={heroImageBeforeAttrs.mobileSrcset}
                    sizes={heroImageBeforeAttrs.mobileSizes}
                    type="image/webp"
                  />
                )
              }
              <img
                src={heroImageBefore}
                srcset={heroImageBeforeAttrs?.srcset}
                sizes={heroImageBeforeAttrs?.sizes}
                width={heroImageBeforeAttrs?.width}
                height={heroImageBeforeAttrs?.height}
                alt={t("homepage", "heroImageAltBefore")}
                fetchpriority="low"
                decoding="async"
              />
            </picture>
          </div>
          <span class="compare-label before">{t("homepage", "before")}</span>
          <span class="compare-label after">{t("homepage", "after")}</span>
          <button
            class="compare-knob"
            type="button"
            data-compare-knob
            role="slider"
            aria-label={t("homepage", "dragSlider")}
            aria-valuemin="5"
            aria-valuemax="95"
            aria-valuenow="50"
            aria-orientation="horizontal">↔</button
          >
        </div>
      </div>
    </section>

    <div class="scroll-hint shell" aria-hidden="true">
      <a href="#scenario-title" class="scroll-hint-arrow" tabindex="-1">
        <span></span>
      </a>
    </div>

    <section
      class="home-stats-bar"
      aria-label={t("homepage", "statsTryonsLabel")}
    >
      <div class="shell stats-inner">
        <div class="stats-item">
          <span class="stats-num">{t("homepage", "statsTryons")}</span>
          <span class="stats-label">{t("homepage", "statsTryonsLabel")}</span>
        </div>
        <div class="stats-item">
          <span class="stats-num">{t("homepage", "statsRealism")}</span>
          <span class="stats-label">{t("homepage", "statsRealismLabel")}</span>
        </div>
        <div class="stats-item">
          <span class="stats-num">{t("homepage", "statsPrivacy")}</span>
          <span class="stats-label">{t("homepage", "statsPrivacyLabel")}</span>
        </div>
      </div>
    </section>

    <section
      class="shell home-section scenario-section"
      aria-labelledby="scenario-title"
      data-home-scenarios
    >
      <div class="home-section-head home-section-head-split">
        <div>
          <span class="section-kicker">{t("homepage", "scenarioKicker")}</span>
          <h2 id="scenario-title">{t("homepage", "scenarioTitle")}</h2>
          <p class="muted">{t("homepage", "scenarioSubtitle")}</p>
        </div>
        <a class="section-link" href={localizeAppHref("/discover")}
          >{t("homepage", "scenarioLink")}
          <span class="arrow" aria-hidden="true">→</span></a
        >
      </div>
      <div class="scenario-showcase">
        {
          scenarioHighlights.map((item) => (
            <a
              class="scenario-card fade-in-on-scroll"
              href={item.href}
              data-home-scenario-card
              aria-label={`${t("homepage", "scenarioCardCta")}：${item.look.title}`}
            >
              <img
                src={item.scenarioImage}
                alt={item.look.imageAlt}
                width="600"
                height="800"
                loading="lazy"
              />
              <span class="scenario-shade" aria-hidden="true" />
              <div class="scenario-copy">
                <small>{item.moment}</small>
                <h3>{item.look.title}</h3>
                <p class="scenario-reason">{item.reason}</p>
                <div class="scenario-meta">
                  <div class="scenario-tags">
                    <span class="scenario-tag">{item.label}</span>
                    <span class="scenario-tag">{item.look.finish[0]}</span>
                  </div>
                  <span class="scenario-cta">
                    {t("homepage", "scenarioCardCta")}
                    <span aria-hidden="true">→</span>
                  </span>
                </div>
              </div>
            </a>
          ))
        }
      </div>
      <nav
        class="scenario-dots"
        aria-label="Scenario carousel"
        data-scenario-dots
      >
        {
          scenarioHighlights.map((_, i) => (
            <button
              type="button"
              class:list={["scenario-dot", { active: i === 0 }]}
              data-dot-index={i}
              aria-label={`Go to card ${i + 1}`}
            />
          ))
        }
      </nav>
    </section>

    <section
      class="shell home-section how-section"
      id="how-it-works"
      aria-labelledby="how-title"
    >
      <div class="home-section-head home-section-head-split">
        <div>
          <span class="section-kicker">{t("homepage", "howKicker")}</span>
          <h2 id="how-title">{t("homepage", "howTitle")}</h2>
        </div>
        <p class="muted">{t("homepage", "howSubtitle")}</p>
      </div>
      <div class="product-tour fade-in-on-scroll">
        <div class="product-tour-steps">
          {
            howSteps.map((step, index) => (
              <article
                class="product-tour-step"
                data-step-index={index}
                aria-current={index === 0 ? "step" : undefined}
              >
                <span>{String(index + 1).padStart(2, "0")}</span>
                <div>
                  <h3>{step.title}</h3>
                  <p>{step.copy}</p>
                </div>
              </article>
            ))
          }
          <a
            class="btn btn-primary product-tour-cta"
            href={localizeAppHref("/tryon-free")}
            >{t("homepage", "startTryOn")}</a
          >
        </div>
        <div class="product-tour-screen">
          <div class="mockup-toolbar">
            <span aria-hidden="true"></span><span aria-hidden="true"
            ></span><span aria-hidden="true"></span>
            <b>{t("homepage", "workflowWorkspace")}</b>
            <small>{t("homepage", "workflowStatus")}</small>
          </div>
          <div class="mockup-body">
            <div class="mockup-look-list">
              {
                featuredLooks.slice(0, 3).map((look, index) => (
                  <div
                    class:list={["mockup-look", { active: index === 0 }]}
                    data-image={getLookPreviewImage(look.image)}
                  >
                    <img
                      src={getLookThumbnail(look.image)}
                      alt=""
                      loading="lazy"
                    />
                    <span>{look.title}</span>
                  </div>
                ))
              }
            </div>
            <div class="mockup-preview">
              <img
                id="mockup-preview-img"
                src={getLookPreviewImage(featuredLooks[0].image)}
                alt={t("homepage", "workflowPreviewAlt")}
                width="640"
                height="800"
                loading="lazy"
              />
              <span
                id="mockup-preview-status"
                class="mockup-preview-status"
                data-text-preview={t("homepage", "workflowPreview")}
                data-text-uploaded={t("homepage", "workflowUploaded")}
                data-text-ready={t("homepage", "workflowReady")}
                >{t("homepage", "workflowPreview")}</span
              >
              <div id="mockup-preview-copy" class="mockup-preview-copy">
                <small>{t("homepage", "workflowSelected")}</small>
                <strong id="mockup-preview-title"
                  >{featuredLooks[0].title}</strong
                >
              </div>
              <div class="mockup-scan-overlay" aria-hidden="true">
                <div class="scan-line"></div>
                <span class="scan-text"
                  >{t("homepage", "workflowScanning")}</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="shell home-section ai-section" aria-labelledby="ai-title">
      <div class="ai-story">
        <figure class="ai-visual fade-in-on-scroll">
          <img
            src={diagnosisPreviewImage}
            alt={t("homepage", "aiVisualAlt")}
            loading="lazy"
          />
          <div class="ai-callout-row">
            <span class="ai-callout ai-callout-light"
              >{aiFeatures[0].title}</span
            >
            <span class="ai-callout ai-callout-skin">{aiFeatures[1].title}</span
            >
          </div>
          <figcaption>{t("homepage", "aiVisualCaption")}</figcaption>
        </figure>
        <div class="ai-story-copy">
          <div class="home-section-head">
            <span class="section-kicker">{t("homepage", "aiKicker")}</span>
            <h2 id="ai-title">{t("homepage", "aiTitle")}</h2>
            <p class="muted">{t("homepage", "aiSubtitle")}</p>
          </div>
          <div class="ai-feature-list">
            {
              aiFeatures.map((feature, index) => (
                <article class="ai-feature fade-in-on-scroll">
                  <span class="ai-feature-index">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <div>
                    <h3>{feature.title}</h3>
                    <p>{feature.copy}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section
      class="shell home-section proof-section"
      aria-labelledby="proof-title"
    >
      <div class="home-section-head">
        <span class="section-kicker">{t("homepage", "proofKicker")}</span>
        <h2 id="proof-title">{t("homepage", "proofTitle")}</h2>
        <p class="muted">{t("homepage", "proofSubtitle")}</p>
      </div>

      <div class="decision-showcase">
        {
          proofCases.map((item, index) => (
            <a
              class:list={[
                "decision-case",
                "fade-in-on-scroll",
                { "decision-case-lead": index === 0 },
              ]}
              href={localizeAppHref(
                `/tryon-free?look=${item.look.slug}&scenario=${encodeURIComponent(item.look.scenarios[0])}&source=home_decision_case`,
              )}
            >
              <div class="decision-media">
                <img
                  src={getLookPreviewImage(item.look.image)}
                  alt={item.look.imageAlt}
                  width="640"
                  height="800"
                  loading="lazy"
                />
                <span>{item.eyebrow}</span>
              </div>
              <div class="decision-copy">
                <small>{item.need}</small>
                <h3>{item.title}</h3>
                <p>{item.copy}</p>
                <strong>{item.outcome}</strong>
              </div>
            </a>
          ))
        }
      </div>

      <div class="proof-principles">
        {
          proofPrinciples.map((item, index) => (
            <div>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <p>
                <b>{item.title}</b>
                {item.copy}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <section
      class="shell home-section assurance-section"
      aria-labelledby="assurance-title"
      data-home-assurance
    >
