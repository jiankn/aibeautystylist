</style>

<script is:inline>
  (() => {
    document.querySelectorAll("[data-compare-slider]").forEach((slider) => {
      if (slider.dataset.compareReady === "true") return;
      const knob = slider.querySelector("[data-compare-knob]");
      if (!knob) return;
      slider.dataset.compareReady = "true";

      const setPosition = (value) => {
        const pct = Math.max(5, Math.min(95, value));
        slider.style.setProperty("--compare-position", `${pct}%`);
        knob.setAttribute("aria-valuenow", String(Math.round(pct)));
      };

      let sliderRect = null;
      let pendingPosition = null;
      let positionFrame = 0;

      const flushPosition = () => {
        positionFrame = 0;
        if (pendingPosition === null) return;
        setPosition(pendingPosition);
        pendingPosition = null;
      };

      const queuePosition = (value) => {
        pendingPosition = Math.max(5, Math.min(95, value));
        if (!positionFrame) {
          positionFrame = window.requestAnimationFrame(flushPosition);
        }
      };

      const setFromClientX = (clientX, immediate = false) => {
        const rect = sliderRect || slider.getBoundingClientRect();
        if (!rect.width) return;
        const next = ((clientX - rect.left) / rect.width) * 100;
        immediate ? setPosition(next) : queuePosition(next);
      };

      let isDragging = false;
      const endDrag = (event) => {
        if (!isDragging) return;
        isDragging = false;
        sliderRect = null;
        slider.classList.remove("is-dragging");
        if (event?.pointerId !== undefined) {
          slider.releasePointerCapture?.(event.pointerId);
        }
        if (positionFrame) {
          window.cancelAnimationFrame(positionFrame);
          flushPosition();
        }
      };

      slider.addEventListener("pointerdown", (event) => {
        if (event.button !== undefined && event.button !== 0) return;
        isDragging = true;
        sliderRect = slider.getBoundingClientRect();
        slider.classList.add("is-dragging");
        slider.setPointerCapture?.(event.pointerId);
        knob.focus({ preventScroll: true });
        setFromClientX(event.clientX, true);
        event.preventDefault();
      });
      slider.addEventListener("pointermove", (event) => {
        if (!isDragging) return;
        setFromClientX(event.clientX);
        event.preventDefault();
      });
      slider.addEventListener("pointerup", endDrag);
      slider.addEventListener("pointercancel", endDrag);
      slider.addEventListener("lostpointercapture", endDrag);

      knob.addEventListener("keydown", (event) => {
        const current = Number(knob.getAttribute("aria-valuenow") || 50);
        const step = event.shiftKey ? 10 : 5;
        if (event.key === "ArrowLeft") {
          event.preventDefault();
          setPosition(current - step);
        } else if (event.key === "ArrowRight") {
          event.preventDefault();
          setPosition(current + step);
        } else if (event.key === "Home") {
          event.preventDefault();
          setPosition(5);
        } else if (event.key === "End") {
          event.preventDefault();
          setPosition(95);
        }
      });
    });
  })();

  (() => {
    const items = document.querySelectorAll(".fade-in-on-scroll");
    if (!items.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const parent = entry.target.parentElement;
          const siblings = parent
            ? Array.from(parent.children).filter((child) =>
                child.classList.contains("fade-in-on-scroll"),
              )
            : [];
          const index = siblings.indexOf(entry.target);
          window.setTimeout(
            () => {
              entry.target.classList.add("visible");
            },
            Math.max(0, index) * 120,
          );
          observer.unobserve(entry.target);
        });
      },
      {
        threshold: 0.05,
        rootMargin: "0px 0px -40px 0px",
      },
    );

    items.forEach((item) => observer.observe(item));
  })();

  // Mockup 交互步骤联动动效
  (() => {
    const steps = document.querySelectorAll(".product-tour-step");
    const screen = document.querySelector(".product-tour-screen");
    const previewImg = document.getElementById("mockup-preview-img");
    const previewTitle = document.getElementById("mockup-preview-title");
    const previewStatus = document.getElementById("mockup-preview-status");
    const previewCopy = document.getElementById("mockup-preview-copy");
    const mockupLooks = document.querySelectorAll(".mockup-look");

    if (!steps.length || !screen || !previewImg) return;

    const originalImage =
      document.querySelector("[data-home-original-image]")?.dataset
        .homeOriginalImage || "/images/home-hero-multicultural.webp";
    const commuteImage =
      mockupLooks[0]?.getAttribute("data-image") || "/images/look-commute.webp";
    const commuteTitle = previewTitle ? previewTitle.innerText : "";

    // 图片切换带 fade 过渡的工具函数
    function fadeToImage(src, onMid) {
      previewImg.classList.add("fade-out");
      setTimeout(() => {
        previewImg.src = src;
        if (onMid) onMid();
        // 图片加载后淡入
        const reveal = () => {
          previewImg.classList.remove("fade-out");
          previewImg.removeEventListener("load", reveal);
        };
        if (previewImg.complete) {
          reveal();
        } else {
          previewImg.addEventListener("load", reveal);
        }
      }, 200);
    }

    // 激活指定步骤
    function activateStep(idx) {
      steps.forEach((s) => s.classList.remove("active"));
      mockupLooks.forEach((l) => l.classList.remove("active"));
      screen.classList.remove("show-scan");

      steps[idx].classList.add("active");
      steps[idx].setAttribute("aria-current", "step");
      // 其他步骤取消当前步骤标记
      steps.forEach((s, i) => {
        if (i !== idx) s.removeAttribute("aria-current");
      });

      if (idx === 0) {
        if (mockupLooks[0]) mockupLooks[0].classList.add("active");
        fadeToImage(commuteImage, () => {
          if (previewTitle) previewTitle.innerText = commuteTitle;
        });
        if (previewStatus) {
          previewStatus.innerText =
            previewStatus.getAttribute("data-text-preview") || "AI 生成预览";
          previewStatus.style.background = "rgba(9, 20, 35, 0.7)";
        }
        if (previewCopy) previewCopy.style.opacity = "1";
      } else if (idx === 1) {
        screen.classList.add("show-scan");
        fadeToImage(originalImage);
        if (previewStatus) {
          previewStatus.innerText =
            previewStatus.getAttribute("data-text-uploaded") || "自拍已上传";
          previewStatus.style.background = "var(--rose)";
        }
        if (previewCopy) previewCopy.style.opacity = "0";
      } else if (idx === 2) {
        if (mockupLooks[0]) mockupLooks[0].classList.add("active");
        fadeToImage(commuteImage, () => {
          if (previewTitle) previewTitle.innerText = commuteTitle;
        });
        if (previewStatus) {
          previewStatus.innerText =
            previewStatus.getAttribute("data-text-ready") || "生成完成";
          previewStatus.style.background = "var(--teal)";
        }
        if (previewCopy) previewCopy.style.opacity = "1";
      }
    }

    // 默认激活第一步
    steps[0].classList.add("active");
    steps[0].setAttribute("aria-current", "step");

    // 绑定 mouseenter + click（兼容移动端触摸）
    steps.forEach((step, idx) => {
      step.addEventListener("mouseenter", () => activateStep(idx));
      step.addEventListener("click", () => activateStep(idx));
    });

    // 妆容列表点击切换预览
    const lookImages = Array.from(mockupLooks).map(
      (el) => el.getAttribute("data-image") || "",
    );

    mockupLooks.forEach((look, idx) => {
      look.style.cursor = "pointer";
      look.addEventListener("click", () => {
        mockupLooks.forEach((l) => l.classList.remove("active"));
        look.classList.add("active");

        const lookTitle = look.querySelector("span")?.innerText || "";
        const lookSrc = lookImages[idx] || lookImages[0];

        fadeToImage(lookSrc, () => {
          if (previewTitle) previewTitle.innerText = lookTitle;
        });

        // 同步步骤到"查看效果"
        activateStep(2);
        // 覆盖回当前妆容的图
        setTimeout(() => {
          mockupLooks.forEach((l) => l.classList.remove("active"));
          look.classList.add("active");
          fadeToImage(lookSrc, () => {
            if (previewTitle) previewTitle.innerText = lookTitle;
          });
        }, 250);
      });
    });
  })();

  // 场景卡片轮播圆点指示器
  (() => {
    const showcase = document.querySelector(".scenario-showcase");
    const dotsNav = document.querySelector("[data-scenario-dots]");
    if (!showcase || !dotsNav) return;

    const cards = showcase.querySelectorAll(".scenario-card");
    const dots = dotsNav.querySelectorAll(".scenario-dot");
    if (!cards.length || !dots.length) return;

    let currentIndex = 0;
    let ticking = false;

    function syncDots() {
      // 根据滚动位置计算当前卡片索引
      const containerLeft = showcase.getBoundingClientRect().left;
      let closest = 0;
      let minDist = Infinity;
      cards.forEach((card, i) => {
        const dist = Math.abs(
          card.getBoundingClientRect().left - containerLeft,
        );
        if (dist < minDist) {
          minDist = dist;
          closest = i;
        }
      });
      if (closest !== currentIndex) {
        currentIndex = closest;
        dots.forEach((d, i) => d.classList.toggle("active", i === closest));
      }
      ticking = false;
    }

    showcase.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(syncDots);
        }
      },
      { passive: true },
    );

    // 点击圆点跳转对应卡片
    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        const idx = Number(dot.dataset.dotIndex);
        cards[idx]?.scrollIntoView({
          behavior: "smooth",
          block: "nearest",
          inline: "start",
        });
      });
    });
  })();
</script>
