---
import SiteHeader from "./SiteHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  badge: string;
  updatedLabel: string;
  updated?: string;
}

const { title, description, badge, updatedLabel, updated } = Astro.props;
---

<BaseLayout title={`${title} | AI Beauty Stylist`} description={description}>
  <SiteHeader />
  <main class="legal-main">
    <article class="legal-document panel">
      <header class="legal-header">
        <span class="pill pill-rose">{badge}</span>
        <h1>{title}</h1>
        <p>{description}</p>
        <small>{updatedLabel}: {updated}</small>
      </header>
      <div class="legal-content">
        <slot />
      </div>
    </article>
  </main>
</BaseLayout>
