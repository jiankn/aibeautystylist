---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = true;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About AI Beauty Stylist',
  url: 'https://aibeautystylist.com/about/',
  description: 'AI Beauty Stylist helps people understand what makeup suits their face, skin tone, and real-life scenarios.',
};
---

<BaseLayout
  title="About AI Beauty Stylist | Personalized Makeup Guidance"
  description="AI Beauty Stylist helps you understand what makeup suits your face, your skin tone, and your real-life scenarios."
  structuredData={structuredData}
>
  <section class="section">
    <div class="container section-copy narrow">
      <span class="eyebrow">About</span>
      <h1>Beauty guidance that starts with your face, not a trend.</h1>
      <p>
        AI Beauty Stylist is built for people who want clear makeup direction:
        what suits me, how do I recreate it, and which products are actually worth buying.
      </p>
    </div>

    <div class="container grid-cards grid-cards-3">
      <article class="card coach-card">
        <h3>Personal fit first</h3>
        <p>Recommendations begin with undertone, facial structure, scenario, and experience level.</p>
      </article>
      <article class="card coach-card">
        <h3>Execution over inspiration</h3>
        <p>Every look connects to steps, mistakes to avoid, self-checks, and a practical kit.</p>
      </article>
      <article class="card coach-card">
        <h3>Privacy by design</h3>
        <p>Uploads are treated as sensitive data, with deletion and minimal retention as product requirements.</p>
      </article>
    </div>

    <div class="container tutorial-cta-row top-gap">
      <a class="btn" href="/try-on">Start Try-On</a>
      <a class="btn btn-secondary" href="/privacy">Read Privacy Policy</a>
    </div>
  </section>
</BaseLayout>
