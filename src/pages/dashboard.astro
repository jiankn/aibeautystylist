const representationKeys = [
  "diverse",
  "east-asian",
  "black",
  "south-asian",
  "latina",
  "middle-eastern",
  "white",
  "mixed",
] as const;
const representationOptions = representationKeys.map((value) => ({
  value,
  label: accountCenterCopy.preferences.representationLabels[value] ?? value,
}));

const recommendations = resolveLookCatalog(audienceContext)
  .slice(0, 4)
  .map((look) => ({
    slug: look.slug,
    title: look.title,
    image: look.image,
    imageAlt: look.imageAlt,
    intent: look.intent,
    finish: look.finish.slice(0, 2),
  }));
const primaryRecommendation = recommendations[0];

