---

<BaseLayout
  title={copy.title}
  description={copy.description}
  bodyClass="dashboard-body"
  robots="noindex,follow"
>
  <SiteHeader
    active="dashboard"
    mobileMenuSection={dashboardMobileMenu}
    mobileSmartHide
    mobileHidden
  />
  <MobileAppTopBar title={copy.heading} tabs={dashboardMobileTabs} />
  <main class="dashboard-main" data-dashboard>
    <div class="dashboard-shell">
      <aside class="dashboard-rail" aria-label={copy.railLabel}>
        {
          dashboardNavItems.map((item) => (
            <a
              class:list={["rail-link", item.active && "active"]}
              href={item.href}
              data-workspace-href={item.workspace || undefined}
              data-dashboard-label={item.label}
              data-dashboard-nav-link
            >
              <AppIconBadge icon={item.icon} size="sm" tone={item.tone} />
              {item.label}
            </a>
          ))
        }
      </aside>

      <div class="dashboard-content">
        <section
          class="dashboard-hero"
          id="overview"
          aria-labelledby="dashboard-title"
        >
          <div class="dashboard-hero-content">
            <p class="dashboard-eyebrow" data-dashboard-email>
              {copy.loadingAccount}
            </p>
            <h1 id="dashboard-title">{copy.heading}</h1>
          </div>
          <div class="dashboard-hero-actions">
            <a
              class="btn btn-primary"
              href={hrefs.tryonFree}
              data-primary-workspace
            >
              {copy.startTryon}
            </a>
            <a class="btn btn-outline-rose" href={hrefs.diagnosis}>
              {copy.openDiagnosis}
            </a>
          </div>
        </section>

        <section class="dashboard-gate panel" data-dashboard-gate hidden>
          <p>{copy.signInRequired}</p>
          <a class="btn btn-primary" href={hrefs.login}>{copy.signIn}</a>
        </section>

        <section class="dashboard-metrics" aria-label={copy.overview}>
          <article class="metric-card metric-card-primary">
            <div class="metric-icon">
              <AppIconBadge icon="membership" size="sm" tone="gold" />
            </div>
            <div class="metric-content">
              <span>{copy.plan}</span>
              <strong data-plan-value>--</strong>
            </div>
          </article>
          <article class="metric-card metric-card-primary">
            <div class="metric-icon">
              <AppIconBadge icon="tryon" size="sm" tone="teal" />
            </div>
            <div class="metric-content">
              <span>{copy.quota}</span>
              <strong data-quota-value>--</strong>
            </div>
          </article>
          <article class="metric-card metric-card-dual">
            <div class="metric-dual-item">
              <div class="metric-icon">
                <AppIconBadge icon="history" size="sm" tone="navy" />
              </div>
              <div class="metric-content">
                <span>{copy.looks}</span>
                <strong data-result-count>--</strong>
              </div>
            </div>
            <div class="metric-dual-divider"></div>
            <div class="metric-dual-item">
              <div class="metric-icon">
                <AppIconBadge icon="saved" size="sm" tone="rose" />
              </div>
              <div class="metric-content">
                <span>{copy.savedLooks}</span>
                <strong data-saved-count>--</strong>
              </div>
            </div>
          </article>
        </section>

        <section
          class="panel dashboard-panel next-action-card"
          id="workspace"
          data-dashboard-view="overview"
        >
            <div class="panel-head">
              <div>
                <p class="section-kicker">{copy.nextAction}</p>
                <h2>{copy.nextActionTitle}</h2>
              </div>
            </div>
            <div class="next-action-layout">
              {
                primaryRecommendation && (
                  <div class="next-action-media">
                    <img
                      src={primaryRecommendation.image}
                      alt={primaryRecommendation.imageAlt}
                      width="360"
                      height="460"
                      loading="eager"
                    />
                  </div>
                )
              }
              <div class="next-action-copy">
                <span class="status-pill">{copy.recommended}</span>
                <h3 data-recommended-title>
                  {primaryRecommendation?.title ?? copy.unknownLook}
                </h3>
                <p data-recommended-body>
                  {primaryRecommendation?.intent ?? copy.nextActionBody}
                </p>
                <div class="finish-tags">
                  {
                    primaryRecommendation?.finish.map((label) => (
                      <span>{label}</span>
                    ))
                  }
                </div>
                <div class="inline-actions">
                  <a
                    class="btn btn-primary"
                    href={hrefs.tryonFree}
                    data-workspace-href
                  >
                    {copy.startTryon}
                  </a>
                  <a class="btn btn-outline" href={hrefs.discover}>
                    {copy.allLooks}
                  </a>
                </div>
                <p class="dashboard-note">{copy.nextActionBody}</p>
              </div>
            </div>
          </section>

        <div class="dashboard-grid">
          <section
            class="panel dashboard-panel history-panel"
            id="history-panel"
            data-dashboard-view="history"
          >
            <div class="panel-head">
              <div>
                <p class="section-kicker">{copy.history}</p>
                <h2>{copy.recentHistory}</h2>
              </div>
            </div>
            <div class="history-list" data-history-list>
              <p class="loading-line">{copy.loadingAccount}</p>
            </div>
            <div class="history-actions" data-history-actions hidden>
              <a class="btn btn-primary" href={hrefs.history}>
                {copy.viewAllHistory}
              </a>
            </div>
          </section>

          <aside class="dashboard-quick-links">
            <section
              class="panel dashboard-panel dashboard-panel-compact"
              id="saved-panel"
              data-dashboard-view="saved"
            >
              <div class="panel-head">
                <div>
                  <p class="section-kicker">{copy.saved}</p>
                  <h2>{copy.savedPanelTitle}</h2>
                </div>
                <a
                  class="btn btn-outline-rose dashboard-panel-action dashboard-share-cta"
                  href={hrefs.shareCard}
                >
                  {copy.viewShareCard}
                </a>
              </div>
              <div class="saved-strip" data-saved-list>
                <p class="loading-line">{copy.loadingAccount}</p>
              </div>
            </section>

            <section
              class="panel dashboard-panel dashboard-panel-compact"
              id="diagnosis-panel"
              data-dashboard-view="overview"
            >
              <div class="panel-head">
                <div>
                  <p class="section-kicker">{diagnosisCopy.ui.kicker}</p>
                  <h2>{diagnosisCopy.ui.panelTitle}</h2>
                </div>
                <a
                  class="btn btn-primary dashboard-diagnosis-cta"
                  href={`${hrefs.diagnosis}#diagnosis-new`}
                  data-diagnosis-head-action
                  hidden
                >
                  {diagnosisCopy.ui.rerunDiagnosis ?? diagnosisCopy.ui.runDiagnosis}
                </a>
              </div>
              <div class="diagnosis-summary" data-diagnosis-summary>
                <p class="loading-line">{diagnosisCopy.ui.loadingAccount}</p>
              </div>
            </section>

            <section
              class="panel dashboard-panel dashboard-panel-compact"
              id="preferences-panel"
              data-dashboard-view="preferences"
            >
              <div class="panel-head">
                <div>
                  <p class="section-kicker">{copy.preferences}</p>
                  <h2>{copy.preferencesTitle}</h2>
                </div>
              </div>
              <div class="dashboard-module-intro">
                <div>
                  <span>{dashboardModuleCopy.currentPreference}</span>
                  <p>{dashboardModuleCopy.preferenceHint}</p>
                </div>
                <dl class="preference-summary">
                  <div>
                    <dt>{copy.marketProfile}</dt>
                    <dd data-market-profile>{currentMarketProfileLabel}</dd>
                  </div>
                  <div>
                    <dt>{copy.representation}</dt>
                    <dd data-representation-preference>{copy.noPreference}</dd>
                  </div>
                </dl>
              </div>
              <form class="dashboard-preference-form" data-dashboard-preferences>
                <div class="dashboard-preference-card">
                  <label class="dashboard-preference-field">
                    <span>{accountCenterCopy.preferences.marketProfile}</span>
                    <select name="marketProfile" data-dashboard-market-select>
                      {
                        marketOptions.map((option) => (
                          <option
                            value={option.value}
                            selected={
                              option.value === audienceContext.marketProfile
                            }
                          >
                            {option.label}
                          </option>
                        ))
                      }
                    </select>
                  </label>
                </div>
                <fieldset class="dashboard-representation-field">
                  <legend>{accountCenterCopy.preferences.representation}</legend>
                  <div class="dashboard-representation-options">
                    {
                      representationOptions.map((option) => (
                        <label class="dashboard-representation-chip">
                          <input
                            type="checkbox"
                            name="representationPreference"
                            value={option.value}
                            checked={audienceContext.representationPreference.some(
                              (preference) => preference === option.value,
                            )}
                          />
                          <span>{option.label}</span>
                        </label>
                      ))
                    }
                  </div>
                </fieldset>
                <div class="dashboard-form-footer">
                  <button class="btn btn-primary" type="submit">
                    {accountCenterCopy.preferences.save}
                  </button>
                </div>
                <p
                  class="dashboard-message"
                  data-dashboard-preference-status
                  role="status"
                >
                </p>
              </form>
            </section>

            <section
              class="panel dashboard-panel dashboard-panel-compact"
              id="billing-panel"
              data-dashboard-view="billing"
            >
              <div class="panel-head">
                <div>
                  <p class="section-kicker">{copy.billing}</p>
                  <h2>{copy.billingTitle}</h2>
                </div>
              </div>
              <div class="dashboard-billing-status" data-billing-plan-card>
                <article class="dashboard-billing-plan">
                  <span>{dashboardModuleCopy.billingCurrentPlan}</span>
                  <strong data-billing-plan>--</strong>
                  <p data-billing-note>{copy.planNote}</p>
                </article>
                <article class="dashboard-billing-quota">
                  <div>
                    <span>{dashboardModuleCopy.billingUsage}</span>
                    <strong data-billing-quota>--</strong>
                  </div>
                  <div class="meter">
                    <i data-billing-meter style="width: 0%;"></i>
                  </div>
                  <small data-billing-refresh>
                    {dashboardModuleCopy.billingRefreshFallback}
                  </small>
                </article>
                <article class="dashboard-billing-limit">
                  <span>{dashboardModuleCopy.billingSavedLimit}</span>
                  <strong>
                    <span data-billing-saved-limit>--</span>
                    <small>{dashboardModuleCopy.billingSavedUnit}</small>
                  </strong>
                </article>
              </div>
              <div class="dashboard-billing-benefits">
                <span>{dashboardModuleCopy.billingIncluded}</span>
                <div>
                  <b data-billing-benefit-main>{dashboardModuleCopy.billingFreeBenefit}</b>
                  <b>{dashboardModuleCopy.billingSharedBenefit}</b>
                </div>
              </div>
              <div class="inline-actions dashboard-billing-actions">
                <button
                  class="btn btn-primary"
                  type="button"
                  data-manage-billing
                  hidden
                >
                  {copy.manageBilling}
                </button>
                <a
                  class="btn btn-outline-rose"
                  href={hrefs.subscription}
                  data-plan-upgrade
                >
                  {copy.upgrade}
                </a>
              </div>
              <p class="dashboard-message" data-dashboard-message role="status">
              </p>
            </section>

            <section
              class="panel dashboard-panel dashboard-panel-compact dashboard-account-panel"
              id="account-panel"
              data-dashboard-view="account"
            >
              <div class="panel-head">
                <div>
                  <p class="section-kicker">{accountCenterCopy.menuLabel}</p>
                  <h2>{accountCenterCopy.pageTitle}</h2>
                </div>
              </div>
              <div class="dashboard-account-layout">
                <article class="dashboard-account-card">
                  <div class="dashboard-account-identity">
                    <AppIconBadge icon="account" tone="navy" />
                    <div>
                      <span>{accountCenterCopy.email}</span>
                      <strong data-dashboard-account-email>--</strong>
                    </div>
                  </div>
                  <div class="dashboard-account-stats">
                    <div>
                      <span>{accountCenterCopy.plan}</span>
                      <strong data-dashboard-account-plan>--</strong>
                    </div>
                    <div>
                      <span>{accountCenterCopy.quota}</span>
                      <strong data-dashboard-account-quota>--</strong>
                    </div>
                  </div>
                </article>
                <div class="dashboard-account-actions">
                  <span>{dashboardModuleCopy.accountActions}</span>
                  <a href={hrefs.account}>
                    <AppIconBadge icon="account" size="sm" />
                    <span>{accountCenterCopy.profile}</span>
                  </a>
                  <a href="#billing-panel" data-dashboard-module-link="billing">
                    <AppIconBadge icon="membership" size="sm" tone="gold" />
                    <span>{accountCenterCopy.memberCenter}</span>
                  </a>
                  <a href={hrefs.faq}>
                    <AppIconBadge icon="help" size="sm" tone="teal" />
                    <span>{accountCenterCopy.helpCenter}</span>
                  </a>
                  <button type="button" data-dashboard-logout>
                    <AppIconBadge icon="logout" size="sm" tone="danger" />
                    <span>{accountCenterCopy.signOut}</span>
                  </button>
                </div>
              </div>
              <p
                class="dashboard-message"
                data-dashboard-account-message
                role="status"
              >
              </p>
            </section>
          </aside>
        </div>
      </div>
    </div>
  </main>
  <MobileBottomNav active="account" />

  <style>
    .dashboard-main {
      min-height: calc(100vh - 64px);
      padding: 28px 16px 56px;
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--rose-soft) 42%, transparent),
          transparent 320px
        ),
        var(--page-surface);
    }
    .dashboard-shell {
      display: grid;
      grid-template-columns: 236px minmax(0, 1fr);
      gap: 20px;
      width: min(1280px, 100%);
      margin: 0 auto;
    }
    .dashboard-rail {
      position: sticky;
      top: 82px;
      display: grid;
      align-self: start;
      height: min(680px, calc(100vh - 104px));
      min-height: min(560px, calc(100vh - 104px));
      align-content: start;
      gap: 8px;
      overflow-y: auto;
      padding: 16px;
      border: 1px solid color-mix(in srgb, var(--line) 86%, transparent);
      border-radius: 12px;
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--rose-soft) 34%, transparent),
          transparent 44%
        ),
        var(--bg-elevated);
      box-shadow:
        0 18px 42px rgba(18, 39, 66, 0.08),
        inset 0 1px 0 rgba(255, 255, 255, 0.62);
      scrollbar-width: thin;
    }
    @supports (height: 100dvh) {
      .dashboard-rail {
        height: min(680px, calc(100dvh - 104px));
        min-height: min(560px, calc(100dvh - 104px));
      }
    }
    .rail-link {
      position: relative;
      display: grid;
      grid-template-columns: 38px minmax(0, 1fr);
      gap: 12px;
      align-items: center;
      min-height: 54px;
      padding: 0 12px;
      overflow: hidden;
      border: 1px solid transparent;
      border-radius: 12px;
      color: var(--muted);
      font-size: 15px;
      font-weight: 850;
      letter-spacing: 0;
      line-height: 1.2;
      text-decoration: none;
      transition:
        background-color 180ms ease,
        border-color 180ms ease,
        color 180ms ease,
        box-shadow 180ms ease;
    }
    .rail-link::before {
      position: absolute;
      inset: 10px auto 10px 0;
      width: 3px;
      border-radius: 0 999px 999px 0;
      background: linear-gradient(180deg, var(--rose), var(--teal));
      opacity: 0;
      content: "";
      transition: opacity 180ms ease;
    }
    .rail-link :global(.app-icon-badge) {
      --app-icon-size: 34px;
      position: relative;
      z-index: 1;
      box-shadow:
        0 8px 18px color-mix(in srgb, currentColor 12%, transparent),
        inset 0 1px 0 rgba(255, 255, 255, 0.62);
      transition:
        background-color 180ms ease,
        border-color 180ms ease,
        transform 180ms ease,
        box-shadow 180ms ease;
    }
    .rail-link:hover,
    .rail-link.active {
      border-color: color-mix(in srgb, var(--rose) 22%, var(--line));
      background:
        linear-gradient(
          135deg,
          color-mix(in srgb, var(--rose-soft) 72%, var(--bg-elevated)),
          color-mix(in srgb, var(--teal-soft) 34%, var(--bg-elevated))
        );
      color: var(--navy);
      box-shadow: 0 10px 22px rgba(18, 39, 66, 0.07);
    }
    .rail-link:hover::before,
    .rail-link.active::before {
      opacity: 1;
    }
    .rail-link:hover :global(.app-icon-badge),
    .rail-link.active :global(.app-icon-badge) {
      --app-icon-bg: color-mix(
        in srgb,
        currentColor 18%,
        var(--bg-elevated)
      );
      --app-icon-border: color-mix(in srgb, currentColor 42%, var(--line));
      transform: translateY(-1px);
      box-shadow:
        0 10px 22px color-mix(in srgb, currentColor 18%, transparent),
        inset 0 1px 0 rgba(255, 255, 255, 0.7);
    }
    :global([data-theme="dark"]) .dashboard-rail {
      border-color: rgba(255, 255, 255, 0.08);
      background:
        linear-gradient(
          180deg,
          rgba(255, 151, 184, 0.08),
          transparent 44%
        ),
        var(--bg-elevated);
      box-shadow:
        0 18px 42px rgba(0, 0, 0, 0.28),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }
    :global([data-theme="dark"]) .dashboard-hero {
      border-color: rgba(255, 255, 255, 0.06);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
    }
    :global([data-theme="dark"]) .metric-card {
