  tryRecommendedLook?: string;
};

type DiagnosisCopyOptions = {
  ui: DiagnosisUiCopy;
  summaryParts: DiagnosisSummaryParts;
  labels: DiagnosisValueLabels;
  directionLabels?: Record<string, string>;
  seasonDirection: string;
  useRawDirection?: boolean;
  useStructuredSummary?: boolean;
};

type DiagnosisCopy = {
  ui: DiagnosisUiCopy;
  summaryParts: DiagnosisSummaryParts;
  labels: DiagnosisValueLabels;
  seasonDirection: string;
  useRawDirection: boolean;
  useStructuredSummary: boolean;
  directionLabels: Record<string, string>;
  directionKeywordLabels: Array<{ terms: string[]; label: string }>;
};

const makeDiagnosisCopy = ({
  ui,
  summaryParts,
  labels,
  directionLabels = {},
  seasonDirection,
  useRawDirection = false,
  useStructuredSummary = true,
}: DiagnosisCopyOptions): DiagnosisCopy => ({
  ui,
  summaryParts,
  labels,
  seasonDirection,
  useRawDirection,
  useStructuredSummary,
  directionLabels: Object.fromEntries(
    Object.entries(diagnosisDirectionTitleKeys)
      .map(([title, key]) => [title, directionLabels[key]])
      .filter(([, label]) => Boolean(label)),
  ),
  directionKeywordLabels: diagnosisDirectionRules
    .map((rule) => ({
      terms: rule.terms,
      label: directionLabels[rule.key],
    }))
    .filter((rule) => Boolean(rule.label)),
});

