  </style>

  <script
    is:inline
    define:vars={{
      accountCenterCopy,
      avatarCopy,
      copy,
      dashboardModuleCopy,
      diagnosisCopy,
      diagnosisValueAliases,
      hrefs,
      marketOptions,
      planNames,
      recommendations,
    }}
  >
    (() => {
      const root = document.querySelector("[data-dashboard]");
      if (!root) return;

      const savedLookLimitByPlan = { free: 10, pro: 30, premium: 100 };
      const defaultMarketOptions = Array.isArray(marketOptions)
        ? marketOptions
        : [];
      const workspaceByPlan = {
        free: hrefs.tryonFree,
        pro: hrefs.tryonPro,
        premium: hrefs.tryonPremium,
      };
      const resultHrefForJob = (jobId) => {
        if (!jobId) return workspaceHref;
        const base = String(hrefs.resultBase || "/result").replace(/\/+$/, "");
        return `${base}/${encodeURIComponent(jobId)}`;
      };
      const runningStatuses = new Set([
        "created",
        "upload_validating",
        "diagnosis_running",
        "image_running",
      ]);
      const recommendationBySlug = new Map(
        recommendations.map((look) => [look.slug, look]),
      );
      const fallbackDiagnosisLabels = {
        faceShape: {
          oval: "oval",
          round: "round",
          square: "square",
          heart: "heart",
          oblong: "oblong",
          diamond: "diamond",
          uncertain: "uncertain",
        },
      };
      const diagnosisUi = {
        latestReport: "Latest report",
        emptyDiagnosisBody:
          "Complete one diagnosis and this card will keep your tone, face shape, color direction, and next recommended look.",
        skinTone: "Skin tone",
        faceShape: "Face shape",
        colorDirection: "Color direction",
        viewFullReport: "View full report",
        rerunDiagnosis: "Run again",
        tryRecommendedLook: "Try recommended look",
        ...diagnosisCopy.ui,
      };
      let workspaceHref = hrefs.tryonFree;
      const pageParams = new URLSearchParams(window.location.search);
      const checkoutSucceeded = pageParams.get("checkout") === "success";
      const dashboardWideQuery = window.matchMedia("(min-width: 1061px)");
      const historyDesktopQuery = window.matchMedia("(min-width: 768px)");
      let latestHistoryJobs = [];
      let hasRenderedHistory = false;
      let savedResultCount = 0;
      let favoriteLookCount = Number(window.__absFavoriteLookCount ?? 0) || 0;

      const query = (selector) => root.querySelector(selector);
      const setText = (selector, value) => {
        const node = query(selector);
        if (node) node.textContent = value;
      };
      const clear = (node) => {
        if (node) node.replaceChildren();
      };
      const applyDashboardAvatar = (avatarUrl) => {
        const image = query("[data-dashboard-account-avatar]");
        const fallback = query("[data-dashboard-avatar-fallback]");
        if (!image || !fallback) return;
        if (!avatarUrl) {
          image.hidden = true;
          image.removeAttribute("src");
          fallback.hidden = false;
          return;
        }
        image.onload = () => {
          image.hidden = false;
          fallback.hidden = true;
        };
        image.onerror = () => {
          image.hidden = true;
          fallback.hidden = false;
        };
        image.src = avatarUrl;
      };
      const dashboardNavLinks = Array.from(
        root.querySelectorAll("[data-dashboard-nav-link]"),
      );
      const dashboardViewByHash = new Map([
        ["#overview", "overview"],
        ["#history-panel", "history"],
        ["#saved-panel", "saved"],
        ["#preferences-panel", "preferences"],
        ["#billing-panel", "billing"],
        ["#account-panel", "account"],
      ]);
      const dashboardMobileTabLinks = Array.from(
        document.querySelectorAll(
          '[data-mobile-app-topbar] .mobile-app-tabs a[href^="#"]',
        ),
      ).filter((link) =>
        dashboardViewByHash.has(link.getAttribute("href") || ""),
      );
      const dashboardMobileTabOverflowGroups = Array.from(
        document.querySelectorAll(
          "[data-mobile-app-topbar] [data-mobile-tab-overflow]",
        ),
      );
      const formatDate = (value) => {
        if (!value) return "";
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return "";
        return new Intl.DateTimeFormat(
          document.documentElement.lang || undefined,
          {
            month: "short",
            day: "numeric",
          },
        ).format(date);
      };
      const fallbackLook = (slug) =>
        recommendationBySlug.get(slug) || recommendations[0] || {};
      const renderSavedMetric = () => {
        setText(
          "[data-saved-count]",
          String(Math.max(0, savedResultCount + favoriteLookCount)),
        );
      };
      const getJson = async (url) => {
        const response = await fetch(url);
        const body = await response.json().catch(() => null);
        if (!response.ok || !body?.ok) {
          throw new Error(body?.error?.message || "REQUEST_FAILED");
        }
        return body.data;
      };
      const delay = (ms) =>
        new Promise((resolve) => window.setTimeout(resolve, ms));

      function setActiveDashboardSection(hash) {
        if (!hash) return;
        [...dashboardNavLinks, ...dashboardMobileTabLinks].forEach((link) => {
          const isActive = link.getAttribute("href") === hash;
          link.classList.toggle("active", isActive);
          if (isActive) {
            link.setAttribute("aria-current", "page");
          } else {
            link.removeAttribute("aria-current");
          }
        });
        dashboardMobileTabOverflowGroups.forEach((group) => {
          const isActive = Array.from(
            group.querySelectorAll('a[href^="#"]'),
          ).some((link) => link.getAttribute("href") === hash);
          group.classList.toggle("active", isActive);
        });
      }

      function normalizeDashboardHash(hash) {
        return dashboardViewByHash.has(hash) ? hash : "#overview";
      }

      function setDashboardView(hash, options = {}) {
        const normalizedHash = normalizeDashboardHash(hash);
        const view = dashboardViewByHash.get(normalizedHash) || "overview";
        root.dataset.activeView = view;
        setActiveDashboardSection(normalizedHash);
        if (
          options.updateHash !== false &&
          window.location.hash !== normalizedHash
        ) {
          history.replaceState(null, "", normalizedHash);
        }
        if (options.scroll) {
          root.scrollIntoView({ block: "start", behavior: "smooth" });
        }
      }

      dashboardNavLinks.forEach((link) => {
        link.addEventListener("click", (event) => {
          const href = link.getAttribute("href") || "";
          if (dashboardViewByHash.has(href)) {
            if (dashboardWideQuery.matches) {
              event.preventDefault();
              setDashboardView(href, { scroll: true });
            } else {
              setDashboardView(href, { updateHash: false });
            }
          }
        });
      });
      dashboardMobileTabLinks.forEach((link) => {
        link.addEventListener("click", (event) => {
          const href = link.getAttribute("href") || "";
          if (!dashboardViewByHash.has(href)) return;
          event.preventDefault();
          setDashboardView(href, { scroll: true });
        });
      });
      root.querySelectorAll("[data-dashboard-module-link]").forEach((link) => {
        link.addEventListener("click", (event) => {
          const href = link.getAttribute("href") || "";
          if (!dashboardViewByHash.has(href)) return;
          if (dashboardWideQuery.matches) {
            event.preventDefault();
            setDashboardView(href, { scroll: true });
          }
        });
      });
      window.addEventListener("hashchange", () => {
        setDashboardView(window.location.hash, { updateHash: false });
      });
      dashboardWideQuery.addEventListener("change", (event) => {
        if (event.matches) {
          setDashboardView(window.location.hash, { updateHash: false });
        } else {
          setDashboardView(window.location.hash, { updateHash: false });
        }
      });
      setDashboardView(window.location.hash, { updateHash: false });

      async function getSessionWithCheckoutRefresh() {
        let session = await getJson("/api/session");
        if (!checkoutSucceeded || session?.plan !== "free") return session;

        for (let attempt = 0; attempt < 6; attempt += 1) {
          await delay(1500);
          const nextSession = await getJson("/api/session");
          session = nextSession;
          if (nextSession?.plan && nextSession.plan !== "free") break;
        }
        return session;
      }
      const formatDiagnosisPart = (template, value) =>
        template && value ? template.replace("{value}", value) : "";
      function labelDiagnosisValue(group, value) {
        const rawValue = String(value || "").trim();
        if (!rawValue) return "";
        const normalizedValue = rawValue.toLowerCase().replace(/_/g, "-");
        const labelMap = diagnosisCopy.labels?.[group] || {};
        const aliasMap = diagnosisValueAliases?.[group] || {};
        const direct =
          labelMap[rawValue] ||
          labelMap[normalizedValue] ||
          aliasMap[rawValue] ||
          aliasMap[normalizedValue] ||
          fallbackDiagnosisLabels[group]?.[rawValue] ||
          fallbackDiagnosisLabels[group]?.[normalizedValue];
        if (direct) return direct;
        if (normalizedValue.includes("-")) {
          const parts = normalizedValue
            .split("-")
            .map((part) => labelMap[part] || aliasMap[part])
            .filter(Boolean);
          if (parts.length >= 2) return parts.join(" / ");
        }
        return rawValue;
      }
      const normalizeDiagnosisText = (value) =>
        String(value || "")
          .toLowerCase()
          .replace(/[\u2010-\u2015]/g, "-")
          .replace(/[^a-z0-9\s-]/g, " ")
          .replace(/\s+/g, " ")
          .trim();

      function formatDiagnosisSummary(diagnosis) {
        const partsCopy = diagnosisCopy.summaryParts || {};
        const parts = [
          formatDiagnosisPart(
            partsCopy.skinDepth,
            labelDiagnosisValue("skinDepth", diagnosis.skinTone?.depth),
          ),
          formatDiagnosisPart(
            partsCopy.undertone,
            labelDiagnosisValue("undertone", diagnosis.skinTone?.undertone),
          ),
          formatDiagnosisPart(
            partsCopy.season,
            labelDiagnosisValue("season", diagnosis.colorSeason?.season),
          ),
        ].filter(Boolean);
        if (diagnosisCopy.useStructuredSummary !== false && parts.length) {
          return `${parts.join(partsCopy.separator || ", ")}${
            partsCopy.suffix || ""
          }`;
        }
        const rawSummary =
          diagnosis.skinTone?.summary || diagnosis.colorSeason?.rationale || "";
        if (rawSummary) return rawSummary;
        if (parts.length) {
          return `${parts.join(partsCopy.separator || ", ")}${
            partsCopy.suffix || ""
          }`;
        }
        return diagnosisCopy.ui.panelTitle;
      }

      function localizeDiagnosisDirection(title) {
        const normalized = normalizeDiagnosisText(title);
        if (!normalized) return "";
        const direct = diagnosisCopy.directionLabels?.[normalized];
        if (direct) return direct;
        const keywordRules = Array.isArray(diagnosisCopy.directionKeywordLabels)
          ? diagnosisCopy.directionKeywordLabels
          : [];
        const matchedRule = keywordRules.find((rule) =>
          rule.terms?.every((term) => normalized.includes(term)),
        );
        if (matchedRule?.label) return matchedRule.label;
        return diagnosisCopy.useRawDirection ? title : "";
      }

      function formatDiagnosisDirection(diagnosis) {
        const title = localizeDiagnosisDirection(
          diagnosis.makeupDirections?.[0]?.title,
        );
        if (title) return title;
        const season = labelDiagnosisValue(
          "season",
          diagnosis.colorSeason?.season,
        );
        if (season && diagnosisCopy.seasonDirection) {
          return diagnosisCopy.seasonDirection.replace("{season}", season);
        }
        return diagnosisCopy.ui.noPreference;
      }

      function formatDiagnosisSkinTone(diagnosis) {
        const undertone = labelDiagnosisValue(
          "undertone",
          diagnosis.skinTone?.undertone,
        );
        const depth = labelDiagnosisValue(
          "skinDepth",
          diagnosis.skinTone?.depth,
        );
        return (
          [undertone, depth].filter(Boolean).join(" / ") ||
          diagnosisUi.noPreference
        );
      }

      function formatDiagnosisConfidence(diagnosis) {
        const confidenceScore = Number(
          typeof diagnosis.confidence === "number"
            ? diagnosis.confidence
            : diagnosis.confidence?.overall,
        );
        return Number.isFinite(confidenceScore)
          ? `${Math.round(confidenceScore * 100)}%`
          : diagnosisUi.noPreference;
      }

      function getRecommendedLook(record, diagnosis) {
        const jobLook = recommendationBySlug.get(record?.lookSlug);
        if (jobLook) return jobLook;

        const directionText = normalizeDiagnosisText(
          (diagnosis.makeupDirections || [])
            .flatMap((direction) => [
              direction.title,
              direction.rationale,
              ...(direction.palette || []),
            ])
            .join(" "),
        );
        if (!directionText) return recommendations[0] || {};

        const scored = recommendations
          .map((look) => {
            const haystack = normalizeDiagnosisText(
              [look.title, look.intent, ...(look.finish || [])].join(" "),
            );
            const score = directionText
              .split(" ")
              .filter(
                (word) => word.length > 2 && haystack.includes(word),
              ).length;
            return { look, score };
          })
          .sort((a, b) => b.score - a.score);

        return scored[0]?.look || recommendations[0] || {};
      }

      function makeLookHref(look) {
        if (!look?.slug) return workspaceHref;
        const separator = workspaceHref.includes("?") ? "&" : "?";
        return `${workspaceHref}${separator}look=${encodeURIComponent(look.slug)}`;
      }

      function setWorkspaceLinks(plan) {
        workspaceHref = workspaceByPlan[plan] || hrefs.tryonFree;
        root.querySelectorAll("[data-workspace-href]").forEach((link) => {
          link.setAttribute("href", workspaceHref);
        });
        root.querySelectorAll("[data-primary-workspace]").forEach((link) => {
          link.setAttribute("href", workspaceHref);
        });
      }

      function setDiagnosisHeadAction(visible) {
        const action = query("[data-diagnosis-head-action]");
        if (!action) return;
        action.toggleAttribute("hidden", !visible);
        if (visible) {
          action.setAttribute("href", `${hrefs.diagnosis}#diagnosis-new`);
          action.textContent =
            diagnosisUi.rerunDiagnosis || diagnosisUi.runDiagnosis;
        }
      }

      function renderEmpty(target, message, actionLabel, actionHref) {
        clear(target);
        const box = document.createElement("div");
        box.className = "empty-state";
        const text = document.createElement("span");
        text.textContent = message;
        box.append(text);
        if (actionLabel && actionHref) {
          const link = document.createElement("a");
          link.href = actionHref;
          link.className = "btn btn-primary empty-state-action";
          link.textContent = actionLabel;
          box.append(link);
        }
        target?.append(box);
      }

      function renderDiagnosisEmpty(target) {
        setDiagnosisHeadAction(false);
        clear(target);
        const box = document.createElement("article");
        box.className = "dashboard-diagnosis-entry";
        const main = document.createElement("div");
        main.className = "dashboard-diagnosis-main";
        const badge = document.createElement("span");
        badge.className = "dashboard-diagnosis-badge";
        badge.textContent = "AI";
        const title = document.createElement("h3");
        title.textContent =
          dashboardModuleCopy.diagnosisEmptyTitle || diagnosisUi.emptyDiagnosis;
        const body = document.createElement("p");
        body.textContent =
          diagnosisUi.emptyDiagnosisBody || diagnosisUi.emptyDiagnosis;
        const link = document.createElement("a");
        link.href = hrefs.diagnosis;
        link.className = "btn btn-primary dashboard-diagnosis-cta";
        link.textContent = diagnosisUi.runDiagnosis;
        main.append(badge, title, body, link);
        const capability = document.createElement("div");
        capability.className = "dashboard-diagnosis-capabilities";
        const capabilityTitle = document.createElement("span");
        capabilityTitle.textContent = dashboardModuleCopy.diagnosisCapabilities;
        const capabilityList = document.createElement("div");
        [
          dashboardModuleCopy.diagnosisCapabilityTone,
          dashboardModuleCopy.diagnosisCapabilityFace,
          dashboardModuleCopy.diagnosisCapabilityLook,
        ].forEach((item) => {
          const pill = document.createElement("b");
          pill.textContent = item;
          capabilityList.append(pill);
        });
        capability.append(capabilityTitle, capabilityList);
        box.append(main, capability);
        target?.append(box);
      }

      function renderHistory(items) {
        const target = query("[data-history-list]");
        const actions = query("[data-history-actions]");
        const jobs = Array.isArray(items) ? items : [];
        latestHistoryJobs = jobs;
        hasRenderedHistory = true;
        setText(
          "[data-result-count]",
          String(jobs.filter((job) => job?.status === "succeeded").length),
        );
        if (!target) return;
        if (!jobs.length) {
          if (actions) actions.hidden = true;
          renderEmpty(target, copy.emptyHistory);
          return;
        }
        if (actions) actions.hidden = false;
        clear(target);
        const visibleLimit = historyDesktopQuery.matches ? 6 : 4;
        jobs.slice(0, visibleLimit).forEach((job) => {
          const fallback = fallbackLook(job?.lookSlug);
          const item = document.createElement("a");
          item.className = "history-item";
          item.href = resultHrefForJob(job?.id);

          const image = document.createElement("img");
          image.src =
            job?.resultThumbImage ||
            job?.resultDisplayImage ||
            job?.resultImage ||
            fallback.image ||
            "";
          image.alt = job?.lookTitle || fallback.title || copy.unknownLook;
          image.loading = "lazy";
          image.decoding = "async";

          const copyNode = document.createElement("div");
          copyNode.className = "history-copy";
          const title = document.createElement("strong");
          title.textContent =
            job?.lookTitle || fallback.title || copy.unknownLook;
          const meta = document.createElement("span");
          meta.textContent = formatDate(job?.createdAt);
          copyNode.append(title, meta);

          const status = document.createElement("span");
          const statusState =
            job?.status === "succeeded"
              ? "succeeded"
              : runningStatuses.has(job?.status)
                ? "running"
                : "failed";
          status.className = "history-status";
          status.dataset.state = statusState;
          status.textContent =
            statusState === "succeeded"
              ? copy.statusSucceeded
              : statusState === "running"
                ? copy.statusRunning
                : copy.statusFailed;

          item.append(image, copyNode, status);
          target.append(item);
        });
      }

      const rerenderHistoryForViewport = () => {
        if (hasRenderedHistory) renderHistory(latestHistoryJobs);
      };

      historyDesktopQuery.addEventListener(
        "change",
        rerenderHistoryForViewport,
      );

      document.addEventListener("abs:favorite-looks-changed", (event) => {
        const count = Number(event.detail?.count);
        if (!Number.isFinite(count)) return;
        favoriteLookCount = Math.max(0, count);
        renderSavedMetric();
      });

      function renderFavoriteLooks(items) {
        favoriteLookCount = Array.isArray(items) ? items.length : 0;
        renderSavedMetric();
      }

      function renderSaved(items) {
        const target = query("[data-saved-list]");
        const saved = Array.isArray(items) ? items : [];
        savedResultCount = saved.length;
        renderSavedMetric();
        if (!target) return;
        if (!saved.length) {
          renderEmpty(target, copy.emptySaved, copy.startTryon, workspaceHref);
          return;
        }
        clear(target);
        saved.slice(0, 4).forEach((item) => {
          const job = item?.jobDetails || {};
          const fallback = fallbackLook(item?.lookSlug || job.lookSlug);
          const card = document.createElement("article");
          card.className = "saved-look";
          const link = document.createElement("a");
          link.className = "saved-look-open";
          link.href = resultHrefForJob(job.id || item.jobId);

          const image = document.createElement("img");
          image.src =
            job.resultThumbImage ||
            job.resultDisplayImage ||
            job.resultImage ||
            fallback.image ||
            "";
          image.alt = job.lookTitle || fallback.title || copy.unknownLook;
          image.loading = "lazy";
          image.decoding = "async";

          const title = document.createElement("strong");
          title.textContent =
            job.lookTitle || fallback.title || copy.unknownLook;
          const meta = document.createElement("span");
          meta.textContent = formatDate(item?.createdAt);

          const remove = document.createElement("button");
          remove.className = "saved-look-remove";
          remove.type = "button";
          remove.textContent = copy.removeSaved;
          remove.addEventListener("click", async () => {
            remove.disabled = true;
            try {
              const res = await fetch("/api/saved-looks/" + item.jobId, {
                method: "DELETE",
              });
              const data = await res.json().catch(() => null);
              if (!res.ok || !data?.ok) throw new Error("UNSAVE_FAILED");
              hydrateDashboard();
            } catch {
              remove.disabled = false;
            }
          });

          link.append(image, title, meta);
          card.append(link, remove);
          target.append(card);
        });
      }

      function renderDiagnosis(items) {
        const target = query("[data-diagnosis-summary]");
        const records = Array.isArray(items) ? items : [];
        if (!target) return;
        if (!records.length) {
          renderDiagnosisEmpty(target);
          return;
        }
        const latest = records[0];
        const diagnosis = latest?.diagnosis || {};
        const recommendedLook = getRecommendedLook(latest, diagnosis);
        const primaryDirection = diagnosis.makeupDirections?.[0] || {};
        setDiagnosisHeadAction(true);
        clear(target);

        const profile = document.createElement("article");
        profile.className = "diagnosis-profile";

        const head = document.createElement("div");
        head.className = "diagnosis-profile-head";
        const badge = document.createElement("span");
        badge.className = "diagnosis-profile-badge";
        badge.textContent = diagnosisUi.latestReport;
        const meta = document.createElement("span");
        meta.className = "diagnosis-profile-date";
        meta.textContent = formatDate(latest?.createdAt);
        head.append(badge, meta);

        const lead = document.createElement("div");
        lead.className = "diagnosis-profile-lead";
        const title = document.createElement("h3");
        title.textContent = formatDiagnosisSummary(diagnosis);
        const summary = document.createElement("p");
        summary.textContent =
          diagnosis.colorSeason?.rationale ||
          diagnosis.skinTone?.summary ||
          formatDiagnosisDirection(diagnosis);
        lead.append(title, summary);

        const metrics = document.createElement("div");
        metrics.className = "diagnosis-profile-grid";
        [
          [diagnosisUi.skinTone, formatDiagnosisSkinTone(diagnosis)],
          [
            diagnosisUi.faceShape,
            labelDiagnosisValue("faceShape", diagnosis.faceShape?.primary) ||
              diagnosisUi.noPreference,
          ],
          [
            diagnosisUi.colorDirection,
            labelDiagnosisValue("season", diagnosis.colorSeason?.season) ||
              diagnosisUi.noPreference,
          ],
          [diagnosisUi.confidence, formatDiagnosisConfidence(diagnosis)],
        ].forEach(([label, value]) => {
          const tile = document.createElement("div");
          tile.className = "diagnosis-profile-metric";
          const tileLabel = document.createElement("span");
          tileLabel.textContent = label;
          const tileValue = document.createElement("strong");
          tileValue.textContent = value;
          tile.append(tileLabel, tileValue);
          metrics.append(tile);
        });

        const direction = document.createElement("div");
        direction.className = "diagnosis-direction";
        const directionLabel = document.createElement("span");
        directionLabel.textContent = diagnosisUi.recommended;
        const directionTitle = document.createElement("strong");
        directionTitle.textContent = formatDiagnosisDirection(diagnosis);
        direction.append(directionLabel, directionTitle);
        if (primaryDirection.rationale) {
          const rationale = document.createElement("p");
          rationale.textContent = primaryDirection.rationale;
          direction.append(rationale);
        }
        if (primaryDirection.palette?.length) {
          const palette = document.createElement("div");
          palette.className = "diagnosis-palette";
          primaryDirection.palette.slice(0, 5).forEach((color) => {
            const tag = document.createElement("i");
            tag.textContent = color;
            palette.append(tag);
          });
          direction.append(palette);
        }

        const actions = document.createElement("div");
        actions.className = "diagnosis-actions inline-actions";
        [
          [diagnosisUi.viewFullReport, hrefs.diagnosis, "btn btn-primary"],
          [
            diagnosisUi.tryRecommendedLook,
            makeLookHref(recommendedLook),
            "btn btn-outline-rose",
          ],
        ].forEach(([label, href, className]) => {
          const link = document.createElement("a");
          link.className = className;
          link.href = href;
          link.textContent = label;
          actions.append(link);
        });

        profile.append(head, lead, metrics, direction, actions);
        target.append(profile);
      }

      function renderPreferences(data) {
        const audience = data?.audienceContext || {};
        const responseMarketOptions = Array.isArray(data?.marketOptions)
          ? data.marketOptions
          : [];
        const effectiveMarketOptions =
          responseMarketOptions.length > 0
            ? responseMarketOptions
            : defaultMarketOptions;
        const marketLabel =
          effectiveMarketOptions.find(
            (option) => option.value === audience.marketProfile,
          )?.label || copy.noPreference;
        const representation = Array.isArray(audience.representationPreference)
          ? audience.representationPreference
              .map(
                (value) =>
                  accountCenterCopy.preferences?.representationLabels?.[
                    value
                  ] ||
                  copy.representationLabels?.[value] ||
                  value,
              )
              .join(", ")
          : copy.noPreference;
        setText("[data-market-profile]", marketLabel);
        setText("[data-representation-preference]", representation);

        const marketSelect = query("[data-dashboard-market-select]");
        if (marketSelect && audience.marketProfile) {
          marketSelect.value = audience.marketProfile;
        }
        const preferences = Array.isArray(audience.representationPreference)
          ? audience.representationPreference
          : ["diverse"];
        root
          .querySelectorAll(
            '[data-dashboard-preferences] input[name="representationPreference"]',
          )
          .forEach((input) => {
            input.checked = preferences.includes(input.value);
          });
      }

      function applySession(data) {
        const plan =
          data?.plan === "pro" || data?.plan === "premium" ? data.plan : "free";
        setWorkspaceLinks(plan);
        const email = data?.user?.email || "";
        const planLabel = planNames[plan] || plan;
        const isPaid = plan === "pro" || plan === "premium";
        const planCard = query("[data-plan-card]");
        if (planCard) planCard.dataset.plan = plan;
        setText(
          "[data-dashboard-email]",
          email ? `${copy.signedInAs} ${email}` : copy.signedInAs,
        );
        setText("[data-plan-value]", planLabel);
        const quota = data?.quota;
        const quotaLabel = quota
          ? `${quota.remaining ?? 0}/${quota.total ?? 0}`
          : "--";
        setText("[data-quota-value]", quotaLabel);
        setText("[data-dashboard-account-email]", email || "--");
        setText("[data-dashboard-account-plan]", planLabel);
        setText("[data-dashboard-account-quota]", quotaLabel);
        applyDashboardAvatar(data?.user?.avatarUrl);
        setText("[data-billing-plan]", planLabel);
        setText("[data-billing-quota]", quotaLabel);
        setText(
          "[data-billing-saved-limit]",
          String(savedLookLimitByPlan[plan] ?? savedLookLimitByPlan.free),
        );

        const billingCard = query("[data-billing-plan-card]");
        if (billingCard) billingCard.dataset.plan = plan;
        const billingMeter = query("[data-billing-meter]");
        if (billingMeter) {
          const total = Number(quota?.total ?? 0);
          const remaining = Number(quota?.remaining ?? 0);
          const percent =
            total > 0
              ? Math.max(0, Math.min(100, (remaining / total) * 100))
              : 0;
          billingMeter.style.width = `${percent}%`;
        }
        const refreshText = quota?.nextRefreshAt
          ? `${dashboardModuleCopy.billingRefresh}: ${formatDate(quota.nextRefreshAt)}`
          : dashboardModuleCopy.billingRefreshFallback;
        setText("[data-billing-refresh]", refreshText);
        setText(
          "[data-billing-benefit-main]",
          isPaid
            ? dashboardModuleCopy.billingPaidBenefit
            : dashboardModuleCopy.billingFreeBenefit,
        );

        query("[data-manage-billing]")?.toggleAttribute("hidden", !isPaid);
        query("[data-plan-upgrade]")?.toggleAttribute("hidden", isPaid);
        setText(
          "[data-billing-note]",
          isPaid ? copy.paidPlanNote : copy.freePlanNote,
        );
      }

      async function hydrateDashboard() {
        try {
          const session = await getSessionWithCheckoutRefresh();
          if (!session?.user || session.user.kind !== "account") {
            query("[data-dashboard-gate]")?.removeAttribute("hidden");
            window.location.href = hrefs.login;
            return;
          }
          applySession(session);
        } catch {
          query("[data-dashboard-gate]")?.removeAttribute("hidden");
          return;
        }

        const [jobs, saved, favoriteLooks, diagnoses, preferences] =
          await Promise.allSettled([
            getJson("/api/tryon-jobs?limit=20"),
            getJson("/api/saved-looks"),
            getJson("/api/favorite-looks"),
            getJson("/api/diagnoses"),
            getJson("/api/content-preferences"),
          ]);

        if (jobs.status === "fulfilled") renderHistory(jobs.value?.items);
        else {
          setText("[data-result-count]", "0");
          query("[data-history-actions]")?.setAttribute("hidden", "");
          renderEmpty(query("[data-history-list]"), copy.loadFailed);
        }

        if (saved.status === "fulfilled") renderSaved(saved.value?.items);
        else {
          savedResultCount = 0;
          renderSavedMetric();
          renderEmpty(query("[data-saved-list]"), copy.loadFailed);
        }

        if (favoriteLooks.status === "fulfilled") {
          renderFavoriteLooks(favoriteLooks.value?.items);
        } else {
          favoriteLookCount = Number(window.__absFavoriteLookCount ?? 0) || 0;
          renderSavedMetric();
        }

        if (diagnoses.status === "fulfilled")
          renderDiagnosis(diagnoses.value?.items);
        else {
          setDiagnosisHeadAction(false);
          renderEmpty(
            query("[data-diagnosis-summary]"),
            diagnosisCopy.ui.loadFailed,
          );
        }

        if (preferences.status === "fulfilled")
          renderPreferences(preferences.value);
      }

      query("[data-manage-billing]")?.addEventListener("click", async () => {
        const message = query("[data-dashboard-message]");
        if (message) message.textContent = "";
        try {
          const response = await fetch("/api/billing/portal", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              returnPath: `${window.location.pathname}${
                window.location.hash || "#billing-panel"
              }`,
            }),
          });
          const body = await response.json().catch(() => null);
          if (body?.ok && body.data?.url) {
            window.location.href = body.data.url;
            return;
          }
          throw new Error(body?.error?.message || copy.portalFailed);
        } catch (error) {
          if (message) message.textContent = error.message || copy.portalFailed;
        }
      });

      query("[data-dashboard-logout]")?.addEventListener("click", async () => {
        const button = query("[data-dashboard-logout]");
        const message = query("[data-dashboard-account-message]");
        if (button) button.disabled = true;
        if (message) message.textContent = accountCenterCopy.signingOut;
        try {
          const response = await fetch("/api/auth/logout", { method: "POST" });
          if (!response.ok) throw new Error("LOGOUT_FAILED");
          window.location.href = hrefs.home;
        } catch {
          if (button) button.disabled = false;
          if (message) message.textContent = accountCenterCopy.signOutFailed;
        }
      });
      const avatarButton = query("[data-dashboard-avatar-button]");
      const avatarInput = query("[data-dashboard-avatar-input]");
      avatarButton?.addEventListener("click", () => avatarInput?.click());
      avatarInput?.addEventListener("change", async () => {
        const file = avatarInput.files?.[0];
        avatarInput.value = "";
        if (!file) return;

        const status = query("[data-dashboard-account-message]");
        const supportedTypes = new Set([
          "image/jpeg",
          "image/png",
          "image/webp",
        ]);
        if (!supportedTypes.has(file.type) || file.size > 20 * 1024 * 1024) {
          if (status) status.textContent = avatarCopy.invalid;
          return;
        }

        avatarButton.disabled = true;
        if (status) status.textContent = avatarCopy.uploading;
        try {
          const blob = await compressAvatarToWebp(file);
          const form = new FormData();
          form.set("avatar", blob, "avatar.webp");
          const response = await fetch("/api/profile/avatar", {
            method: "PUT",
            body: form,
          });
          const body = await response.json().catch(() => null);
          if (!response.ok || !body?.ok || !body.data?.avatarUrl) {
            throw new Error("UPLOAD_FAILED");
          }
          applyDashboardAvatar(body.data.avatarUrl);
          document.dispatchEvent(
            new CustomEvent("profile-avatar-updated", {
              detail: { avatarUrl: body.data.avatarUrl },
            }),
          );
          if (status) status.textContent = avatarCopy.success;
        } catch {
          if (status) status.textContent = avatarCopy.failed;
        } finally {
          avatarButton.disabled = false;
        }
      });

      async function compressAvatarToWebp(file) {
        const source = await loadAvatarImage(file);
        const width = source.width || source.naturalWidth;
        const height = source.height || source.naturalHeight;
        if (!width || !height) throw new Error("INVALID_IMAGE");

        const side = Math.min(width, height);
        const sourceX = (width - side) / 2;
        const sourceY = (height - side) / 2;
        const canvas = document.createElement("canvas");
        canvas.width = 256;
        canvas.height = 256;
        const context = canvas.getContext("2d");
        if (!context) throw new Error("CANVAS_UNAVAILABLE");
        context.drawImage(source, sourceX, sourceY, side, side, 0, 0, 256, 256);
        source.close?.();

        const blob = await new Promise((resolve, reject) => {
          canvas.toBlob(
            (result) =>
              result?.type === "image/webp"
                ? resolve(result)
                : reject(new Error("WEBP_UNAVAILABLE")),
            "image/webp",
            0.82,
          );
        });
        if (blob.size > 512 * 1024) throw new Error("AVATAR_TOO_LARGE");
        return blob;
      }

      async function loadAvatarImage(file) {
        if ("createImageBitmap" in window) {
          try {
            return await createImageBitmap(file, {
              imageOrientation: "from-image",
            });
          } catch {
            return await createImageBitmap(file);
          }
        }
        return await new Promise((resolve, reject) => {
          const image = new Image();
          const url = URL.createObjectURL(file);
          image.onload = () => {
            URL.revokeObjectURL(url);
            resolve(image);
          };
          image.onerror = () => {
            URL.revokeObjectURL(url);
            reject(new Error("INVALID_IMAGE"));
          };
          image.src = url;
        });
      }
      query("[data-dashboard-theme-shortcut]")?.addEventListener(
        "click",
        () => {
          document.getElementById("theme-toggle")?.click();
        },
      );

      const preferenceForm = query("[data-dashboard-preferences]");
      const preferenceStatus = query("[data-dashboard-preference-status]");
      const representationInputs = preferenceForm
        ? [
            ...preferenceForm.querySelectorAll(
              'input[name="representationPreference"]',
            ),
          ]
        : [];
      const diverseRepresentationInput = representationInputs.find(
        (input) => input.value === "diverse",
      );
      representationInputs.forEach((input) => {
        input.addEventListener("change", () => {
          if (input.value === "diverse" && input.checked) {
            representationInputs.forEach((candidate) => {
              if (candidate !== input) candidate.checked = false;
            });
            return;
          }
          if (input.checked && diverseRepresentationInput) {
            diverseRepresentationInput.checked = false;
          }
          if (
            diverseRepresentationInput &&
            !representationInputs.some((candidate) => candidate.checked)
          ) {
            diverseRepresentationInput.checked = true;
          }
        });
      });
      preferenceForm?.addEventListener("submit", async (event) => {
        event.preventDefault();
        const submit = preferenceForm.querySelector('[type="submit"]');
        const formData = new FormData(preferenceForm);
        let representationPreferences = formData.getAll(
          "representationPreference",
        );
        if (representationPreferences.length === 0) {
          representationPreferences = ["diverse"];
        }
        if (representationPreferences.includes("diverse")) {
          representationPreferences = ["diverse"];
        }
        if (submit) submit.disabled = true;
        if (preferenceStatus) {
          preferenceStatus.textContent = accountCenterCopy.preferences.saving;
        }
        try {
          const response = await fetch("/api/content-preferences", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              marketProfile: formData.get("marketProfile"),
              representationPreferences,
            }),
          });
          const body = await response.json().catch(() => null);
          if (!response.ok || !body?.ok) throw new Error("SAVE_FAILED");
          renderPreferences(body.data);
          if (preferenceStatus) {
            preferenceStatus.textContent = accountCenterCopy.preferences.saved;
          }
        } catch {
          if (preferenceStatus) {
            preferenceStatus.textContent =
              accountCenterCopy.preferences.saveFailed;
          }
        } finally {
          if (submit) submit.disabled = false;
        }
      });

      if (checkoutSucceeded) {
        const message = query("[data-dashboard-message]");
        if (message) message.textContent = copy.checkoutSuccess;
      }

      hydrateDashboard();
    })();
  </script>
</BaseLayout>
