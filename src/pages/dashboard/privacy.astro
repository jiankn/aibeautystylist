---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout
  pageKey="privacy"
  pageHeading="Privacy & Data"
  pageDescription="Your photo, your control. Delete data anytime."
>
  <div class="dashboard-privacy">
    <!-- 隐私承诺 -->
    <article class="dashboard-card">
      <p class="dashboard-card-eyebrow">Our promise</p>
      <ul class="privacy-promise-list">
        <li>Your photos are used <strong>only</strong> to generate your diagnoses.</li>
        <li>We <strong>never</strong> train AI models on your photos.</li>
        <li>You can delete your data at any time, and inactive photos auto-delete within 24 hours.</li>
      </ul>
      <p class="dashboard-card-note">
        Read our full <a href="/privacy">Privacy Policy</a> and <a href="/terms">Terms of Service</a>.
      </p>
    </article>

    <!-- Action 1: 删除试妆历史 -->
    <article class="dashboard-card">
      <p class="dashboard-card-eyebrow">Try-on history</p>
      <h2 class="dashboard-card-title">Delete all try-on records</h2>
      <p>
        Removes every diagnosis, look, and tutorial linked to your account.
        Your account, subscription, and saved preferences are kept.
      </p>
      <div class="dashboard-card-actions">
        <button class="btn btn-secondary" type="button" data-action="delete-history">
          Delete try-on history
        </button>
      </div>
      <p class="dashboard-card-note" data-history-status hidden></p>
    </article>

    <!-- Action 2: 删除账号（危险区） -->
    <article class="dashboard-card dashboard-card-danger">
      <p class="dashboard-card-eyebrow danger-eyebrow">Danger zone</p>
      <h2 class="dashboard-card-title">Delete account permanently</h2>
      <p>
        This removes <strong>everything</strong>: profile, sessions, try-on history,
        subscriptions records, and login credentials. <strong>This cannot be undone.</strong>
      </p>
      <p class="dashboard-card-note">
        If you have an active paid subscription, cancel it on
        <a href="/dashboard/subscription">Subscription page</a> first to avoid surprise charges.
      </p>
      <div class="dashboard-card-actions">
        <button class="btn btn-danger" type="button" data-action="delete-account">
          Delete my account
        </button>
      </div>
    </article>
  </div>

  <!-- 删除账号确认对话框 -->
  <div class="dashboard-modal" id="delete-account-modal" hidden>
    <button class="dashboard-modal-backdrop" type="button" data-modal-close aria-label="Close"></button>
    <div class="dashboard-modal-panel" role="dialog" aria-labelledby="delete-modal-title">
      <h3 id="delete-modal-title">Permanently delete your account?</h3>
      <p>
        Type <code>DELETE</code> below to confirm. This will sign you out immediately
        and erase all your data within 24 hours.
      </p>
      <label class="dashboard-modal-input">
        <span class="sr-only">Type DELETE to confirm</span>
        <input
          type="text"
          autocomplete="off"
          autocapitalize="characters"
          placeholder="Type DELETE"
          data-delete-confirm-input
        />
      </label>
      <p class="dashboard-modal-error" data-delete-error hidden></p>
      <div class="dashboard-modal-actions">
        <button type="button" class="btn btn-secondary" data-modal-close>Cancel</button>
        <button type="button" class="btn btn-danger" data-delete-confirm-submit disabled>
          Delete my account
        </button>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  // ── 删除试妆历史 ────────────────────────────────────────
  const historyBtn = document.querySelector('[data-action="delete-history"]') as HTMLButtonElement | null;
  const historyStatus = document.querySelector('[data-history-status]') as HTMLElement | null;

  historyBtn?.addEventListener('click', async () => {
    const confirmed = window.confirm(
      'Delete all your try-on records? Your account and subscription will be kept.',
    );
    if (!confirmed) return;
    historyBtn.disabled = true;
    historyBtn.textContent = 'Deleting…';
    try {
      const resp = await fetch('/api/account/delete-history', { method: 'POST' });
      if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
      historyBtn.textContent = 'Deleted';
      if (historyStatus) {
        historyStatus.removeAttribute('hidden');
        historyStatus.textContent = 'All try-on records have been removed.';
      }
    } catch (err) {
      historyBtn.disabled = false;
      historyBtn.textContent = 'Delete try-on history';
      if (historyStatus) {
        historyStatus.removeAttribute('hidden');
        historyStatus.textContent = 'Delete failed. Please try again.';
      }
      console.error(err);
    }
  });

  // ── 删除账号模态框 ─────────────────────────────────────
  const modal = document.getElementById('delete-account-modal');
  const accountBtn = document.querySelector('[data-action="delete-account"]') as HTMLButtonElement | null;
  const confirmInput = document.querySelector('[data-delete-confirm-input]') as HTMLInputElement | null;
  const confirmBtn = document.querySelector('[data-delete-confirm-submit]') as HTMLButtonElement | null;
  const errorEl = document.querySelector('[data-delete-error]') as HTMLElement | null;

  function openModal() {
    modal?.removeAttribute('hidden');
    setTimeout(() => confirmInput?.focus(), 50);
  }
  function closeModal() {
    modal?.setAttribute('hidden', '');
    if (confirmInput) confirmInput.value = '';
    if (confirmBtn) confirmBtn.disabled = true;
    errorEl?.setAttribute('hidden', '');
  }

  accountBtn?.addEventListener('click', openModal);
  document.querySelectorAll('[data-modal-close]').forEach((el) => {
    el.addEventListener('click', closeModal);
  });

  confirmInput?.addEventListener('input', () => {
    if (confirmBtn) confirmBtn.disabled = confirmInput.value.trim() !== 'DELETE';
  });

  confirmBtn?.addEventListener('click', async () => {
    confirmBtn.disabled = true;
    confirmBtn.textContent = 'Deleting…';
    errorEl?.setAttribute('hidden', '');
    try {
      const resp = await fetch('/api/account/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ confirm: 'DELETE' }),
      });
      if (!resp.ok) {
        const data = (await resp.json().catch(() => ({}))) as { error?: string; message?: string };
        throw new Error(data.message ?? data.error ?? `HTTP ${resp.status}`);
      }
      // 成功后跳首页
      window.location.replace('/');
    } catch (err) {
      confirmBtn.disabled = false;
      confirmBtn.textContent = 'Delete my account';
      if (errorEl) {
        errorEl.removeAttribute('hidden');
        errorEl.textContent = err instanceof Error ? err.message : 'Delete failed.';
      }
    }
  });
</script>
