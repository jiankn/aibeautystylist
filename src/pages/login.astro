    /* 系统暗色偏好下的移动端渐变适配 */
    @media (max-width: 900px) and (prefers-color-scheme: dark) {
      :global(:root:not([data-theme="light"])) .auth-form-pane::before {
        background: linear-gradient(
          180deg,
          transparent 0%,
          rgba(15, 14, 17, 0.15) 25%,
          rgba(15, 14, 17, 0.55) 55%,
          rgba(15, 14, 17, 0.88) 80%,
          var(--auth-pane) 100%
        );
      }
    }
    /* ── 东亚语言排版微调（CJK 标题 line-height 与 letter-spacing） ── */
    :global(.auth-east-asian) .auth-poster h1 {
      max-width: 510px;
      font-size: clamp(34px, 3.8vw, 58px);
      line-height: 1.32;
      letter-spacing: 0.02em;
    }
    :global([data-theme="dark"] .auth-east-asian) .auth-poster-copy {
      width: min(100%, 455px);
    }
    :global(.auth-east-asian) .auth-poster p {
      max-width: 455px;
      line-height: 1.85;
      letter-spacing: 0.01em;
    }
    :global(.auth-east-asian) .poster-kicker {
      letter-spacing: 0.06em;
      text-transform: none;
    }
    :global(.auth-east-asian) .auth-intro h2 {
      line-height: 1.3;
      letter-spacing: 0.01em;
    }
    :global(.auth-east-asian) .auth-intro p {
      line-height: 1.8;
    }
  </style>

  <script
    is:inline
    define:vars={{
      authMessages,
      microsoftAuthMessages,
      authResponseMessages,
      authNextPath,
      currentLocale,
    }}
  >
    (() => {
      const root = document.querySelector("[data-auth]");
      if (!root) return;
      const message = root.querySelector("[data-auth-message]");
      const forms = {
        login: root.querySelector('[data-auth-form="login"]'),
        register: root.querySelector('[data-auth-form="register"]'),
        forgot: root.querySelector('[data-auth-form="forgot"]'),
      };
      const tabs = root.querySelectorAll("[data-auth-tab]");

      function setMessage(text, kind) {
        message.textContent = text || "";
        message.className = "auth-message" + (kind ? " is-" + kind : "");
      }
      function responseMessage(body, fallback) {
        const code = body?.error?.code;
        const byCode = {
          NETWORK_ERROR: authResponseMessages.networkError,
          INVALID_CREDENTIALS: authResponseMessages.invalidCredentials,
          EMAIL_NOT_VERIFIED: authResponseMessages.emailNotVerified,
          OAUTH_REQUIRED: authResponseMessages.oauthRequired,
          AUTH_UNAVAILABLE: authResponseMessages.authUnavailable,
          RATE_LIMITED: authResponseMessages.rateLimited,
          INVALID_EMAIL: authResponseMessages.invalidEmail,
          WEAK_PASSWORD: authResponseMessages.weakPassword,
          EMAIL_IN_USE: authResponseMessages.emailInUse,
          INVALID_TOKEN: authResponseMessages.invalidToken,
        };
        return (code && byCode[code]) || fallback;
      }
      function show(name) {
        for (const key of Object.keys(forms)) forms[key].hidden = key !== name;
        tabs.forEach((tab) => {
          const active = tab.dataset.authTab === name;
          tab.classList.toggle("active", active);
          tab.setAttribute("aria-selected", String(active));
        });
        setMessage("");
      }

      tabs.forEach((tab) =>
        tab.addEventListener("click", () => show(tab.dataset.authTab)),
      );
      root
        .querySelector("[data-auth-forgot]")
        ?.addEventListener("click", () => show("forgot"));
      root
        .querySelector("[data-auth-back]")
        ?.addEventListener("click", () => show("login"));

      root.querySelectorAll("[data-oauth-auth]").forEach((oauthLink) => {
        oauthLink.addEventListener("click", (event) => {
          if (
            event.defaultPrevented ||
            event.button !== 0 ||
            event.metaKey ||
            event.ctrlKey ||
            event.shiftKey ||
            event.altKey
          ) {
            return;
          }
          const link = event.currentTarget;
          link.classList.add("is-loading");
          link.setAttribute("aria-disabled", "true");
          const label = link.querySelector("[data-oauth-label]");
          if (label) {
            label.textContent =
              link.dataset.oauthConnecting || authMessages.connectingGoogle;
          }
        });
      });

      async function postJson(url, payload) {
        try {
          const res = await fetch(url, {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify(payload),
          });
          return {
            status: res.status,
            body: await res.json().catch(() => null),
          };
        } catch {
          return {
            status: 0,
            body: {
              ok: false,
              error: {
                code: "NETWORK_ERROR",
                message: authResponseMessages.networkError,
              },
            },
          };
        }
      }

      function setPending(form, pending, label) {
        const button = form.querySelector('button[type="submit"]');
        if (!button) return;
        if (!button.dataset.defaultLabel) {
          button.dataset.defaultLabel = button.textContent.trim();
        }
        button.disabled = pending;
        button.textContent = pending ? label : button.dataset.defaultLabel;
      }

      forms.login.addEventListener("submit", async (event) => {
        event.preventDefault();
        const data = new FormData(forms.login);
        setMessage(authMessages.signingIn);
        setPending(forms.login, true, authMessages.signingIn);
        const { body } = await postJson("/api/auth/login", {
          email: data.get("email"),
          password: data.get("password"),
        });
        if (body?.ok) {
          setMessage(authMessages.signInSuccess, "success");
          window.location.href = authNextPath || "/";
        } else {
          setPending(forms.login, false);
          setMessage(responseMessage(body, authMessages.signInFailed), "error");
        }
      });

      forms.register.addEventListener("submit", async (event) => {
        event.preventDefault();
        const data = new FormData(forms.register);
        setMessage(authMessages.registering);
        setPending(forms.register, true, authMessages.registering);
        const { body } = await postJson("/api/auth/register", {
          email: data.get("email"),
          password: data.get("password"),
          locale: currentLocale,
        });
        setPending(forms.register, false);
        if (body?.ok) {
          setMessage(
            body.data?.emailSent === false
              ? authResponseMessages.registerSuccessEmailPending
              : authResponseMessages.registerSuccess,
            "success",
          );
        } else {
          setMessage(
            responseMessage(body, authMessages.registerFailed),
            "error",
          );
        }
      });

      forms.forgot.addEventListener("submit", async (event) => {
        event.preventDefault();
        const data = new FormData(forms.forgot);
        setMessage(authMessages.sending);
        setPending(forms.forgot, true, authMessages.sending);
        const { body } = await postJson("/api/auth/forgot-password", {
          email: data.get("email"),
          locale: currentLocale,
        });
        setPending(forms.forgot, false);
        setMessage(
          body?.ok
            ? authResponseMessages.resetFallback
            : responseMessage(body, authResponseMessages.resetFallback),
          body?.ok ? "success" : "error",
        );
      });

      const params = new URLSearchParams(window.location.search);
      const oauthMessages =
        params.get("provider") === "microsoft"
          ? microsoftAuthMessages
          : authMessages;
      if (params.get("verify") === "invalid")
        setMessage(authMessages.verifyInvalid, "error");
      if (params.get("oauth") === "failed")
        setMessage(oauthMessages.oauthFailed, "error");
      if (params.get("oauth") === "invalid")
        setMessage(oauthMessages.oauthInvalid, "error");
      if (params.get("oauth") === "unavailable")
        setMessage(oauthMessages.oauthUnavailable, "error");
      if (params.get("oauth") === "cancelled")
        setMessage(oauthMessages.oauthCancelled);
      if (params.get("oauth") === "unverified")
        setMessage(oauthMessages.oauthUnverified, "error");
      if (params.get("oauth") === "conflict")
        setMessage(oauthMessages.oauthConflict, "error");
    })();
  </script>
</BaseLayout>
