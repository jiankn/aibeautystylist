---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { resolvePageAssets } from "../data/makeup/resolvePageAssets";
import { getLocalizedAppHref, resolveLocaleRoute } from "../i18n/routing";
import { isGoogleOAuthConfigured } from "../lib/googleOAuth";
import { getCurrentLocale } from "../lib/i18n";
import { isMicrosoftOAuthConfigured } from "../lib/microsoftOAuth";
import { safeAuthNextPath } from "../lib/oauth";
import { getRuntimeBindings } from "../lib/runtime";
import {
  getLocalizedAuthResponseMessages,
  getLocalizedLoginContent,
} from "../data/authContent";

const runtimeBindings = getRuntimeBindings();
const googleOAuthAvailable = isGoogleOAuthConfigured(runtimeBindings);
const microsoftOAuthAvailable = isMicrosoftOAuthConfigured(runtimeBindings);
const oauthAvailable = googleOAuthAvailable || microsoftOAuthAvailable;
const currentLocale = getCurrentLocale();
const currentPathname = Astro.originPathname || Astro.url.pathname;
const currentRoute =
  Astro.locals.localeRoute ?? resolveLocaleRoute(currentPathname);
const localizeAppHref = (href: string) =>
  getLocalizedAppHref(href, currentRoute.language.slug);
const nextPath = safeAuthNextPath(Astro.url.searchParams.get("next"));
const authNextPath = nextPath === "/" ? localizeAppHref("/") : nextPath;
const initialAuthMode =
  Astro.url.searchParams.get("mode") === "register" ? "register" : "login";
const googleHref = `/api/auth/google/start?next=${encodeURIComponent(authNextPath)}`;
const microsoftHref = `/api/auth/microsoft/start?next=${encodeURIComponent(authNextPath)}`;
const termsHref = localizeAppHref("/terms");
const privacyHref = localizeAppHref("/privacy");
const isEnglish = !currentLocale.startsWith("zh");
const isEastAsianLocale = /^(zh|ja|ko)/i.test(currentLocale);
const pageAssets = resolvePageAssets("login", Astro.locals.audienceContext);
const posterLight =
  pageAssets.heroImages?.light ?? "/images/login-hero-global-light.webp";
const posterDark =
  pageAssets.heroImages?.dark ?? "/images/login-hero-global-dark.webp";

const fallbackCopy = isEnglish
  ? {
      title: "Get started | AI Beauty Stylist",
      description:
        "Sign in or create an AI Beauty Stylist account to save looks, diagnoses and membership benefits.",
      posterAria: "Editorial makeup portrait",
      posterKicker: "Your beauty, directed",
      posterTitle: "See the look before it becomes the moment.",
      posterBody:
        "Explore makeup directions shaped around your features, lighting and occasion.",
      proof: ["Personalized looks", "Private by design", "Saved for later"],
      eyebrow: "One account for every look",
      heading: "Get started",
      intro:
        "Sign in or create an account to save looks, diagnoses and membership benefits.",
      google: "Continue with Google",
      emailDivider: "or continue with email",
      tabsLabel: "Account actions",
      login: "Sign in",
      register: "Create account",
      email: "Email",
      password: "Password",
      passwordHint: "At least 8 characters with letters and numbers",
      forgot: "Forgot password",
      forgotHint: "Enter your account email and we will send a reset link.",
      sendReset: "Send reset email",
      back: "Back to sign in",
      legalPrefix: "By continuing, you agree to the ",
      terms: "Terms of Service",
      legalJoin: " and ",
      privacy: "Privacy Policy",
      legalSuffix: ".",
      messages: {
        connectingGoogle: "Connecting to Google...",
        networkError:
          "Network connection failed. Check your connection and try again.",
        signingIn: "Signing in...",
        signInSuccess: "Signed in. Redirecting...",
        signInFailed: "Sign in failed",
        registering: "Creating account...",
        registerSuccess: "Account created. Check your email to verify it.",
        registerFailed: "Account creation failed",
        sending: "Sending...",
        resetFallback:
          "If this email is registered, we have sent a password reset link.",
        verifyInvalid:
          "This verification link is invalid or expired. Create an account again or reset your password.",
        oauthFailed: "Google sign in failed. Please try again.",
        oauthInvalid:
          "Google sign in session validation failed. Please try again.",
        oauthUnavailable:
          "Google sign in is temporarily unavailable. Use email or try again later.",
        oauthCancelled:
          "Google sign in was cancelled. You can try again or use email.",
        oauthUnverified:
          "This Google account email is not verified. Try another account.",
        oauthConflict:
          "This Google account cannot be linked right now. Contact support.",
      },
    }
  : {
      title: "开始使用 | AI Beauty Stylist",
      description:
        "登录或创建 AI Beauty Stylist 账户，保存你的试妆记录、诊断报告和会员权益。",
      posterAria: "精致妆容人物海报",
      posterKicker: "为你的美，找到方向",
      posterTitle: "在重要时刻到来前，先看见理想妆容。",
      posterBody: "结合你的五官、光线与场景，探索真正适合你的妆容方向。",
      proof: ["专属妆容方向", "隐私优先", "随时回看"],
      eyebrow: "一个账户管理所有妆容",
      heading: "开始使用",
      intro: "登录或创建账户，保存试妆记录、诊断报告和会员权益。",
      google: "使用 Google 账户继续",
      emailDivider: "或使用邮箱",
      tabsLabel: "账户操作",
      login: "登录",
      register: "创建账户",
      email: "邮箱",
      password: "密码",
      passwordHint: "至少 8 位，包含字母和数字",
      forgot: "忘记密码",
      forgotHint: "输入注册邮箱，我们会发送密码重置链接。",
      sendReset: "发送重置邮件",
      back: "返回登录",
      legalPrefix: "继续即表示你同意",
      terms: "服务条款",
      legalJoin: "和",
      privacy: "隐私政策",
      legalSuffix: "。",
      messages: {
        connectingGoogle: "正在连接 Google...",
        networkError: "网络连接失败，请检查网络后重试",
        signingIn: "登录中...",
        signInSuccess: "登录成功，正在跳转...",
        signInFailed: "登录失败",
        registering: "注册中...",
        registerSuccess: "注册成功，请查收验证邮件",
        registerFailed: "注册失败",
        sending: "发送中...",
        resetFallback: "如果该邮箱已注册，我们已发送重置邮件",
        verifyInvalid: "验证链接无效或已过期，请重新创建账户或找回密码",
        oauthFailed: "Google 登录失败，请重试",
        oauthInvalid: "Google 登录会话校验失败，请重试",
        oauthUnavailable: "Google 登录暂时不可用，请使用邮箱登录或稍后重试",
        oauthCancelled: "你已取消 Google 登录，可以重新尝试或使用邮箱登录",
        oauthUnverified: "该 Google 账户的邮箱尚未验证，请更换账户后重试",
        oauthConflict: "该 Google 账户暂时无法关联，请联系支持",
      },
    };
const copy = getLocalizedLoginContent(currentLocale) ?? fallbackCopy;
const authResponseMessages = getLocalizedAuthResponseMessages(currentLocale);

const authMessages = copy.messages;
const microsoftAuthMessagesByLocale = {
  en: {
    label: "Continue with Microsoft",
    connecting: "Connecting to Microsoft...",
    oauthFailed: "Microsoft sign in failed. Please try again.",
    oauthInvalid:
      "Microsoft sign in session validation failed. Please try again.",
    oauthUnavailable:
      "Microsoft sign in is temporarily unavailable. Use email or try again later.",
    oauthCancelled:
      "Microsoft sign in was cancelled. You can try again or use email.",
    oauthUnverified:
      "This Microsoft account did not return a usable email address. Try another account.",
    oauthConflict:
      "This Microsoft account cannot be linked right now. Contact support.",
  },
  "zh-CN": {
    label: "使用 Microsoft 账户继续",
    connecting: "正在连接 Microsoft...",
    oauthFailed: "Microsoft 登录失败，请重试",
    oauthInvalid: "Microsoft 登录会话校验失败，请重试",
    oauthUnavailable: "Microsoft 登录暂时不可用，请使用邮箱登录或稍后重试",
    oauthCancelled: "你已取消 Microsoft 登录，可以重新尝试或使用邮箱登录",
    oauthUnverified: "该 Microsoft 账户未返回可用邮箱，请更换账户后重试",
    oauthConflict: "该 Microsoft 账户暂时无法关联，请联系支持",
  },
  "zh-TW": {
    label: "使用 Microsoft 帳戶繼續",
    connecting: "正在連接 Microsoft...",
    oauthFailed: "Microsoft 登入失敗，請重試。",
    oauthInvalid: "Microsoft 登入工作階段驗證失敗，請重試。",
    oauthUnavailable: "Microsoft 登入暫時無法使用，請改用電子郵件或稍後再試。",
    oauthCancelled: "你已取消 Microsoft 登入，可重新嘗試或改用電子郵件。",
    oauthUnverified: "此 Microsoft 帳戶未返回可用電子郵件，請更換帳戶後重試。",
    oauthConflict: "目前無法連結此 Microsoft 帳戶，請聯絡支援。",
  },
  "de-DE": {
    label: "Mit Microsoft fortfahren",
    connecting: "Verbindung zu Microsoft...",
    oauthFailed: "Microsoft-Anmeldung fehlgeschlagen. Bitte erneut versuchen.",
    oauthInvalid:
      "Microsoft-Anmeldesitzung konnte nicht validiert werden. Bitte erneut versuchen.",
    oauthUnavailable: "Microsoft-Anmeldung ist vorübergehend nicht verfügbar.",
    oauthCancelled: "Microsoft-Anmeldung wurde abgebrochen.",
    oauthUnverified:
      "Dieses Microsoft-Konto hat keine nutzbare E-Mail-Adresse zurückgegeben.",
    oauthConflict:
      "Dieses Microsoft-Konto kann derzeit nicht verknüpft werden.",
  },
  "fr-FR": {
    label: "Continuer avec Microsoft",
    connecting: "Connexion à Microsoft...",
    oauthFailed: "Échec de la connexion Microsoft. Réessayez.",
    oauthInvalid: "La session Microsoft n'a pas pu être validée. Réessayez.",
    oauthUnavailable: "La connexion Microsoft est temporairement indisponible.",
    oauthCancelled: "La connexion Microsoft a été annulée.",
    oauthUnverified: "Ce compte Microsoft n'a pas renvoyé d'e-mail utilisable.",
    oauthConflict: "Ce compte Microsoft ne peut pas être associé actuellement.",
  },
  "ja-JP": {
    label: "Microsoftで続ける",
    connecting: "Microsoftに接続中...",
    oauthFailed: "Microsoftログインに失敗しました。もう一度お試しください。",
    oauthInvalid:
      "Microsoftログインセッションを確認できませんでした。もう一度お試しください。",
    oauthUnavailable: "Microsoftログインは一時的に利用できません。",
    oauthCancelled: "Microsoftログインをキャンセルしました。",
    oauthUnverified:
      "このMicrosoftアカウントから利用可能なメールアドレスを取得できませんでした。",
    oauthConflict: "このMicrosoftアカウントは現在連携できません。",
  },
  "ko-KR": {
    label: "Microsoft로 계속",
    connecting: "Microsoft 연결 중...",
    oauthFailed: "Microsoft 로그인에 실패했습니다. 다시 시도하세요.",
    oauthInvalid:
      "Microsoft 로그인 세션을 확인하지 못했습니다. 다시 시도하세요.",
    oauthUnavailable: "Microsoft 로그인을 일시적으로 사용할 수 없습니다.",
    oauthCancelled: "Microsoft 로그인이 취소되었습니다.",
    oauthUnverified:
      "이 Microsoft 계정에서 사용할 수 있는 이메일을 받지 못했습니다.",
    oauthConflict: "현재 이 Microsoft 계정을 연결할 수 없습니다.",
  },
  "es-ES": {
    label: "Continuar con Microsoft",
    connecting: "Conectando con Microsoft...",
    oauthFailed: "Error al iniciar sesión con Microsoft. Inténtalo de nuevo.",
    oauthInvalid:
      "No se pudo validar la sesión de Microsoft. Inténtalo de nuevo.",
    oauthUnavailable:
      "El inicio con Microsoft no está disponible temporalmente.",
    oauthCancelled: "Has cancelado el inicio con Microsoft.",
    oauthUnverified:
      "Esta cuenta Microsoft no devolvió un correo electrónico utilizable.",
    oauthConflict: "Esta cuenta Microsoft no se puede vincular ahora.",
  },
  "es-419": {
    label: "Continuar con Microsoft",
    connecting: "Conectando con Microsoft...",
    oauthFailed: "Error al iniciar sesión con Microsoft. Inténtalo de nuevo.",
    oauthInvalid:
      "No se pudo validar la sesión de Microsoft. Inténtalo de nuevo.",
    oauthUnavailable:
      "El inicio con Microsoft no está disponible temporalmente.",
    oauthCancelled: "Has cancelado el inicio con Microsoft.",
    oauthUnverified:
      "Esta cuenta Microsoft no devolvió un correo electrónico utilizable.",
    oauthConflict: "Esta cuenta Microsoft no se puede vincular ahora.",
  },
  "pt-BR": {
    label: "Continuar com Microsoft",
    connecting: "Conectando ao Microsoft...",
    oauthFailed: "Falha no login com Microsoft. Tente novamente.",
    oauthInvalid:
      "Não foi possível validar a sessão Microsoft. Tente novamente.",
    oauthUnavailable:
      "O login com Microsoft está temporariamente indisponível.",
    oauthCancelled: "O login com Microsoft foi cancelado.",
    oauthUnverified: "Esta conta Microsoft não retornou um e-mail utilizável.",
    oauthConflict: "Esta conta Microsoft não pode ser vinculada agora.",
  },
} as const;
const microsoftAuthMessages =
  microsoftAuthMessagesByLocale[
    currentLocale as keyof typeof microsoftAuthMessagesByLocale
  ] ?? microsoftAuthMessagesByLocale.en;
const bodyClass = `auth-body ${isEastAsianLocale ? "auth-east-asian" : "auth-global"}`;
const posterLightDesktop =
  posterLight === "/images/login-hero-global-light.webp"
    ? "/images/login-hero-global-light-desktop.webp"
    : undefined;
const posterStyle = [
  `--auth-poster-light: url("${posterLight}")`,
  `--auth-poster-dark: url("${posterDark}")`,
  posterLightDesktop
    ? `--auth-poster-light-desktop: url("${posterLightDesktop}")`
    : "",
]
  .filter(Boolean)
  .join("; ");
---

<BaseLayout
  title={copy.title}
  description={copy.description}
  bodyClass={bodyClass}
  robots="noindex,follow"
>
  <SiteHeader showAuth={false} minimal />
  <main class="auth-main" style={posterStyle}>
    <section class="auth-poster" aria-label={copy.posterAria}>
      <div class="auth-poster-copy">
        <span class="poster-kicker">{copy.posterKicker}</span>
        <h1>{copy.posterTitle}</h1>
        <p>{copy.posterBody}</p>
        <div class="poster-proof" aria-label={copy.posterBody}>
          {copy.proof.map((item) => <span>{item}</span>)}
        </div>
      </div>
    </section>

    <section class="auth-form-pane">
      <div class="auth-card" data-auth>
        <header class="auth-intro">
          <span class="auth-eyebrow">{copy.eyebrow}</span>
          <h2>{copy.heading}</h2>
          <p>{copy.intro}</p>
        </header>

        {
          oauthAvailable && (
            <>
              <div class="auth-provider-stack">
                {googleOAuthAvailable && (
                  <a
                    class="btn btn-wide auth-provider"
                    href={googleHref}
                    data-oauth-auth
                    data-oauth-connecting={authMessages.connectingGoogle}
                    aria-label={copy.google}
                  >
                    <img
                      class="oauth-mark"
                      src="/images/google-g.svg"
                      alt=""
                      width="20"
                      height="20"
                    />
                    <span data-oauth-label>{copy.google}</span>
                  </a>
                )}
                {microsoftOAuthAvailable && (
                  <a
                    class="btn btn-wide auth-provider"
                    href={microsoftHref}
                    data-oauth-auth
                    data-oauth-connecting={microsoftAuthMessages.connecting}
                    aria-label={microsoftAuthMessages.label}
                  >
                    <img
                      class="oauth-mark"
                      src="/images/microsoft.svg"
                      alt=""
                      width="20"
                      height="20"
                    />
                    <span data-oauth-label>{microsoftAuthMessages.label}</span>
                  </a>
                )}
              </div>
              <div class="auth-divider">
                <span>{copy.emailDivider}</span>
              </div>
            </>
          )
        }

        <div class="auth-tabs" role="tablist" aria-label={copy.tabsLabel}>
          <button
            type="button"
            class:list={["auth-tab", { active: initialAuthMode === "login" }]}
            role="tab"
            aria-selected={initialAuthMode === "login"}
            aria-controls="auth-login"
            data-auth-tab="login">{copy.login}</button
          >
          <button
            type="button"
            class:list={[
              "auth-tab",
              { active: initialAuthMode === "register" },
            ]}
            role="tab"
            aria-selected={initialAuthMode === "register"}
            aria-controls="auth-register"
            data-auth-tab="register">{copy.register}</button
          >
        </div>

        <form
          class="auth-form"
          id="auth-login"
          role="tabpanel"
          data-auth-form="login"
          hidden={initialAuthMode !== "login"}
        >
          <label
            >{copy.email}<input
              type="email"
              name="email"
              autocomplete="email"
              required
            /></label
          >
          <label
            >{copy.password}<input
              type="password"
              name="password"
              autocomplete="current-password"
              required
            /></label
          >
          <button class="btn btn-primary btn-wide" type="submit"
            >{copy.login}</button
          >
          <button type="button" class="auth-link" data-auth-forgot
            >{copy.forgot}</button
          >
        </form>

        <form
          class="auth-form"
          id="auth-register"
          role="tabpanel"
          data-auth-form="register"
          hidden={initialAuthMode !== "register"}
        >
          <label
            >{copy.email}<input
              type="email"
              name="email"
              autocomplete="email"
              required
            /></label
          >
          <label
            >{copy.password}<input
              type="password"
              name="password"
              autocomplete="new-password"
              required
            /><small>{copy.passwordHint}</small></label
          >
          <button class="btn btn-primary btn-wide" type="submit"
            >{copy.register}</button
          >
        </form>

        <form class="auth-form" data-auth-form="forgot" hidden>
          <p class="auth-hint">{copy.forgotHint}</p>
          <label
            >{copy.email}<input
              type="email"
              name="email"
              autocomplete="email"
              required
            /></label
          >
          <button class="btn btn-primary btn-wide" type="submit"
            >{copy.sendReset}</button
          >
          <button type="button" class="auth-link" data-auth-back
            >{copy.back}</button
          >
        </form>

        <p
          class="auth-message"
          data-auth-message
          role="status"
          aria-live="polite"
        >
        </p>
        <p class="auth-legal">
          {copy.legalPrefix}<a href={termsHref}>{copy.terms}</a>{
            copy.legalJoin
          }<a href={privacyHref}>{copy.privacy}</a>{copy.legalSuffix}
        </p>
      </div>
    </section>
  </main>

  <style>
    :global(.auth-body) {
      --auth-pane: rgba(247, 247, 246, 0.91);
      --auth-card: rgba(255, 255, 255, 0.82);
      --auth-card-border: rgba(55, 61, 70, 0.12);
      --auth-control: rgba(255, 255, 255, 0.72);
      --auth-control-hover: rgba(255, 255, 255, 0.96);
      --auth-control-border: rgba(65, 70, 78, 0.2);
      --auth-heading: #17191d;
      --auth-text: #34383f;
      --auth-muted: #6c7179;
      --auth-accent: #a72f54;
      --auth-accent-soft: rgba(179, 50, 89, 0.09);
      --auth-accent-border: rgba(167, 47, 84, 0.36);
      --auth-shadow: 0 28px 70px rgba(24, 29, 36, 0.13);
      background: #e9e9e7;
    }
    :global([data-theme="dark"] .auth-body) {
      --auth-pane: rgba(15, 14, 17, 0.9);
      --auth-card: rgba(26, 24, 28, 0.86);
      --auth-card-border: rgba(255, 255, 255, 0.12);
      --auth-control: rgba(255, 255, 255, 0.055);
      --auth-control-hover: rgba(255, 255, 255, 0.09);
      --auth-control-border: rgba(255, 255, 255, 0.16);
      --auth-heading: #f3edef;
      --auth-text: #e1dadd;
      --auth-muted: #a89fa4;
      --auth-accent: #ef8ca7;
      --auth-accent-soft: rgba(218, 79, 119, 0.14);
      --auth-accent-border: rgba(239, 140, 167, 0.42);
      --auth-shadow: 0 30px 90px rgba(0, 0, 0, 0.42);
      background: #0d0c0f;
    }
    :global(.auth-body .site-footer) {
      display: none;
    }
    :global(.auth-body .site-header-minimal) {
      border-bottom-color: rgba(72, 75, 82, 0.16);
      background: rgba(248, 248, 247, 0.72);
    }
    :global([data-theme="dark"] .auth-body .site-header-minimal) {
      border-bottom-color: rgba(255, 255, 255, 0.08);
      background: rgba(12, 11, 14, 0.7);
    }
    .auth-main {
      --auth-mobile-poster-image: var(--auth-poster-light);
      --auth-poster-image: var(
        --auth-poster-light-desktop,
        var(--auth-poster-light)
      );
      position: relative;
      display: grid;
      min-height: 100dvh;
      grid-template-columns: minmax(0, 1.48fr) minmax(390px, 0.92fr);
      padding-top: 52px;
      overflow: hidden;
      background: var(--auth-pane);
      isolation: isolate;
    }
    :global([data-theme="dark"]) .auth-main {
      --auth-mobile-poster-image: var(--auth-poster-dark);
      --auth-poster-image: var(--auth-poster-dark);
    }
    :global([data-theme="dark"]) .auth-poster-copy {
      color: #f7f3f5;
      text-shadow: 0 2px 16px rgba(0, 0, 0, 0.55);
    }
    :global([data-theme="dark"]) .auth-poster p {
      color: rgba(255, 255, 255, 0.92);
    }
    .auth-main::before {
      position: absolute;
      z-index: -1;
      inset: 0;
      content: "";
      pointer-events: none;
    }
    .auth-poster {
      position: relative;
      display: flex;
      min-width: 0;
      align-items: flex-end;
      padding: clamp(42px, 7vw, 104px);
      overflow: hidden;
      background-image: var(--auth-poster-image);
      background-position: var(--auth-poster-position, 52% 32%);
      background-repeat: no-repeat;
      background-size: cover;
      isolation: isolate;
    }
    :global(.auth-east-asian) .auth-poster {
      --auth-poster-position: 50% 31%;
    }
    :global([data-theme="dark"] .auth-east-asian) .auth-poster {
      --auth-poster-position: 50% 64%;
    }
    .auth-poster::before {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(
          90deg,
          rgba(5, 7, 11, 0.3) 0%,
          rgba(5, 7, 11, 0.06) 46%,
          rgba(5, 7, 11, 0.2) 100%
        ),
        linear-gradient(180deg, rgba(5, 7, 11, 0.08) 0%, transparent 42%);
      content: "";
      pointer-events: none;
    }
    .auth-poster::after {
      position: absolute;
      inset: 42% 0 0;
      background: linear-gradient(
        180deg,
        transparent,
        rgba(8, 9, 12, 0.2) 46%,
        rgba(8, 9, 12, 0.68) 100%
      );
      content: "";
      pointer-events: none;
    }
    :global([data-theme="dark"] .auth-east-asian) .auth-poster::before {
      background:
        linear-gradient(
          90deg,
          rgba(5, 6, 10, 0.78) 0%,
          rgba(5, 6, 10, 0.58) 25%,
          rgba(5, 6, 10, 0.18) 52%,
          rgba(5, 6, 10, 0.32) 100%
        ),
        linear-gradient(180deg, rgba(5, 6, 10, 0.1) 0%, transparent 40%);
