        );
      }
      .auth-card {
        position: relative;
        z-index: 1;
        width: min(100%, 460px);
        padding: 24px;
        border: 1px solid var(--auth-card-border);
        border-radius: 8px;
        background: var(--auth-card);
        box-shadow: var(--auth-shadow);
        backdrop-filter: blur(20px) saturate(0.9);
        -webkit-backdrop-filter: blur(20px) saturate(0.9);
