      }
      :global(:root:not([data-theme="light"]) .auth-body .site-header-minimal) {
        border-bottom-color: rgba(255, 255, 255, 0.08);
        background: rgba(12, 11, 14, 0.7);
      }
      :global(:root:not([data-theme="light"])) .auth-main {
        --auth-mobile-poster-image: var(--auth-poster-dark);
        --auth-poster-image: var(--auth-poster-dark);
      }
      :global(:root:not([data-theme="light"])) .auth-main::before {
        display: none;
      }
    }
    @media (max-width: 900px) {
      .auth-main {
        display: flex;
        flex-direction: column;
        min-height: 100dvh;
        overflow: visible;
        /* 人脸居中、按宽度铺满、顶部对齐头部 */
        background-image: var(
          --auth-mobile-poster-image,
          var(--auth-poster-image)
        );
        background-position: center top;
        background-size: 100% auto;
        background-repeat: no-repeat;
        background-color: var(--auth-pane);
      }
      /* 移动端不需要水平渐变遮罩 */
      .auth-main::before {
        display: none !important;
      }
      .auth-poster {
        display: none;
      }
      .auth-form-pane {
        position: relative;
        flex: 1;
        min-height: 0;
        align-items: flex-start;
        /* 上方留足空间展示完整人脸（含下巴），渐变在图片底部区域开始 */
        margin-top: clamp(280px, 46vh, 420px);
        padding: 40px 18px 48px;
        border-left: 0;
        background: transparent;
        backdrop-filter: none;
        -webkit-backdrop-filter: none;
      }
      /* 表单区域顶部的渐变遮罩 —— 从透明平滑过渡到面板色，让人脸与文字自然融合 */
      .auth-form-pane::before {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        bottom: 100%;
        height: clamp(140px, 22vh, 260px);
        pointer-events: none;
        background: linear-gradient(
          180deg,
          transparent 0%,
          rgba(247, 247, 246, 0.08) 20%,
          rgba(247, 247, 246, 0.35) 42%,
          rgba(247, 247, 246, 0.65) 60%,
          rgba(247, 247, 246, 0.88) 78%,
          var(--auth-pane) 100%
        );
      }
      /* 表单区域本身的纯色背景 */
      .auth-form-pane::after {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        top: 0;
        bottom: 0;
        background: var(--auth-pane);
        z-index: -1;
      }
      :global([data-theme="dark"]) .auth-form-pane::before {
        background: linear-gradient(
          180deg,
          transparent 0%,
          rgba(15, 14, 17, 0.08) 20%,
          rgba(15, 14, 17, 0.35) 42%,
          rgba(15, 14, 17, 0.65) 60%,
          rgba(15, 14, 17, 0.88) 78%,
