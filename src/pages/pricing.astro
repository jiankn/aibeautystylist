            circle at 84% 0,
            rgba(240, 168, 50, 0.22),
            transparent 38%
          ),
          linear-gradient(
            150deg,
            rgba(56, 43, 21, 0.94) 0%,
            rgba(30, 35, 46, 0.96) 46%,
            rgba(24, 32, 48, 0.98) 100%
          );
        --premium-card-wash: linear-gradient(
          115deg,
          rgba(255, 226, 152, 0.12),
          transparent 32%,
          rgba(255, 255, 255, 0.04) 58%,
          transparent 78%
        );
        --premium-card-inset-border: rgba(255, 226, 149, 0.18);
        --premium-card-shadow:
          0 24px 52px rgba(0, 0, 0, 0.42), 0 0 0 1px rgba(237, 181, 82, 0.08),
          var(--panel-inset);
        --premium-ribbon-bg: linear-gradient(
          90deg,
          #f2cd7a 0%,
          #b8791a 38%,
          #f8df9a 56%,
          #a1620f 100%
        );
        --premium-ribbon-text: #1d1304;
        --premium-pill-bg: linear-gradient(
          135deg,
          rgba(246, 204, 115, 0.2),
          rgba(172, 109, 18, 0.18)
        );
        --premium-pill-border: rgba(240, 185, 84, 0.38);
        --premium-pill-color: #f5cf82;
        --premium-price-color: #f6d58c;
        --premium-price-unit: #cbb990;
        --premium-cta-bg: linear-gradient(
          135deg,
          #ffeaa5 0%,
          #d9a33a 42%,
          #9c5f10 100%
        );
        --premium-cta-border: rgba(244, 196, 94, 0.76);
        --premium-cta-shadow:
          0 16px 34px rgba(0, 0, 0, 0.34), 0 0 22px rgba(216, 154, 48, 0.14),
          inset 0 1px 0 rgba(255, 255, 255, 0.36),
          inset 0 -1px 0 rgba(61, 36, 3, 0.42);
        background:
          linear-gradient(
            180deg,
            rgba(36, 23, 28, 0.55),
            rgba(15, 23, 35, 0.72) 42%,
            var(--page-surface)
          ),
          var(--page-surface);
      }
    }
    .pricing-main {
      padding: calc(52px + 34px) 0 52px;
    }
    .section-eyebrow {
      display: inline-flex;
      width: fit-content;
      align-items: center;
      padding: 6px 10px;
      border: 1px solid var(--rose-border);
      border-radius: 999px;
      background: var(--surface-rose);
      color: var(--rose);
      font-size: 12px;
      font-weight: 800;
    }
    .pricing-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      justify-items: center;
      gap: 18px;
      margin-bottom: 26px;
      text-align: center;
    }
    .pricing-hero-copy {
      display: grid;
      justify-items: center;
      gap: 0;
    }
    .pricing-hero-copy .section-eyebrow {
      margin-bottom: 20px;
    }
    .pricing-hero h1 {
      margin: 0;
      max-width: 860px;
      color: var(--heading);
      font-family: var(--font-display);
      font-size: clamp(42px, 5vw, 68px);
      line-height: 1.02;
      letter-spacing: 0;
    }
    .pricing-hero-copy > p {
      margin: 16px 0 0;
      max-width: 780px;
      color: var(--text);
      font-size: 17px;
      line-height: 1.75;
    }
    .pricing-hero-points {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      width: 100%;
      max-width: 960px;
      margin-top: 24px;
    }
    .pricing-hero-points > div {
      min-width: 0;
      padding-top: 13px;
      border-top: 1px solid var(--line);
    }
    .pricing-hero-points b {
      display: block;
      margin-bottom: 5px;
      color: var(--heading);
      font-size: 13px;
    }
    .pricing-hero-points span {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.55;
    }
    .billing-toggle {
      display: flex;
      width: fit-content;
      margin: 0 auto 18px;
      padding: 4px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--bg-elevated);
      box-shadow: var(--shadow);
    }
    .billing-toggle button {
      min-height: 38px;
      padding: 0 18px;
      border: 0;
      border-radius: 999px;
      background: transparent;
      color: var(--text);
      cursor: pointer;
      font-size: 14px;
      font-weight: 800;
    }
    .billing-toggle button.active {
      background: var(--rose);
      color: #fff;
    }
    .billing-toggle span {
      margin-left: 5px;
      font-size: 12px;
      opacity: 0.85;
    }
    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px;
      align-items: stretch;
    }
    .pricing-choice-helper {
      display: grid;
      grid-template-columns: minmax(240px, 0.36fr) minmax(0, 1fr);
      gap: 18px;
      align-items: center;
      margin-top: 18px;
      padding: 18px 0;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }
    .pricing-choice-copy {
      display: grid;
      gap: 5px;
    }
    .pricing-choice-copy b {
      color: var(--heading);
      font-size: 16px;
    }
    .pricing-choice-copy span {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.55;
    }
    .pricing-choice-list {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0;
    }
    .pricing-choice-list span {
      display: grid;
      gap: 4px;
      min-width: 0;
      padding: 0 14px;
      border-left: 1px solid var(--line);
      color: var(--muted);
      font-size: 12px;
      line-height: 1.5;
    }
    .pricing-choice-list strong {
      color: var(--heading);
      font-size: 13px;
    }
    .pricing-plan-card {
      position: relative;
      display: flex;
      min-width: 0;
      min-height: 520px;
      flex-direction: column;
      padding: 26px;
      overflow: hidden;
    }
    .pricing-plan-card.recommended {
      isolation: isolate;
      border-color: var(--pro-card-border);
      background: var(--pro-card-bg);
      box-shadow: var(--pro-card-shadow);
      padding-top: 72px;
    }
    .pricing-plan-card.recommended::before,
    .pricing-plan-card.recommended::after {
      content: "";
      position: absolute;
      z-index: 0;
      pointer-events: none;
    }
    .pricing-plan-card.recommended::before {
      inset: 0;
      background: var(--pro-card-wash);
    }
    .pricing-plan-card.recommended::after {
      inset: 1px;
      border: 1px solid var(--pro-card-inset-border);
      border-radius: calc(var(--radius) - 1px);
      box-shadow: inset 0 0 0 1px rgba(132, 34, 68, 0.05);
    }
    .pricing-plan-card.recommended > * {
      position: relative;
      z-index: 1;
    }
    .pricing-plan-card.premium {
      isolation: isolate;
      border-color: var(--premium-card-border);
      background: var(--premium-card-bg);
      box-shadow: var(--premium-card-shadow);
      padding-top: 72px;
    }
    .pricing-plan-card.premium::before,
    .pricing-plan-card.premium::after {
      content: "";
      position: absolute;
      z-index: 0;
      pointer-events: none;
    }
    .pricing-plan-card.premium::before {
      inset: 0;
      background: var(--premium-card-wash);
    }
    .pricing-plan-card.premium::after {
      inset: 1px;
      border: 1px solid var(--premium-card-inset-border);
      border-radius: calc(var(--radius) - 1px);
      box-shadow: inset 0 0 0 1px rgba(124, 76, 10, 0.05);
    }
    .pricing-plan-card.premium > * {
      position: relative;
      z-index: 1;
    }
    .plan-ribbon,
    .current-plan-flag {
      margin: -26px -26px 20px;
      padding: 9px 12px;
      background: var(--rose);
      color: #fff;
      text-align: center;
      font-size: 13px;
      font-weight: 900;
    }
    .pricing-plan-card.recommended .plan-ribbon,
    .pricing-plan-card.premium .plan-ribbon {
      position: absolute;
      inset: 0 0 auto;
      z-index: 2;
      display: grid;
      min-height: 46px;
      place-items: center;
      margin: 0;
      padding: 10px 14px;
      border-radius: calc(var(--radius) - 1px) calc(var(--radius) - 1px) 0 0;
    }
    .recommended .plan-ribbon {
      background: var(--pro-ribbon-bg);
      color: var(--pro-ribbon-text);
      text-shadow: 0 1px 0 rgba(54, 8, 26, 0.3);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.24),
        inset 0 -1px 0 rgba(70, 8, 30, 0.3);
    }
    .premium .plan-ribbon {
      background: var(--premium-ribbon-bg);
      color: var(--premium-ribbon-text);
      text-shadow: 0 1px 0 rgba(255, 255, 255, 0.36);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.42),
        inset 0 -1px 0 rgba(87, 52, 6, 0.28);
    }
    .current-plan-flag {
      background: var(--teal);
    }
    .plan-head {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 14px;
    }
    .plan-head h2 {
      margin: 0 0 6px;
      color: var(--heading);
      font-size: 28px;
    }
    .plan-head p {
      margin: 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.55;
    }
    .plan-head > span {
      flex: 0 0 auto;
      padding: 6px 9px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--soft);
      color: var(--heading);
      font-size: 12px;
      font-weight: 800;
    }
    .recommended .plan-head > span {
      border-color: var(--pro-pill-border);
      background: var(--pro-pill-bg);
      color: var(--pro-pill-color);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4);
    }
    .premium .plan-head > span {
      border-color: var(--premium-pill-border);
      background: var(--premium-pill-bg);
      color: var(--premium-pill-color);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.46);
    }
    @media (min-width: 981px) {
      .plan-head {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 6px 14px;
      }
      .plan-head > div {
        display: contents;
      }
      .plan-head h2 {
        grid-column: 1;
        margin-bottom: 0;
      }
      .plan-head p {
        grid-column: 1 / -1;
        white-space: nowrap;
      }
      .plan-head > span {
        grid-column: 2;
        grid-row: 1;
      }
    }
    .plan-price {
      display: flex;
      align-items: baseline;
      gap: 8px;
      margin: 28px 0 14px;
      color: var(--heading);
    }
    .recommended .plan-price {
      color: var(--pro-price-color);
      text-shadow: 0 1px 0 rgba(255, 255, 255, 0.28);
    }
    .premium .plan-price {
      color: var(--premium-price-color);
      text-shadow: 0 1px 0 rgba(255, 255, 255, 0.34);
    }
    .plan-price > span {
      font-size: 18px;
    }
    .plan-price b {
      font-size: clamp(42px, 5vw, 58px);
      line-height: 0.95;
    }
    .plan-price small {
      color: var(--text);
      font-size: 15px;
    }
    .recommended .plan-price small {
      color: var(--pro-price-unit);
    }
    .premium .plan-price small {
      color: var(--premium-price-unit);
    }
    .plan-reason {
      min-height: 58px;
      margin: 0 0 18px;
      color: var(--text);
      font-size: 13px;
      line-height: 1.65;
    }
    .feature-list {
      display: grid;
      gap: 13px;
      margin-top: 22px;
      padding-top: 20px;
      border-top: 1px solid var(--line);
      font-size: 13px;
    }
    .feature-list b {
      color: var(--heading);
    }
    .recommended .feature-list {
      border-top-color: rgba(200, 62, 104, 0.24);
    }
    .premium .feature-list {
      border-top-color: rgba(195, 143, 42, 0.28);
    }
    .feature-list span {
      position: relative;
      padding-left: 20px;
      color: var(--text);
      line-height: 1.45;
    }
    .feature-list span::before {
      content: "";
      position: absolute;
      top: 0.58em;
      left: 0;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--rose);
    }
    .recommended .feature-list span::before {
      background: var(--pro-dot-bg);
      box-shadow: 0 0 0 3px rgba(200, 62, 104, 0.1);
    }
    .premium .feature-list span::before {
      background: var(--premium-dot-bg);
      box-shadow: 0 0 0 3px rgba(216, 162, 59, 0.12);
    }
    .pricing-plan-card.recommended .btn-primary {
      border-color: var(--pro-cta-border);
      background: var(--pro-cta-bg);
      color: var(--pro-rose-ink-strong);
      box-shadow: var(--pro-cta-shadow);
    }
    .pricing-plan-card.recommended .btn-primary:hover {
      border-color: var(--pro-cta-border);
      box-shadow:
        0 18px 34px rgba(168, 42, 85, 0.3),
        inset 0 1px 0 rgba(255, 255, 255, 0.34),
        inset 0 -1px 0 rgba(83, 12, 35, 0.32);
    }
    .pricing-plan-card.premium .btn-gold {
      border-color: var(--premium-cta-border);
      background: var(--premium-cta-bg);
      color: var(--premium-gold-ink-strong);
      box-shadow: var(--premium-cta-shadow);
    }
    .pricing-plan-card.premium .btn-gold:hover {
      border-color: var(--premium-cta-border);
      box-shadow:
        0 18px 34px rgba(179, 115, 21, 0.3),
        inset 0 1px 0 rgba(255, 255, 255, 0.68),
        inset 0 -1px 0 rgba(92, 53, 5, 0.34);
    }
    .pricing-proof {
      display: grid;
      gap: 24px;
      margin-top: 56px;
      padding: 34px 0 30px;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }
    .pricing-proof-head {
      display: grid;
      max-width: 820px;
    }
    .pricing-proof .section-eyebrow {
      margin-bottom: 16px;
    }
    .pricing-proof h2,
    .pricing-section-head h2,
    .pricing-policy h2 {
      margin: 9px 0 8px;
      color: var(--heading);
      font-family: var(--font-display);
      font-size: clamp(28px, 3vw, 42px);
      line-height: 1.12;
    }
    .pricing-proof h2 {
      margin: 0 0 12px;
    }
    .pricing-proof-head > p {
      max-width: 760px;
    }
    .pricing-proof p,
    .pricing-section-head p,
    .pricing-policy p {
      margin: 0;
      color: var(--muted);
      font-size: 15px;
      line-height: 1.75;
    }
    .pricing-proof-list {
      display: grid;
      border-top: 1px solid var(--line);
    }
    .pricing-proof-list article {
      display: grid;
      grid-template-columns: minmax(150px, 0.42fr) minmax(260px, 0.86fr) minmax(
          0,
          1fr
        );
      gap: 20px;
      align-items: baseline;
      min-width: 0;
      padding: 18px 0;
      border-bottom: 1px solid var(--line);
    }
    .pricing-proof-list span {
      color: var(--muted);
      font-size: 13px;
      font-weight: 800;
    }
    .pricing-proof-list strong {
      color: var(--heading);
      font-size: clamp(17px, 1.8vw, 22px);
      line-height: 1.3;
    }
    .pricing-proof-list p {
      color: var(--text);
      font-size: 13px;
      line-height: 1.65;
    }
    .pricing-proof-link {
      display: inline-flex;
      width: fit-content;
      min-height: 44px;
      align-items: center;
      color: var(--rose);
      font-size: 13px;
      font-weight: 900;
    }
    .pricing-proof-link::after {
      content: " ↓";
    }
    .pricing-comparison {
      scroll-margin-top: 76px;
    }
    .pricing-comparison,
    .pricing-faq,
    .pricing-policy {
      margin-top: 42px;
    }
    .pricing-section-head {
      margin-bottom: 16px;
    }
    .comparison-table {
      overflow: hidden;
    }
    .mobile-comparison-summary,
    .mobile-comparison-details {
      display: none;
    }
    .compare-row {
      display: grid;
      grid-template-columns: 1.1fr repeat(3, 1fr);
    }
    .compare-row > * {
      min-width: 0;
      padding: 13px 16px;
      border-right: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      color: var(--text);
      font-size: 13px;
      text-align: center;
    }
    .compare-row > *:first-child {
      color: var(--heading);
      font-weight: 800;
      text-align: left;
    }
    .compare-row.heading {
      background: var(--soft);
      font-weight: 900;
    }
    .compare-row.heading > * {
      color: var(--heading);
    }
    .compare-yes,
    .compare-no {
      font-weight: 800;
      font-size: 15px;
    }
    .comparison-table .compare-yes {
      color: var(--rose, #c83e68);
      font-weight: 900;
    }
    .compare-no {
      color: var(--muted);
      opacity: 0.5;
    }
    .pricing-faq-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }
    .pricing-faq details {
      padding: 18px;
    }
    .pricing-faq summary {
      color: var(--heading);
      cursor: pointer;
      font-size: 16px;
      font-weight: 900;
    }
    .pricing-faq details p {
      margin: 12px 0 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.7;
    }
    .pricing-policy-inner {
      display: grid;
      grid-template-columns: minmax(200px, 0.42fr) minmax(0, 1fr) minmax(
          190px,
          0.34fr
        );
      gap: 28px;
      align-items: start;
      padding: 30px 0;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }
    .pricing-policy-head {
      display: grid;
      align-content: start;
    }
    .pricing-policy-head .section-eyebrow {
      margin-bottom: 14px;
    }
    .pricing-policy h2 {
      margin: 0;
      font-size: clamp(24px, 2.5vw, 32px);
    }
    .pricing-policy-copy {
      display: grid;
      gap: 20px;
    }
    .pricing-policy-copy > p {
      max-width: 760px;
      color: var(--text);
    }
    .pricing-policy-copy dl {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 0;
      margin: 0;
      padding-top: 16px;
      border-top: 1px solid var(--line);
    }
    .pricing-policy-copy dl > div {
      min-width: 0;
      padding: 0 16px;
      border-left: 1px solid var(--line);
    }
    .pricing-policy-copy dl > div:first-child {
      padding-left: 0;
      border-left: 0;
    }
    .pricing-policy-copy dt {
      margin-bottom: 6px;
      color: var(--heading);
      font-size: 13px;
      font-weight: 900;
    }
    .pricing-policy-copy dd {
      margin: 0;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.6;
    }
    .pricing-policy-support {
      display: grid;
      gap: 14px;
      align-content: start;
      padding-left: 20px;
      border-left: 1px solid var(--line);
    }
    .pricing-policy-support span {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.65;
    }
    .pricing-policy-support .btn {
      width: 100%;
      min-height: 44px;
    }
    .checkout-dialog {
      width: min(420px, calc(100vw - 32px));
      padding: 24px;
      border: 1px solid var(--line);
      border-radius: 16px;
      color: var(--text);
    }
    .checkout-dialog::backdrop {
      background: rgba(9, 20, 35, 0.42);
    }
    .checkout-dialog h2 {
      margin: 0 0 10px;
      color: var(--heading);
    }
    .checkout-dialog p {
      margin: 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.65;
    }
    .dialog-close {
      position: absolute;
      top: 12px;
      right: 12px;
      display: grid;
      width: 34px;
      height: 34px;
      place-items: center;
      border: 1px solid var(--line);
      border-radius: 50%;
      background: var(--bg-elevated);
      color: var(--text);
      cursor: pointer;
      font-size: 18px;
    }
    .checkout-summary {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      margin: 18px 0;
      padding: 14px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--soft);
      color: var(--heading);
    }
    .checkout-actions {
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 10px;
    }

    @media (max-width: 980px) {
      .pricing-hero,
      .pricing-proof,
      .pricing-choice-helper,
      .pricing-policy-inner {
        grid-template-columns: 1fr;
      }
      .pricing-hero-points,
      .pricing-grid {
        grid-template-columns: 1fr;
      }
      .pricing-proof-list article {
        grid-template-columns: minmax(130px, 0.34fr) minmax(0, 1fr);
        gap: 8px 18px;
      }
      .pricing-proof-list p {
        grid-column: 2;
      }
      .pricing-policy-support {
        padding-top: 18px;
        padding-left: 0;
        border-top: 1px solid var(--line);
        border-left: 0;
      }
      .pricing-plan-card {
        min-height: auto;
      }
      .pricing-plan-card[data-plan="pro"] {
        order: 1;
      }
      .pricing-plan-card[data-plan="premium"] {
        order: 2;
