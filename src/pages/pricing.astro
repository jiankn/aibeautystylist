  <script is:inline define:vars={{ checkoutCopy }}>
    (() => {
      const cards = Array.from(document.querySelectorAll(".pricing-plan-card"));
      const intervalButtons = document.querySelectorAll("[data-interval]");
      const dialog = document.getElementById("checkout-dialog");
      const summary = document.querySelector("[data-checkout-summary]");
      const confirmBtn = document.querySelector("[data-checkout-confirm]");
      const cancelBtn = document.querySelector("[data-checkout-cancel]");
      const params = new URLSearchParams(window.location.search);
      let interval = "monthly";
      let pendingPlan = null;

      function toast(msg) {
        if (window.showToast) {
          window.showToast(msg);
          return;
        }
        const toastEl =
          document.querySelector(".toast") || document.createElement("div");
        if (!toastEl.isConnected) {
          toastEl.className = "toast";
          toastEl.setAttribute("role", "status");
          toastEl.setAttribute("aria-live", "polite");
          toastEl.setAttribute("aria-atomic", "true");
          document.body.appendChild(toastEl);
        }
        toastEl.textContent = msg;
        toastEl.classList.add("show");
        window.clearTimeout(toast.timer);
        toast.timer = window.setTimeout(
          () => toastEl.classList.remove("show"),
          3000,
        );
      }

      function delay(ms) {
        return new Promise((resolve) => window.setTimeout(resolve, ms));
      }

      function safeInternalPath(value) {
        if (
          !value ||
          !value.startsWith("/") ||
          value.startsWith("//") ||
          value.includes("\\") ||
          /[\u0000-\u001f\u007f]/.test(value)
        ) {
          return "";
        }
        try {
          const url = new URL(value, window.location.origin);
          const pathname = url.pathname.replace(/\/+$/, "") || "/";
          if (url.origin !== window.location.origin) return "";
          if (pathname === "/api" || pathname.startsWith("/api/")) return "";
          if (pathname === "/_astro" || pathname.startsWith("/_astro/"))
            return "";
          if (pathname === "/pricing" || pathname.endsWith("/pricing"))
            return "";
          return `${url.pathname}${url.search}${url.hash}`;
        } catch {
          return "";
        }
      }

      function addCheckoutStatus(path, status) {
        const target = safeInternalPath(path) || checkoutCopy.dashboardHref;
        const url = new URL(target, window.location.origin);
        url.searchParams.set("checkout", status);
        return `${url.pathname}${url.search}${url.hash}`;
      }

      function getCheckoutReturnTo() {
        return safeInternalPath(params.get("return_to"));
      }

      function getCheckoutSuccessDestination() {
        return addCheckoutStatus(
          getCheckoutReturnTo() || checkoutCopy.dashboardHref,
          "success",
        );
      }

      async function syncCheckoutSession() {
        const sessionId = params.get("session_id");
        if (!sessionId) return false;
        try {
          const res = await fetch("/api/billing/sync-checkout", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ sessionId }),
          });
          const body = await res.json().catch(() => null);
          return Boolean(body?.ok);
        } catch {
          return false;
        }
      }

      async function showCheckoutSuccess() {
        for (let attempt = 0; attempt < 40; attempt += 1) {
          if (typeof window.absAlert === "function") {
            await window.absAlert(checkoutCopy.checkoutSuccess);
            return;
          }
          await delay(50);
        }
        toast(checkoutCopy.checkoutSuccess);
        await delay(1600);
      }

      function priceFor(card) {
        const price = card.querySelector(".plan-price");
        return price?.dataset[interval] || "0";
      }

      function updatePrices() {
        cards.forEach((card) => {
          const price = card.querySelector(".plan-price");
          const amount = card.querySelector(".price-amount");
          const unit = card.querySelector(".price-unit");
          if (!price || !amount || !unit) return;
          amount.textContent = price.dataset[interval] || "0";
          unit.textContent =
            interval === "yearly"
              ? checkoutCopy.yearlyUnit
              : checkoutCopy.monthlyUnit;
        });
      }

      intervalButtons.forEach((button) => {
        button.addEventListener("click", () => {
          interval = button.dataset.interval || "monthly";
          intervalButtons.forEach((item) =>
            item.classList.toggle("active", item === button),
          );
          updatePrices();
        });
      });

      function openCheckout(plan) {
        const card = cards.find((item) => item.dataset.plan === plan);
        if (!card) return;
        pendingPlan = plan;
        const title = card.querySelector("h2")?.textContent?.trim() || plan;
        const price = priceFor(card);
        if (summary) {
          summary.innerHTML = `
            <b>${title}</b>
            <span>$${price} ${
              interval === "yearly"
                ? checkoutCopy.yearlyUnit
                : checkoutCopy.monthlyUnit
            }</span>
          `;
        }
        if (dialog && typeof dialog.showModal === "function") {
          dialog.showModal();
        } else {
          startCheckout();
        }
      }

      async function startCheckout() {
        if (!pendingPlan) return;
        if (confirmBtn) confirmBtn.disabled = true;
        try {
          const payload = {
            planCode: pendingPlan,
            interval,
            pricingPath: window.location.pathname,
          };
          const returnTo = getCheckoutReturnTo();
          if (returnTo) payload.returnTo = returnTo;

          const res = await fetch("/api/billing/checkout", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify(payload),
          });
          const body = await res.json().catch(() => null);
          if (body?.ok && body.data?.url) {
            window.location.href = body.data.url;
            return;
          }
          if (
            body?.error?.code === "BILLING_NOT_CONFIGURED" ||
            body?.error?.code === "PRICE_NOT_CONFIGURED"
          ) {
            toast(checkoutCopy.toastBillingMissing);
          } else {
            toast(body?.error?.message || checkoutCopy.toastCheckoutFailed);
          }
        } catch {
          toast(checkoutCopy.toastCheckoutFailed);
        } finally {
          if (confirmBtn) confirmBtn.disabled = false;
        }
      }

      async function openPortal() {
        try {
          const res = await fetch("/api/billing/portal", { method: "POST" });
          const body = await res.json().catch(() => null);
          if (body?.ok && body.data?.url) {
            window.location.href = body.data.url;
            return;
          }
          toast(body?.error?.message || checkoutCopy.toastPortalFailed);
        } catch {
          toast(checkoutCopy.toastPortalFailed);
        }
      }

      document.querySelectorAll("[data-plan-cta]").forEach((button) => {
        button.addEventListener("click", (event) => {
          event.preventDefault();
          const card = button.closest(".pricing-plan-card");
          const plan = button.dataset.plan;
          if (card?.dataset.current === "true") openPortal();
          else if (plan) openCheckout(plan);
        });
      });

      confirmBtn?.addEventListener("click", startCheckout);
      cancelBtn?.addEventListener("click", () => dialog?.close());

      fetch("/api/session")
        .then((res) => res.json())
        .then((body) => {
          const plan = body?.data?.plan;
          cards.forEach((card) => {
            if (card.dataset.plan !== plan) return;
            card.dataset.current = "true";
            card.insertAdjacentHTML(
              "afterbegin",
              `<div class="current-plan-flag">${checkoutCopy.currentPlan}</div>`,
            );
            const cta = card.querySelector("[data-plan-cta]");
            if (cta) cta.textContent = checkoutCopy.manageCta;
          });
        })
        .catch(() => {});

      if (params.get("checkout") === "success") {
        const destination = getCheckoutSuccessDestination();
        syncCheckoutSession()
          .then(() => showCheckoutSuccess())
          .then(() => {
            window.location.href = destination;
          });
      } else if (params.get("checkout") === "cancel") {
        toast(checkoutCopy.checkoutCancelNotice);
      }
    })();
  </script>

