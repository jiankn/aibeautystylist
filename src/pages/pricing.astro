---
import SiteHeader from "../components/SiteHeader.astro";
import {
  getLocalizedPathForRoute,
  getLocalizedSeoPageByRoute,
} from "../i18n/localizedSeoPages";
import { getLocalizedAppHref, resolveLocaleRoute } from "../i18n/routing";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLocalizedPricingContent } from "../data/pricingContent";
import { getCurrentLocale } from "../lib/i18n";
import { PLAN_DEFINITIONS, type PlanCode } from "../lib/plans";

const currentLocale = getCurrentLocale();
const currentPathname = Astro.originPathname || Astro.url.pathname;
const currentRoute =
  Astro.locals.localeRoute ?? resolveLocaleRoute(currentPathname);
const localizeAppHref = (href: string) =>
  getLocalizedAppHref(href, currentRoute.language.slug);
const dashboardHref = localizeAppHref("/dashboard");
const isEnglish = !currentLocale.startsWith("zh");
const yearlyFactor = 10;
const planOrder: PlanCode[] = ["free", "pro", "premium"];

const fallbackFeatureText = isEnglish
  ? {
      yes: "Included",
      no: "Not included",
      freeCta: "Start free",
      upgradeCta: "Upgrade",
      manageCta: "Manage subscription",
      currentPlan: "Current plan",
    }
  : {
      yes: "包含",
      no: "不包含",
      freeCta: "免费开始",
      upgradeCta: "选择方案",
      manageCta: "管理订阅",
      currentPlan: "当前计划",
    };

const fallbackCopy = isEnglish
  ? {
      metaTitle: "Pricing | AI Beauty Stylist",
      metaDescription:
        "Compare Free, Pro, and Premium plans for AI makeup try-on, facial diagnosis, HD downloads, and priority generation.",
      kicker: "Plans",
      title: "Choose the plan by how often you generate",
      subtitle:
        "Diagnosis and try-on use the same monthly generation credits. Pick a plan by usage frequency, output quality, and whether you need priority and long-term history.",
      billingMonthly: "Monthly",
      billingYearly: "Yearly",
      yearlySave: "Save 2 months",
      bestFor: "Best for",
      included: "Included",
      monthlyUnit: "/ month",
      yearlyUnit: "/ year",
      popular: "Best value",
      premiumRibbon: "For frequent users",
      decisionHelperTitle: "Not sure which plan fits?",
      decisionHelperLead: "Most regular users start with Pro.",
      decisionHelperItems: [
        ["Free", "Use it only to validate the workflow and output quality."],
        [
          "Pro",
          "Best for weekly try-ons, diagnosis-led choices, and HD downloads.",
        ],
        [
          "Premium",
          "Choose it when speed, full catalog access, and longer history matter.",
        ],
      ],
      heroPoints: [
        [
          "One credit model",
          "A diagnosis or a try-on task uses one generation credit.",
        ],
        [
          "Refund on failure",
          "Failed, timed-out, or cancelled tasks are refunded automatically.",
        ],
        [
          "Cancel anytime",
          "Subscription benefits stay active until the end of the paid period.",
        ],
      ],
      planContent: {
        free: {
          badge: "Trial",
          audience: "First-time users validating the product",
          reason:
            "Use Free to confirm whether the AI workflow and image quality fit you.",
          features: [
            "3 monthly generation credits",
            "AI facial diagnosis and try-on both available",
            "Standard preview quality",
            "Daily share reward for extra credits",
          ],
        },
        pro: {
          badge: "Most useful",
          audience: "Regular users building daily looks",
          reason:
            "Enough credits for weekly experiments, diagnosis-led choices, and HD output.",
          features: [
            "70 monthly generation credits",
            "HD downloads",
            "Detailed makeup tutorials",
            "Better fit for comparing multiple scenarios",
          ],
        },
        premium: {
          badge: "Complete",
          audience: "High-frequency creators and beauty explorers",
          reason:
            "Designed for faster iteration, more saved context, and complete look access.",
          features: [
            "150 monthly generation credits",
            "Priority queue",
            "Long-term history",
            "Full look library access",
            "HD downloads and tutorials",
          ],
        },
      },
      proofKicker: "The upgrade experience",
      proofTitle: "Upgrade to reduce the cost of trial and error",
      proofSubtitle:
        "The meaningful difference is how many options you can compare, how useful each result becomes, and how much context the product keeps for you.",
      proofCta: "View the full plan comparison",
      proof: [
        [
          "Options you can compare",
          "3 → 70 → 150 credits / month",
          "Move from validating one result to comparing looks across scenarios.",
        ],
        [
          "Results you can use",
          "Standard preview → HD downloads and tutorials",
          "Keep useful outputs and turn a generated look into something you can recreate.",
        ],
        [
          "Generation and history",
          "Standard queue → priority and long-term history",
          "Premium supports frequent iterations, event preparation, and saved context.",
        ],
      ],
      compareTitle: "Plan comparison",
      compareSubtitle:
        "All generation-related pages follow the same quota rules.",
      mobileCompareTitle: "Choose by how often you try looks",
      mobileCompareSubtitle:
        "Start with the best-fit plan, then expand the full feature list only if you need detail.",
      mobileCompareCredits: "Credits / month",
      mobileCompareDetails: "Compare all features",
      mobilePlanCta: {
        free: "Start free",
        pro: "Choose Pro",
        premium: "Choose Premium",
      },
      faqTitle: "Questions before upgrading",
      faq: [
        [
          "Can I cancel after subscribing?",
          "Yes. Benefits remain active until the end of the current billing period.",
        ],
        [
          "Are diagnosis credits separate?",
          "No. Diagnosis and try-on use the same monthly generation credits.",
        ],
        [
          "What happens if generation fails?",
          "Failed, timed-out, or cancelled tasks refund the reserved credit automatically.",
        ],
        [
          "Can I use downloaded images commercially?",
          "Personal use is supported by default. Commercial use requires separate authorization.",
        ],
      ],
      policyTitle: "Billing and policy",
      policyText:
        "Subscriptions renew automatically. You can cancel from the customer portal. Paid fees are not refunded, but cancellation prevents the next renewal.",
      policyKicker: "Billing clarity",
      policyFacts: [
        ["Renewal", "Renews automatically for the selected billing cycle"],
        [
          "After cancellation",
          "Benefits stay active until the paid period ends",
        ],
        ["Refunds", "Paid subscription fees are not refunded"],
      ],
      policySupportLead: "Still unsure about billing or cancellation?",
      policySupportCta: "Contact support",
      checkoutTitle: "Confirm subscription",
      checkoutCopy:
        "You will be redirected to Stripe Checkout. The subscription renews automatically for the selected billing cycle.",
      checkoutCancel: "Cancel",
      checkoutConfirm: "Continue to checkout",
      toastBillingMissing: "Billing is not configured yet.",
      toastCheckoutFailed: "Unable to start checkout. Please try again later.",
      toastPortalFailed: "Unable to open subscription management.",
      checkoutSuccess:
        "Checkout completed. Your plan may take a moment to update.",
      checkoutCancelNotice: "Checkout was cancelled.",
    }
  : {
      metaTitle: "AI 试妆会员价格 | AI Beauty Stylist",
      metaDescription:
        "比较 AI Beauty Stylist Free、Pro 和 Premium 计划，了解在线 AI 试妆、妆容诊断、高清下载和优先队列权益。",
      kicker: "会员计划",
      title: "按试妆频率选择合适计划",
      subtitle:
        "诊断和试妆共用月度生成额度。先看你每月大概会生成多少次，再决定是否需要高清下载、优先队列和长期历史。",
      billingMonthly: "按月",
      billingYearly: "按年",
      yearlySave: "省 2 个月",
      bestFor: "适合",
      included: "包含功能",
      monthlyUnit: "/ 月",
      yearlyUnit: "/ 年",
      popular: "推荐选择",
      premiumRibbon: "适合高频使用",
      decisionHelperTitle: "不确定选哪个？",
      decisionHelperLead: "先用 Free 验证流程，需要连续试妆时再看 Pro。",
      decisionHelperItems: [
        ["Free", "适合先确认上传、生成和结果展示是否符合预期。"],
        ["Pro", "适合每周试不同妆容，并保存更清晰的结果。"],
        ["Premium", "适合高频对比、活动准备或需要更长历史记录。"],
      ],
      heroPoints: [
        ["统一额度", "一次诊断或一次试妆都使用 1 次月度生成额度。"],
        ["失败返还", "失败、超时或取消的任务会自动返还预占额度。"],
        ["随时取消", "取消后权益保留到当前已付周期结束。"],
      ],
      planContent: {
        free: {
          badge: "入门",
          audience: "第一次验证产品的用户",
          reason: "先确认上传流程、生成效果和照片处理方式是否符合预期。",
          features: [
            "每月 3 次生成额度",
            "可用于 AI 妆容诊断或直接试妆",
            "标准清晰度预览",
            "分享后可获得额外生成额度",
          ],
        },
        pro: {
          badge: "常用",
          audience: "经常探索日常妆容的用户",
          reason: "额度足够做每周试妆、诊断后再选妆，并保留高清结果。",
          features: [
            "每月 70 次生成额度",
            "高清下载",
            "详细妆容教程",
            "适合对比多个场景和妆容方向",
          ],
        },
        premium: {
          badge: "完整",
          audience: "高频试妆、内容创作或活动前准备",
          reason: "更适合频繁迭代、需要完整妆容库和更长历史记录的用户。",
          features: [
            "每月 150 次生成额度",
            "优先队列",
            "长期历史记录",
            "完整妆容库",
            "高清下载和详细教程",
          ],
        },
      },
      proofKicker: "升级后的体验",
      proofTitle: "升级的价值，在于减少反复试错",
      proofSubtitle:
        "差异不只是功能数量，而是你能比较多少方向、保留多清晰的结果，以及是否需要更长时间回看记录。",
      proofCta: "查看完整权益对比",
      proof: [
        [
          "可比较的次数",
          "3 → 70 → 150 次 / 月",
          "从偶尔验证一次效果，到持续比较不同场景和妆容方向。",
        ],
        [
          "可使用的结果",
          "标准预览 → 高清下载与教程",
          "把生成结果保存下来，并转化成可以实际复现的妆容方案。",
        ],
        [
          "生成与记录体验",
          "标准队列 → 优先队列与长期历史",
          "Premium 更适合高频尝试、活动准备和长期回看历史记录。",
        ],
      ],
      compareTitle: "权益对比",
      compareSubtitle: "所有生成相关页面都遵循同一套额度规则。",
      mobileCompareTitle: "先按试妆频率选方案",
      mobileCompareSubtitle: "先看最适合自己的方案，再按需展开完整功能对比。",
      mobileCompareCredits: "每月额度",
      mobileCompareDetails: "查看完整权益对比",
      mobilePlanCta: {
        free: "免费开始",
        pro: "选择 Pro",
        premium: "选择 Premium",
      },
      faqTitle: "升级前常见问题",
      faq: [
        [
          "订阅后可以取消吗？",
          "可以。取消后权益会持续到当前计费周期结束，到期后不再续费。",
        ],
        [
          "诊断额度是单独计算的吗？",
          "不是。AI 妆容诊断和试妆都使用同一套月度生成额度。",
        ],
        ["生成失败会扣额度吗？", "失败、超时或取消任务会自动返还预占额度。"],
        ["下载图片可以商用吗？", "默认支持个人使用；商业使用需要单独授权。"],
      ],
      policyTitle: "扣费与取消说明",
      policyText:
        "订阅会按所选周期自动续费，可在客户门户随时取消；取消后当前周期内权益保留。已支付费用不退款，但不会再产生下一周期扣费。",
      policyKicker: "订阅规则",
      policyFacts: [
        ["续费方式", "按所选月付或年付周期自动续费"],
        ["取消之后", "当前已付周期内的权益继续保留"],
        ["退款规则", "已支付的订阅费用不予退款"],
      ],
      policySupportLead: "对扣费、取消或账户状态仍有疑问？",
      policySupportCta: "联系支持",
      checkoutTitle: "确认订阅",
      checkoutCopy:
        "你将前往 Stripe Checkout 完成支付。订阅会按所选周期自动续费。",
      checkoutCancel: "取消",
      checkoutConfirm: "前往支付",
      toastBillingMissing: "支付尚未配置，敬请期待。",
      toastCheckoutFailed: "无法发起结账，请稍后重试。",
      toastPortalFailed: "无法打开订阅管理页面。",
      checkoutSuccess: "支付已完成，计划状态可能需要片刻同步。",
      checkoutCancelNotice: "支付流程已取消。",
    };

const localizedPricingContent = getLocalizedPricingContent(currentLocale);
const featureText = localizedPricingContent?.featureText ?? fallbackFeatureText;
const copy = localizedPricingContent?.copy
  ? { ...fallbackCopy, ...localizedPricingContent.copy }
  : fallbackCopy;
const comparisonLabels = localizedPricingContent?.comparisonLabels ?? {
  credits: isEnglish ? "Monthly generation credits" : "月度生成额度",
  diagnosis: isEnglish ? "AI diagnosis uses credits" : "妆容诊断使用额度",
  tryon: isEnglish ? "AI try-on uses credits" : "AI 试妆使用额度",
  hd: isEnglish ? "HD download" : "高清下载",
  tutorials: isEnglish ? "Makeup tutorials" : "详细妆容教程",
  priority: isEnglish ? "Priority queue" : "优先队列",
  history: isEnglish ? "Long-term history" : "长期历史",
  catalog: isEnglish ? "Full look library" : "完整妆容库",
};

const localizedPricingPath = getLocalizedPathForRoute(
  "en",
  "/pricing",
  currentRoute.language.slug,
);
const localizedPricingSeo = localizedPricingPath
  ? getLocalizedSeoPageByRoute(currentRoute.language.slug, localizedPricingPath)
  : undefined;
const pageMetaTitle = localizedPricingSeo?.title ?? copy.metaTitle;
const pageMetaDescription =
  localizedPricingSeo?.description ?? copy.metaDescription;
const pageTitle = localizedPricingSeo?.heroTitle ?? copy.title;
const pageSubtitle = localizedPricingSeo?.heroSubtitle ?? copy.subtitle;

const boolText = (value: boolean) => (value ? featureText.yes : featureText.no);
const comparisonRows = [
  {
    label: comparisonLabels.credits,
    values: Object.fromEntries(
      planOrder.map((code) => [
        code,
        String(PLAN_DEFINITIONS[code].monthlyQuota),
      ]),
    ) as Record<PlanCode, string>,
  },
  {
    label: comparisonLabels.diagnosis,
    values: {
      free: featureText.yes,
      pro: featureText.yes,
      premium: featureText.yes,
    },
  },
  {
    label: comparisonLabels.tryon,
    values: {
      free: featureText.yes,
      pro: featureText.yes,
      premium: featureText.yes,
    },
  },
  {
    label: comparisonLabels.hd,
    values: Object.fromEntries(
      planOrder.map((code) => [
        code,
        boolText(PLAN_DEFINITIONS[code].features.hdDownload),
      ]),
    ) as Record<PlanCode, string>,
  },
  {
    label: comparisonLabels.tutorials,
    values: Object.fromEntries(
      planOrder.map((code) => [
        code,
        boolText(PLAN_DEFINITIONS[code].features.tutorials),
      ]),
    ) as Record<PlanCode, string>,
  },
  {
    label: comparisonLabels.priority,
    values: Object.fromEntries(
      planOrder.map((code) => [
        code,
        boolText(PLAN_DEFINITIONS[code].features.priorityQueue),
      ]),
    ) as Record<PlanCode, string>,
  },
  {
    label: comparisonLabels.history,
    values: Object.fromEntries(
      planOrder.map((code) => [
        code,
        boolText(PLAN_DEFINITIONS[code].features.longTermHistory),
      ]),
    ) as Record<PlanCode, string>,
  },
  {
    label: comparisonLabels.catalog,
    values: Object.fromEntries(
      planOrder.map((code) => [
        code,
        boolText(PLAN_DEFINITIONS[code].features.fullLookLibrary),
      ]),
    ) as Record<PlanCode, string>,
  },
];

const planCards = planOrder.map((code) => ({
  code,
  title: PLAN_DEFINITIONS[code].title,
  quota: PLAN_DEFINITIONS[code].monthlyQuota,
  monthlyPrice: PLAN_DEFINITIONS[code].monthlyPriceUsd.toFixed(
    code === "free" ? 0 : 2,
  ),
  yearlyPrice: (PLAN_DEFINITIONS[code].monthlyPriceUsd * yearlyFactor).toFixed(
    code === "free" ? 0 : 2,
  ),
  content: copy.planContent[code],
}));

const productJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Product",
      name: "AI Beauty Stylist",
      description: pageMetaDescription,
      brand: { "@type": "Brand", name: "AI Beauty Stylist" },
      offers: planCards
        .filter((plan) => plan.code !== "free")
        .map((plan) => ({
          "@type": "Offer",
          name: plan.title,
          price: plan.monthlyPrice,
          priceCurrency: "USD",
          category: "subscription",
        })),
    },
    {
      "@type": "FAQPage",
      mainEntity: copy.faq.map(([question, answer]) => ({
        "@type": "Question",
        name: question,
        acceptedAnswer: { "@type": "Answer", text: answer },
      })),
    },
  ],
});

const checkoutCopy = {
  ...featureText,
  monthly: copy.billingMonthly,
  yearly: copy.billingYearly,
  monthlyUnit: copy.monthlyUnit,
  yearlyUnit: copy.yearlyUnit,
  checkoutTitle: copy.checkoutTitle,
  checkoutCopy: copy.checkoutCopy,
  checkoutConfirm: copy.checkoutConfirm,
  toastBillingMissing: copy.toastBillingMissing,
  toastCheckoutFailed: copy.toastCheckoutFailed,
  toastPortalFailed: copy.toastPortalFailed,
  checkoutSuccess: copy.checkoutSuccess,
  checkoutCancelNotice: copy.checkoutCancelNotice,
  dashboardHref,
};
---

<BaseLayout
  title={pageMetaTitle}
  description={pageMetaDescription}
  bodyClass="pricing-body"
  jsonLd={productJsonLd}
>
  <SiteHeader active="pricing" />
  <main class="pricing-main">
    <section class="pricing-hero shell" aria-labelledby="pricing-title">
      <div class="pricing-hero-copy">
        <span class="section-eyebrow">{copy.kicker}</span>
        <h1 id="pricing-title">{pageTitle}</h1>
        <p>{pageSubtitle}</p>
        <div class="pricing-hero-points">
          {
            copy.heroPoints.map(([title, text]) => (
              <div>
                <b>{title}</b>
                <span>{text}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="pricing-plans shell" aria-label={copy.kicker}>
      <div class="billing-toggle" role="group" aria-label={copy.kicker}>
        <button type="button" data-interval="monthly" class="active">
          {copy.billingMonthly}
        </button>
        <button type="button" data-interval="yearly">
          {copy.billingYearly}
          <span>{copy.yearlySave}</span>
        </button>
      </div>

      <div class="pricing-grid">
        {
          planCards.map((plan) => (
            <article
              class:list={[
                "pricing-plan-card",
                "panel",
                plan.code === "pro" && "recommended",
                plan.code === "premium" && "premium",
              ]}
              data-plan={plan.code}
            >
              {plan.code === "pro" && (
                <div class="plan-ribbon">{copy.popular}</div>
              )}
              {plan.code === "premium" && (
                <div class="plan-ribbon">{copy.premiumRibbon}</div>
              )}
              <div class="plan-head">
                <div>
                  <h2>{plan.title}</h2>
                  <p>{plan.content.audience}</p>
                </div>
                <span>{plan.content.badge}</span>
              </div>
              <div
                class="plan-price"
                data-monthly={plan.monthlyPrice}
                data-yearly={plan.yearlyPrice}
              >
                <span>$</span>
                <b class="price-amount">{plan.monthlyPrice}</b>
                <small class="price-unit">{copy.monthlyUnit}</small>
              </div>
              <p class="plan-reason">{plan.content.reason}</p>
              {plan.code === "free" ? (
                <a
                  class="btn btn-wide btn-outline-rose"
                  href={localizeAppHref("/tryon-free")}
                >
                  {featureText.freeCta}
                </a>
              ) : (
                <a
                  class:list={[
                    "btn",
                    "btn-wide",
                    plan.code === "premium" ? "btn-gold" : "btn-primary",
                  ]}
                  href="#checkout"
                  data-plan-cta
                  data-plan={plan.code}
                >
                  {featureText.upgradeCta}
                </a>
              )}
              <div class="feature-list">
                <b>{copy.included}</b>
                {plan.content.features.map((feature) => (
                  <span>{feature}</span>
                ))}
              </div>
            </article>
          ))
        }
      </div>

      <div class="pricing-choice-helper" aria-label={copy.decisionHelperTitle}>
        <div class="pricing-choice-copy">
          <b>{copy.decisionHelperTitle}</b>
          <span>{copy.decisionHelperLead}</span>
        </div>
        <div class="pricing-choice-list">
          {
            copy.decisionHelperItems.map(([plan, text]) => (
              <span>
                <strong>{plan}</strong>
                {text}
              </span>
            ))
          }
        </div>
      </div>
    </section>

    <section class="pricing-proof shell" aria-labelledby="pricing-proof-title">
      <div class="pricing-proof-head">
        <span class="section-eyebrow">{copy.proofKicker}</span>
        <h2 id="pricing-proof-title">{copy.proofTitle}</h2>
        <p>{copy.proofSubtitle}</p>
      </div>
      <div class="pricing-proof-list">
        {
          copy.proof.map(([title, value, text]) => (
            <article>
              <span>{title}</span>
              <strong>{value}</strong>
              <p>{text}</p>
            </article>
          ))
        }
      </div>
      <a class="pricing-proof-link" href="#pricing-comparison">
        {copy.proofCta}
      </a>
    </section>

    <section
      class="pricing-comparison shell"
      id="pricing-comparison"
      aria-labelledby="compare-title"
    >
      <div class="pricing-section-head">
        <h2 id="compare-title">{copy.compareTitle}</h2>
        <p>{copy.compareSubtitle}</p>
      </div>
      <div
        class="mobile-comparison-summary"
        aria-label={copy.mobileCompareTitle}
      >
        <div class="mobile-comparison-intro">
          <h3>{copy.mobileCompareTitle}</h3>
          <p>{copy.mobileCompareSubtitle}</p>
        </div>
        <div class="mobile-plan-compare-cards">
          {
            planCards.map((plan) => (
              <article
                class:list={[
                  "mobile-plan-compare-card",
                  plan.code === "pro" && "recommended",
                  plan.code === "premium" && "premium",
                ]}
              >
                <div class="mobile-plan-compare-head">
