                    <li>{feature}</li>
                  ))}
                </ul>
                {plan.code === "free" ? (
                  <a class="btn btn-wide" href={localizeAppHref("/tryon-free")}>
                    {copy.mobilePlanCta[plan.code]}
                  </a>
                ) : (
                  <a
                    class:list={[
                      "btn",
                      "btn-wide",
                      plan.code === "premium" ? "btn-gold" : "btn-primary",
                    ]}
                    href="#checkout"
                    data-plan-cta
                    data-plan={plan.code}
                  >
                    {copy.mobilePlanCta[plan.code]}
                  </a>
                )}
