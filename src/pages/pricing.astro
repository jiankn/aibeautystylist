        {
          comparisonRows.map((row) => (
            <div class="compare-row">
              <span>{row.label}</span>
              {planOrder.map((code) => {
                const val = row.values[code];
                const isYes = val === featureText.yes;
                const isNo = val === featureText.no;
                return (
                  <span
                    data-plan-label={PLAN_DEFINITIONS[code].title}
                    class:list={[isYes && "compare-yes", isNo && "compare-no"]}
