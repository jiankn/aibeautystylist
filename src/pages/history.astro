  </style>

  <script is:inline define:vars={{ copy, hrefs, recommendations }}>
    (() => {
      const root = document.querySelector("[data-history-page]");
      if (!root) return;

      const runningStatuses = new Set([
        "created",
        "upload_validating",
        "diagnosis_running",
        "image_running",
      ]);
      const locale = document.documentElement.lang || undefined;
      const recommendationBySlug = new Map(
        recommendations.map((look) => [look.slug, look]),
      );
      const state = {
        jobs: [],
        query: "",
        filter: "all",
        sort: "newest",
        selectMode: false,
        selectedIds: new Set(),
        favoriteIds: new Set(),
      };

      const controls = {
        list: root.querySelector("[data-history-list]"),
        search: root.querySelector("[data-history-search]"),
        clearSearch: root.querySelector("[data-history-search-clear]"),
        filterButtons: Array.from(
          root.querySelectorAll("[data-history-filter]"),
        ),
        sort: root.querySelector("[data-history-sort]"),
        selectToggle: root.querySelector("[data-history-select-toggle]"),
        selectLabel: root.querySelector("[data-history-select-label]"),
        total: root.querySelector("[data-history-total]"),
        visible: root.querySelector("[data-history-visible]"),
        selected: root.querySelector("[data-history-selected]"),
        selectionBar: root.querySelector("[data-history-selection-bar]"),
        selectionCount: root.querySelector("[data-selection-count]"),
        delete: root.querySelector("[data-history-delete]"),
        compare: root.querySelector("[data-history-compare]"),
        share: root.querySelector("[data-history-share]"),
        cancel: root.querySelector("[data-history-cancel]"),
        feedback: root.querySelector("[data-history-feedback]"),
      };
      const setSelectionNavSuppressed = (suppressed) => {
        window.absSetMobileBottomNavSuppressed?.(
          "history-selection",
          suppressed,
        );
      };

      const icons = {
        heart:
          '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.8 4.7a5.5 5.5 0 0 0-7.8 0L12 5.8l-1-1.1a5.5 5.5 0 0 0-7.8 7.8L12 21l8.8-8.5a5.5 5.5 0 0 0 0-7.8Z"></path></svg>',
        more: '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="6" cy="12" r="1.3"></circle><circle cx="12" cy="12" r="1.3"></circle><circle cx="18" cy="12" r="1.3"></circle></svg>',
      };

      function clear(node) {
        if (node) node.replaceChildren();
      }

      async function getJson(url) {
        const response = await fetch(url);
        const body = await response.json().catch(() => null);
        if (!response.ok || !body?.ok) {
          throw new Error(body?.error?.message || "REQUEST_FAILED");
        }
        return body.data;
      }

      function fallbackLook(slug) {
        return recommendationBySlug.get(slug) || recommendations[0] || {};
      }

      function formatDate(value, options) {
        if (!value) return "";
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return "";
        return new Intl.DateTimeFormat(locale, options).format(date);
      }

      function getDateKey(date) {
        if (!date || Number.isNaN(date.getTime())) return "unknown";
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, "0");
        const day = String(date.getDate()).padStart(2, "0");
        return `${year}-${month}-${day}`;
      }

      function getDateGroup(value) {
        if (!value) return copy.dateUnknown;
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return copy.dateUnknown;
        const today = new Date();
        const todayStart = new Date(
          today.getFullYear(),
          today.getMonth(),
          today.getDate(),
        );
        const dateStart = new Date(
          date.getFullYear(),
          date.getMonth(),
          date.getDate(),
        );
        const diff = Math.round((todayStart - dateStart) / 86400000);
        if (diff === 0) return copy.dateToday;
        if (diff === 1) return copy.dateYesterday;
        return formatDate(value, { month: "long", day: "numeric" });
      }

      function getStatusState(status) {
        if (status === "succeeded") return "succeeded";
        if (runningStatuses.has(status)) return "running";
        return "failed";
      }

      function getStatusLabel(statusState) {
        if (statusState === "succeeded") return copy.statusSucceeded;
        if (statusState === "running") return copy.statusRunning;
        return copy.statusFailed;
      }

      function normalizeJob(job, index) {
        const fallback = fallbackLook(job?.lookSlug);
        const createdAt = job?.createdAt || job?.updatedAt || "";
        const createdDate = createdAt ? new Date(createdAt) : null;
        const statusState = getStatusState(job?.status);
        const id =
          job?.id ||
          `${job?.lookSlug || "look"}-${createdAt || "unknown"}-${index}`;
        const title = job?.lookTitle || fallback.title || copy.unknownLook;
        const timeLabel =
          formatDate(createdAt, {
            year: "numeric",
            month: "short",
            day: "numeric",
          }) || copy.dateUnknown;

        return {
          id,
          lookSlug: job?.lookSlug || fallback.slug || "",
          title,
          image: job?.resultImage || fallback.image || "",
          imageAlt: title,
          resultImage: job?.resultImage || "",
          status: job?.status || "failed",
          statusState,
          statusLabel: getStatusLabel(statusState),
          createdAt,
          createdTime:
            createdDate && !Number.isNaN(createdDate.getTime())
              ? createdDate.getTime()
              : 0,
          dateKey: getDateKey(createdDate),
          dateGroup: getDateGroup(createdAt),
          timeLabel,
          searchText: [
            title,
            job?.lookSlug,
            getStatusLabel(statusState),
            timeLabel,
            createdAt,
          ]
            .filter(Boolean)
            .join(" ")
            .toLocaleLowerCase(locale),
        };
      }

      function getFilteredJobs() {
        const query = state.query.trim().toLocaleLowerCase(locale);
        const filtered = state.jobs.filter((job) => {
          if (state.filter === "succeeded" && job.statusState !== "succeeded") {
            return false;
          }
          if (state.filter === "failed" && job.statusState === "succeeded") {
            return false;
          }
          if (state.filter === "favorited" && !state.favoriteIds.has(job.id)) {
            return false;
          }
          return !query || job.searchText.includes(query);
        });

        return filtered.sort((a, b) => {
          if (state.sort === "oldest") return a.createdTime - b.createdTime;
          if (state.sort === "name") {
            return a.title.localeCompare(b.title, locale, {
              sensitivity: "base",
            });
          }
          return b.createdTime - a.createdTime;
        });
      }

      function updateCounts(visibleJobs) {
        const counts = {
          all: state.jobs.length,
          succeeded: state.jobs.filter((job) => job.statusState === "succeeded")
            .length,
          failed: state.jobs.filter((job) => job.statusState !== "succeeded")
            .length,
          favorited: state.jobs.filter((job) => state.favoriteIds.has(job.id))
            .length,
        };

        Object.entries(counts).forEach(([key, count]) => {
          const node = root.querySelector(`[data-history-count="${key}"]`);
          if (node) node.textContent = String(count);
        });
        if (controls.total)
          controls.total.textContent = String(state.jobs.length);
        if (controls.visible)
          controls.visible.textContent = String(visibleJobs.length);
        updateSelectionUi();
      }

      function renderEmpty() {
        clear(controls.list);
        const box = document.createElement("div");
        box.className = "history-empty-state";

        const mark = document.createElement("span");
        mark.className = "history-empty-mark";
        mark.setAttribute("aria-hidden", "true");
        mark.textContent = "AI";

        const copyBox = document.createElement("div");
        copyBox.className = "history-empty-copy";
        const title = document.createElement("strong");
        title.textContent = copy.emptyHistoryTitle;
        const hint = document.createElement("span");
        hint.textContent = copy.emptyHistoryHint;
        copyBox.append(title, hint);

        const actions = document.createElement("div");
        actions.className = "history-empty-actions";
        const primary = document.createElement("a");
        primary.href = hrefs.tryonFree;
        primary.textContent = copy.startTryon;
        const secondary = document.createElement("a");
        secondary.href = hrefs.discover;
        secondary.textContent = copy.browseLooks;
        actions.append(primary, secondary);

        box.append(mark, copyBox, actions);
        controls.list?.append(box);
      }

      function renderNoResults() {
        clear(controls.list);
        const box = document.createElement("div");
        box.className = "history-no-results";

        const mark = document.createElement("span");
        mark.className = "history-empty-mark";
        mark.setAttribute("aria-hidden", "true");
        mark.textContent = "AI";

        const copyBox = document.createElement("div");
        copyBox.className = "history-no-results-copy";
        const title = document.createElement("strong");
        title.textContent = copy.noResultsTitle;
        const hint = document.createElement("span");
        hint.textContent = copy.noResultsHint;
        const button = document.createElement("button");
        button.type = "button";
        button.textContent = copy.clearFilters;
        button.addEventListener("click", () => {
          state.query = "";
          state.filter = "all";
          state.sort = "newest";
          if (controls.search) controls.search.value = "";
          if (controls.sort) controls.sort.value = "newest";
          render();
        });
        copyBox.append(title, hint, button);
        box.append(mark, copyBox);
        controls.list?.append(box);
      }

      function renderFailure() {
        clear(controls.list);
        const box = document.createElement("div");
        box.className = "history-empty-state";

        const mark = document.createElement("span");
        mark.className = "history-empty-mark";
        mark.setAttribute("aria-hidden", "true");
        mark.textContent = "AI";

        const copyBox = document.createElement("div");
        copyBox.className = "history-empty-copy";
        const title = document.createElement("strong");
        title.textContent = copy.loadFailedTitle;
        const hint = document.createElement("span");
        hint.textContent = copy.loadFailedHint;
        copyBox.append(title, hint);

        const actions = document.createElement("div");
        actions.className = "history-empty-actions";
        const link = document.createElement("a");
        link.href = hrefs.login;
        link.textContent = copy.signIn;
        actions.append(link);

        box.append(mark, copyBox, actions);
        controls.list?.append(box);
      }

      function createFavoriteButton(job) {
        const button = document.createElement("button");
        const isFavorite = state.favoriteIds.has(job.id);
        button.className = "history-card-icon";
        button.type = "button";
        button.setAttribute("aria-pressed", String(isFavorite));
        button.setAttribute(
          "aria-label",
          isFavorite ? copy.unfavorite : copy.favorite,
        );
        button.innerHTML = icons.heart;
        if (job.statusState !== "succeeded") {
          button.disabled = true;
          button.setAttribute("aria-disabled", "true");
        }
        button.addEventListener("click", (event) => {
          event.stopPropagation();
          toggleFavorite(job, button);
        });
        return button;
      }

      async function toggleFavorite(job, button) {
        if (!job?.id || button?.disabled) return;
        button.disabled = true;
        const wasFavorite = state.favoriteIds.has(job.id);
        try {
          if (wasFavorite) {
            const response = await fetch(
              `/api/saved-looks/${encodeURIComponent(job.id)}`,
              { method: "DELETE" },
            );
            const body = await response.json().catch(() => null);
            if (!response.ok || !body?.ok) throw new Error("UNSAVE_FAILED");
            state.favoriteIds.delete(job.id);
          } else {
            const response = await fetch("/api/saved-looks", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                jobId: job.id,
                lookSlug: job.lookSlug || "commute",
              }),
            });
            const body = await response.json().catch(() => null);
            if (!response.ok || !body?.ok) {
              if (body?.error?.code === "SAVED_LOOK_LIMIT_REACHED") {
                showFeedback(copy.savedLimitReached);
                return;
              }
              throw new Error(body?.error?.message || "SAVE_FAILED");
            }
            state.favoriteIds.add(job.id);
          }
          render();
        } catch (error) {
          console.error(copy.saveFailed, error);
          showFeedback(copy.saveFailed);
        } finally {
          button.disabled = false;
        }
      }

      function createCard(job) {
        const card = document.createElement("article");
        card.className = "history-card";
        card.dataset.historyId = job.id;
        card.dataset.status = job.statusState;
        if (state.selectMode) card.classList.add("is-selectable");
        if (state.selectedIds.has(job.id)) card.classList.add("is-selected");

        const media = document.createElement("div");
        media.className = "history-card-media";
        if (job.image) {
          const image = document.createElement("img");
          image.className = "history-card-image";
          image.src = job.image;
          image.alt = job.imageAlt;
          image.loading = "lazy";
          media.append(image);
        } else {
          const placeholder = document.createElement("span");
          placeholder.className = "history-card-placeholder";
          placeholder.textContent = copy.unknownLook;
          media.append(placeholder);
        }

        const status = document.createElement("span");
        status.className = "history-status";
        status.dataset.state = job.statusState;
        status.textContent = job.statusLabel;

        const topActions = document.createElement("div");
        topActions.className = "history-card-top-actions";
        topActions.append(createFavoriteButton(job));

        const checkboxLabel = document.createElement("label");
        checkboxLabel.className = "history-card-check";
        const checkbox = document.createElement("input");
        checkbox.type = "checkbox";
        checkbox.checked = state.selectedIds.has(job.id);
        checkbox.setAttribute("aria-label", `${copy.selectMode}: ${job.title}`);
        checkbox.addEventListener("change", () => toggleSelected(job.id));
        checkboxLabel.append(checkbox);

        media.append(status, topActions, checkboxLabel);

        const body = document.createElement("div");
        body.className = "history-card-body";
        const copyNode = document.createElement("div");
        copyNode.className = "history-card-copy";
        const title = document.createElement("strong");
        title.textContent = job.title;
        const meta = document.createElement("span");
        meta.textContent = job.timeLabel;
        copyNode.append(title, meta);

        const more = document.createElement("button");
        more.className = "history-card-more";
        more.type = "button";
        more.setAttribute("aria-label", `${copy.more}: ${job.title}`);
        more.innerHTML = icons.more;
        more.addEventListener("click", () => {
          if (job.resultImage) {
            window.open(job.resultImage, "_blank", "noopener,noreferrer");
          } else {
            showFeedback(copy.shareFailed);
          }
        });

        body.append(copyNode, more);
        card.append(media, body);
        card.addEventListener("click", (event) => {
          if (!state.selectMode) return;
          if (event.target?.closest("button, a, input, select, label")) return;
          toggleSelected(job.id);
        });
        return card;
      }

      function renderGroups(jobs) {
        clear(controls.list);
        const groups = new Map();
        jobs.forEach((job) => {
          const groupKey = `${job.dateKey}:${job.dateGroup}`;
          if (!groups.has(groupKey)) groups.set(groupKey, []);
          groups.get(groupKey).push(job);
        });

        groups.forEach((groupJobs) => {
          const section = document.createElement("section");
          section.className = "history-date-group";
          const heading = document.createElement("h2");
          heading.className = "history-date-heading";
          heading.textContent = groupJobs[0]?.dateGroup || copy.dateUnknown;
          const grid = document.createElement("div");
          grid.className = "history-grid";
          groupJobs.forEach((job) => grid.append(createCard(job)));
          section.append(heading, grid);
          controls.list?.append(section);
        });
      }

      function render() {
        const filteredJobs = getFilteredJobs();
        controls.filterButtons.forEach((button) => {
          const active = button.dataset.historyFilter === state.filter;
          button.classList.toggle("active", active);
          button.setAttribute("aria-pressed", String(active));
        });
        if (controls.clearSearch) {
          controls.clearSearch.hidden = state.query.trim().length === 0;
        }
        updateCounts(filteredJobs);

        if (!state.jobs.length) {
          renderEmpty();
          return;
        }
        if (!filteredJobs.length) {
          renderNoResults();
          return;
        }
        renderGroups(filteredJobs);
        updateSelectionUi();
      }

      function toggleSelected(id) {
        if (state.selectedIds.has(id)) {
          state.selectedIds.delete(id);
        } else {
          state.selectedIds.add(id);
        }
        render();
      }

      function setSelectMode(enabled) {
        state.selectMode = enabled;
        if (!enabled) state.selectedIds.clear();
        controls.selectToggle?.setAttribute("aria-pressed", String(enabled));
        if (controls.selectLabel) {
          controls.selectLabel.textContent = enabled
            ? copy.exitSelect
            : copy.select;
        }
        render();
      }

      function updateSelectionUi() {
        const count = state.selectedIds.size;
        if (controls.selected) controls.selected.textContent = String(count);
        if (controls.selectionCount) {
          controls.selectionCount.textContent = String(count);
        }
        if (controls.selectionBar) {
          controls.selectionBar.hidden = !state.selectMode;
        }
        setSelectionNavSuppressed(state.selectMode);
        if (controls.delete) controls.delete.disabled = count === 0;
        if (controls.compare) controls.compare.disabled = count < 2;
        if (controls.share) controls.share.disabled = count !== 1;
      }

      function selectedJobs() {
        return state.jobs.filter((job) => state.selectedIds.has(job.id));
      }

      async function deleteSelected() {
        const targets = selectedJobs();
        if (!targets.length) return;
        const message = copy.deleteConfirm.replace(
          "{count}",
          String(targets.length),
        );
        if (!window.confirm(message)) return;
        controls.delete.disabled = true;
        const results = await Promise.allSettled(
          targets.map(async (job) => {
            const response = await fetch(
              `/api/tryon-jobs/${encodeURIComponent(job.id)}`,
              { method: "DELETE" },
            );
            const body = await response.json().catch(() => null);
            if (!response.ok || !body?.ok) throw new Error("DELETE_FAILED");
            return job.id;
          }),
        );
        const deletedIds = new Set(
          results
            .filter((result) => result.status === "fulfilled")
            .map((result) => result.value),
        );
        if (deletedIds.size) {
          state.jobs = state.jobs.filter((job) => !deletedIds.has(job.id));
          deletedIds.forEach((id) => {
            state.selectedIds.delete(id);
            state.favoriteIds.delete(id);
          });
        }
        setSelectMode(false);
        showFeedback(
          deletedIds.size === targets.length
            ? copy.deleteSuccess
            : copy.deleteFailed,
        );
      }

      function compareSelected() {
        if (state.selectedIds.size < 2) {
          showFeedback(copy.compareNeedTwo);
          return;
        }
        showFeedback(copy.comparePending);
      }

      async function shareSelected() {
        const [job] = selectedJobs();
        if (!job?.resultImage) {
          showFeedback(copy.shareFailed);
          return;
        }
        const url = new URL(job.resultImage, window.location.origin).toString();
        try {
          if (navigator.share) {
            await navigator.share({ title: job.title, url });
          } else if (navigator.clipboard) {
            await navigator.clipboard.writeText(url);
            showFeedback(copy.shareCopied);
          } else {
            showFeedback(copy.shareFailed);
          }
        } catch {
          showFeedback(copy.shareFailed);
        }
      }

      let feedbackTimer;
      function showFeedback(message) {
        if (!controls.feedback) return;
        controls.feedback.textContent = message;
        controls.feedback.hidden = false;
        window.clearTimeout(feedbackTimer);
        feedbackTimer = window.setTimeout(() => {
          controls.feedback.hidden = true;
        }, 3600);
      }

      function bindControls() {
        controls.search?.addEventListener("input", (event) => {
          state.query = event.currentTarget.value;
          render();
        });
        controls.clearSearch?.addEventListener("click", () => {
          state.query = "";
          if (controls.search) {
            controls.search.value = "";
            controls.search.focus();
          }
          render();
        });
        controls.filterButtons.forEach((button) => {
          button.addEventListener("click", () => {
            state.filter = button.dataset.historyFilter || "all";
            render();
          });
        });
        controls.sort?.addEventListener("change", (event) => {
          state.sort = event.currentTarget.value || "newest";
          render();
        });
        controls.selectToggle?.addEventListener("click", () => {
          setSelectMode(!state.selectMode);
        });
        controls.cancel?.addEventListener("click", () => setSelectMode(false));
        controls.delete?.addEventListener("click", deleteSelected);
        controls.compare?.addEventListener("click", compareSelected);
        controls.share?.addEventListener("click", shareSelected);
      }

      async function hydrateHistory() {
        try {
          const [data, savedData] = await Promise.all([
            getJson("/api/tryon-jobs?limit=100"),
            getJson("/api/saved-looks"),
          ]);
          const savedItems = Array.isArray(savedData?.items)
            ? savedData.items
            : [];
          state.favoriteIds = new Set(
            savedItems.map((item) => item.jobId).filter(Boolean),
          );
          const jobs = Array.isArray(data?.items) ? data.items : [];
          state.jobs = jobs.map(normalizeJob);
          render();
        } catch {
          state.jobs = [];
          updateCounts([]);
          renderFailure();
        }
      }

      bindControls();
      hydrateHistory();
    })();
  </script>
</BaseLayout>
