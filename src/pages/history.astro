const copy =
  copyByLocale[locale as keyof typeof copyByLocale] ?? copyByLocale.en;
---

<BaseLayout
  title={copy.title}
  description={copy.description}
  bodyClass="history-body"
>
  <SiteHeader active="dashboard" mobileHidden />
  <MobileAppTopBar title={copy.eyebrow} rightAction="none" />
  <main class="history-main" data-history-page>
    <div class="history-shell">
      <section
        class="panel history-command-panel"
        aria-labelledby="history-title"
      >
        <div class="history-page-head">
          <a class="history-back-link" href={hrefs.dashboard}>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="m15 5-7 7 7 7"></path>
            </svg>
            <span>{copy.backDashboard}</span>
          </a>
          <div class="history-title-block">
            <p class="section-kicker">{copy.eyebrow}</p>
            <h1 id="history-title">{copy.heading}</h1>
            <p>{copy.subtitle}</p>
          </div>
          <button
            class="history-select-toggle"
            type="button"
            data-history-select-toggle
            aria-pressed="false"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 7h14"></path>
              <path d="M5 12h14"></path>
              <path d="M5 17h10"></path>
              <path d="m16.5 16.5 1.8 1.8 3.2-3.8"></path>
            </svg>
            <span data-history-select-label>{copy.select}</span>
          </button>
        </div>

        <div class="history-search-row">
          <label class="history-search-field">
            <span class="history-sr-only">{copy.searchLabel}</span>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="10.8" cy="10.8" r="6.2"></circle>
              <path d="m16 16 4.2 4.2"></path>
            </svg>
            <input
              type="search"
              inputmode="search"
              autocomplete="off"
              data-history-search
              placeholder={copy.searchPlaceholder}
            />
            <button
              type="button"
              data-history-search-clear
              aria-label={copy.clearSearch}
              hidden
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="m6 6 12 12"></path>
                <path d="M18 6 6 18"></path>
              </svg>
            </button>
          </label>
        </div>

        <div class="history-filter-row">
          <div
            class="history-chip-group"
            role="group"
            aria-label={copy.filtersLabel}
          >
            <button
              class="history-chip active"
              type="button"
              data-history-filter="all"
              aria-pressed="true"
            >
              <span>{copy.filterAll}</span>
              <b data-history-count="all">0</b>
            </button>
            <button
              class="history-chip"
              type="button"
              data-history-filter="succeeded"
              aria-pressed="false"
            >
              <span>{copy.filterSucceeded}</span>
              <b data-history-count="succeeded">0</b>
            </button>
            <button
              class="history-chip"
              type="button"
              data-history-filter="failed"
              aria-pressed="false"
            >
              <span>{copy.filterFailed}</span>
              <b data-history-count="failed">0</b>
            </button>
            <button
              class="history-chip"
              type="button"
              data-history-filter="favorited"
              aria-pressed="false"
            >
              <span>{copy.filterFavorited}</span>
              <b data-history-count="favorited">0</b>
            </button>
          </div>

          <label class="history-sort-control">
            <span>{copy.sortLabel}</span>
            <select data-history-sort>
              <option value="newest">{copy.sortNewest}</option>
              <option value="oldest">{copy.sortOldest}</option>
              <option value="name">{copy.sortName}</option>
            </select>
          </label>
        </div>

        <div class="history-stats-row" aria-live="polite">
          <span><b data-history-total>0</b> {copy.totalLabel}</span>
          <span><b data-history-visible>0</b> {copy.visibleLabel}</span>
          <span><b data-history-selected>0</b> {copy.selected}</span>
        </div>
      </section>

      <section class="panel history-full-panel" aria-label={copy.heading}>
        <div class="history-list" data-history-list>
          <div class="history-loading-state">
            <p class="loading-line">{copy.loading}</p>
            <div class="history-skeleton-grid" aria-hidden="true">
              <span></span><span></span><span></span><span></span>
            </div>
          </div>
        </div>
      </section>
    </div>

    <div
      class="history-selection-bar"
      data-history-selection-bar
      aria-live="polite"
      hidden
    >
      <span><b data-selection-count>0</b> {copy.selected}</span>
      <div class="history-selection-actions">
        <button type="button" data-history-delete disabled>{copy.delete}</button
        >
        <button type="button" data-history-compare disabled
          >{copy.compare}</button
        >
        <button type="button" data-history-share disabled>{copy.share}</button>
        <button type="button" data-history-cancel>{copy.cancel}</button>
      </div>
    </div>

    <div
      class="history-feedback"
      data-history-feedback
      role="status"
      aria-live="polite"
      hidden
    >
    </div>
  </main>
  {isLoggedIn && <MobileBottomNav active="history" />}

  <style is:global>
    .history-body .history-main {
      min-height: 100dvh;
      padding: 28px 20px 92px;
      background:
        radial-gradient(
          circle at 8% 0,
          color-mix(in srgb, var(--rose) 10%, transparent),
          transparent 34%
        ),
        var(--bg);
    }

    .history-body .history-shell {
      display: grid;
      gap: 16px;
      width: min(100%, 1160px);
      margin: 0 auto;
    }

    .history-body .history-command-panel,
    .history-body .history-full-panel {
      border-radius: 8px;
      padding: 18px;
    }

    .history-body .history-command-panel {
      display: grid;
      gap: 16px;
      background:
        linear-gradient(
          135deg,
          color-mix(in srgb, var(--rose-soft) 70%, transparent),
          transparent 52%
        ),
        var(--bg-elevated);
    }

    .history-body .history-page-head {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      align-items: center;
      gap: 14px;
    }

    .history-body .history-back-link,
    .history-body .history-select-toggle,
    .history-body .history-chip,
    .history-body .history-sort-control,
    .history-body .history-empty-actions a,
    .history-body .history-selection-actions button,
    .history-body .history-card-icon,
    .history-body .history-card-more,
    .history-body .history-no-results button {
      touch-action: manipulation;
    }

    .history-body .history-back-link {
      display: inline-flex;
      min-height: 44px;
      align-items: center;
      gap: 7px;
      padding: 0 11px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--bg);
      color: var(--navy);
      font-size: 13px;
      font-weight: 800;
      text-decoration: none;
      white-space: nowrap;
    }

    .history-body .history-back-link svg,
    .history-body .history-select-toggle svg,
    .history-body .history-search-field svg,
    .history-body .history-card-icon svg,
    .history-body .history-card-more svg {
      width: 18px;
      height: 18px;
      fill: none;
      stroke: currentColor;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-width: 2;
    }

    .history-body .history-title-block {
      min-width: 0;
      text-align: center;
    }

    .history-body .history-title-block h1 {
      margin: 0;
      color: var(--navy);
      font-size: clamp(26px, 4vw, 42px);
      line-height: 1.1;
      letter-spacing: 0;
      text-wrap: balance;
    }

    .history-body .history-title-block p:not(.section-kicker) {
      max-width: 680px;
      margin: 8px auto 0;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.6;
    }

    .history-body .history-select-toggle {
      display: inline-flex;
      min-height: 44px;
      align-items: center;
      justify-content: center;
      gap: 7px;
      padding: 0 13px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--bg);
      color: var(--navy);
      cursor: pointer;
      font: inherit;
      font-size: 13px;
      font-weight: 900;
      white-space: nowrap;
    }

    .history-body .history-select-toggle[aria-pressed="true"] {
      border-color: color-mix(in srgb, var(--rose) 55%, var(--line));
      background: var(--rose);
      color: #fff;
    }

    .history-body .history-search-row {
      display: grid;
      justify-items: center;
    }

    .history-body .history-search-field {
      display: grid;
      width: min(100%, 720px);
      min-height: 50px;
      grid-template-columns: auto minmax(0, 1fr) auto;
      align-items: center;
      gap: 10px;
      padding: 0 14px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: color-mix(in srgb, var(--bg-elevated) 76%, var(--bg));
      color: var(--muted);
      box-shadow: 0 10px 28px rgba(15, 23, 42, 0.04);
    }

    .history-body .history-search-field:focus-within {
      border-color: color-mix(in srgb, var(--rose) 46%, var(--line));
      box-shadow: 0 0 0 4px color-mix(in srgb, var(--rose) 14%, transparent);
    }

    .history-body .history-search-field input {
      min-width: 0;
      border: 0;
      outline: 0;
      background: transparent;
      color: var(--navy);
      font: inherit;
      font-size: 15px;
      line-height: 1.4;
    }

    .history-body .history-search-field input::placeholder {
      color: color-mix(in srgb, var(--muted) 76%, transparent);
    }

    .history-body .history-search-field button {
      display: grid;
      width: 36px;
      height: 36px;
      place-items: center;
      border: 0;
      border-radius: 50%;
      background: color-mix(in srgb, var(--surface-neutral) 80%, transparent);
      color: var(--muted);
      cursor: pointer;
    }

    .history-body .history-search-field button svg {
      width: 16px;
      height: 16px;
    }

    .history-body .history-filter-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .history-body .history-chip-group {
      display: flex;
      min-width: 0;
      flex-wrap: wrap;
      gap: 8px;
    }

    .history-body .history-chip {
      display: inline-flex;
      min-height: 40px;
      align-items: center;
      gap: 8px;
      padding: 0 12px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--bg);
      color: var(--muted);
      cursor: pointer;
      font: inherit;
      font-size: 13px;
      font-weight: 800;
      white-space: nowrap;
    }

    .history-body .history-chip b {
      display: inline-grid;
      min-width: 24px;
      height: 24px;
      place-items: center;
      padding: 0 6px;
      border-radius: 999px;
      background: var(--surface-neutral);
      color: var(--navy);
      font-size: 12px;
      font-variant-numeric: tabular-nums;
    }

    .history-body .history-chip.active {
      border-color: color-mix(in srgb, var(--rose) 58%, var(--line));
      background: color-mix(in srgb, var(--rose-soft) 78%, var(--bg));
      color: var(--rose);
    }

    .history-body .history-chip.active b {
      background: var(--rose);
      color: #fff;
    }

    .history-body .history-sort-control {
      display: inline-flex;
      min-height: 40px;
      align-items: center;
      gap: 8px;
      padding: 0 10px 0 12px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: var(--bg);
      color: var(--muted);
      font-size: 13px;
      font-weight: 800;
      white-space: nowrap;
    }

    .history-body .history-sort-control select {
      max-width: 160px;
      border: 0;
      outline: 0;
      background: transparent;
      color: var(--navy);
      cursor: pointer;
      font: inherit;
      font-weight: 900;
    }

    .history-body .history-stats-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
    }

    .history-body .history-stats-row span {
      display: inline-flex;
      min-height: 30px;
      align-items: center;
      gap: 5px;
      padding: 0 10px;
      border-radius: 999px;
      background: color-mix(in srgb, var(--bg) 78%, transparent);
    }

    .history-body .history-stats-row b {
      color: var(--navy);
      font-variant-numeric: tabular-nums;
    }

    .history-body .history-list {
      min-height: 220px;
    }

    .history-body .history-loading-state {
      display: grid;
      gap: 14px;
    }

    .history-body .loading-line {
      margin: 0;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.6;
    }

    .history-body .history-skeleton-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .history-body .history-skeleton-grid span {
      display: block;
      min-height: 210px;
      border-radius: 8px;
      background: linear-gradient(
        90deg,
        color-mix(in srgb, var(--surface-neutral) 70%, transparent),
        color-mix(in srgb, var(--bg-elevated) 92%, transparent),
        color-mix(in srgb, var(--surface-neutral) 70%, transparent)
      );
      background-size: 240% 100%;
      animation: history-skeleton 1.2s ease-in-out infinite;
    }

    @keyframes history-skeleton {
      from {
        background-position: 100% 0;
      }
      to {
        background-position: -100% 0;
      }
    }

    .history-body .history-date-group {
      display: grid;
      gap: 12px;
    }

    .history-body .history-date-group + .history-date-group {
      margin-top: 22px;
    }

    .history-body .history-date-heading {
      display: flex;
      align-items: center;
      gap: 10px;
      margin: 0;
      color: var(--navy);
      font-size: 17px;
      line-height: 1.35;
    }

    .history-body .history-date-heading::after {
      content: "";
      height: 1px;
      flex: 1;
      background: var(--line);
    }

    .history-body .history-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .history-body .history-card {
      position: relative;
      display: grid;
      min-width: 0;
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--bg);
      box-shadow: 0 12px 28px rgba(15, 23, 42, 0.05);
      transition:
        border-color 0.18s ease,
        box-shadow 0.18s ease,
        transform 0.18s ease;
    }

    .history-body .history-card:hover {
      border-color: color-mix(in srgb, var(--rose) 34%, var(--line));
      box-shadow: 0 16px 32px rgba(15, 23, 42, 0.08);
      transform: translateY(-1px);
    }

    .history-body .history-card.is-selected {
      border-color: var(--rose);
      box-shadow:
        0 0 0 3px color-mix(in srgb, var(--rose) 16%, transparent),
        0 16px 32px rgba(15, 23, 42, 0.08);
    }

    .history-body .history-card-media {
      position: relative;
      overflow: hidden;
      aspect-ratio: 1 / 1.08;
      background: var(--surface-neutral);
    }

    .history-body .history-card-image {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .history-body .history-card-placeholder {
      display: grid;
      width: 100%;
      height: 100%;
      place-items: center;
      color: var(--muted);
      font-size: 13px;
      font-weight: 800;
      text-align: center;
    }

    .history-body .history-status {
      position: absolute;
      left: 10px;
      top: 10px;
      display: inline-flex;
      min-height: 28px;
      align-items: center;
      padding: 0 9px;
      border-radius: 999px;
      background: color-mix(in srgb, var(--bg-elevated) 90%, transparent);
      color: var(--muted);
      font-size: 12px;
      font-weight: 900;
      line-height: 1;
      white-space: nowrap;
      box-shadow: 0 8px 20px rgba(15, 23, 42, 0.12);
