---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = true;
---

<BaseLayout title="Page Not Found — AI Beauty Stylist" description="The page you're looking for doesn't exist.">
  <section class="section">
    <div class="container error-page">
      <h1>404</h1>
      <p class="lead">Oops! This page got lost in the makeup bag.</p>
      <p>The page you're looking for doesn't exist or has been moved.</p>
      <div class="tutorial-cta-row">
        <a class="btn" href="/">Go Home</a>
        <a class="btn btn-secondary" href="/try-on">Try On Studio</a>
      </div>
    </div>
  </section>
</BaseLayout>
