---
import BaseLayout from '../layouts/BaseLayout.astro';
import TryOnStudio from '../components/TryOnStudio.astro';
---

<BaseLayout
  title="AI Try-On Studio | AI Beauty Stylist"
  description="Upload a bare-face selfie, get AI face and color diagnosis, and see 3 personalized makeup looks tailored just for you."
>
  <!--
    P0.1: 工具页移除独立 hero。/try-on 是 tool-first 页面，
    工具卡是首屏第一公民；headline 由 TryOnStudio 内部承担。
  -->
  <section class="section" style="padding-top: 32px; padding-bottom: 56px;">
    <div class="container">
      <TryOnStudio />
    </div>
  </section>
</BaseLayout>
