---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import InspirationGrid from '../components/InspirationGrid.astro';
import StylePicker from '../components/StylePicker.astro';
import ScenarioCards from '../components/ScenarioCards.astro';
import FeatureSteps from '../components/FeatureSteps.astro';
import TrustAndPlans from '../components/TrustAndPlans.astro';
import { homeStyleItems } from '../data/stylePages';
import { scenarioPages } from '../data/scenarioPages';

export const prerender = true;

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'AI Beauty Stylist',
    url: 'https://aibeautystylist.com/',
    description: 'AI-powered personalized makeup try-on, shade diagnosis, step-by-step tutorials, and curated product recommendations.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'AI Beauty Stylist',
    applicationCategory: 'LifestyleApplication',
    operatingSystem: 'Web',
    url: 'https://aibeautystylist.com/try-on/',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Makeup styles to try',
    itemListElement: homeStyleItems.map((style, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: style.label,
      url: `https://aibeautystylist.com/try-on/?scenario=${style.tryOnScenario}&style=${style.slug}&look=${style.lookSlug}`,
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Makeup guides by goal',
    itemListElement: scenarioPages.slice(0, 6).map((page, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: page.title,
      url: `https://aibeautystylist.com/scenarios/${page.slug}/`,
    })),
  },
];
---

<BaseLayout
  title="AI Beauty Stylist | Personalized Makeup Try-On & Tutorial"
  description="AI-powered personalized makeup try-on, shade diagnosis, step-by-step tutorials, and curated product recommendations."
  structuredData={structuredData}
>
  <HeroSection />
  <InspirationGrid />
  <StylePicker />
  <ScenarioCards />
  <FeatureSteps />
  <TrustAndPlans />
</BaseLayout>
