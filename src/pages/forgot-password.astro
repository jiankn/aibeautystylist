---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Forgot password — AI Beauty Stylist"
  description="Request a secure password reset link for your AI Beauty Stylist account."
  robots="noindex,nofollow"
>
  <section class="auth-page-shell">
    <div class="auth-card auth-card-narrow">
      <div class="auth-copy">
        <p class="auth-eyebrow">Password help</p>
        <h1>Reset your password</h1>
        <p>Enter your account email and we’ll send a secure reset link if the account exists.</p>
      </div>

      <form class="auth-form" data-forgot-form>
        <label class="auth-field">
          <span>Email</span>
          <input name="email" type="email" autocomplete="email" placeholder="you@example.com" required />
        </label>

        <button class="btn auth-submit" type="submit" data-forgot-submit>Send reset link</button>
        <p class="auth-message" data-forgot-message hidden></p>
      </form>

      <p class="auth-footnote"><a href="/login">Back to sign in</a></p>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.querySelector('[data-forgot-form]') as HTMLFormElement | null;
  const submit = document.querySelector('[data-forgot-submit]') as HTMLButtonElement | null;
  const message = document.querySelector('[data-forgot-message]') as HTMLElement | null;

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!submit || !message) return;

    const formData = new FormData(form);
    submit.disabled = true;
    submit.textContent = 'Sending…';
    message.hidden = true;
    message.classList.remove('is-error', 'is-success');

    try {
      const resp = await fetch('/api/auth/forgot-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: String(formData.get('email') ?? '') }),
      });
      const data = (await resp.json().catch(() => ({}))) as { message?: string };
      if (!resp.ok) throw new Error(data.message ?? 'Unable to send reset link.');

      message.textContent = 'If that email exists, a reset link has been sent.';
      message.classList.add('is-success');
      message.hidden = false;
      submit.textContent = 'Sent';
    } catch (error) {
      message.textContent = error instanceof Error ? error.message : 'Unable to send reset link.';
      message.classList.add('is-error');
      message.hidden = false;
      submit.disabled = false;
      submit.textContent = 'Send reset link';
    }
  });
</script>
