---
import LookSelector from "../components/LookSelector.astro";
import MobileAppTopBar from "../components/MobileAppTopBar.astro";
import MobileBottomNav from "../components/MobileBottomNav.astro";
import ResultState from "../components/ResultState.astro";
import SelfiePhotoGuide from "../components/SelfiePhotoGuide.astro";
import SiteHeader from "../components/SiteHeader.astro";
import TutorialSteps from "../components/TutorialSteps.astro";
import TryOnHistoryPreview from "../components/TryOnHistoryPreview.astro";
import WorkspaceStatusBar from "../components/WorkspaceStatusBar.astro";
import { resolveLookCatalog } from "../data/makeup/resolveCatalog";
import { getTutorialByLookSlug, getTutorialUiCopy } from "../data/tutorials";
import { getLocalizedAppHref, resolveLocaleRoute } from "../i18n/routing";
import { getEntitlementContext } from "../lib/entitlements";
import { t } from "../lib/i18n";
import { getRuntimeBindings } from "../lib/runtime";
import { resolveTryOnExperience } from "../lib/tryonExperience";
import BaseLayout from "../layouts/BaseLayout.astro";

const audienceContext = Astro.locals.audienceContext;
const { DB } = getRuntimeBindings();
const currentUserId = Astro.locals.currentUserId;
let authenticated = Boolean(currentUserId);
let planCode: "free" | "pro" | "premium" = "free";
let quota = { remaining: 3, total: 3 };

if (authenticated) {
  try {
    if (currentUserId) {
      const entitlement = await getEntitlementContext(currentUserId, DB);
      planCode = entitlement.plan.planCode;
      quota = {
        remaining: entitlement.quota.remaining,
        total: entitlement.quota.total,
      };
    }
  } catch {
    planCode = "free";
  }
}

const experience = resolveTryOnExperience({ authenticated, planCode });
const isLoggedIn = experience.authenticated;
const currentPathname = Astro.originPathname || Astro.url.pathname;
const currentRoute =
  Astro.locals.localeRoute ?? resolveLocaleRoute(currentPathname);
const localizeAppHref = (href: string) =>
  getLocalizedAppHref(href, currentRoute.language.slug);
const mobileTryonTitle =
  {
    "zh-CN": "AI 试妆",
    "zh-TW": "AI 試妝",
    "de-DE": "AI Try-on",
    "fr-FR": "Essayage IA",
    "ja-JP": "AIメイク試着",
    "ko-KR": "AI 시착",
    "es-ES": "Prueba IA",
    "es-419": "Prueba IA",
    "pt-BR": "Teste IA",
    en: "AI Try-On",
  }[currentRoute.language.locale] ?? "AI Try-On";
const currentReturnPath = `${currentPathname}${Astro.url.search}`;
const pricingHref = localizeAppHref(
  `/pricing?return_to=${encodeURIComponent(currentReturnPath)}`,
);
const discoverHref = localizeAppHref("/discover");
const diagnosisHref = localizeAppHref("/diagnosis");
const historyHref = localizeAppHref("/history");
const loginHref = localizeAppHref(
  `/login?mode=register&next=${encodeURIComponent(localizeAppHref("/tryon"))}`,
);
const shareCardHref = localizeAppHref("/share-card");
const shareBaseHref = localizeAppHref("/share");
const subscriptionHref = localizeAppHref("/subscription");
const creditPacksHref = `${subscriptionHref}#credit-packs`;
const tryonHref = localizeAppHref("/tryon");
const resolvedLooks = resolveLookCatalog(audienceContext);
const featuredSlugs = ["commute", "no-makeup", "rose-milk-date", "photogenic"];
const defaultFeaturedLooks = featuredSlugs
  .map((slug) => resolvedLooks.find((look) => look.slug === slug))
  .filter(Boolean) as typeof resolvedLooks;
const requestedSlug = Astro.url.searchParams.get("look");
const requestedLook = resolvedLooks.find((look) => look.slug === requestedSlug);
const featuredLooks = requestedLook
  ? [
      requestedLook,
      ...defaultFeaturedLooks.filter(
        (look) => look.slug !== requestedLook.slug,
      ),
    ].slice(0, 4)
  : defaultFeaturedLooks;
const selected = requestedLook ?? featuredLooks[0];
const tutorial = getTutorialByLookSlug(
  selected.slug,
  currentRoute.language.locale,
);
const tutorialUiCopy = getTutorialUiCopy(currentRoute.language.locale);
const hasExternalSelection =
  requestedLook && !featuredSlugs.includes(requestedLook.slug);
const isChineseLocale = currentRoute.language.locale.startsWith("zh");
const tryonWaitingCopy = isChineseLocale
  ? {
      backgroundTitle: "试妆已转入后台生成",
      backgroundDesc:
        "你可以继续浏览妆容库、查看诊断页，完成后右下角会提醒你回来查看结果。",
      stages: [
        ["upload", "上传自拍"],
        ["queue", "创建任务"],
        ["analyze", "分析面部"],
        ["render", "生成妆效"],
      ],
      preferenceTitle: "等待时先微调你的偏好",
      preferenceDesc:
        "这些选择会保存在本机，用于下次默认推荐，不会打断当前生成。",
      groups: [
        {
          label: "妆感",
          key: "finish",
          options: ["通勤自然", "约会甜美", "上镜清透"],
        },
        {
          label: "重点",
          key: "focus",
          options: ["提气色", "显脸小", "放大眼神"],
        },
      ],
      intensity: "妆感强度",
      intensityMin: "自然",
      intensityMax: "明艳",
      browse: "继续浏览妆容库",
    }
  : {
      backgroundTitle: "Your try-on is running in the background",
      backgroundDesc:
        "Keep browsing looks or open diagnosis. A task card will remind you when the result is ready.",
      stages: [
        ["upload", "Upload selfie"],
        ["queue", "Create task"],
        ["analyze", "Analyze face"],
        ["render", "Generate look"],
      ],
      preferenceTitle: "Tune your preference while you wait",
      preferenceDesc:
        "Saved locally for your next recommendation. It will not interrupt this generation.",
      groups: [
        {
          label: "Finish",
          key: "finish",
          options: ["Work natural", "Soft date", "Camera glow"],
        },
        {
          label: "Focus",
          key: "focus",
          options: ["Fresh tone", "Slimmer face", "Brighter eyes"],
        },
      ],
      intensity: "Makeup intensity",
      intensityMin: "Natural",
      intensityMax: "Bold",
      browse: "Browse more looks",
    };
const freeClientMessages = {
  copied: t("tryon", "copied"),
  copyShareLink: t("tryon", "copyShareLink"),
  rewarded: t("tryon", "rewarded"),
  alreadyRewarded: t("tryon", "alreadyRewarded"),
  failed: t("tryon", "failed"),
  loadSavedFailed: t("tryon", "loadSavedFailed"),
  operationSavedFailed: t("tryon", "operationSavedFailed"),
  saveResult: t("tryon", "saveResult"),
  savedLimitReached: t("tryon", "savedLimitReached"),
  savedResult: t("tryon", "savedResult"),
};
const sharePromptCopy = {
  reward: {
    title: t("tryon", "shareTitle"),
    desc: t("tryon", "shareDesc"),
  },
  member: {
    title: t("tryon", "memberShareTitle"),
    desc: t("tryon", "memberShareDesc"),
  },
};
const initialSharePrompt = experience.features.shareReward
  ? sharePromptCopy.reward
  : sharePromptCopy.member;
const upgradeBannerCopy = {
  free: {
    title: t("tryon", "upgradeTitle"),
    desc: t("tryon", "upgradeDesc"),
    primary: t("tryon", "viewPlansShort"),
  },
  pro: {
    title: t("tryon", "proActiveTitle"),
    desc: t("tryon", "proActiveDesc"),
    primary: t("tryon", "continuePro"),
    secondary: t("tryon", "learnPremium"),
  },
  premium: {
    title: t("tryon", "premiumActiveTitle"),
    desc: t("tryon", "premiumActiveDesc"),
    primary: t("tryon", "continuePremium"),
  },
  proExhausted: {
    title: t("tryon", "memberQuotaExhaustedTitle"),
    desc: t("tryon", "memberQuotaExhaustedDesc"),
    primary: t("tryon", "learnPremium"),
    secondary: t("creditPacks", "buy"),
  },
  premiumExhausted: {
    title: t("tryon", "memberQuotaExhaustedTitle"),
    desc: t("creditPacks", "subtitle"),
    primary: t("creditPacks", "buy"),
    secondary: t("workspace", "viewHistory"),
  },
};
const upgradeBannerHrefs = {
  pricing: pricingHref,
  account: subscriptionHref,
  credits: creditPacksHref,
  history: historyHref,
  pro: tryonHref,
  premium: tryonHref,
};
const workspaceStatusCopy = {
  planNames: {
    free: "Free",
    pro: "Pro",
    premium: "Premium",
  },
  titles: {
    free: t("tryon", "title"),
    pro: t("tryon", "proTitle"),
    premium: t("tryon", "premiumTitle"),
  },
  subtitles: {
    free: t("tryon", "subtitle"),
    pro: t("tryon", "proSubtitle"),
    premium: t("tryon", "premiumSubtitle"),
  },
  perks: {
    free: t("workspace", "freeBenefits"),
    pro: t("workspace", "proPerks"),
    premium: t("workspace", "premiumPerks"),
  },
  notes: {
    free: t("tryon", "remainingPrefix"),
    pro: t("tryon", "proNote"),
    premium: t("tryon", "premiumNote"),
  },
  actions: {
    startFree: t("workspace", "startTryon"),
    openFullCatalog: t("workspace", "openFullCatalog"),
    viewHistory: t("workspace", "viewHistory"),
    diagnosis: t("workspace", "diagnosis"),
    upgrade: t("workspace", "upgradeGetMore"),
    learnPremium: t("tryon", "learnPremium"),
    buyCredits: t("creditPacks", "buy"),
    browseLooks: t("workspace", "browseLooks"),
  },
  lowQuota: {
    free: t("workspace", "lowQuotaHint"),
    paid: t("creditPacks", "lowQuota"),
  },
};
const workspaceStatusHrefs = {
  free: tryonHref,
  discover: discoverHref,
  history: historyHref,
  diagnosis: diagnosisHref,
  pricing: pricingHref,
  credits: creditPacksHref,
};
const experienceTitle = workspaceStatusCopy.titles[experience.planCode];
const experienceSubtitle =
  experience.planCode === "free"
    ? workspaceStatusCopy.subtitles.free
    : workspaceStatusCopy.perks[experience.planCode];
const experienceNote = workspaceStatusCopy.notes[experience.planCode];
---

<BaseLayout
  title={experienceTitle + " | " + t("brand", "name")}
  description={experienceSubtitle}
  bodyClass="workspace-body"
>
  <SiteHeader active="tryOn" mobileHidden />
  <MobileAppTopBar
    title={mobileTryonTitle}
    backHref={localizeAppHref("/discover")}
    rightAction="help"
    rightHref={diagnosisHref}
  />
  <main
    class="workspace-main"
    data-tryon-audience={experience.audience}
    data-tryon-plan={experience.planCode}
  >
    <div class="shell">
      {
        isLoggedIn ? (
          <WorkspaceStatusBar
            plan={experience.planLabel}
            title={experienceTitle}
            subtitle={experienceSubtitle}
            active="tryon"
            remaining={quota.remaining}
            total={quota.total}
            note={experienceNote}
            live
          />
        ) : (
          <section class="workspace-status panel" data-plan="Free">
            <div class="workspace-status-main">
              <span class="workspace-status-plan">Free</span>
              <div>
                <h1>{t("tryon", "title")}</h1>
                <p>{t("workspace", "loginDesc")}</p>
                <p class="workspace-status-perks">
                  {t("workspace", "freeBenefits")}
                </p>
              </div>
            </div>
            <div
              class="workspace-status-actions"
              aria-label={t("workspace", "quickActions")}
            >
              <a class="btn btn-primary workspace-status-link" href={loginHref}>
                {t("workspace", "loginCta")}
              </a>
              <a class="btn workspace-status-link" href={discoverHref}>
                {t("workspace", "browseLooks")}
              </a>
            </div>
          </section>
        )
      }
      <div
        class:list={[
          "workspace-grid",
          experience.showMemberGuidance && "member-workspace-grid",
        ]}
      >
        <aside class="selector-panel panel">
          <div class="selector-head">
            <div>
              <h2 class="panel-title">{t("tryon", "selectLook")}</h2><p
                class="panel-subtitle"
              >
                {
                  hasExternalSelection
                    ? t("tryon", "externalSelectionDesc")
                    : t("tryon", "featuredLooksDesc")
                }
              </p>
            </div>
          </div>
          <LookSelector looks={featuredLooks} selectedSlug={selected.slug} />
          <a
            class="btn btn-wide"
            style="margin-top:12px"
            href={localizeAppHref("/discover")}>{t("tryon", "allLooksBtn")}</a
          >
        </aside>
        <section class="result-panel panel">
          <div class="result-head">
            <div>
              <h2>
                {t("tryon", "previewTitle")} · <span data-look-title
                  >{selected.title}</span
                >
              </h2><p class="panel-subtitle">
                {t("tryon", "uploadPromptDesc")}
              </p>
            </div>
          </div>
          <div class="upload-preview">
            <div class="upload-box upload-box-guided">
              <span class="upload-camera">▣</span>
              <h3>{t("tryon", "uploadSelfie")}</h3>
              <p>{t("tryon", "uploadFormatDesc")}</p>
              <SelfiePhotoGuide />
              <div class="privacy-promise">
                <span>✓ {t("privacy", "photoPurpose")}</span>
                <span>✓ {t("privacy", "deletion")}</span>
                <span>✓ {t("privacy", "noTraining")}</span>
              </div>
              <div class="upload-auth-lock" data-upload-auth-lock hidden>
                <b>{t("tryon", "loginToUseQuota")}</b>
                <span>{t("tryon", "loginToUseDesc")}</span>
              </div>
              <label class="privacy-consent">
                <input type="checkbox" data-photo-consent />
                <span>{t("tryon", "consentCheckbox")}</span>
              </label>
              <button
                class="btn btn-primary"
                data-upload
                data-login-label={t("tryon", "loginToUpload")}
                disabled>{t("tryon", "uploadBtn")}</button
              >
              <div class="upload-task-status" data-upload-task hidden>
                <div class="upload-task-head">
                  <span data-upload-status>{t("tryon", "waitingUpload")}</span>
                  <b data-upload-percent>0%</b>
                </div>
                <div class="meter">
                  <i data-upload-progress style="width:0%"></i>
                </div>
                <ol
                  class="task-stage-list"
                  data-upload-stages
                  aria-label={tryonWaitingCopy.backgroundTitle}
                >
                  {
                    tryonWaitingCopy.stages.map(([key, label]) => (
                      <li data-upload-stage={key}>
                        <span aria-hidden="true" />
                        <b>{label}</b>
                      </li>
                    ))
                  }
                </ol>
                <div class="upload-task-actions">
                  <button class="btn" type="button" data-upload-cancel hidden
                    >{t("tryon", "cancelUpload")}</button
                  >
                  <button class="btn" type="button" data-upload-retry hidden
                    >{t("tryon", "retry")}</button
                  >
                  <button class="btn" type="button" data-upload-delete hidden
                    >{t("tryon", "deleteOriginal")}</button
                  >
                  <button class="btn" type="button" data-result-delete hidden
                    >{t("tryon", "deleteResult")}</button
                  >
                </div>
              </div>
            </div>
            <div class="upload-arrow">→</div>
            <div data-result-target>
              <ResultState
                title={t("tryon", "previewPlaceholderTitle")}
                message={t("tryon", "previewPlaceholderDesc")}
              />
            </div>
          </div>
          <section class="tryon-waiting-panel" data-tryon-waiting hidden>
            <div class="tryon-waiting-copy">
              <span class="section-eyebrow"
                >{tryonWaitingCopy.backgroundTitle}</span
              >
              <h3>{tryonWaitingCopy.preferenceTitle}</h3>
              <p>{tryonWaitingCopy.backgroundDesc}</p>
            </div>
            <div class="tryon-waiting-controls">
              {
                tryonWaitingCopy.groups.map((group) => (
                  <fieldset class="tryon-preference-group">
                    <legend>{group.label}</legend>
                    <div>
                      {group.options.map((option, index) => (
                        <button
                          class:list={["btn", index === 0 && "active"]}
                          type="button"
                          data-tryon-preference={group.key}
                          data-tryon-preference-value={option}
                          aria-pressed={index === 0 ? "true" : "false"}
                        >
                          {option}
                        </button>
                      ))}
                    </div>
                  </fieldset>
                ))
              }
              <label class="tryon-intensity-control">
                <span>{tryonWaitingCopy.intensity}</span>
                <input
                  type="range"
                  min="1"
                  max="5"
                  value="3"
                  data-tryon-intensity
                />
                <small>
                  <span>{tryonWaitingCopy.intensityMin}</span>
                  <span>{tryonWaitingCopy.intensityMax}</span>
                </small>
              </label>
            </div>
            <a class="btn btn-primary" href={discoverHref}>
              {tryonWaitingCopy.browse}
            </a>
          </section>
          <div class="rule-strip">
            ▣&nbsp; {t("tryon", "ruleStrip")}
            <a href={pricingHref}>{t("tryon", "learnRules")} ›</a>
          </div>
          <section
            class="result-share-bar"
            id="free-share-actions"
            aria-label={t("tryon", "shareAria")}
            hidden
          >
            <div>
              <strong data-share-prompt-title>{initialSharePrompt.title}</strong
              >
              <span data-share-prompt-desc>{initialSharePrompt.desc}</span>
            </div>
            <button class="btn" id="free-share-card" disabled
              >▧&nbsp; {t("tryon", "saveShareCard")}</button
            >
            <button class="btn" id="free-save-result" disabled
              >☆&nbsp; {t("tryon", "saveResult")}</button
            >
            <button class="btn" id="free-copy-link" disabled
              >⌘&nbsp; {t("tryon", "copyLink")}</button
            >
            {
              experience.features.hdDownload && (
                <a
                  class="btn btn-primary"
                  id="member-download-result"
                  href="#"
                  download
                  aria-disabled="true"
                >
                  ↓&nbsp; {t("tryon", "downloadHd")}
                </a>
              )
            }
            <button
              class="btn btn-outline-rose"
              id="free-share-reward"
              disabled
              hidden>{t("tryon", "shareReward")}</button
            >
          </section>
        </section>
        {
          experience.showAdvisor && (
            <aside
              class="explain-panel panel advisor-panel"
              data-look-advisor
              aria-labelledby="look-advisor-title"
            >
              <div class="advisor-head">
                <span class="advisor-kicker">
                  {t("tryon", "advisorKicker")}
                </span>
                <h2
                  class="panel-title"
                  id="look-advisor-title"
                  data-advisor-title
                >
                  {selected.title}
                </h2>
              </div>
              <section class="advisor-section">
                <h3>{t("tryon", "advisorFit")}</h3>
                <p data-advisor-fit-text>{selected.advisor.fit}</p>
              </section>
              <section class="advisor-section">
                <h3>{t("tryon", "advisorEffect")}</h3>
                <p data-advisor-effect-text>{selected.advisor.effect}</p>
              </section>
              <section class="advisor-section">
                <h3>{t("tryon", "advisorAnchors")}</h3>
                <ul data-advisor-anchor-list>
                  {selected.advisor.anchors.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </section>
              <section class="advisor-section advisor-caution">
                <h3>{t("tryon", "advisorCaution")}</h3>
                <p data-advisor-caution-text>{selected.advisor.caution}</p>
              </section>
              <section class="advisor-section">
                <h3>{t("tryon", "advisorJudge")}</h3>
                <ul data-advisor-judge-list>
                  {selected.advisor.judge.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </section>
            </aside>
          )
        }
      </div>
      {
        experience.showMemberGuidance && (
          <section
            class="panel member-guidance"
            aria-label={tutorialUiCopy.ariaLabel}
          >
            {tutorial ? (
              <TutorialSteps
                tutorial={tutorial}
                userPlan={experience.planCode}
                locale={currentRoute.language.locale}
              />
            ) : (
              <div class="member-guidance-empty">
                <h2 class="panel-title">{t("tryon", "productTypes")}</h2>
                <p class="panel-subtitle">{t("tryon", "tutorialComing")}</p>
              </div>
            )}
          </section>
        )
      }
      {experience.showHistoryPreview && <TryOnHistoryPreview />}
      <section class="panel upgrade-banner" id="free-upgrade" hidden>
        <div>
          <h3 data-upgrade-title>{t("tryon", "upgradeTitle")}</h3>
          <p data-upgrade-desc>{t("tryon", "upgradeDesc")}</p>
        </div>
        <div class="upgrade-banner-actions">
          <a class="btn btn-primary" href={pricingHref} data-upgrade-primary>
            {t("tryon", "viewPlansShort")}
          </a>
          <a
            class="btn btn-outline"
            href={pricingHref}
            data-upgrade-secondary
            hidden
          >
            {t("tryon", "learnPremium")}
          </a>
        </div>
      </section>
    </div>
  </main>
  <MobileBottomNav active="tryon" />
</BaseLayout>

<script
  is:inline
  define:vars={{
    freeClientMessages,
    initialPlan: experience.planCode,
    sharePromptCopy,
    shareBaseHref,
    shareCardHref,
    selectedLookSlug: selected.slug,
    upgradeBannerCopy,
    upgradeBannerHrefs,
    workspaceStatusCopy,
    workspaceStatusHrefs,
    reloadGuidanceOnLookChange: experience.showMemberGuidance,
  }}
>
  (function () {
    const preferenceButtons = document.querySelectorAll(
      "[data-tryon-preference]",
    );
    const intensityInput = document.querySelector("[data-tryon-intensity]");
    let lastSucceededJobId = window.__absLastSucceededJobId || null;
    let lastSucceededLookSlug = selectedLookSlug || null;
    let currentPlan = initialPlan;
    let hasLoadedPlan = false;
    let savedJobIds = new Set();
    const publicShareUrlByJobId = new Map();
    const checkoutSucceeded =
      new URLSearchParams(window.location.search).get("checkout") === "success";
    const delay = (ms) =>
      new Promise((resolve) => window.setTimeout(resolve, ms));
    const preferenceStorageKey = "abs:tryon-waiting-preferences";
    document.addEventListener("abs:look-selected", (event) => {
      if (!reloadGuidanceOnLookChange || !event.detail?.changed) return;
      window.location.assign(event.detail.href || window.location.href);
    });

    function readWaitingPreferences() {
      try {
        return JSON.parse(localStorage.getItem(preferenceStorageKey) || "{}");
      } catch {
        return {};
      }
    }

    function writeWaitingPreferences(next) {
      try {
        localStorage.setItem(preferenceStorageKey, JSON.stringify(next));
      } catch {
        /* ignore private storage failures */
      }
    }

    function syncWaitingPreferences() {
      const stored = readWaitingPreferences();
      preferenceButtons.forEach((button) => {
        const key = button.dataset.tryonPreference;
        const selectedValue = stored[key];
        const active = selectedValue
          ? button.dataset.tryonPreferenceValue === selectedValue
          : button.classList.contains("active");
        button.classList.toggle("active", active);
        button.setAttribute("aria-pressed", String(active));
      });
      if (intensityInput && stored.intensity) {
        intensityInput.value = stored.intensity;
      }
    }

    preferenceButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const key = button.dataset.tryonPreference;
        if (!key) return;
        const stored = readWaitingPreferences();
        stored[key] = button.dataset.tryonPreferenceValue || "";
        writeWaitingPreferences(stored);
        syncWaitingPreferences();
      });
    });

    intensityInput?.addEventListener("input", () => {
      const stored = readWaitingPreferences();
      stored.intensity = intensityInput.value;
      writeWaitingPreferences(stored);
    });
    syncWaitingPreferences();

    async function loadSession() {
      try {
        const res = await fetch("/api/session");
        const data = await res.json();
        const session = data.ok ? data.data : null;
        currentPlan = session ? normalizePlan(session.plan) : initialPlan;
        hasLoadedPlan = true;
        refreshRewardButtonState();
        return session;
      } catch {
        currentPlan = initialPlan;
        hasLoadedPlan = true;
        refreshRewardButtonState();
        return null;
      }
    }

    async function loadSessionWithCheckoutRefresh() {
      let session = await loadSession();
      if (!checkoutSucceeded || session?.plan !== "free") return session;
      for (let attempt = 0; attempt < 6; attempt += 1) {
        await delay(1500);
        session = await loadSession();
        if (session?.plan && session.plan !== "free") break;
      }
      return session;
    }

    function shareClaimStorageKey(jobId) {
      return "abs:share-claim:" + jobId;
    }

    function getStoredShareClaim(jobId) {
      try {
        const raw = sessionStorage.getItem(shareClaimStorageKey(jobId));
        if (!raw) return null;
        const claim = JSON.parse(raw);
        if (!claim?.claimToken || !claim?.expiresAt) return null;
        if (claim.expiresAt <= new Date().toISOString()) {
          sessionStorage.removeItem(shareClaimStorageKey(jobId));
          return null;
        }
        return claim;
      } catch {
        return null;
      }
    }

    function storeShareClaim(jobId, claim) {
      try {
        sessionStorage.setItem(
          shareClaimStorageKey(jobId),
          JSON.stringify(claim),
        );
      } catch {
        /* ignore private storage failures */
      }
    }

    async function createShareClaim(jobId, method) {
      const res = await fetch("/api/shares/intent", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ jobId, method }),
      });
      const data = await res.json();
      if (!res.ok || !data.ok || !data.data?.claimToken) {
        throw new Error(data?.error?.message || "SHARE_INTENT_FAILED");
      }
      storeShareClaim(jobId, data.data);
      return data.data;
    }

    async function createPublicShareUrl(jobId) {
      if (publicShareUrlByJobId.has(jobId)) {
        return publicShareUrlByJobId.get(jobId);
      }
      const res = await fetch("/api/shares", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ jobId }),
      });
      const data = await res.json();
      if (!res.ok || !data.ok || !data.data?.sourceCode) {
        throw new Error(data?.error?.message || "SHARE_FAILED");
      }
      const base = String(shareBaseHref || "/share").replace(/\/+$/, "");
      const shareUrl = new URL(
        `${base}/${encodeURIComponent(data.data.sourceCode)}`,
        location.origin,
      ).toString();
      publicShareUrlByJobId.set(jobId, shareUrl);
      return shareUrl;
    }

    function refreshRewardButtonState() {
      const rewardBtn = document.getElementById("free-share-reward");
      if (!rewardBtn) return;
      const hasShareReward = currentPlan === "free";
      const isRewardEligible = hasLoadedPlan && hasShareReward;
      const prompt = hasShareReward
        ? sharePromptCopy.reward
        : sharePromptCopy.member;
      const title = document.querySelector("[data-share-prompt-title]");
      const desc = document.querySelector("[data-share-prompt-desc]");
      if (title) title.textContent = prompt.title;
      if (desc) desc.textContent = prompt.desc;
      if (!isRewardEligible) {
        rewardBtn.hidden = true;
        rewardBtn.disabled = true;
        return;
      }
      if (!lastSucceededJobId) {
        rewardBtn.hidden = false;
        rewardBtn.disabled = true;
        return;
      }
      rewardBtn.hidden = false;
      rewardBtn.disabled = !getStoredShareClaim(lastSucceededJobId);
    }

    function normalizePlan(plan) {
      return plan === "premium" ? "premium" : plan === "pro" ? "pro" : "free";
    }

    function renderWorkspaceQuota(quota) {
      if (!quota) return;
      const total = Number(quota.total);
      const remaining = Number(quota.remaining);
      const used = Number.isFinite(Number(quota.used))
        ? Number(quota.used)
        : total - remaining;
      const safeTotal = Number.isFinite(total) ? Math.max(0, total) : 0;
      const safeRemaining = Number.isFinite(remaining)
        ? Math.max(0, remaining)
        : 0;
      const safeUsed = Number.isFinite(used) ? Math.max(0, used) : 0;
      const label = document.querySelector("[data-quota-label]");
      const meter = document.querySelector("[data-quota-meter]");
      if (label) label.textContent = safeRemaining + "/" + safeTotal;
      if (meter) {
        meter.style.width =
          safeTotal > 0
            ? Math.min(100, (safeUsed / safeTotal) * 100) + "%"
            : "0%";
      }
      updateQuotaWarning(currentPlan, {
        remaining: safeRemaining,
        total: safeTotal,
      });
    }

    function updateQuotaWarning(plan, quota) {
      const status = document.querySelector(".workspace-status");
      const content = status?.querySelector(".workspace-status-main > div");
      if (!content) return;
      const remaining = Number(quota?.remaining);
      const total = Number(quota?.total);
      const showFree =
        plan === "free" && Number.isFinite(remaining) && remaining < 2;
      const showPaid =
        plan !== "free" &&
        Number.isFinite(remaining) &&
        Number.isFinite(total) &&
        total > 0 &&
        remaining > 0 &&
        remaining / total <= 0.2;
      const message = showFree
        ? workspaceStatusCopy.lowQuota.free
        : showPaid
          ? workspaceStatusCopy.lowQuota.paid
          : "";
      let warning = content.querySelector(".workspace-status-low");
      if (!message) {
        warning?.remove();
        return;
      }
      if (!warning) {
        warning = document.createElement("p");
        warning.className = "workspace-status-low";
        content.appendChild(warning);
      }
      warning.textContent = message;
    }

    function updateWorkspaceLinks(status, plan, exhausted) {
      const actions = status.querySelector(".workspace-status-actions");
      if (!actions) return;
      const links = Array.from(
        actions.querySelectorAll(".workspace-status-link"),
      );
      const configs =
        plan === "premium" && exhausted
          ? [
              {
                label: workspaceStatusCopy.actions.buyCredits,
                href: workspaceStatusHrefs.credits,
                primary: true,
                hidden: false,
              },
              {
                label: workspaceStatusCopy.actions.viewHistory,
                href: workspaceStatusHrefs.history,
                primary: false,
                hidden: false,
              },
            ]
          : plan === "premium"
            ? [
                {
                  label: workspaceStatusCopy.actions.openFullCatalog,
                  href: workspaceStatusHrefs.discover,
                  primary: true,
                  hidden: false,
                },
                {
                  label: workspaceStatusCopy.actions.viewHistory,
                  href: workspaceStatusHrefs.history,
                  primary: false,
                  hidden: false,
                },
                {
                  label: workspaceStatusCopy.actions.buyCredits,
                  href: workspaceStatusHrefs.credits,
                  primary: false,
                  hidden: false,
                },
              ]
            : plan === "pro" && exhausted
              ? [
                  {
                    label: workspaceStatusCopy.actions.learnPremium,
                    href: workspaceStatusHrefs.pricing,
                    primary: true,
                    hidden: false,
                  },
                  {
                    label: workspaceStatusCopy.actions.buyCredits,
                    href: workspaceStatusHrefs.credits,
                    primary: false,
                    hidden: false,
                  },
                  {
                    label: workspaceStatusCopy.actions.viewHistory,
                    href: workspaceStatusHrefs.history,
                    primary: false,
                    hidden: false,
                  },
                ]
              : plan === "pro"
                ? [
                    {
                      label: workspaceStatusCopy.actions.diagnosis,
                      href: workspaceStatusHrefs.diagnosis,
                      primary: true,
                      hidden: false,
                    },
                    {
                      label: workspaceStatusCopy.actions.viewHistory,
                      href: workspaceStatusHrefs.history,
                      primary: false,
                      hidden: false,
                    },
                    {
                      label: workspaceStatusCopy.actions.buyCredits,
                      href: workspaceStatusHrefs.credits,
                      primary: false,
                      hidden: false,
                    },
                  ]
                : exhausted
                  ? [
                      {
                        label: workspaceStatusCopy.actions.upgrade,
                        href: workspaceStatusHrefs.pricing,
                        primary: true,
                        hidden: false,
                      },
                      {
                        label: workspaceStatusCopy.actions.browseLooks,
                        href: workspaceStatusHrefs.discover,
                        primary: false,
                        hidden: false,
                      },
                    ]
                  : [
                      {
                        label: workspaceStatusCopy.actions.startFree,
                        href: workspaceStatusHrefs.free,
                        primary: true,
                        hidden: false,
                      },
                      {
                        label: workspaceStatusCopy.actions.diagnosis,
                        href: workspaceStatusHrefs.diagnosis,
                        primary: false,
                        hidden: false,
                      },
                      {
                        label: workspaceStatusCopy.actions.upgrade,
                        href: workspaceStatusHrefs.pricing,
                        primary: false,
                        hidden: false,
                      },
                    ];

      configs.forEach((config, index) => {
        const link = links[index];
        if (!link) return;
        if (config.hidden) {
          link.hidden = true;
          return;
        }
        link.hidden = false;
        link.textContent = config.label;
        link.href = config.href;
        link.classList.toggle("btn-primary", Boolean(config.primary));
        link.classList.toggle("btn-outline", !config.primary);
        link.classList.remove("active");
      });
      links.slice(configs.length).forEach((link) => {
        link.hidden = true;
      });
    }

    function renderWorkspaceStatus(session) {
      if (session?.user?.kind !== "account") return;
      const status = document.querySelector(".workspace-status");
      if (!status) return;
      const plan = normalizePlan(session.plan);
      const exhausted = Number(session?.quota?.remaining) <= 0;
      const planLabel = workspaceStatusCopy.planNames[plan] || plan;
      const planNode = status.querySelector(".workspace-status-plan");
      const title = status.querySelector(".workspace-status-main h1");
      const subtitle = status.querySelector("[data-workspace-subtitle]");
      const refresh = status.querySelector("[data-quota-refresh]");

      status.dataset.plan = planLabel;
      if (planNode) {
        planNode.textContent = planLabel;
        planNode.classList.toggle("workspace-status-plan-pro", plan === "pro");
        planNode.classList.remove("workspace-status-plan-teal");
        planNode.classList.toggle(
          "workspace-status-plan-gold",
          plan === "premium",
        );
      }
      if (title) title.textContent = workspaceStatusCopy.titles[plan];
      if (subtitle) {
        const paidStatusText =
          plan === "free"
            ? workspaceStatusCopy.subtitles[plan]
            : workspaceStatusCopy.perks[plan];
        subtitle.textContent = paidStatusText || "";
        subtitle.classList.toggle("workspace-status-perks", plan !== "free");
      }
      if (refresh) refresh.textContent = workspaceStatusCopy.notes[plan];
      renderWorkspaceQuota(session.quota);
      updateWorkspaceLinks(status, plan, exhausted);
    }

    window.updateQuotaDisplay = renderWorkspaceQuota;

    async function loadSavedLooks() {
      try {
        const res = await fetch("/api/saved-looks");
        const data = await res.json();
        if (data.ok && data.data?.items) {
          savedJobIds = new Set(data.data.items.map((item) => item.jobId));
        }
      } catch (error) {
        console.error(freeClientMessages.loadSavedFailed, error);
      }
    }

    function renderSaveButton() {
      const saveBtn = document.getElementById("free-save-result");
      if (!saveBtn || !lastSucceededJobId) return;
      const isSaved = savedJobIds.has(lastSucceededJobId);
      saveBtn.textContent =
        (isSaved ? "★ " : "☆ ") +
        (isSaved
          ? freeClientMessages.savedResult
          : freeClientMessages.saveResult);
      saveBtn.disabled = false;
      saveBtn.setAttribute("aria-pressed", String(isSaved));
    }

    function flashSaveButton(message) {
      const saveBtn = document.getElementById("free-save-result");
      if (!saveBtn) return;
      const previous = saveBtn.textContent;
      saveBtn.textContent = message;
      window.setTimeout(() => {
        saveBtn.textContent = previous;
      }, 2400);
    }

    function renderUpgradeBanner(session) {
      const upgrade = document.getElementById("free-upgrade");
      if (!upgrade) return;
      const plan = normalizePlan(session?.plan);
      const remaining = Number(session?.quota?.remaining);
      const exhausted = Number.isFinite(remaining) && remaining <= 0;
      const state = plan;
      if (state !== "free" && !exhausted) {
        upgrade.hidden = true;
        return;
      }
      const copy =
        state === "pro" && exhausted
          ? upgradeBannerCopy.proExhausted
          : state === "premium" && exhausted
            ? upgradeBannerCopy.premiumExhausted
            : upgradeBannerCopy[state] || upgradeBannerCopy.free;
      const title = upgrade.querySelector("[data-upgrade-title]");
      const desc = upgrade.querySelector("[data-upgrade-desc]");
      const primary = upgrade.querySelector("[data-upgrade-primary]");
      const secondary = upgrade.querySelector("[data-upgrade-secondary]");

      upgrade.dataset.plan = state;
      upgrade.dataset.exhausted = exhausted ? "true" : "false";
      if (title) title.textContent = copy.title;
      if (desc) desc.textContent = copy.desc;
      if (primary) {
        primary.textContent = copy.primary;
        primary.href =
          state === "premium" && exhausted
            ? upgradeBannerHrefs.credits
            : state === "premium" && !exhausted
              ? upgradeBannerHrefs.premium
              : state === "pro" && !exhausted
                ? upgradeBannerHrefs.pro
                : upgradeBannerHrefs.pricing;
      }
      if (secondary) {
        if (state === "pro" && !exhausted) {
          secondary.hidden = false;
          secondary.textContent = copy.secondary;
          secondary.href = upgradeBannerHrefs.pricing;
        } else if (state === "pro" && exhausted) {
          secondary.hidden = false;
          secondary.textContent = copy.secondary;
          secondary.href = upgradeBannerHrefs.credits;
        } else if (state === "premium" && exhausted) {
          secondary.hidden = false;
          secondary.textContent = copy.secondary;
          secondary.href = upgradeBannerHrefs.history;
        } else {
          secondary.hidden = true;
        }
      }
      upgrade.hidden = false;
    }

    async function refreshUpgradeBanner() {
      const session = await loadSession();
      if (!session) return;
      renderUpgradeBanner(session);
    }

    async function refreshWorkspaceStatus() {
      const session = await loadSessionWithCheckoutRefresh();
      if (!session) return;
      renderWorkspaceStatus(session);
    }

    function activateShareActions(jobId, lookSlug) {
      if (!jobId) return;
      lastSucceededJobId = jobId;
      lastSucceededLookSlug =
        lookSlug || lastSucceededLookSlug || selectedLookSlug;
      refreshUpgradeBanner();
      const shareActions = document.getElementById("free-share-actions");
      if (shareActions) shareActions.hidden = false;
      ["free-share-card", "free-save-result", "free-copy-link"].forEach(
        (id) => {
          const btn = document.getElementById(id);
          if (btn) btn.disabled = false;
        },
      );
      const downloadLink = document.getElementById("member-download-result");
      if (downloadLink) {
        downloadLink.href =
          "/api/tryon-jobs/" + encodeURIComponent(jobId) + "/result";
        downloadLink.setAttribute(
          "download",
          (lastSucceededLookSlug || "tryon-result") + ".webp",
        );
        downloadLink.setAttribute("aria-disabled", "false");
      }
      refreshRewardButtonState();
      loadSavedLooks().then(renderSaveButton);
    }
    document.addEventListener("abs:tryon-succeeded", function (event) {
      activateShareActions(event.detail?.job?.id, event.detail?.job?.lookSlug);
      if (event.detail?.quota) renderWorkspaceQuota(event.detail.quota);
    });
    if (lastSucceededJobId) activateShareActions(lastSucceededJobId);
    refreshWorkspaceStatus();
    refreshUpgradeBanner();

    const copyBtn = document.getElementById("free-copy-link");
    if (copyBtn) {
      copyBtn.addEventListener("click", async () => {
        if (!lastSucceededJobId) return;
        if (!navigator.clipboard?.writeText) return;
        let shareUrl;
        try {
          shareUrl = await createPublicShareUrl(lastSucceededJobId);
          await navigator.clipboard.writeText(shareUrl);
        } catch (error) {
          console.error("Copy share link failed", error);
          return;
        }
        try {
          await createShareClaim(lastSucceededJobId, "copy_link");
          refreshRewardButtonState();
        } catch (error) {
          console.error("Share claim failed", error);
        }
        copyBtn.textContent = "✓ " + freeClientMessages.copied;
        setTimeout(() => {
          copyBtn.textContent = "⌘  " + freeClientMessages.copyShareLink;
        }, 2000);
      });
    }

    const rewardBtn = document.getElementById("free-share-reward");
    if (rewardBtn) {
      rewardBtn.addEventListener("click", async () => {
        if (!lastSucceededJobId) return;
        rewardBtn.disabled = true;
        try {
          const res = await fetch("/api/shares/reward", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              jobId: lastSucceededJobId,
              shareClaimToken:
                getStoredShareClaim(lastSucceededJobId)?.claimToken,
            }),
          });
          const data = await res.json();
          if (data.ok && data.data.rewarded) {
            rewardBtn.textContent = "✓ " + freeClientMessages.rewarded;
            if (data.data.quota && window.updateQuotaDisplay) {
              window.updateQuotaDisplay(data.data.quota);
            }
          } else {
            rewardBtn.textContent =
              "i " + (data.data?.reason || freeClientMessages.alreadyRewarded);
            if (data.data?.quota && window.updateQuotaDisplay) {
              window.updateQuotaDisplay(data.data.quota);
            }
          }
        } catch {
          rewardBtn.textContent = "× " + freeClientMessages.failed;
          rewardBtn.disabled = false;
        }
      });
    }

    const shareCardBtn = document.getElementById("free-share-card");
    if (shareCardBtn) {
      shareCardBtn.addEventListener("click", () => {
        if (!lastSucceededJobId) return;
        window.location.href = shareCardHref + "?jobId=" + lastSucceededJobId;
      });
    }

    const saveResultBtn = document.getElementById("free-save-result");
    if (saveResultBtn) {
      saveResultBtn.addEventListener("click", async () => {
        if (!lastSucceededJobId) return;
        saveResultBtn.disabled = true;
        try {
          if (savedJobIds.has(lastSucceededJobId)) {
            const res = await fetch("/api/saved-looks/" + lastSucceededJobId, {
              method: "DELETE",
            });
            const data = await res.json().catch(() => null);
            if (!res.ok || !data?.ok) throw new Error("DELETE_SAVED_FAILED");
            savedJobIds.delete(lastSucceededJobId);
          } else {
            const res = await fetch("/api/saved-looks", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                jobId: lastSucceededJobId,
                lookSlug:
                  lastSucceededLookSlug || selectedLookSlug || "commute",
              }),
            });
            const data = await res.json().catch(() => null);
            if (!res.ok || !data?.ok) {
              if (data?.error?.code === "SAVED_LOOK_LIMIT_REACHED") {
                flashSaveButton(freeClientMessages.savedLimitReached);
                return;
              }
              throw new Error(data?.error?.message || "SAVE_LOOK_FAILED");
            }
            savedJobIds.add(lastSucceededJobId);
          }
          renderSaveButton();
        } catch (error) {
          console.error(freeClientMessages.operationSavedFailed, error);
          flashSaveButton(freeClientMessages.operationSavedFailed);
        } finally {
          saveResultBtn.disabled = false;
        }
      });
    }
  })();
</script>

