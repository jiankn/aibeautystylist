    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 16px;
    padding: 20px 24px;
    background: linear-gradient(135deg, var(--rose-soft), var(--teal-soft));
  }
  .upgrade-banner[data-plan="pro"] {
    background: linear-gradient(
      135deg,
      var(--teal-soft),
      var(--surface-neutral)
    );
  }
  .upgrade-banner[data-plan="premium"] {
    background: linear-gradient(
      135deg,
      var(--surface-gold),
