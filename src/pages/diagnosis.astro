---

<BaseLayout
  title={diagnosisCopy.metaTitle}
  description={diagnosisCopy.metaDescription}
  bodyClass="diagnosis-body"
>
  <SiteHeader active="diagnosis" mobileHidden />
  <MobileAppTopBar
    title={diagnosisCopy.kicker}
    backHref={tryOnFreeHref}
    rightAction="help"
  />
  <main class="diagnosis-main" data-diagnosis-main>
    <section class="diagnosis-hero shell" aria-labelledby="diagnosis-title">
      <div class="diagnosis-hero-copy">
        <span class="section-eyebrow">{diagnosisCopy.kicker}</span>
        <h1 id="diagnosis-title" aria-label={diagnosisCopy.title}>
          {diagnosisCopy.titleLines.map((line) => <span>{line}</span>)}
        </h1>
        <p>{diagnosisCopy.subtitle}</p>
        <div class="diagnosis-hero-actions">
          <a class="btn btn-primary" href="#diagnosis-new"
            >{diagnosisCopy.startCta}</a
          >
          <a class="btn" href={pricingHref}>{diagnosisCopy.plansCta}</a>
        </div>
        <div class="diagnosis-hero-trust" aria-label={diagnosisCopy.kicker}>
          {
            diagnosisCopy.trust.map(([title, text]) => (
              <div>
                <b>{title}</b>
                <span>{text}</span>
              </div>
            ))
          }
        </div>
      </div>
      <aside class="diagnosis-report-preview panel">
        <div class="report-preview-media">
          <img
            src={diagnosisPreviewImage}
            alt={diagnosisCopy.previewAlt}
            width="720"
            height="720"
          />
        </div>
        <div class="report-preview-summary">
          <div class="report-preview-copy">
            <span class="report-preview-label"
              >{diagnosisCopy.previewLabel}</span
            >
            <h2>{diagnosisCopy.previewTitle}</h2>
          </div>
          <div class="report-preview-stats">
            {
              diagnosisCopy.previewStats.map(([label, value]) => (
                <div>
                  <small>{label}</small>
                  <b>{value}</b>
                </div>
              ))
            }
          </div>
          <ul class="report-preview-notes">
            {
              diagnosisCopy.previewNotes
                .slice(0, 2)
                .map((item) => <li>{item}</li>)
            }
          </ul>
        </div>
      </aside>
    </section>

    <section class="diagnosis-outcomes shell" aria-labelledby="outcome-title">
      <div class="home-section-head-split">
        <div>
          <span class="section-eyebrow">{diagnosisCopy.kicker}</span>
          <h2 id="outcome-title">{diagnosisCopy.outcomeTitle}</h2>
          <p>{diagnosisCopy.outcomeSubtitle}</p>
        </div>
      </div>
      <div class="diagnosis-outcome-grid">
        {
          diagnosisCopy.outcomes.map(([title, text]) => (
            <article class="diagnosis-outcome-card">
              <span>{title}</span>
              <p>{text}</p>
            </article>
          ))
        }
      </div>
    </section>

    <div class="diagnosis-workspace shell">
      <section class="diagnosis-banner panel">
        <div>
          <span class="section-eyebrow">{diagnosisCopy.quotaTitle}</span>
          <h2>{diagnosisCopy.uploadTitle}</h2>
          <p>{diagnosisCopy.uploadSubtitle}</p>
        </div>
        <div class="diagnosis-credit" data-diagnosis-quota>
          <span aria-hidden="true">AI</span>
          <div>
            <b data-diagnosis-quota-text>—</b>
            <div class="small muted" data-diagnosis-quota-note>
              {diagnosisCopy.quotaLoading}
            </div>
          </div>
        </div>
      </section>

      <section class="diagnosis-new panel" id="diagnosis-new" tabindex="-1">
        <div class="diagnosis-upload-copy">
          <span class="section-eyebrow">{diagnosisCopy.guideTitle}</span>
          <h2>{diagnosisCopy.uploadTitle}</h2>
          <p>{diagnosisCopy.uploadSubtitle}</p>
        </div>
        <div class="diagnosis-upload-area">
          <div class="privacy-promise">
            {
              diagnosisCopy.guide.map((item) => (
                <span>
                  <i aria-hidden="true" />
                  {item}
                </span>
              ))
            }
          </div>
          <label class="privacy-consent">
            <input type="checkbox" data-diag-consent />
            <span>{diagnosisCopy.consent}</span>
          </label>
          <button class="btn btn-primary" id="diag-upload-btn" disabled>
            {diagnosisCopy.uploadCta}
          </button>
          <div class="upload-task-status" id="diag-task-status" hidden>
            <div class="upload-task-head">
              <span id="diag-status-text">{diagnosisCopy.quotaLoading}</span>
              <b id="diag-percent">0%</b>
            </div>
            <div class="meter"><i id="diag-progress" style="width:0%"></i></div>
          </div>
          <section
            class="diagnosis-progress-plan"
            data-diagnosis-progress-plan
            hidden
          >
            <div>
              <strong>{diagnosisProgressCopy.progressTitle}</strong>
              <p>{diagnosisProgressCopy.progressDesc}</p>
            </div>
            <ol
              class="diagnosis-stage-list"
              aria-label={diagnosisProgressCopy.progressTitle}
            >
              {
                diagnosisProgressCopy.stages.map(([key, label]) => (
                  <li data-diagnosis-stage={key}>
                    <span aria-hidden="true" />
                    <b>{label}</b>
                  </li>
                ))
              }
            </ol>
          </section>
          <section
            class="diagnosis-waiting-questions"
            data-diagnosis-waiting
            hidden
          >
            <div class="diagnosis-waiting-copy">
              <strong>{diagnosisProgressCopy.questionTitle}</strong>
              <p>{diagnosisProgressCopy.questionDesc}</p>
            </div>
            {
              diagnosisProgressCopy.groups.map((group) => (
                <fieldset class="diagnosis-waiting-group">
                  <legend>{group.label}</legend>
                  <div>
                    {group.options.map((option, index) => (
                      <button
                        class:list={["btn", index === 0 && "active"]}
                        type="button"
                        data-diagnosis-preference={group.key}
                        data-diagnosis-preference-value={option}
                        aria-pressed={index === 0 ? "true" : "false"}
                      >
                        {option}
                      </button>
                    ))}
                  </div>
                </fieldset>
              ))
            }
          </section>
        </div>
      </section>

      <!-- 诊断结果区（JS 动态填充） -->
      <div class="diagnosis-result-shell" id="diagnosis-result" hidden>
        <section class="diagnosis-result-hero panel">
          <div class="diagnosis-result-copy">
            <span class="section-eyebrow" id="diag-result-meta"
              >{diagnosisCopy.historyKicker}</span
            >
            <p class="diagnosis-report-type">
              {professionalReportCopy.reportType}
            </p>
            <h2 id="diag-result-title">{diagnosisCopy.resultKeywords}</h2>
            <p id="diag-result-summary">{diagnosisCopy.resultNotice}</p>
            <div class="diagnosis-result-chips" id="diag-result-chips"></div>
            <div class="diagnosis-result-actions">
              <a
                class="btn btn-primary"
                id="diag-primary-look"
                href={discoverHref}>{professionalReportCopy.actionLook}</a
              >
              <a class="btn" href="#diagnosis-new">
                {professionalReportCopy.newReport}
              </a>
            </div>
          </div>
          <aside class="diagnosis-report-facts" id="diag-report-facts"></aside>
        </section>

        <section class="diagnosis-executive panel">
          <div class="diagnosis-section-head">
            <div>
              <span class="section-eyebrow"
                >{professionalReportCopy.summaryEyebrow}</span
              >
              <h2 class="panel-title">{professionalReportCopy.summaryTitle}</h2>
              <p class="panel-subtitle">
                {professionalReportCopy.summarySubtitle}
              </p>
            </div>
          </div>
          <div class="diagnosis-executive-grid">
            <article class="diagnosis-summary-card">
              <small>{professionalReportCopy.conclusionLabel}</small>
              <strong id="diag-archetype">—</strong>
              <p id="diag-one-line-advice">{diagnosisCopy.resultNotice}</p>
            </article>
            <article class="diagnosis-summary-card diagnosis-strategy-card">
              <small>{professionalReportCopy.strategyLabel}</small>
              <p id="diag-core-strategy">{diagnosisCopy.resultNotice}</p>
            </article>
            <article class="diagnosis-summary-card diagnosis-palette-card">
              <small>{professionalReportCopy.paletteTitle}</small>
              <div class="diagnosis-palette" id="diag-color-palette"></div>
            </article>
          </div>
        </section>

        <section class="diagnosis-insight-grid">
          <aside class="portrait-panel panel diagnosis-profile-panel">
            <img id="diag-selfie" src="" alt="用户诊断自拍" hidden />
            <h3>{professionalReportCopy.keywordsTitle}</h3>
            <div id="diag-keywords"></div>
            <div class="rule-strip" id="diag-disclaimer">
              {diagnosisCopy.resultNotice}
            </div>
          </aside>
          <section class="diagnosis-analysis-panel panel">
            <div class="diagnosis-section-head compact">
              <div>
                <span class="section-eyebrow"
                  >{professionalReportCopy.evidenceEyebrow}</span
                >
                <h2 class="panel-title">
                  {professionalReportCopy.evidenceTitle}
                </h2>
                <p class="panel-subtitle">
                  {professionalReportCopy.evidenceSubtitle}
                </p>
              </div>
            </div>
            <div class="analysis-cards" id="diag-cards"></div>
          </section>
        </section>

        <section class="diagnosis-routine-panel panel">
          <div class="diagnosis-section-head">
            <div>
              <span class="section-eyebrow"
                >{professionalReportCopy.routineEyebrow}</span
              >
              <h2 class="panel-title">{professionalReportCopy.routineTitle}</h2>
              <p class="panel-subtitle">
                {professionalReportCopy.routineSubtitle}
              </p>
            </div>
          </div>
          <div class="diagnosis-routine-grid" id="diag-routine-steps"></div>
          <details class="diagnosis-scenario-block">
            <summary>
              <div>
                <h3>{professionalReportCopy.scenarioTitle}</h3>
                <p>{professionalReportCopy.scenarioSubtitle}</p>
              </div>
            </summary>
            <div class="diagnosis-scenario-grid" id="diag-scenario-grid"></div>
          </details>
        </section>

        <details class="diagnosis-detail-panel panel" id="diag-detail-panel">
          <summary>
            <div class="diagnosis-detail-summary">
              <strong>{detailPanelCopy.title}</strong>
              <small>{detailPanelCopy.subtitle}</small>
              <div class="diagnosis-detail-pills">
                {detailPanelCopy.pills.map((pill) => <span>{pill}</span>)}
              </div>
            </div>
          </summary>
          <div
            class="analysis-cards diagnosis-detail-cards"
            id="diag-detail-cards"
          >
          </div>
        </details>

        <section class="recommend-panel panel diagnosis-priority-recommend">
          <div class="diagnosis-section-head">
            <div>
              <span class="section-eyebrow"
                >{professionalReportCopy.recommendedEyebrow}</span
              >
              <h2 class="panel-title">
                {professionalReportCopy.recommendedTitle}
              </h2>
              <p class="panel-subtitle">{diagnosisCopy.recommendSubtitle}</p>
            </div>
            <a class="btn" href={discoverHref}>{diagnosisCopy.recommendMore}</a>
          </div>
          <div class="recommend-list" id="diag-recommends">
            {
              defaultRecommends.map((look) => (
                <article class="recommend">
                  <img src={look.image} alt={look.title} />
                  <div>
                    <h3>{look.title}</h3>
                    <p>{look.scenarios.join(" / ")}</p>
                    <a class="btn btn-primary" href={tryLookHref(look.slug)}>
                      {diagnosisCopy.tryLook}
                    </a>
                  </div>
                </article>
              ))
            }
          </div>
        </section>
      </div>

      <section
        class="diagnosis-history panel"
        id="diagnosis-history"
        aria-labelledby="diagnosis-history-title"
      >
        <div class="diagnosis-history-header">
          <div>
            <span class="section-eyebrow">{diagnosisCopy.historyKicker}</span>
            <h2 id="diagnosis-history-title">{diagnosisCopy.historyTitle}</h2>
            <p>{diagnosisCopy.historySubtitle}</p>
          </div>
          <a
            class="btn btn-primary"
            href="#diagnosis-new"
            data-diagnosis-history-cta
            hidden
          >
            {diagnosisCopy.historyNewCta}
          </a>
        </div>
        <div
          id="diag-history-list"
          class="diag-history-list"
          aria-live="polite"
        >
          <div class="diag-history-skeleton" role="status">
            <span>{diagnosisCopy.historyLoading}</span>
            <i></i>
            <i></i>
          </div>
        </div>
      </section>
    </div>
  </main>
  <MobileBottomNav active="tryon" />

  <script
    is:inline
    define:vars={{
      diagnosisClientCopy,
      diagnosisProgressCopy,
      professionalReportCopy,
      discoverHref,
      loginHref,
      tryOnFreeHref,
    }}
  >
    (function () {
      const copy = diagnosisClientCopy;
      // === 配置 ===
      const POLL_INTERVAL = 2000;
      const POLL_MAX = 60;

      // === DOM 引用 ===
      const consentBox = document.querySelector("[data-diag-consent]");
      const diagnosisMain = document.querySelector("[data-diagnosis-main]");
      const uploadBtn = document.getElementById("diag-upload-btn");
      const taskStatus = document.getElementById("diag-task-status");
      const statusText = document.getElementById("diag-status-text");
      const percentText = document.getElementById("diag-percent");
      const progressBar = document.getElementById("diag-progress");
      const resultSection = document.getElementById("diagnosis-result");
      const newSection = document.getElementById("diagnosis-new");
      const cardsContainer = document.getElementById("diag-cards");
      const detailCardsContainer = document.getElementById("diag-detail-cards");
      const detailPanel = document.getElementById("diag-detail-panel");
      const keywordsContainer = document.getElementById("diag-keywords");
      const reportFacts = document.getElementById("diag-report-facts");
      const archetypeNode = document.getElementById("diag-archetype");
      const oneLineAdvice = document.getElementById("diag-one-line-advice");
      const coreStrategy = document.getElementById("diag-core-strategy");
      const colorPalette = document.getElementById("diag-color-palette");
      const routineSteps = document.getElementById("diag-routine-steps");
      const scenarioGrid = document.getElementById("diag-scenario-grid");
      const resultMeta = document.getElementById("diag-result-meta");
      const resultTitle = document.getElementById("diag-result-title");
      const resultSummary = document.getElementById("diag-result-summary");
      const resultChips = document.getElementById("diag-result-chips");
      const primaryLook = document.getElementById("diag-primary-look");
      const historyList = document.getElementById("diag-history-list");
      const historyHeaderCta = document.querySelector(
        "[data-diagnosis-history-cta]",
      );
      const quotaCard = document.querySelector("[data-diagnosis-quota]");
      const quotaText = document.querySelector("[data-diagnosis-quota-text]");
      const quotaNote = document.querySelector("[data-diagnosis-quota-note]");
      const recommendsContainer = document.getElementById("diag-recommends");
      const progressPlan = document.querySelector(
        "[data-diagnosis-progress-plan]",
      );
      const waitingQuestions = document.querySelector(
        "[data-diagnosis-waiting]",
      );
      const stageItems = Array.from(
        document.querySelectorAll("[data-diagnosis-stage]"),
      );
      const preferenceButtons = document.querySelectorAll(
        "[data-diagnosis-preference]",
      );
      const setTaskNavSuppressed = (suppressed) => {
        window.absSetMobileBottomNavSuppressed?.("diagnosis-task", suppressed);
      };
      const START_HASH = "#diagnosis-new";
      let isAccountUser = false;
      let wantsNewDiagnosis = location.hash === START_HASH;
      let quotaSnapshot = null;
      const preferenceStorageKey = "abs:diagnosis-waiting-preferences";

      function readWaitingPreferences() {
        try {
          return JSON.parse(localStorage.getItem(preferenceStorageKey) || "{}");
        } catch {
          return {};
        }
      }

      function writeWaitingPreferences(next) {
        try {
          localStorage.setItem(preferenceStorageKey, JSON.stringify(next));
        } catch {
          /* ignore private storage failures */
        }
      }

      function syncWaitingPreferences() {
        const stored = readWaitingPreferences();
        preferenceButtons.forEach((button) => {
          const key = button.dataset.diagnosisPreference;
          const selectedValue = stored[key];
          const active = selectedValue
            ? button.dataset.diagnosisPreferenceValue === selectedValue
            : button.classList.contains("active");
          button.classList.toggle("active", active);
          button.setAttribute("aria-pressed", String(active));
        });
      }

      preferenceButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const key = button.dataset.diagnosisPreference;
          if (!key) return;
          const stored = readWaitingPreferences();
          stored[key] = button.dataset.diagnosisPreferenceValue || "";
          writeWaitingPreferences(stored);
          syncWaitingPreferences();
        });
      });
      syncWaitingPreferences();

      function getTaskRoutes() {
        return window.__absBackgroundTasks?.routes || {};
      }

      function currentTaskHref() {
        return location.pathname + location.search + location.hash;
      }

      function syncDiagnosisBackgroundTask(job, overrides = {}) {
        if (!job?.id) return;
        const routes = getTaskRoutes();
        const stage =
          overrides.stage ||
          (job.status === "succeeded"
            ? copy.complete
            : diagnosisProgressCopy.progressTitle);
        window.__absBackgroundTasks?.upsert?.({
          id: job.id,
          type: "diagnosis",
          title: diagnosisProgressCopy.progressTitle,
          status: job.status || "running",
          progress: overrides.progress,
          stage,
          href: currentTaskHref(),
          resultHref: routes.diagnosis || location.pathname,
          ...overrides,
        });
      }

      function setDiagnosisExperienceVisible(visible) {
        if (progressPlan) progressPlan.hidden = !visible;
        if (waitingQuestions) waitingQuestions.hidden = !visible;
        setTaskNavSuppressed(visible);
      }

      function setDiagnosisStage(stageKey) {
        if (!stageItems.length) return;
        const stageOrder = ["quality", "intake", "features", "report"];
        const currentIndex = Math.max(0, stageOrder.indexOf(stageKey));
        stageItems.forEach((item) => {
          const itemIndex = stageOrder.indexOf(
            item.dataset.diagnosisStage || "",
          );
          item.dataset.state =
            itemIndex < currentIndex
              ? "complete"
              : itemIndex === currentIndex
                ? "current"
                : "upcoming";
        });
      }

      function scrollToDiagnosisStart() {
        if (!newSection) return;
        wantsNewDiagnosis = true;
        newSection.hidden = false;
        if (resultSection) resultSection.hidden = true;
        if (taskStatus) taskStatus.hidden = true;
        setDiagnosisExperienceVisible(false);
        newSection.scrollIntoView({ behavior: "smooth", block: "start" });
        window.history.replaceState(null, "", START_HASH);

        const focusTarget =
          uploadBtn && !uploadBtn.disabled
            ? uploadBtn
            : consentBox && !consentBox.disabled
              ? consentBox
              : newSection;
        requestAnimationFrame(() => {
          focusTarget?.focus?.({ preventScroll: true });
        });
      }

      document.addEventListener("click", (event) => {
        if (!(event.target instanceof Element)) return;
        const startLink = event.target.closest('a[href="#diagnosis-new"]');
        if (!startLink) return;
        event.preventDefault();
        scrollToDiagnosisStart();
      });

      if (location.hash === START_HASH) {
        requestAnimationFrame(scrollToDiagnosisStart);
      }

      function loginUrl() {
        return (
          loginHref +
          "?next=" +
          encodeURIComponent(
            location.pathname + location.search + location.hash,
          )
        );
      }

      function quotaRemainingValue() {
        if (!quotaSnapshot) return null;
        const remaining = Number(quotaSnapshot.remaining);
        return Number.isFinite(remaining) ? remaining : null;
      }

      function isQuotaExhausted() {
        const remaining = quotaRemainingValue();
        return isAccountUser && remaining !== null && remaining <= 0;
      }

      function renderQuota(q) {
        const remaining = Number(q?.remaining ?? 0);
        const total = Number(q?.total ?? 0);
        const safeRemaining = Number.isFinite(remaining)
          ? Math.max(0, remaining)
          : 0;
        const safeTotal = Number.isFinite(total) ? Math.max(0, total) : 0;
        const quotaLabel = safeRemaining + "/" + safeTotal;
        const exhausted = safeRemaining <= 0;
        if (quotaText) quotaText.textContent = quotaLabel;
        if (quotaNote) {
          quotaNote.textContent = exhausted
            ? copy.quotaExhaustedNote ||
              copy.quotaExhausted ||
              copy.quotaLoading
            : (copy.quotaRemainingPrefix || "") +
              quotaLabel +
              (copy.quotaRemainingSuffix || "");
        }
        quotaCard?.classList.toggle("is-exhausted", exhausted);
      }

      function syncUploadAvailability() {
        if (!uploadBtn) return;
        if (!isAccountUser) {
          uploadBtn.disabled = false;
          uploadBtn.textContent = copy.loginCta;
          return;
        }
        if (isQuotaExhausted()) {
          uploadBtn.disabled = true;
          uploadBtn.textContent =
            copy.quotaExhaustedCta || copy.quotaExhausted || copy.uploadCta;
          return;
        }
        uploadBtn.disabled = !consentBox?.checked;
        uploadBtn.textContent = copy.uploadCta;
      }

      function showQuotaExhaustedState() {
        if (taskStatus) taskStatus.hidden = true;
        quotaSnapshot = {
          ...(quotaSnapshot || { total: 0 }),
          remaining: 0,
        };
        renderQuota(quotaSnapshot);
        syncUploadAvailability();
      }

      function isQuotaError(err) {
        const value = String(
          [
            err?.code,
            err?.errorCode,
            err?.name,
            err?.message,
            typeof err === "string" ? err : "",
          ]
            .filter(Boolean)
            .join(" "),
        );
        return /QUOTA_EXHAUSTED|额度已用完|額度已用完|credits? (exhausted|used up)/i.test(
          value,
        );
      }

      // === 同意控制 ===
      if (consentBox && uploadBtn) {
        consentBox.addEventListener("change", () => {
          syncUploadAvailability();
        });
      }

      // === 上传 + 创建任务 ===
      let currentJobId = null;
      if (uploadBtn) {
        uploadBtn.addEventListener("click", async () => {
          if (!isAccountUser) {
            window.location.href = loginUrl();
            return;
          }
          if (isQuotaExhausted()) {
            showQuotaExhaustedState();
            return;
          }
          const input = document.createElement("input");
          input.type = "file";
          input.accept =
            "image/jpeg,image/png,image/webp,image/heic,image/heif";
          input.onchange = async () => {
            const file = input.files?.[0];
            if (!file) return;
            try {
              const createTryOnJob = window.__absCreateTryOnJob;
              if (typeof createTryOnJob !== "function") {
                throw new Error(copy.uploadFlowNotReady);
              }
              uploadBtn.disabled = true;
              taskStatus.hidden = false;
              setDiagnosisExperienceVisible(true);
              updateProgress(copy.uploading, 12, "quality", "1/4");
              updateProgress(copy.confirming, 22, "quality", "1/4");
              const result = await createTryOnJob({
                file,
                lookSlug: "commute",
                purpose: "diagnosis",
                idempotencyKey:
                  "diag-" +
                  Date.now() +
                  "-" +
                  Math.random().toString(36).slice(2),
              });
              updateProgress(copy.creating, 38, "intake", "2/4");
              currentJobId = result.job.id;
              syncDiagnosisBackgroundTask(result.job, {
                progress: 38,
                stage: copy.creating,
              });
              updateProgress(copy.analyzing, 52, "features", "3/4");

              // 3. 轮询
              pollJob(currentJobId);
            } catch (err) {
              if (isQuotaError(err)) {
                showQuotaExhaustedState();
                return;
              }
              const message =
                err instanceof Error ? err.message : String(err || "");
              updateProgress(message || copy.failed, 0, "quality");
              setDiagnosisExperienceVisible(false);
              syncUploadAvailability();
            }
          };
          input.click();
        });
      }

      function updateProgress(text, pct, stageKey, stepLabel) {
        if (statusText) statusText.textContent = text;
        if (percentText) percentText.textContent = stepLabel || pct + "%";
        if (progressBar) progressBar.style.width = pct + "%";
        if (stageKey) setDiagnosisStage(stageKey);
      }

      async function pollJob(jobId) {
        let attempt = 0;
        const interval = setInterval(async () => {
          attempt++;
          if (attempt > POLL_MAX) {
            clearInterval(interval);
            updateProgress(copy.timeout, 0, "report");
            if (currentJobId) {
              syncDiagnosisBackgroundTask(
                { id: currentJobId, status: "timed_out" },
                {
                  progress: 0,
                  stage: copy.timeout,
                },
              );
            }
            setDiagnosisExperienceVisible(false);
            syncUploadAvailability();
            return;
          }
          try {
            const res = await fetch("/api/tryon-jobs/" + jobId);
            const data = await res.json();
            if (!data.ok) return;
            const job = data.data;
            if (job.status === "diagnosis_running") {
              const progress = Math.min(76, 52 + attempt);
              updateProgress(copy.running, progress, "features", "3/4");
              syncDiagnosisBackgroundTask(job, {
                progress,
                stage: copy.running,
              });
            } else if (job.status === "image_running") {
              const progress = Math.min(94, 78 + attempt);
              updateProgress(copy.generating, progress, "report", "4/4");
              syncDiagnosisBackgroundTask(job, {
                progress,
                stage: copy.generating,
              });
            } else if (job.status === "succeeded") {
              clearInterval(interval);
              updateProgress(copy.complete, 100, "report", "4/4");
              syncDiagnosisBackgroundTask(job, {
                status: "succeeded",
                progress: 100,
                stage: copy.complete,
              });
              setDiagnosisExperienceVisible(false);
              window.showToast?.(copy.complete);
              // 加载诊断结果
              loadDiagnosisResult(jobId);
            } else if (job.status === "failed" || job.status === "timed_out") {
              clearInterval(interval);
              const message = job.errorCode
                ? copy.failed + "：" + job.errorCode
                : copy.failed;
              updateProgress(message, 0, "report");
              syncDiagnosisBackgroundTask(job, {
                status: job.status,
                progress: 0,
                stage: message,
              });
              setDiagnosisExperienceVisible(false);
              syncUploadAvailability();
            }
          } catch {
            /* ignore */
          }
        }, POLL_INTERVAL);
      }

      // === 加载诊断结果（含重试） ===
      async function loadDiagnosisResult(jobId) {
        const MAX_RETRIES = 5;
        const RETRY_DELAY = 2000;
        for (let attempt = 0; attempt <= MAX_RETRIES; attempt++) {
          try {
            const res = await fetch("/api/diagnoses");
            const data = await res.json();
            if (!data.ok) continue;
            const item = data.data.items.find((i) => i.jobId === jobId);
            if (item?.diagnosis) {
              renderDiagnosis(item.diagnosis, item);
              loadHistory();
              return;
            }
          } catch {
            /* ignore */
          }
          if (attempt < MAX_RETRIES) {
            await new Promise((r) => setTimeout(r, RETRY_DELAY));
          }
        }
        // 所有重试失败后仍然刷新历史，确保页面状态一致
        loadHistory();
      }

      const resultLabels = copy.resultLabels || {};
      const valueMaps = resultLabels.valueMaps || {};
      const keywordIcons = resultLabels.keywordIcons || {};
      const reportCopy = professionalReportCopy || {};

      function iconSvg(paths) {
        return `<svg viewBox="0 0 24 24" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.85" stroke-linecap="round" stroke-linejoin="round">${paths}</svg>`;
      }

      const reportIconSvg = {
        skin: iconSvg(
          `<path d="M12 3.5c-3.5 4-5.5 6.9-5.5 9.6A5.5 5.5 0 0 0 12 18.6a5.5 5.5 0 0 0 5.5-5.5c0-2.7-2-5.6-5.5-9.6Z" /><path d="M9.8 13.4c.4 1.2 1.2 2 2.2 2.4" />`,
        ),
        face: iconSvg(
          `<path d="M8 6.5c1-1.7 2.4-2.5 4-2.5s3 .8 4 2.5c1 1.5 1.5 3.6 1.5 5.8 0 2.3-.8 4.4-2.1 5.9-.9 1-2.1 1.8-3.4 1.8s-2.5-.8-3.4-1.8C7.3 16.7 6.5 14.6 6.5 12.3c0-2.2.5-4.3 1.5-5.8Z" /><circle cx="9.5" cy="10.5" r="0.8" fill="currentColor" stroke="none" /><circle cx="14.5" cy="10.5" r="0.8" fill="currentColor" stroke="none" /><path d="M10 14.8c.7.5 1.4.8 2 .8s1.3-.3 2-.8" />`,
        ),
        eye: iconSvg(
          `<path d="M2.5 12s3.5-5 9.5-5 9.5 5 9.5 5-3.5 5-9.5 5-9.5-5-9.5-5Z" /><circle cx="12" cy="12" r="2.4" />`,
        ),
        color: iconSvg(
          `<rect x="4.5" y="6" width="15" height="12" rx="3" /><circle cx="8.3" cy="10" r="1" fill="currentColor" stroke="none" /><circle cx="12" cy="13" r="1" fill="currentColor" stroke="none" /><circle cx="15.7" cy="10" r="1" fill="currentColor" stroke="none" />`,
        ),
        depth: iconSvg(
          `<path d="M7 17v-5" /><path d="M12 17V8" /><path d="M17 17V5" />`,
        ),
        tone: iconSvg(
          `<circle cx="12" cy="12" r="6.5" /><path d="M12 5.5a6.5 6.5 0 0 1 0 13" />`,
        ),
        season: iconSvg(
          `<path d="M12 4v4" /><path d="M12 16v4" /><path d="M4 12h4" /><path d="M16 12h4" /><path d="m6.5 6.5 2.8 2.8" /><path d="m14.7 14.7 2.8 2.8" /><path d="m17.5 6.5-2.8 2.8" /><path d="m9.3 14.7-2.8 2.8" />`,
        ),
        makeup: iconSvg(
          `<path d="m7 17 8.8-8.8a1.8 1.8 0 0 1 2.5 0l.5.5a1.8 1.8 0 0 1 0 2.5L10 20" /><path d="m6.5 17.5-2 2" /><path d="m14.5 9.5 3 3" />`,
        ),
        strength: iconSvg(
          `<path d="m12 4.5 1.8 4.2 4.2 1.8-4.2 1.8-1.8 4.2-1.8-4.2-4.2-1.8 4.2-1.8L12 4.5Z" />`,
        ),
        percent: iconSvg(
          `<path d="m8.5 15.5 7-7" /><circle cx="8.5" cy="8.5" r="1.4" /><circle cx="15.5" cy="15.5" r="1.4" />`,
        ),
        limit: iconSvg(
          `<path d="M12 5.5 19 18H5L12 5.5Z" /><path d="M12 10v3.5" /><circle cx="12" cy="15.8" r=".8" fill="currentColor" stroke="none" />`,
        ),
        caution: iconSvg(
          `<path d="M9 3.5h6l5.5 5.5v6L15 20.5H9L3.5 15V9L9 3.5Z" /><path d="M12 8.5v4.8" /><circle cx="12" cy="16.3" r=".8" fill="currentColor" stroke="none" />`,
        ),
        info: iconSvg(
          `<circle cx="12" cy="12" r="7" /><path d="M12 10.2v4.4" /><circle cx="12" cy="7.6" r=".8" fill="currentColor" stroke="none" />`,
        ),
      };

      function renderReportIcon(key) {
        const safeKey = String(key || "");
        const icon = reportIconSvg[safeKey] || reportIconSvg.info;
        return `<i class="report-ui-icon" data-icon="${escapeHtml(safeKey)}" aria-hidden="true">${icon}</i>`;
      }

      function labelFrom(map, key, fallback) {
        return (key && map?.[key]) || fallback || key || "";
      }

      function joinEvidence(items) {
        if (!Array.isArray(items)) return "";
        const normalized = items
          .map((item) =>
            String(item || "")
              .trim()
              .replace(/[、,，;；\s]+$/u, ""),
          )
          .filter(Boolean);
        if (!normalized.length) return "";
        const hasSentenceEnd = normalized.some((item) =>
          /[。.!?！？]$/u.test(item),
        );
        return normalized.join(
          hasSentenceEnd ? " " : resultLabels.paletteJoiner || ", ",
        );
      }

      function titleWithValue(label, value) {
        return value ? label + ": " + value : label;
      }

      function paletteSuffix(palette) {
        if (!Array.isArray(palette) || palette.length === 0) return "";
        return (
          (resultLabels.paletteOpen || " (") +
          (resultLabels.palettePrefix || "Palette: ") +
          palette.join(resultLabels.paletteJoiner || ", ") +
          (resultLabels.paletteClose || ")")
        );
      }

      function buildPhotoEvidenceCard({ originalImage, quality, stability }) {
        const hasOriginal = Boolean(originalImage);
        const title = hasOriginal
          ? reportCopy.photoEvidenceTitle || reportCopy.photoQuality || "Photo"
          : reportCopy.photoEvidenceMissingTitle ||
            "Original photo unavailable";
        const status = [
          `${reportCopy.photoStatusQualityPrefix || ""}${quality}`,
          `${reportCopy.photoStatusStabilityPrefix || ""}${stability}`,
        ].join(reportCopy.photoStatusJoiner || " · ");
        return `
          <div class="diagnosis-report-photo-card">
            <div class="diagnosis-report-photo-media${hasOriginal ? "" : " is-missing"}">
              ${
                hasOriginal
                  ? `<img src="${escapeHtml(originalImage)}" alt="${escapeHtml(title)}" loading="eager" decoding="async" data-diagnosis-original-image />`
                  : ""
              }
              <div class="diagnosis-report-photo-placeholder"${hasOriginal ? " hidden" : ""}>
                <b>${escapeHtml(reportCopy.photoEvidenceMissingTitle || "Photo")}</b>
                <span>${escapeHtml(reportCopy.photoEvidenceMissingBody || "")}</span>
              </div>
              <div class="diagnosis-photo-badges" aria-label="${escapeHtml(title)}">
                <span>${escapeHtml(title)}</span>
              </div>
              <div class="diagnosis-photo-status">
                <span>${escapeHtml(status)}</span>
                <small>${escapeHtml(reportCopy.photoPrivateNote || "")}</small>
              </div>
            </div>
          </div>
        `;
      }

      function installReportPhotoFallback(container) {
        const image = container?.querySelector(
          "[data-diagnosis-original-image]",
        );
        if (!(image instanceof HTMLImageElement)) return;
        image.addEventListener("error", () => {
          const media = image.closest(".diagnosis-report-photo-media");
          media?.classList.add("is-missing");
          media
            ?.querySelector(".diagnosis-report-photo-placeholder")
            ?.removeAttribute("hidden");
          const badge = media?.querySelector(".diagnosis-photo-badges span");
          if (badge) {
            badge.textContent =
              reportCopy.photoEvidenceMissingTitle ||
              "Original photo unavailable";
          }
        });
      }

      function qualityLabel(d) {
        const level = d?.photoQuality?.level;
        if (level === "good") return reportCopy.qualityGood || "Good";
        if (level === "usable") return reportCopy.qualityUsable || "Usable";
        if (level === "limited") return reportCopy.qualityLimited || "Limited";
        const overall = Number(d?.confidence?.overall || 0);
        if (overall >= 0.82) return reportCopy.qualityGood || "Good";
        if (overall >= 0.62) return reportCopy.qualityUsable || "Usable";
        return reportCopy.qualityLimited || "Limited";
      }

      function stabilityLabel(confidence) {
        const band = confidence?.band;
        if (band === "high") return reportCopy.stabilityHigh || "High";
        if (band === "medium") return reportCopy.stabilityMedium || "Medium";
        return reportCopy.stabilityLow || "Needs confirmation";
      }

      function stabilityDescription(confidence) {
        const band = confidence?.band;
        if (band === "high") return reportCopy.stabilityNotes?.high || "";
        if (band === "medium") return reportCopy.stabilityNotes?.medium || "";
        return reportCopy.stabilityNotes?.low || "";
      }

      function normalizeColorAnchor(value) {
        return String(value || "")
          .replace(
            /(粉底液?|底妆|遮瑕膏?|散粉|定妆粉?|眼影|眼线笔?|睫毛膏|腮红|唇膏|口红|唇釉|唇彩|foundation|concealer|setting powder|powder|eyeshadow|eye shadow|eyeliner|liner|mascara|blush|lipstick|lip gloss)/gi,
            "",
          )
          .replace(/[·|/、,，;；()（）\s]+$/gu, "")
          .trim();
      }

      function extractPalette(d) {
        const seen = new Set();
        const palette = [];
        (d.colorPalette?.recommended || []).forEach((color) => {
          const normalized = normalizeColorAnchor(color?.name);
          const key = normalized.toLowerCase();
          if (normalized && !seen.has(key)) {
            seen.add(key);
            palette.push(normalized);
          }
        });
        (d.makeupDirections || []).forEach((direction) => {
          (direction.palette || []).forEach((color) => {
            const normalized = normalizeColorAnchor(color);
            const key = normalized.toLowerCase();
            if (normalized && !seen.has(key)) {
              seen.add(key);
              palette.push(normalized);
            }
          });
        });
        return palette;
      }

      function inferArchetype(d, primaryDirection, seasonLabel) {
        if (d.reportSummary?.archetype) return d.reportSummary.archetype;
        if (primaryDirection?.title && seasonLabel) {
          return `${primaryDirection.title} · ${seasonLabel}`;
        }
        return (
          primaryDirection?.title ||
          seasonLabel ||
          reportCopy.fallbacks?.archetype
        );
      }

      function inferCoreStrategy(d, skinLabel, faceLabel, eyeLabel) {
        if (d.reportSummary?.primaryStrategy) {
          return d.reportSummary.primaryStrategy;
        }
        const parts = [];
        if (d.skinTone?.summary) parts.push(d.skinTone.summary);
        if (d.colorSeason?.rationale) parts.push(d.colorSeason.rationale);
        if (d.strengths?.[0]) parts.push(d.strengths[0]);
        if (parts.length) return parts.slice(0, 3).join(" ");
        const context = [skinLabel, faceLabel, eyeLabel]
          .filter(Boolean)
          .join(" / ");
        return context
          ? `${context}。${reportCopy.fallbacks?.strategy || ""}`
          : reportCopy.fallbacks?.strategy || "";
      }

      function buildRoutine(d, labels) {
        const plan = d.makeupPlan || {};
        const colorFallbacks = reportCopy.routineColorFallbacks || {};
        const colors = {
          eyes: paletteForUsage(
            d,
            "eyes",
            ["eyes", "multi"],
            colorFallbacks.eyes,
          ),
          cheeks: paletteForUsage(
            d,
            "cheeks",
            ["cheeks", "multi"],
            colorFallbacks.cheeks,
          ),
          lips: paletteForUsage(
            d,
            "lips",
            ["lips", "multi"],
            colorFallbacks.lips,
          ),
        };
        const evidence = {
          base: [d.skinTone?.summary],
          brows: [joinEvidence(d.faceShape?.evidence), labels.faceLabel],
          eyes: [joinEvidence(d.eyeShape?.evidence), labels.eyeLabel],
          contour: [joinEvidence(d.faceShape?.evidence), labels.faceLabel],
        };
        const fallbackPoints = reportCopy.routineActions || {};
        const steps = [
          {
            key: "base",
            title: reportCopy.rows?.base,
            points: routinePoints(
              "base",
              plan.base,
              fallbackPoints.base,
              evidence.base,
            ),
          },
          {
            key: "brows",
            title: reportCopy.rows?.brows,
            points: routinePoints(
              "brows",
              plan.brows,
              fallbackPoints.brows,
              evidence.brows,
            ),
          },
          {
            key: "eyes",
            title: reportCopy.rows?.eyes,
            points: routinePoints(
              "eyes",
              plan.eyes,
              fallbackPoints.eyes,
              evidence.eyes,
              colors.eyes,
            ),
          },
          {
            key: "cheeks",
            title: reportCopy.rows?.cheeks,
            points: routinePoints(
              "cheeks",
              plan.cheeks,
              fallbackPoints.cheeks,
              [],
              colors.cheeks,
            ),
          },
          {
            key: "lips",
            title: reportCopy.rows?.lips,
            points: routinePoints(
              "lips",
              plan.lips,
              fallbackPoints.lips,
              [],
              colors.lips,
            ),
          },
          {
            key: "contour",
            title: reportCopy.rows?.contour,
            points: routinePoints(
              "contour",
              plan.contourHighlight,
              fallbackPoints.contour,
              evidence.contour,
            ),
          },
        ];
        return steps
          .map((item) => ({
            ...item,
            body: item.points.join(" "),
          }))
          .filter((item) => item.title && item.body);
      }

      function routinePoints(
        key,
        items,
        fallbackItems,
        evidence = [],
        colors = "",
      ) {
        const cleaned = normalizePlanItems(items, evidence)
          .map((item) => applyRoutineColors(item, colors))
          .filter((item) => !hasCategoryLeak(key, item));
        const source = cleaned.length >= 2 ? cleaned : fallbackItems || cleaned;
        return normalizePlanItems(source, [])
          .map((item) => applyRoutineColors(item, colors))
          .filter(Boolean)
          .slice(0, 3);
      }

      function normalizePlanItems(items, evidence = []) {
        const list = Array.isArray(items) ? items : items ? [items] : [];
        return list
          .map((item) => stripEvidenceLead(String(item || ""), evidence))
          .map((item) => item.replace(/\s+/g, " ").trim())
          .filter(Boolean);
      }

      function stripEvidenceLead(text, evidence = []) {
        let next = text.trim();
        evidence
          .map((item) => String(item || "").trim())
          .filter(Boolean)
          .sort((a, b) => b.length - a.length)
          .forEach((item) => {
            if (next.startsWith(item)) {
              next = next
                .slice(item.length)
                .replace(/^[。.!?！？、,，;；\s]+/u, "")
                .trim();
            }
          });
        return next;
      }

      function applyRoutineColors(text, colors) {
        return String(text || "").replaceAll("{colors}", colors || "");
      }

      function paletteForUsage(d, target, usages, fallback) {
        const seen = new Set();
        const colors = [];
        (d.colorPalette?.recommended || []).forEach((color) => {
          const usage = String(color?.usage || "");
          const name = String(color?.name || "").trim();
          const key = name.toLowerCase();
          if (
            name &&
            usages.includes(usage) &&
            !seen.has(key) &&
            isPaletteNameAllowed(target, usage, name)
          ) {
            seen.add(key);
            colors.push(name);
          }
        });
        return colors.length
          ? colors.slice(0, 3).join(resultLabels.paletteJoiner || ", ")
          : fallback || "";
      }

      function isPaletteNameAllowed(target, usage, name) {
        if (isBaseProductName(name)) return false;
        if (usage === "multi") return isGenericColorFamily(name);
        return !hasProductCategoryLeak(target, name);
      }

      function isGenericColorFamily(value) {
        return !/(粉底|底妆|遮瑕|散粉|定妆|眼影|眼线|睫毛膏|睫毛|腮红|唇膏|口红|唇釉|foundation|concealer|powder|eyeshadow|eye shadow|eyeliner|liner|mascara|lash|blush|cheek|lipstick|lip gloss|lip|rouge)/i.test(
          String(value || ""),
        );
      }

      function hasProductCategoryLeak(target, value) {
        const text = String(value || "");
        const eyeProduct =
          /眼影|眼线|睫毛膏|睫毛|eyeshadow|eye shadow|eyeliner|liner|mascara|lash/i.test(
            text,
          );
        const cheekProduct = /腮红|blush|cheek/i.test(text);
        const lipProduct =
          /唇膏|口红|唇釉|唇彩|lipstick|lip gloss|lip\b|rouge/i.test(text);
        if (target === "eyes") return cheekProduct || lipProduct;
        if (target === "cheeks") return eyeProduct || lipProduct;
        if (target === "lips") return eyeProduct || cheekProduct;
        return false;
      }

      function isBaseProductName(value) {
        return /粉底|底妆|遮瑕|散粉|定妆|foundation|concealer|powder|setting powder/i.test(
          String(value || ""),
        );
      }

      function hasCategoryLeak(key, value) {
        const text = String(value || "");
        const baseLeak = isBaseProductName(text);
        const eyeLeak =
          /眼影|眼线|睫毛膏|睫毛|eyeshadow|eye shadow|eyeliner|liner|mascara|lash/i.test(
            text,
          );
        if (key === "cheeks" || key === "lips") {
          return baseLeak || eyeLeak || hasProductCategoryLeak(key, text);
        }
        if (key === "eyes")
          return baseLeak || hasProductCategoryLeak(key, text);
        return false;
      }

      function buildScenarioMatrix(d) {
        if (
          Array.isArray(d.scenarioStrategies) &&
          d.scenarioStrategies.length
        ) {
          return d.scenarioStrategies.map((item) => {
            const technique = normalizePlanItems(item.keyTechniques, [])
              .filter((text) => !hasCategoryLeak("scenario", text))
              .join(resultLabels.paletteJoiner || ", ");
            const colors = safeScenarioColors(item.colors);
            return {
              title: reportCopy.rows?.[item.scenario] || item.scenario,
              look: item.lookName,
              technique:
                colors && technique
                  ? `${technique}：${colors}`
                  : technique || colors,
              avoid: joinEvidence(item.avoid),
              validation: item.validation,
            };
          });
        }
        return (reportCopy.scenarios || []).map(
          ([key, look, technique, avoid, validation]) => ({
            title: reportCopy.rows?.[key] || key,
            look,
            technique,
            avoid,
            validation,
          }),
        );
      }

      function safeScenarioColors(colors) {
        if (!Array.isArray(colors)) return "";
        const seen = new Set();
        const safe = colors
          .map((color) => String(color || "").trim())
          .filter((color) => color && isGenericColorFamily(color))
          .filter((color) => {
            const key = color.toLowerCase();
            if (seen.has(key)) return false;
            seen.add(key);
            return true;
          });
        return safe.slice(0, 3).join(resultLabels.paletteJoiner || ", ");
      }

      function renderDiagnosis(d, record) {
        if (!resultSection || !cardsContainer || !keywordsContainer) return;
        wantsNewDiagnosis = false;
        diagnosisMain?.classList.add("has-account-result");
        newSection.hidden = true;
        resultSection.hidden = false;

        const skinDepthLabel = labelFrom(
          valueMaps.skinDepth,
          d.skinTone?.depth,
          d.skinTone?.depth,
        );
        const skinLabel = labelFrom(
          valueMaps.undertone,
          d.skinTone?.undertone,
          resultLabels.defaultSkinTone,
        );
        const faceLabel = labelFrom(
          valueMaps.faceShape,
          d.faceShape?.primary,
          resultLabels.defaultFaceShape,
        );
        const eyeLabel = labelFrom(
          valueMaps.eyeShape,
          d.eyeShape?.primary,
          resultLabels.defaultEyeShape,
        );
        const seasonLabel =
          (d.colorSeason &&
            labelFrom(
              valueMaps.season,
              d.colorSeason.season,
              d.colorSeason.season,
            )) ||
          resultLabels.colorDirection;
        const primaryDirection = d.makeupDirections?.[0];
        const palette = extractPalette(d);
        const archetype = inferArchetype(d, primaryDirection, seasonLabel);
        const strategy = inferCoreStrategy(d, skinLabel, faceLabel, eyeLabel);
        const oneLine =
          d.reportSummary?.oneLineAdvice ||
          primaryDirection?.rationale ||
          d.skinTone?.summary ||
          d.colorSeason?.rationale ||
          reportCopy.fallbacks?.oneLine ||
          "";
        const resultHeading =
          archetype || primaryDirection?.title || copy.reportTitle;
        const summaryText = strategy || oneLine || copy.reportTitle;
        const createdAt = record?.createdAt ? new Date(record.createdAt) : null;
        const shortDateLabel = createdAt
          ? createdAt.toLocaleDateString(
              document.documentElement.lang || "zh-CN",
              {
                month: "2-digit",
                day: "2-digit",
              },
            )
          : "";
        const quality = qualityLabel(d);
        const stability = stabilityLabel(d.confidence);

        if (resultMeta) {
          resultMeta.textContent = shortDateLabel
            ? (reportCopy.latestReport ||
                resultLabels.latestDiagnosis ||
                copy.reportTitle) +
              " · " +
              shortDateLabel
            : reportCopy.latestReport ||
              resultLabels.latestDiagnosis ||
              copy.reportTitle;
        }
        if (resultTitle) resultTitle.textContent = resultHeading;
        if (resultSummary) resultSummary.textContent = summaryText;
        if (archetypeNode) archetypeNode.textContent = resultHeading;
        if (oneLineAdvice) oneLineAdvice.textContent = oneLine;
        if (coreStrategy) coreStrategy.textContent = strategy;
        if (primaryLook) {
          primaryLook.href = discoverHref;
          primaryLook.textContent =
            reportCopy.actionLook || copy.recommendMore || copy.tryLook;
        }

        if (reportFacts) {
          reportFacts.innerHTML = buildPhotoEvidenceCard({
            originalImage: record?.originalImage,
            quality,
            stability,
          });
          installReportPhotoFallback(reportFacts);
        }

        const resultChipRows = [
          [resultLabels.skinTone, `${skinDepthLabel} / ${skinLabel}`],
          [resultLabels.facialFocus, `${faceLabel} / ${eyeLabel}`],
          [resultLabels.colorDirection, seasonLabel],
          [reportCopy.photoQuality, quality],
        ];
        if (quotaSnapshot) {
          resultChipRows.push([
            resultLabels.monthlyQuota,
            `${quotaSnapshot.remaining}/${quotaSnapshot.total}`,
          ]);
        }
        if (resultChips) {
          resultChips.innerHTML = resultChipRows
            .map(
              ([label, value]) =>
                `<span><small>${escapeHtml(label)}</small><b>${escapeHtml(value)}</b></span>`,
            )
            .join("");
        }

        const kw = [
          {
            key: "skin",
            icon: keywordIcons.skin || "S",
            title: `${skinDepthLabel} / ${skinLabel}`,
            desc: d.skinTone?.summary || "",
          },
          {
            key: "face",
            icon: keywordIcons.face || "F",
            title: faceLabel,
            desc: joinEvidence(d.faceShape?.evidence),
          },
          {
            key: "eye",
            icon: keywordIcons.eye || "E",
            title: eyeLabel,
            desc: joinEvidence(d.eyeShape?.evidence),
          },
          {
            key: "color",
            icon: keywordIcons.color || "C",
            title: seasonLabel,
            desc: d.colorSeason?.rationale || "",
          },
        ];
        keywordsContainer.innerHTML = kw
          .map(
            (k) => `
      <div class="keyword">${renderReportIcon(k.key)}<div><b>${escapeHtml(k.title)}</b><span>${escapeHtml(k.desc)}</span></div></div>
    `,
          )
          .join("");

        if (colorPalette) {
          colorPalette.innerHTML = (
            palette.length ? palette : [seasonLabel, skinLabel]
          )
            .slice(0, 8)
            .map(
              (color, index) =>
                `<span class="palette-chip" data-tone="${index % 6}"><i aria-hidden="true"></i>${escapeHtml(color)}</span>`,
            )
            .join("");
        }

        const routine = buildRoutine(d, {
          skinLabel,
          skinDepthLabel,
          faceLabel,
          eyeLabel,
          seasonLabel,
          palette,
        });
        if (routineSteps) {
          routineSteps.innerHTML = routine
            .map(
              (item, index) => `
                <article class="routine-step">
                  <span>${String(index + 1).padStart(2, "0")}</span>
                  <div>
                    <h3>${escapeHtml(item.title)}</h3>
                    <ul>
                      ${item.points.map((point) => `<li>${escapeHtml(point)}</li>`).join("")}
                    </ul>
                  </div>
                </article>
              `,
            )
            .join("");
        }
        if (scenarioGrid) {
          scenarioGrid.innerHTML = buildScenarioMatrix(d)
            .map(
              (item) => `
                <article class="scenario-card">
                  <strong>${escapeHtml(item.title)}</strong>
                  <b>${escapeHtml(item.look)}</b>
                  <dl>
                    <div><dt>${escapeHtml(reportCopy.rows?.technique)}</dt><dd>${escapeHtml(item.technique)}</dd></div>
                    <div><dt>${escapeHtml(reportCopy.rows?.avoid)}</dt><dd>${escapeHtml(item.avoid)}</dd></div>
                    <div><dt>${escapeHtml(reportCopy.rows?.validation)}</dt><dd>${escapeHtml(item.validation)}</dd></div>
                  </dl>
                </article>
              `,
            )
            .join("");
        }

        const insightCards = [];
        insightCards.push(
          buildCard(
            reportCopy.sections?.skin || resultLabels.sections?.skinAndColor,
            [
              {
                key: "depth",
                icon: keywordIcons.depth || "D",
                title: resultLabels.rows?.skinDepth,
                desc: skinDepthLabel,
              },
              {
                key: "tone",
                icon: keywordIcons.tone || "T",
                title: resultLabels.rows?.undertone,
                desc: [skinLabel, d.skinTone?.summary]
                  .filter(Boolean)
                  .join(" - "),
              },
              {
                key: "makeup",
                icon: keywordIcons.makeup || "M",
                title: reportCopy.rows?.base,
                desc: routine.find((item) => item.key === "base")?.body,
              },
            ],
          ),
        );
        insightCards.push(
          buildCard(
            reportCopy.sections?.color || resultLabels.sections?.skinAndColor,
            [
              {
                key: "season",
                icon: keywordIcons.season || "C",
                title: resultLabels.rows?.colorSeason,
                desc: [seasonLabel, d.colorSeason?.rationale]
                  .filter(Boolean)
                  .join(": "),
              },
              {
                key: "color",
                icon: keywordIcons.color || "C",
                title: reportCopy.paletteTitle,
                desc: palette.length
                  ? palette.join(resultLabels.paletteJoiner || ", ")
                  : oneLine,
              },
              {
                key: "caution",
                icon: keywordIcons.caution || "!",
                title: resultLabels.sections?.cautions,
                desc: (d.cautions || [])[0] || reportCopy.fallbacks?.oneLine,
              },
            ],
          ),
        );
        insightCards.push(
          buildCard(
            reportCopy.sections?.structure ||
              resultLabels.sections?.whyRecommended,
            [
              {
                key: "face",
                icon: keywordIcons.face || "F",
                title: titleWithValue(resultLabels.rows?.faceShape, faceLabel),
                desc: joinEvidence(d.faceShape?.evidence),
              },
              ...(d.strengths || []).slice(0, 3).map((s) => ({
                key: "strength",
                icon: keywordIcons.strength || "+",
                title: resultLabels.rows?.strengthenPoint,
                desc: s,
              })),
              {
                key: "makeup",
                icon: keywordIcons.makeup || "M",
                title: reportCopy.rows?.contour,
                desc: routine.find((item) => item.key === "contour")?.body,
              },
            ],
          ),
        );
        insightCards.push(
          buildCard(
            reportCopy.sections?.eyes || resultLabels.sections?.whyRecommended,
            [
              {
                key: "eye",
                icon: keywordIcons.eye || "E",
                title: titleWithValue(resultLabels.rows?.eyeShape, eyeLabel),
                desc: joinEvidence(d.eyeShape?.evidence),
              },
              {
                key: "makeup",
                icon: keywordIcons.makeup || "M",
                title: reportCopy.rows?.eyes,
                desc: routine.find((item) => item.key === "eyes")?.body,
              },
            ],
          ),
        );
        if (d.makeupDirections?.length) {
          insightCards.push(
            buildCard(
              reportCopy.sections?.directions ||
                resultLabels.sections?.makeupDirections,
              d.makeupDirections.map((dir) => ({
                key: "makeup",
                icon: keywordIcons.makeup || "M",
                title: dir.title,
                desc: (dir.rationale || "") + paletteSuffix(dir.palette),
              })),
            ),
          );
        }
        cardsContainer.innerHTML = insightCards.join("");

        const detailCards = [];
        const conf = d.confidence;
        if (conf) {
          detailCards.push(
            buildCard(resultLabels.sections?.analysisConfidence, [
              {
                key: "percent",
                icon: keywordIcons.percent || "%",
                title: stability,
                desc: stabilityDescription(conf),
              },
              ...(d.photoQuality?.notes || []).map((note) => ({
                key: "limit",
                icon: keywordIcons.limit || "L",
                title: reportCopy.photoQuality,
                desc: note,
              })),
              ...(conf.limitations || []).map((l) => ({
                key: "limit",
                icon: keywordIcons.limit || "L",
                title: resultLabels.rows?.limitation,
                desc: l,
              })),
            ]),
          );
        }
        const cautionRows = [
          ...(d.cautions || []).map((c) => ({
            key: "caution",
            icon: keywordIcons.caution || "!",
            title: resultLabels.rows?.suggestion,
            desc: c,
          })),
          ...(d.colorPalette?.avoid || []).map((c) => ({
            key: "caution",
            icon: keywordIcons.caution || "!",
            title: reportCopy.rows?.avoid || resultLabels.rows?.suggestion,
            desc: c,
          })),
        ];
        if (cautionRows.length) {
          detailCards.push(
            buildCard(resultLabels.sections?.cautions, cautionRows),
          );
        }
        if (detailCardsContainer)
          detailCardsContainer.innerHTML = detailCards.join("");
        if (detailPanel) detailPanel.hidden = detailCards.length === 0;

        if (d.makeupDirections?.length && recommendsContainer) {
          try {
            fetch("/api/looks")
              .then((r) => r.json())
              .then((looksData) => {
                if (!looksData.ok) return;
                const allLooks = looksData.data?.looks || [];
                const matched = matchRecommends(
                  d,
                  allLooks,
                  d.recommendationReasoning,
                );
                if (matched.length > 0) {
                  const primary = matched[0];
                  if (primaryLook && primary) {
                    primaryLook.href = `${tryOnFreeHref}?look=${encodeURIComponent(primary.slug)}`;
                    primaryLook.textContent = copy.tryLook;
                  }
                  recommendsContainer.innerHTML = matched
                    .slice(0, 4)
                    .map(
                      (m) => `
              <article class="recommend report-recommend">
                <img src="${escapeHtml(m.image)}" alt="${escapeHtml(m.title)}" />
                <div>
                  <h3>${escapeHtml(m.title)} <span class="pill pill-rose">${escapeHtml(reportCopy.matchBadge)}</span></h3>
                  <p><b>${escapeHtml(reportCopy.matchedReason)}：</b>${escapeHtml(m.reason)}</p>
                  <p class="recommend-watch"><b>${escapeHtml(reportCopy.watchTitle)}：</b>${escapeHtml(m.watch)}</p>
                  <a class="btn btn-primary" href="${escapeHtml(tryOnFreeHref)}?look=${encodeURIComponent(m.slug)}">${escapeHtml(copy.tryLook)}</a>
                </div>
              </article>
            `,
                    )
                    .join("");
                }
              });
          } catch {
            /* ignore */
          }
        }
      }

      function buildCard(title, rows) {
        const safeRows = Array.isArray(rows) ? rows : [];
        return `<article class="analysis-card report-section-card"><h2>${escapeHtml(title || copy.reportTitle)}</h2>${safeRows
          .filter((r) => r?.title || r?.desc)
          .map(
            (r) =>
              `<div class="analysis-row">${renderReportIcon(r.key || "")}<div><b>${escapeHtml(r.title || "")}</b><span>${escapeHtml(r.desc || "")}</span></div></div>`,
          )
          .join("")}</article>`;
      }

      function matchRecommends(diagnosis, allLooks, reasoning = []) {
        const directions = diagnosis?.makeupDirections || [];
        const firstDirection = directions[0] || {};
        const diagnosisText = [
          diagnosis?.reportSummary?.archetype,
          diagnosis?.reportSummary?.primaryStrategy,
          diagnosis?.colorSeason?.rationale,
          ...directions.flatMap((item) => [
            item?.title,
            item?.rationale,
            ...(item?.palette || []),
          ]),
        ]
          .filter(Boolean)
          .join(" ")
          .toLowerCase();
        const signals = [
          "清透",
          "自然",
          "柔和",
          "柔雾",
          "低饱和",
          "显气色",
          "通勤",
          "面试",
          "约会",
          "拍照",
          "水润",
          "光泽",
          "natural",
          "soft",
          "muted",
          "work",
          "date",
          "camera",
          "dewy",
        ].filter((signal) => diagnosisText.includes(signal));
        const season = String(diagnosis?.colorSeason?.season || "");
        const isCoolSeason = /summer|winter/i.test(season);
        const isWarmSeason = /spring|autumn/i.test(season);
        const matchedReasoning =
          reasoning.find(
            (item) =>
              item?.directionTitle &&
              item.directionTitle === firstDirection.title,
          ) || reasoning[0];
        const palette = (firstDirection.palette || []).join(
          resultLabels.paletteJoiner || ", ",
        );
        const safeFallbackOrder = [
          "no-makeup",
          "interview-ready",
          "rose-milk-date",
          "photogenic",
        ];
        const eligible = allLooks.filter((look) => {
          const haystack = [look.slug, look.title, look.intent]
            .filter(Boolean)
            .join(" ")
            .toLowerCase();
          if (/mature|熟龄/.test(haystack)) return false;
          if (
            isCoolSeason &&
            /蜜桃|珊瑚|暖金|鎏金|bronze|warm gold|peach|coral/.test(haystack)
          )
            return false;
          if (isWarmSeason && /灰粉|冷调莓|icy|cool mauve/.test(haystack))
            return false;
          return true;
        });
        const ranked = eligible
          .map((look) => {
            const haystack = [
              look.slug,
              look.title,
              look.intent,
              ...(look.scenarios || []),
              ...(look.finish || []),
              ...(look.anchors || []),
            ]
              .join(" ")
              .toLowerCase();
            const hits = signals.filter((signal) =>
              haystack.includes(signal),
            ).length;
            return {
              ...look,
              score: hits,
              reason:
                joinEvidence(matchedReasoning?.matchedFactors) ||
                firstDirection.rationale ||
                (palette
                  ? `${resultLabels.palettePrefix || "Palette: "}${palette}`
                  : reportCopy.fallbacks?.oneLine || ""),
              watch:
                joinEvidence(matchedReasoning?.watchOut) ||
                reportCopy.fallbacks?.oneLine ||
                firstDirection.rationale ||
                copy.reportTitle,
            };
          })
          .filter((look) => look.score > 0)
          .sort((a, b) => b.score - a.score);
        if (ranked.length) return ranked;
        return safeFallbackOrder
          .map((slug) => eligible.find((look) => look.slug === slug))
          .filter(Boolean)
          .map((look) => ({
            ...look,
            score: 0,
            reason:
              firstDirection.rationale || reportCopy.fallbacks?.oneLine || "",
            watch: reportCopy.fallbacks?.oneLine || copy.reportTitle,
          }));
      }

      // === 加载额度 ===
      async function loadQuota() {
        try {
          const res = await fetch("/api/session");
          const data = await res.json();
          if (!data.ok) return false;
          isAccountUser = data.data.user?.kind === "account";
          if (!isAccountUser) {
            quotaSnapshot = null;
            quotaCard?.classList.remove("is-exhausted");
            if (quotaText) quotaText.textContent = copy.quotaGuest;
            if (quotaNote) quotaNote.textContent = copy.quotaGuestNote;
            if (consentBox) {
              consentBox.checked = false;
              consentBox.disabled = true;
            }
            syncUploadAvailability();
            return false;
          }
          if (consentBox) consentBox.disabled = false;
          const q = data.data.quota;
          quotaSnapshot = q;
          renderQuota(q);
          if (isQuotaExhausted() && taskStatus) taskStatus.hidden = true;
          syncUploadAvailability();
          return true;
        } catch {
          return false;
        }
      }

      function escapeHtml(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      function setHistoryHeaderCtaVisible(isVisible) {
        if (historyHeaderCta instanceof HTMLElement) {
          historyHeaderCta.hidden = !isVisible;
        }
      }

      function renderHistoryEmpty() {
        if (!historyList) return;
        setHistoryHeaderCtaVisible(false);
        diagnosisMain?.classList.remove("has-account-result");
        historyList.classList.remove("has-items");
        historyList.classList.add("is-empty");
        historyList.innerHTML = `
        <div class="diag-history-empty">
          <div class="history-empty-main">
            <span class="history-empty-mark" aria-hidden="true">AI</span>
            <div>
              <b>${escapeHtml(copy.historyEmptyTitle)}</b>
              <p>${escapeHtml(copy.historyEmptyBody)}</p>
            </div>
          </div>
          <div class="history-empty-actions">
            <a class="btn btn-primary" href="#diagnosis-new">${escapeHtml(copy.historyEmptyCta)}</a>
            <a class="btn" href="${escapeHtml(discoverHref)}">${escapeHtml(copy.historyEmptySecondary)}</a>
          </div>
          <div class="history-empty-meta">
            ${copy.historyEmptyMeta
              .map(
                ([title, text]) => `
                  <span>
                    <strong>${escapeHtml(title)}</strong>
                    <small>${escapeHtml(text)}</small>
                  </span>
                `,
              )
              .join("")}
          </div>
        </div>
      `;
      }

      async function loadHistory() {
        try {
          const res = await fetch("/api/diagnoses");
          const data = await res.json();
          if (!data.ok || !data.data.items.length) {
            renderHistoryEmpty();
            return;
          }
          if (historyList) {
            setHistoryHeaderCtaVisible(true);
            historyList.classList.remove("is-empty");
            historyList.classList.add("has-items");
            historyList.innerHTML = data.data.items
              .map((item) => {
                const diagnosis = item.diagnosis;
                const title = diagnosis?.skinTone?.summary || copy.reportTitle;
                const date = new Date(item.createdAt).toLocaleDateString(
                  document.documentElement.lang || "en",
                );
                const tags = diagnosis
                  ? [
                      labelFrom(
                        valueMaps.faceShape,
                        diagnosis.faceShape?.primary,
                        "",
                      ),
                      labelFrom(
                        valueMaps.eyeShape,
                        diagnosis.eyeShape?.primary,
                        "",
                      ),
                      labelFrom(
                        valueMaps.season,
                        diagnosis.colorSeason?.season,
                        "",
                      ),
                    ].filter(Boolean)
                  : [];
                const note =
                  diagnosis?.makeupDirections?.[0]?.title ||
                  diagnosis?.colorSeason?.season ||
                  "";
                const jobId = escapeHtml(item.jobId);
                return `
                  <article class="diag-history-item" data-job-id="${jobId}">
                    <div class="diag-history-marker" aria-hidden="true">AI</div>
                    <div class="diag-history-content">
                      <div class="diag-history-head">
                        <div>
                          <b>${escapeHtml(title)}</b>
                          ${note ? `<p>${escapeHtml(note)}</p>` : ""}
                        </div>
                        <time datetime="${escapeHtml(item.createdAt)}">${escapeHtml(date)}</time>
                      </div>
                      <div class="diag-history-tags">
                        ${tags.map((tag) => `<span class="pill">${escapeHtml(tag)}</span>`).join("")}
                      </div>
                    </div>
                    <div class="diag-history-actions">
                      <button class="btn btn-sm" type="button" data-history-action="view">${escapeHtml(copy.viewDetail)}</button>
                      <button class="btn btn-sm btn-outline-rose" type="button" data-history-action="delete">${escapeHtml(copy.delete)}</button>
                    </div>
                  </article>
                `;
              })
              .join("");
          }

          const latest = data.data.items[0];
          if (!wantsNewDiagnosis && latest?.diagnosis) {
            renderDiagnosis(latest.diagnosis, latest);
          }
        } catch {
          if (historyList) {
            setHistoryHeaderCtaVisible(false);
            historyList.classList.remove("has-items");
            historyList.classList.add("is-empty");
            historyList.innerHTML = `
            <div class="diag-history-empty compact" role="alert">
              <div class="history-empty-main">
                <span class="history-empty-mark" aria-hidden="true">!</span>
                <div>
                  <b>${escapeHtml(copy.historyFailed)}</b>
                  <p>${escapeHtml(copy.historyEmptyBody)}</p>
                </div>
              </div>
            </div>
          `;
          }
        }
      }

      // 全局：查看诊断
      window.viewDiagnosis = async function (jobId) {
        try {
          const res = await fetch("/api/diagnoses");
          const data = await res.json();
          if (!data.ok) return;
          const item = data.data.items.find((i) => i.jobId === jobId);
          if (item?.diagnosis) renderDiagnosis(item.diagnosis, item);
          window.scrollTo({ top: 0, behavior: "smooth" });
        } catch {
          /* ignore */
        }
      };

      // 全局：删除诊断
      window.deleteDiagnosis = async function (jobId) {
        const confirmed =
          typeof window.absConfirm === "function"
            ? await window.absConfirm(copy.confirmDelete, { variant: "danger" })
            : confirm(copy.confirmDelete);
        if (!confirmed) return;
        try {
          await fetch("/api/tryon-jobs/" + jobId, { method: "DELETE" });
          loadHistory();
        } catch {
          /* ignore */
        }
      };

      historyList?.addEventListener("click", (event) => {
        if (!(event.target instanceof Element)) return;
        const actionButton = event.target.closest("[data-history-action]");
        if (!actionButton || !historyList.contains(actionButton)) return;

        const historyItem = actionButton.closest(".diag-history-item");
        const jobId = historyItem?.getAttribute("data-job-id");
        if (!jobId) return;

        const action = actionButton.getAttribute("data-history-action");
        if (action === "view") window.viewDiagnosis(jobId);
        if (action === "delete") window.deleteDiagnosis(jobId);
      });

      // === 初始化 ===
      loadQuota().then((accountUser) => {
        if (accountUser) loadHistory();
        else renderHistoryEmpty();
      });
    })();
  </script>

