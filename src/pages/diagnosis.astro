          0 20px 46px rgba(0, 0, 0, 0.34);
        --diagnosis-outcome-card-wash:
          radial-gradient(
            circle at 18px 0,
            rgba(62, 201, 189, 0.24),
            transparent 38%
          ),
          linear-gradient(
            135deg,
            rgba(62, 201, 189, 0.11),
            transparent 46%,
            rgba(232, 122, 152, 0.08)
