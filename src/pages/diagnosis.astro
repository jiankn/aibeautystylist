<BaseLayout
  title={diagnosisCopy.metaTitle}
  description={diagnosisCopy.metaDescription}
  bodyClass="diagnosis-body"
>
  <SiteHeader active="diagnosis" mobileHidden />
  <MobileAppTopBar
    title={diagnosisCopy.kicker}
    backHref={tryOnFreeHref}
    rightAction="help"
  />
  <main class="diagnosis-main" data-diagnosis-main>
    <section class="diagnosis-hero shell" aria-labelledby="diagnosis-title">
      <div class="diagnosis-hero-copy">
        <span class="section-eyebrow">{diagnosisCopy.kicker}</span>
        <h1 id="diagnosis-title" aria-label={diagnosisCopy.title}>
