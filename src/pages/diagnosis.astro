  </main>
  <MobileBottomNav active="tryon" />

  <script
    is:inline
    define:vars={{
      diagnosisClientCopy,
      diagnosisProgressCopy,
      professionalReportCopy,
      discoverHref,
      loginHref,
      tryOnFreeHref,
    }}
  >
    (function () {
      const copy = diagnosisClientCopy;
      // === 配置 ===
      const POLL_INTERVAL = 2000;
      const POLL_MAX = 60;

      // === DOM 引用 ===
      const consentBox = document.querySelector("[data-diag-consent]");
      const diagnosisMain = document.querySelector("[data-diagnosis-main]");
      const uploadBtn = document.getElementById("diag-upload-btn");
      const taskStatus = document.getElementById("diag-task-status");
      const statusText = document.getElementById("diag-status-text");
      const percentText = document.getElementById("diag-percent");
      const progressBar = document.getElementById("diag-progress");
      const resultSection = document.getElementById("diagnosis-result");
      const newSection = document.getElementById("diagnosis-new");
      const cardsContainer = document.getElementById("diag-cards");
      const detailCardsContainer = document.getElementById("diag-detail-cards");
      const detailPanel = document.getElementById("diag-detail-panel");
      const keywordsContainer = document.getElementById("diag-keywords");
      const reportFacts = document.getElementById("diag-report-facts");
      const archetypeNode = document.getElementById("diag-archetype");
      const oneLineAdvice = document.getElementById("diag-one-line-advice");
      const coreStrategy = document.getElementById("diag-core-strategy");
      const colorPalette = document.getElementById("diag-color-palette");
      const routineSteps = document.getElementById("diag-routine-steps");
      const scenarioGrid = document.getElementById("diag-scenario-grid");
      const resultMeta = document.getElementById("diag-result-meta");
      const resultTitle = document.getElementById("diag-result-title");
      const resultSummary = document.getElementById("diag-result-summary");
      const resultChips = document.getElementById("diag-result-chips");
      const primaryLook = document.getElementById("diag-primary-look");
      const historyList = document.getElementById("diag-history-list");
      const historyHeaderCta = document.querySelector(
        "[data-diagnosis-history-cta]",
      );
      const quotaCard = document.querySelector("[data-diagnosis-quota]");
      const quotaText = document.querySelector("[data-diagnosis-quota-text]");
      const quotaNote = document.querySelector("[data-diagnosis-quota-note]");
      const recommendsContainer = document.getElementById("diag-recommends");
      const progressPlan = document.querySelector(
        "[data-diagnosis-progress-plan]",
      );
      const waitingQuestions = document.querySelector(
        "[data-diagnosis-waiting]",
      );
      const stageItems = Array.from(
        document.querySelectorAll("[data-diagnosis-stage]"),
      );
      const preferenceButtons = document.querySelectorAll(
        "[data-diagnosis-preference]",
      );
      const setTaskNavSuppressed = (suppressed) => {
        window.absSetMobileBottomNavSuppressed?.("diagnosis-task", suppressed);
      };
      const START_HASH = "#diagnosis-new";
      let isAccountUser = false;
      let wantsNewDiagnosis = location.hash === START_HASH;
      let quotaSnapshot = null;
      const preferenceStorageKey = "abs:diagnosis-waiting-preferences";

      function readWaitingPreferences() {
        try {
          return JSON.parse(localStorage.getItem(preferenceStorageKey) || "{}");
        } catch {
          return {};
        }
      }

      function writeWaitingPreferences(next) {
        try {
          localStorage.setItem(preferenceStorageKey, JSON.stringify(next));
        } catch {
          /* ignore private storage failures */
        }
      }

      function syncWaitingPreferences() {
        const stored = readWaitingPreferences();
        preferenceButtons.forEach((button) => {
          const key = button.dataset.diagnosisPreference;
          const selectedValue = stored[key];
          const active = selectedValue
            ? button.dataset.diagnosisPreferenceValue === selectedValue
            : button.classList.contains("active");
          button.classList.toggle("active", active);
          button.setAttribute("aria-pressed", String(active));
        });
      }

      preferenceButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const key = button.dataset.diagnosisPreference;
          if (!key) return;
          const stored = readWaitingPreferences();
          stored[key] = button.dataset.diagnosisPreferenceValue || "";
          writeWaitingPreferences(stored);
          syncWaitingPreferences();
        });
      });
      syncWaitingPreferences();

      function getTaskRoutes() {
        return window.__absBackgroundTasks?.routes || {};
      }

      function currentTaskHref() {
        return location.pathname + location.search + location.hash;
      }

      function syncDiagnosisBackgroundTask(job, overrides = {}) {
        if (!job?.id) return;
        const routes = getTaskRoutes();
        const stage =
          overrides.stage ||
          (job.status === "succeeded"
            ? copy.complete
            : diagnosisProgressCopy.progressTitle);
        window.__absBackgroundTasks?.upsert?.({
          id: job.id,
          type: "diagnosis",
          title: diagnosisProgressCopy.progressTitle,
          status: job.status || "running",
          progress: overrides.progress,
          stage,
          href: currentTaskHref(),
          resultHref: routes.diagnosis || location.pathname,
          ...overrides,
        });
      }

      function setDiagnosisExperienceVisible(visible) {
        if (progressPlan) progressPlan.hidden = !visible;
        if (waitingQuestions) waitingQuestions.hidden = !visible;
        setTaskNavSuppressed(visible);
      }

      function setDiagnosisStage(stageKey) {
        if (!stageItems.length) return;
        const stageOrder = ["quality", "intake", "features", "report"];
        const currentIndex = Math.max(0, stageOrder.indexOf(stageKey));
        stageItems.forEach((item) => {
          const itemIndex = stageOrder.indexOf(
            item.dataset.diagnosisStage || "",
          );
          item.dataset.state =
            itemIndex < currentIndex
              ? "complete"
              : itemIndex === currentIndex
                ? "current"
                : "upcoming";
        });
      }

      function scrollToDiagnosisStart() {
        if (!newSection) return;
        wantsNewDiagnosis = true;
        newSection.hidden = false;
        if (resultSection) resultSection.hidden = true;
        if (taskStatus) taskStatus.hidden = true;
        setDiagnosisExperienceVisible(false);
        newSection.scrollIntoView({ behavior: "smooth", block: "start" });
        window.history.replaceState(null, "", START_HASH);

        const focusTarget =
          uploadBtn && !uploadBtn.disabled
            ? uploadBtn
            : consentBox && !consentBox.disabled
              ? consentBox
              : newSection;
        requestAnimationFrame(() => {
          focusTarget?.focus?.({ preventScroll: true });
        });
      }

      document.addEventListener("click", (event) => {
        if (!(event.target instanceof Element)) return;
        const startLink = event.target.closest('a[href="#diagnosis-new"]');
        if (!startLink) return;
        event.preventDefault();
        scrollToDiagnosisStart();
      });

      if (location.hash === START_HASH) {
        requestAnimationFrame(scrollToDiagnosisStart);
      }

      function loginUrl() {
        return (
          loginHref +
          "?next=" +
          encodeURIComponent(
            location.pathname + location.search + location.hash,
          )
        );
      }

      function quotaRemainingValue() {
        if (!quotaSnapshot) return null;
        const remaining = Number(quotaSnapshot.remaining);
        return Number.isFinite(remaining) ? remaining : null;
      }

      function isQuotaExhausted() {
        const remaining = quotaRemainingValue();
        return isAccountUser && remaining !== null && remaining <= 0;
      }

      function renderQuota(q) {
        const remaining = Number(q?.remaining ?? 0);
        const total = Number(q?.total ?? 0);
        const safeRemaining = Number.isFinite(remaining)
          ? Math.max(0, remaining)
          : 0;
        const safeTotal = Number.isFinite(total) ? Math.max(0, total) : 0;
        const quotaLabel = safeRemaining + "/" + safeTotal;
        const exhausted = safeRemaining <= 0;
        if (quotaText) quotaText.textContent = quotaLabel;
        if (quotaNote) {
          quotaNote.textContent = exhausted
            ? copy.quotaExhaustedNote ||
              copy.quotaExhausted ||
              copy.quotaLoading
            : (copy.quotaRemainingPrefix || "") +
              quotaLabel +
              (copy.quotaRemainingSuffix || "");
        }
        quotaCard?.classList.toggle("is-exhausted", exhausted);
      }

      function syncUploadAvailability() {
        if (!uploadBtn) return;
        if (!isAccountUser) {
          uploadBtn.disabled = false;
          uploadBtn.textContent = copy.loginCta;
          return;
        }
        if (isQuotaExhausted()) {
          uploadBtn.disabled = true;
          uploadBtn.textContent =
            copy.quotaExhaustedCta || copy.quotaExhausted || copy.uploadCta;
          return;
        }
        uploadBtn.disabled = !consentBox?.checked;
        uploadBtn.textContent = copy.uploadCta;
      }

      function showQuotaExhaustedState() {
        if (taskStatus) taskStatus.hidden = true;
        quotaSnapshot = {
          ...(quotaSnapshot || { total: 0 }),
          remaining: 0,
        };
        renderQuota(quotaSnapshot);
        syncUploadAvailability();
      }

      function isQuotaError(err) {
        const value = String(
          [
            err?.code,
            err?.errorCode,
            err?.name,
            err?.message,
            typeof err === "string" ? err : "",
          ]
            .filter(Boolean)
            .join(" "),
        );
        return /QUOTA_EXHAUSTED|额度已用完|額度已用完|credits? (exhausted|used up)/i.test(
          value,
        );
      }

      // === 同意控制 ===
      if (consentBox && uploadBtn) {
        consentBox.addEventListener("change", () => {
          syncUploadAvailability();
        });
      }

      // === 上传 + 创建任务 ===
      let currentJobId = null;
      if (uploadBtn) {
        uploadBtn.addEventListener("click", async () => {
          if (!isAccountUser) {
            window.location.href = loginUrl();
            return;
          }
          if (isQuotaExhausted()) {
            showQuotaExhaustedState();
            return;
          }
          const input = document.createElement("input");
          input.type = "file";
          input.accept =
            "image/jpeg,image/png,image/webp,image/heic,image/heif";
          input.onchange = async () => {
            const file = input.files?.[0];
            if (!file) return;
            try {
              const createTryOnJob = window.__absCreateTryOnJob;
              if (typeof createTryOnJob !== "function") {
                throw new Error(copy.uploadFlowNotReady);
              }
              uploadBtn.disabled = true;
              taskStatus.hidden = false;
              setDiagnosisExperienceVisible(true);
              updateProgress(copy.uploading, 12, "quality", "1/4");
              updateProgress(copy.confirming, 22, "quality", "1/4");
              const result = await createTryOnJob({
                file,
                lookSlug: "commute",
                purpose: "diagnosis",
                idempotencyKey:
                  "diag-" +
                  Date.now() +
                  "-" +
                  Math.random().toString(36).slice(2),
              });
              updateProgress(copy.creating, 38, "intake", "2/4");
              currentJobId = result.job.id;
              syncDiagnosisBackgroundTask(result.job, {
                progress: 38,
                stage: copy.creating,
              });
              updateProgress(copy.analyzing, 52, "features", "3/4");

              // 3. 轮询
              pollJob(currentJobId);
            } catch (err) {
              if (isQuotaError(err)) {
                showQuotaExhaustedState();
                return;
              }
              const message =
                err instanceof Error ? err.message : String(err || "");
              updateProgress(message || copy.failed, 0, "quality");
              setDiagnosisExperienceVisible(false);
              syncUploadAvailability();
            }
          };
          input.click();
        });
      }

      function updateProgress(text, pct, stageKey, stepLabel) {
        if (statusText) statusText.textContent = text;
        if (percentText) percentText.textContent = stepLabel || pct + "%";
        if (progressBar) progressBar.style.width = pct + "%";
        if (stageKey) setDiagnosisStage(stageKey);
      }

      async function pollJob(jobId) {
        let attempt = 0;
        const interval = setInterval(async () => {
          attempt++;
          if (attempt > POLL_MAX) {
            clearInterval(interval);
            updateProgress(copy.timeout, 0, "report");
            if (currentJobId) {
              syncDiagnosisBackgroundTask(
                { id: currentJobId, status: "timed_out" },
                {
                  progress: 0,
                  stage: copy.timeout,
                },
              );
            }
            setDiagnosisExperienceVisible(false);
            syncUploadAvailability();
            return;
          }
          try {
            const res = await fetch("/api/tryon-jobs/" + jobId);
            const data = await res.json();
            if (!data.ok) return;
            const job = data.data;
            if (job.status === "diagnosis_running") {
              const progress = Math.min(76, 52 + attempt);
              updateProgress(copy.running, progress, "features", "3/4");
              syncDiagnosisBackgroundTask(job, {
                progress,
                stage: copy.running,
              });
            } else if (job.status === "image_running") {
              const progress = Math.min(94, 78 + attempt);
              updateProgress(copy.generating, progress, "report", "4/4");
              syncDiagnosisBackgroundTask(job, {
                progress,
                stage: copy.generating,
              });
            } else if (job.status === "succeeded") {
              clearInterval(interval);
              updateProgress(copy.complete, 100, "report", "4/4");
              syncDiagnosisBackgroundTask(job, {
                status: "succeeded",
                progress: 100,
                stage: copy.complete,
              });
              setDiagnosisExperienceVisible(false);
              window.showToast?.(copy.complete);
              // 加载诊断结果
              loadDiagnosisResult(jobId);
            } else if (job.status === "failed" || job.status === "timed_out") {
              clearInterval(interval);
              const message = job.errorCode
                ? copy.failed + "：" + job.errorCode
                : copy.failed;
              updateProgress(message, 0, "report");
              syncDiagnosisBackgroundTask(job, {
                status: job.status,
                progress: 0,
                stage: message,
              });
              setDiagnosisExperienceVisible(false);
              syncUploadAvailability();
            }
          } catch {
            /* ignore */
          }
        }, POLL_INTERVAL);
      }

      // === 加载诊断结果 ===
      async function loadDiagnosisResult(jobId) {
        try {
          const res = await fetch("/api/diagnoses");
          const data = await res.json();
          if (!data.ok) return false;
          const item = data.data.items.find((i) => i.jobId === jobId);
          if (item?.diagnosis) {
            renderDiagnosis(item.diagnosis, item);
          }
        } catch {
          /* ignore */
        }
      }

      const resultLabels = copy.resultLabels || {};
      const valueMaps = resultLabels.valueMaps || {};
      const keywordIcons = resultLabels.keywordIcons || {};
      const reportCopy = professionalReportCopy || {};

      function labelFrom(map, key, fallback) {
        return (key && map?.[key]) || fallback || key || "";
      }

      function joinEvidence(items) {
        return Array.isArray(items)
          ? items.join(resultLabels.paletteJoiner || ", ")
          : "";
      }

      function titleWithValue(label, value) {
        return value ? label + ": " + value : label;
      }

      function paletteSuffix(palette) {
        if (!Array.isArray(palette) || palette.length === 0) return "";
        return (
          (resultLabels.paletteOpen || " (") +
          (resultLabels.palettePrefix || "Palette: ") +
          palette.join(resultLabels.paletteJoiner || ", ") +
          (resultLabels.paletteClose || ")")
        );
      }

      function buildFacts(rows) {
        return `<dl>${rows
          .filter(([label, value]) => label || value)
          .map(
            ([label, value]) =>
              `<div><dt>${escapeHtml(label)}</dt><dd>${escapeHtml(value)}</dd></div>`,
          )
          .join("")}</dl>`;
      }

      function qualityLabel(d) {
        const level = d?.photoQuality?.level;
        if (level === "good") return reportCopy.qualityGood || "Good";
        if (level === "usable") return reportCopy.qualityUsable || "Usable";
        if (level === "limited") return reportCopy.qualityLimited || "Limited";
        const overall = Number(d?.confidence?.overall || 0);
        if (overall >= 0.82) return reportCopy.qualityGood || "Good";
        if (overall >= 0.62) return reportCopy.qualityUsable || "Usable";
        return reportCopy.qualityLimited || "Limited";
      }

      function stabilityLabel(confidence) {
        const band = confidence?.band;
        if (band === "high") return reportCopy.stabilityHigh || "High";
        if (band === "medium") return reportCopy.stabilityMedium || "Medium";
        return reportCopy.stabilityLow || "Needs confirmation";
      }

      function extractPalette(d) {
        const seen = new Set();
        const palette = [];
        (d.colorPalette?.recommended || []).forEach((color) => {
          const normalized = String(color?.name || "").trim();
          const key = normalized.toLowerCase();
          if (normalized && !seen.has(key)) {
            seen.add(key);
            palette.push(normalized);
          }
        });
        (d.makeupDirections || []).forEach((direction) => {
          (direction.palette || []).forEach((color) => {
            const normalized = String(color || "").trim();
            const key = normalized.toLowerCase();
            if (normalized && !seen.has(key)) {
              seen.add(key);
              palette.push(normalized);
            }
          });
        });
        return palette;
      }

      function inferArchetype(d, primaryDirection, seasonLabel) {
        if (d.reportSummary?.archetype) return d.reportSummary.archetype;
        if (primaryDirection?.title && seasonLabel) {
          return `${primaryDirection.title} · ${seasonLabel}`;
        }
        return (
          primaryDirection?.title ||
          seasonLabel ||
          reportCopy.fallbacks?.archetype
        );
      }

      function inferCoreStrategy(d, skinLabel, faceLabel, eyeLabel) {
        if (d.reportSummary?.primaryStrategy) {
          return d.reportSummary.primaryStrategy;
        }
        const parts = [];
        if (d.skinTone?.summary) parts.push(d.skinTone.summary);
        if (d.colorSeason?.rationale) parts.push(d.colorSeason.rationale);
        if (d.strengths?.[0]) parts.push(d.strengths[0]);
        if (parts.length) return parts.slice(0, 3).join(" ");
        const context = [skinLabel, faceLabel, eyeLabel]
          .filter(Boolean)
          .join(" / ");
        return context
          ? `${context}。${reportCopy.fallbacks?.strategy || ""}`
          : reportCopy.fallbacks?.strategy || "";
      }

      function buildRoutine(d, labels) {
        const paletteText = labels.palette.length
          ? labels.palette.slice(0, 4).join(resultLabels.paletteJoiner || ", ")
          : labels.seasonLabel;
        const plan = d.makeupPlan || {};
        const base =
          joinPlan(plan.base) ||
          [d.skinTone?.summary, reportCopy.fallbacks?.base]
            .filter(Boolean)
            .join(" ");
        const brows =
          joinPlan(plan.brows) ||
          [joinEvidence(d.faceShape?.evidence), reportCopy.fallbacks?.brows]
            .filter(Boolean)
            .join(" ");
        const eyes =
          joinPlan(plan.eyes) ||
          [joinEvidence(d.eyeShape?.evidence), reportCopy.fallbacks?.eyes]
            .filter(Boolean)
            .join(" ");
        const cheeks =
          joinPlan(plan.cheeks) ||
          (paletteText
            ? `${paletteText}。${reportCopy.fallbacks?.cheeks || ""}`
            : reportCopy.fallbacks?.cheeks);
        const lips =
          joinPlan(plan.lips) ||
          (paletteText
            ? `${paletteText}。${reportCopy.fallbacks?.lips || ""}`
            : reportCopy.fallbacks?.lips);
        const contour =
          joinPlan(plan.contourHighlight) ||
          [labels.faceLabel, reportCopy.fallbacks?.contour]
            .filter(Boolean)
            .join("。 ");
        return [
          { key: "base", title: reportCopy.rows?.base, body: base },
          { key: "brows", title: reportCopy.rows?.brows, body: brows },
          { key: "eyes", title: reportCopy.rows?.eyes, body: eyes },
          { key: "cheeks", title: reportCopy.rows?.cheeks, body: cheeks },
          { key: "lips", title: reportCopy.rows?.lips, body: lips },
          { key: "contour", title: reportCopy.rows?.contour, body: contour },
        ].filter((item) => item.title && item.body);
      }

      function joinPlan(items) {
        return Array.isArray(items) ? items.filter(Boolean).join(" ") : "";
      }

      function buildScenarioMatrix(d, palette) {
        if (
          Array.isArray(d.scenarioStrategies) &&
          d.scenarioStrategies.length
        ) {
          return d.scenarioStrategies.map((item) => ({
            title: reportCopy.rows?.[item.scenario] || item.scenario,
            look: item.lookName,
            technique: joinEvidence(item.keyTechniques),
            avoid: joinEvidence(item.avoid),
            validation: item.validation,
          }));
        }
        const paletteHint = palette.length
          ? palette.slice(0, 3).join(resultLabels.paletteJoiner || ", ")
          : "";
        return (reportCopy.scenarios || []).map(
          ([key, look, technique, avoid, validation]) => ({
            title: reportCopy.rows?.[key] || key,
            look,
            technique: paletteHint ? `${technique}：${paletteHint}` : technique,
            avoid,
            validation,
          }),
        );
      }

      function renderDiagnosis(d, record) {
        if (!resultSection || !cardsContainer || !keywordsContainer) return;
        wantsNewDiagnosis = false;
        diagnosisMain?.classList.add("has-account-result");
        newSection.hidden = true;
        resultSection.hidden = false;

        const skinDepthLabel = labelFrom(
          valueMaps.skinDepth,
          d.skinTone?.depth,
          d.skinTone?.depth,
        );
        const skinLabel = labelFrom(
          valueMaps.undertone,
          d.skinTone?.undertone,
          resultLabels.defaultSkinTone,
        );
        const faceLabel = labelFrom(
          valueMaps.faceShape,
          d.faceShape?.primary,
          resultLabels.defaultFaceShape,
        );
        const eyeLabel = labelFrom(
          valueMaps.eyeShape,
          d.eyeShape?.primary,
          resultLabels.defaultEyeShape,
        );
        const seasonLabel =
          (d.colorSeason &&
            labelFrom(
              valueMaps.season,
              d.colorSeason.season,
              d.colorSeason.season,
            )) ||
          resultLabels.colorDirection;
        const primaryDirection = d.makeupDirections?.[0];
        const palette = extractPalette(d);
        const archetype = inferArchetype(d, primaryDirection, seasonLabel);
        const strategy = inferCoreStrategy(d, skinLabel, faceLabel, eyeLabel);
        const oneLine =
          d.reportSummary?.oneLineAdvice ||
          primaryDirection?.rationale ||
          d.skinTone?.summary ||
          d.colorSeason?.rationale ||
          reportCopy.fallbacks?.oneLine ||
          "";
        const resultHeading =
          archetype || primaryDirection?.title || copy.reportTitle;
        const summaryText = strategy || oneLine || copy.reportTitle;
        const createdAt = record?.createdAt ? new Date(record.createdAt) : null;
        const dateLabel = createdAt
          ? createdAt.toLocaleDateString(
              document.documentElement.lang || "zh-CN",
              {
                year: "numeric",
                month: "2-digit",
                day: "2-digit",
              },
            )
          : "";
        const shortDateLabel = createdAt
          ? createdAt.toLocaleDateString(
              document.documentElement.lang || "zh-CN",
              {
                month: "2-digit",
                day: "2-digit",
              },
            )
          : "";
        const reportId = record?.id || record?.jobId || "—";
        const reportIdShort = String(reportId).slice(0, 8).toUpperCase();
        const quality = qualityLabel(d);
        const stability = stabilityLabel(d.confidence);

        if (resultMeta) {
          resultMeta.textContent = shortDateLabel
            ? (reportCopy.latestReport ||
                resultLabels.latestDiagnosis ||
                copy.reportTitle) +
              " · " +
              shortDateLabel
            : reportCopy.latestReport ||
              resultLabels.latestDiagnosis ||
              copy.reportTitle;
        }
        if (resultTitle) resultTitle.textContent = resultHeading;
        if (resultSummary) resultSummary.textContent = summaryText;
        if (archetypeNode) archetypeNode.textContent = resultHeading;
        if (oneLineAdvice) oneLineAdvice.textContent = oneLine;
        if (coreStrategy) coreStrategy.textContent = strategy;
        if (primaryLook) {
          primaryLook.href = discoverHref;
          primaryLook.textContent =
            reportCopy.actionLook || copy.recommendMore || copy.tryLook;
        }

        if (reportFacts) {
          reportFacts.innerHTML = buildFacts([
            [reportCopy.reportNo, reportIdShort],
            [reportCopy.generatedAt, dateLabel || "—"],
            [reportCopy.photoQuality, quality],
            [reportCopy.stability, stability],
            [reportCopy.version, d.schemaVersion || "2026"],
          ]);
        }

        const resultChipRows = [
          [resultLabels.skinTone, `${skinDepthLabel} / ${skinLabel}`],
          [resultLabels.facialFocus, `${faceLabel} / ${eyeLabel}`],
          [resultLabels.colorDirection, seasonLabel],
          [reportCopy.photoQuality, quality],
        ];
        if (quotaSnapshot) {
          resultChipRows.push([
            resultLabels.monthlyQuota,
            `${quotaSnapshot.remaining}/${quotaSnapshot.total}`,
          ]);
        }
        if (resultChips) {
          resultChips.innerHTML = resultChipRows
            .map(
              ([label, value]) =>
                `<span><small>${escapeHtml(label)}</small><b>${escapeHtml(value)}</b></span>`,
            )
            .join("");
        }

        const kw = [
          {
            key: "skin",
            icon: keywordIcons.skin || "S",
            title: `${skinDepthLabel} / ${skinLabel}`,
            desc: d.skinTone?.summary || "",
          },
          {
            key: "face",
            icon: keywordIcons.face || "F",
            title: faceLabel,
            desc: joinEvidence(d.faceShape?.evidence),
          },
          {
            key: "eye",
            icon: keywordIcons.eye || "E",
            title: eyeLabel,
            desc: joinEvidence(d.eyeShape?.evidence),
          },
          {
            key: "color",
            icon: keywordIcons.color || "C",
            title: seasonLabel,
            desc: d.colorSeason?.rationale || "",
          },
        ];
        keywordsContainer.innerHTML = kw
          .map(
            (k) => `
      <div class="keyword"><i data-icon="${escapeHtml(k.key)}">${escapeHtml(k.icon)}</i><div><b>${escapeHtml(k.title)}</b><span>${escapeHtml(k.desc)}</span></div></div>
    `,
          )
          .join("");

        if (colorPalette) {
          colorPalette.innerHTML = (
            palette.length ? palette : [seasonLabel, skinLabel]
          )
            .slice(0, 8)
            .map(
              (color, index) =>
                `<span class="palette-chip" data-tone="${index % 6}"><i aria-hidden="true"></i>${escapeHtml(color)}</span>`,
            )
            .join("");
        }

        const routine = buildRoutine(d, {
          skinLabel,
          skinDepthLabel,
          faceLabel,
          eyeLabel,
          seasonLabel,
          palette,
        });
        if (routineSteps) {
          routineSteps.innerHTML = routine
            .map(
              (item, index) => `
                <article class="routine-step">
                  <span>${String(index + 1).padStart(2, "0")}</span>
                  <div>
                    <h3>${escapeHtml(item.title)}</h3>
                    <p>${escapeHtml(item.body)}</p>
                  </div>
                </article>
              `,
            )
            .join("");
        }
        if (scenarioGrid) {
          scenarioGrid.innerHTML = buildScenarioMatrix(d, palette)
            .map(
              (item) => `
                <article class="scenario-card">
                  <strong>${escapeHtml(item.title)}</strong>
                  <b>${escapeHtml(item.look)}</b>
                  <dl>
                    <div><dt>${escapeHtml(reportCopy.rows?.technique)}</dt><dd>${escapeHtml(item.technique)}</dd></div>
                    <div><dt>${escapeHtml(reportCopy.rows?.avoid)}</dt><dd>${escapeHtml(item.avoid)}</dd></div>
                    <div><dt>${escapeHtml(reportCopy.rows?.validation)}</dt><dd>${escapeHtml(item.validation)}</dd></div>
                  </dl>
                </article>
              `,
            )
            .join("");
        }

        const insightCards = [];
        insightCards.push(
          buildCard(
            reportCopy.sections?.skin || resultLabels.sections?.skinAndColor,
            [
              {
                key: "depth",
                icon: keywordIcons.depth || "D",
                title: resultLabels.rows?.skinDepth,
                desc: skinDepthLabel,
              },
              {
                key: "tone",
                icon: keywordIcons.tone || "T",
                title: resultLabels.rows?.undertone,
                desc: [skinLabel, d.skinTone?.summary]
                  .filter(Boolean)
                  .join(" - "),
              },
              {
                key: "makeup",
                icon: keywordIcons.makeup || "M",
                title: reportCopy.rows?.base,
                desc: routine.find((item) => item.key === "base")?.body,
              },
            ],
          ),
        );
        insightCards.push(
          buildCard(
            reportCopy.sections?.color || resultLabels.sections?.skinAndColor,
            [
              {
                key: "season",
                icon: keywordIcons.season || "C",
                title: resultLabels.rows?.colorSeason,
                desc: [seasonLabel, d.colorSeason?.rationale]
                  .filter(Boolean)
                  .join(": "),
              },
              {
                key: "color",
                icon: keywordIcons.color || "C",
                title: reportCopy.paletteTitle,
                desc: palette.length
                  ? palette.join(resultLabels.paletteJoiner || ", ")
                  : oneLine,
              },
              {
                key: "caution",
                icon: keywordIcons.caution || "!",
                title: resultLabels.sections?.cautions,
                desc: (d.cautions || [])[0] || reportCopy.fallbacks?.oneLine,
              },
            ],
          ),
        );
        insightCards.push(
          buildCard(
            reportCopy.sections?.structure ||
              resultLabels.sections?.whyRecommended,
            [
              {
                key: "face",
                icon: keywordIcons.face || "F",
                title: titleWithValue(resultLabels.rows?.faceShape, faceLabel),
                desc: joinEvidence(d.faceShape?.evidence),
              },
              ...(d.strengths || []).slice(0, 3).map((s) => ({
                key: "strength",
                icon: keywordIcons.strength || "+",
                title: resultLabels.rows?.strengthenPoint,
                desc: s,
              })),
              {
                key: "makeup",
                icon: keywordIcons.makeup || "M",
                title: reportCopy.rows?.contour,
                desc: routine.find((item) => item.key === "contour")?.body,
              },
            ],
          ),
        );
        insightCards.push(
          buildCard(
            reportCopy.sections?.eyes || resultLabels.sections?.whyRecommended,
            [
              {
                key: "eye",
                icon: keywordIcons.eye || "E",
                title: titleWithValue(resultLabels.rows?.eyeShape, eyeLabel),
                desc: joinEvidence(d.eyeShape?.evidence),
              },
              {
                key: "makeup",
                icon: keywordIcons.makeup || "M",
                title: reportCopy.rows?.eyes,
                desc: routine.find((item) => item.key === "eyes")?.body,
              },
            ],
          ),
        );
        if (d.makeupDirections?.length) {
          insightCards.push(
            buildCard(
              reportCopy.sections?.directions ||
                resultLabels.sections?.makeupDirections,
              d.makeupDirections.map((dir) => ({
                key: "makeup",
                icon: keywordIcons.makeup || "M",
                title: dir.title,
                desc: (dir.rationale || "") + paletteSuffix(dir.palette),
              })),
            ),
          );
        }
        cardsContainer.innerHTML = insightCards.join("");

        const detailCards = [];
        const conf = d.confidence;
        if (conf) {
          detailCards.push(
            buildCard(resultLabels.sections?.analysisConfidence, [
              {
                key: "percent",
                icon: keywordIcons.percent || "%",
                title: stability,
                desc:
                  resultLabels.rows?.overallConfidence +
                  " " +
                  Math.round((conf.overall || 0) * 100) +
                  "%",
              },
              ...(d.photoQuality?.notes || []).map((note) => ({
                key: "limit",
                icon: keywordIcons.limit || "L",
                title: reportCopy.photoQuality,
                desc: note,
              })),
              ...(conf.limitations || []).map((l) => ({
                key: "limit",
                icon: keywordIcons.limit || "L",
                title: resultLabels.rows?.limitation,
                desc: l,
              })),
            ]),
          );
        }
        const cautionRows = [
          ...(d.cautions || []).map((c) => ({
            key: "caution",
            icon: keywordIcons.caution || "!",
            title: resultLabels.rows?.suggestion,
            desc: c,
          })),
          ...(d.colorPalette?.avoid || []).map((c) => ({
            key: "caution",
            icon: keywordIcons.caution || "!",
            title: reportCopy.rows?.avoid || resultLabels.rows?.suggestion,
            desc: c,
          })),
        ];
        if (cautionRows.length) {
          detailCards.push(
            buildCard(resultLabels.sections?.cautions, cautionRows),
          );
        }
        if (detailCardsContainer)
          detailCardsContainer.innerHTML = detailCards.join("");
        if (detailPanel) detailPanel.hidden = detailCards.length === 0;

        if (d.makeupDirections?.length && recommendsContainer) {
          try {
            fetch("/api/looks")
              .then((r) => r.json())
              .then((looksData) => {
                if (!looksData.ok) return;
                const allLooks = looksData.data?.looks || [];
                const matched = matchRecommends(
                  d.makeupDirections,
                  allLooks,
                  d.recommendationReasoning,
                );
                if (matched.length > 0) {
                  const primary = matched[0];
                  if (primaryLook && primary) {
                    primaryLook.href = `${tryOnFreeHref}?look=${encodeURIComponent(primary.slug)}`;
                    primaryLook.textContent = copy.tryLook;
                  }
                  recommendsContainer.innerHTML = matched
                    .slice(0, 4)
                    .map(
                      (m) => `
              <article class="recommend report-recommend">
                <img src="${escapeHtml(m.image)}" alt="${escapeHtml(m.title)}" />
                <div>
                  <h3>${escapeHtml(m.title)} <span class="pill pill-rose">${escapeHtml(resultLabels.recommendationScore)} ${escapeHtml(m.score)}%</span></h3>
                  <p><b>${escapeHtml(reportCopy.matchedReason)}：</b>${escapeHtml(m.reason)}</p>
                  <p class="recommend-watch"><b>${escapeHtml(reportCopy.watchTitle)}：</b>${escapeHtml(m.watch)}</p>
                  <a class="btn btn-primary" href="${escapeHtml(tryOnFreeHref)}?look=${encodeURIComponent(m.slug)}">${escapeHtml(copy.tryLook)}</a>
                </div>
              </article>
            `,
                    )
                    .join("");
                }
              });
          } catch {
            /* ignore */
          }
        }
      }

      function buildCard(title, rows) {
        const safeRows = Array.isArray(rows) ? rows : [];
        return `<article class="analysis-card report-section-card"><h2>${escapeHtml(title || copy.reportTitle)}</h2>${safeRows
          .filter((r) => r?.title || r?.desc)
          .map(
            (r) =>
              `<div class="analysis-row"><i data-icon="${escapeHtml(r.key || "")}">${escapeHtml(r.icon || "")}</i><div><b>${escapeHtml(r.title || "")}</b><span>${escapeHtml(r.desc || "")}</span></div></div>`,
          )
          .join("")}</article>`;
      }

      function matchRecommends(directions, allLooks, reasoning = []) {
        // 简单关键词匹配：用 direction.title 和 palette 作为搜索词
        const keywords = directions
          .flatMap((d) => [
            String(d.title || "").toLowerCase(),
            ...(d.palette || []).map((p) => String(p || "").toLowerCase()),
          ])
          .filter(Boolean);
        return allLooks
          .map((look) => {
            const haystack = [
              look.title,
              look.intent,
              ...(look.scenarios || []),
              ...(look.finish || []),
            ]
              .join(" ")
              .toLowerCase();
            const hits = keywords.filter((kw) => haystack.includes(kw)).length;
            const firstDirection = directions[0] || {};
            const matchedReasoning =
              reasoning.find(
                (item) =>
                  item?.directionTitle &&
                  item.directionTitle === firstDirection.title,
              ) || reasoning[0];
            const palette = (firstDirection.palette || []).join(
              resultLabels.paletteJoiner || ", ",
            );
            return {
              ...look,
              score: Math.min(95, 70 + hits * 8),
              reason:
                joinEvidence(matchedReasoning?.matchedFactors) ||
                firstDirection.rationale ||
                (palette
                  ? `${resultLabels.palettePrefix || "Palette: "}${palette}`
                  : reportCopy.fallbacks?.oneLine || ""),
              watch:
                joinEvidence(matchedReasoning?.watchOut) ||
                reportCopy.fallbacks?.oneLine ||
                firstDirection.rationale ||
                copy.reportTitle,
            };
          })
          .filter((l) => l.score > 70)
          .sort((a, b) => b.score - a.score);
      }

      // === 加载额度 ===
      async function loadQuota() {
        try {
          const res = await fetch("/api/session");
          const data = await res.json();
          if (!data.ok) return false;
          isAccountUser = data.data.user?.kind === "account";
          if (!isAccountUser) {
            quotaSnapshot = null;
            quotaCard?.classList.remove("is-exhausted");
            if (quotaText) quotaText.textContent = copy.quotaGuest;
            if (quotaNote) quotaNote.textContent = copy.quotaGuestNote;
            if (consentBox) {
              consentBox.checked = false;
              consentBox.disabled = true;
            }
            syncUploadAvailability();
            return false;
          }
          if (consentBox) consentBox.disabled = false;
          const q = data.data.quota;
          quotaSnapshot = q;
          renderQuota(q);
          if (isQuotaExhausted() && taskStatus) taskStatus.hidden = true;
          syncUploadAvailability();
          return true;
        } catch {
          return false;
        }
      }

      function escapeHtml(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      function setHistoryHeaderCtaVisible(isVisible) {
        if (historyHeaderCta instanceof HTMLElement) {
          historyHeaderCta.hidden = !isVisible;
        }
      }

      function renderHistoryEmpty() {
        if (!historyList) return;
        setHistoryHeaderCtaVisible(false);
        diagnosisMain?.classList.remove("has-account-result");
        historyList.classList.remove("has-items");
        historyList.classList.add("is-empty");
        historyList.innerHTML = `
        <div class="diag-history-empty">
          <div class="history-empty-main">
            <span class="history-empty-mark" aria-hidden="true">AI</span>
            <div>
              <b>${escapeHtml(copy.historyEmptyTitle)}</b>
              <p>${escapeHtml(copy.historyEmptyBody)}</p>
            </div>
          </div>
          <div class="history-empty-actions">
            <a class="btn btn-primary" href="#diagnosis-new">${escapeHtml(copy.historyEmptyCta)}</a>
            <a class="btn" href="${escapeHtml(discoverHref)}">${escapeHtml(copy.historyEmptySecondary)}</a>
          </div>
          <div class="history-empty-meta">
            ${copy.historyEmptyMeta
              .map(
                ([title, text]) => `
                  <span>
                    <strong>${escapeHtml(title)}</strong>
                    <small>${escapeHtml(text)}</small>
                  </span>
                `,
              )
              .join("")}
          </div>
        </div>
      `;
      }

      async function loadHistory() {
        try {
          const res = await fetch("/api/diagnoses");
          const data = await res.json();
          if (!data.ok || !data.data.items.length) {
            renderHistoryEmpty();
            return;
          }
          if (historyList) {
            setHistoryHeaderCtaVisible(true);
            historyList.classList.remove("is-empty");
            historyList.classList.add("has-items");
            historyList.innerHTML = data.data.items
              .map((item) => {
                const diagnosis = item.diagnosis;
                const title = diagnosis?.skinTone?.summary || copy.reportTitle;
                const date = new Date(item.createdAt).toLocaleDateString(
                  document.documentElement.lang || "en",
                );
                const tags = diagnosis
                  ? [
                      labelFrom(
                        valueMaps.faceShape,
                        diagnosis.faceShape?.primary,
                        "",
                      ),
                      labelFrom(
                        valueMaps.eyeShape,
                        diagnosis.eyeShape?.primary,
                        "",
                      ),
                      labelFrom(
                        valueMaps.season,
                        diagnosis.colorSeason?.season,
                        "",
                      ),
                    ].filter(Boolean)
                  : [];
                const note =
                  diagnosis?.makeupDirections?.[0]?.title ||
                  diagnosis?.colorSeason?.season ||
                  "";
                const jobId = escapeHtml(item.jobId);
                return `
                  <article class="diag-history-item" data-job-id="${jobId}">
                    <div class="diag-history-marker" aria-hidden="true">AI</div>
                    <div class="diag-history-content">
                      <div class="diag-history-head">
                        <div>
                          <b>${escapeHtml(title)}</b>
                          ${note ? `<p>${escapeHtml(note)}</p>` : ""}
                        </div>
                        <time datetime="${escapeHtml(item.createdAt)}">${escapeHtml(date)}</time>
                      </div>
                      <div class="diag-history-tags">
                        ${tags.map((tag) => `<span class="pill">${escapeHtml(tag)}</span>`).join("")}
                      </div>
                    </div>
                    <div class="diag-history-actions">
                      <button class="btn btn-sm" type="button" data-history-action="view">${escapeHtml(copy.viewDetail)}</button>
                      <button class="btn btn-sm btn-outline-rose" type="button" data-history-action="delete">${escapeHtml(copy.delete)}</button>
                    </div>
                  </article>
                `;
              })
              .join("");
          }

          const latest = data.data.items[0];
          if (!wantsNewDiagnosis && latest?.diagnosis) {
            renderDiagnosis(latest.diagnosis, latest);
          }
        } catch {
          if (historyList) {
            setHistoryHeaderCtaVisible(false);
            historyList.classList.remove("has-items");
            historyList.classList.add("is-empty");
            historyList.innerHTML = `
            <div class="diag-history-empty compact" role="alert">
              <div class="history-empty-main">
                <span class="history-empty-mark" aria-hidden="true">!</span>
                <div>
                  <b>${escapeHtml(copy.historyFailed)}</b>
                  <p>${escapeHtml(copy.historyEmptyBody)}</p>
                </div>
              </div>
            </div>
          `;
          }
        }
      }

      // 全局：查看诊断
      window.viewDiagnosis = async function (jobId) {
        try {
          const res = await fetch("/api/diagnoses");
          const data = await res.json();
          if (!data.ok) return;
          const item = data.data.items.find((i) => i.jobId === jobId);
          if (item?.diagnosis) renderDiagnosis(item.diagnosis, item);
          window.scrollTo({ top: 0, behavior: "smooth" });
        } catch {
          /* ignore */
        }
      };

      // 全局：删除诊断
      window.deleteDiagnosis = async function (jobId) {
        const confirmed =
          typeof window.absConfirm === "function"
            ? await window.absConfirm(copy.confirmDelete, { variant: "danger" })
            : confirm(copy.confirmDelete);
        if (!confirmed) return;
        try {
          await fetch("/api/tryon-jobs/" + jobId, { method: "DELETE" });
          loadHistory();
        } catch {
          /* ignore */
        }
      };

      historyList?.addEventListener("click", (event) => {
        if (!(event.target instanceof Element)) return;
        const actionButton = event.target.closest("[data-history-action]");
        if (!actionButton || !historyList.contains(actionButton)) return;

        const historyItem = actionButton.closest(".diag-history-item");
        const jobId = historyItem?.getAttribute("data-job-id");
        if (!jobId) return;

        const action = actionButton.getAttribute("data-history-action");
        if (action === "view") window.viewDiagnosis(jobId);
        if (action === "delete") window.deleteDiagnosis(jobId);
      });

      // === 初始化 ===
      loadQuota().then((accountUser) => {
        if (accountUser) loadHistory();
        else renderHistoryEmpty();
      });
    })();
  </script>

