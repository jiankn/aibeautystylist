      isolation: isolate;
      padding: 18px;
      border: 1px solid var(--diagnosis-outcome-card-border);
      border-radius: 12px;
      background: var(--diagnosis-outcome-card-bg);
      box-shadow: var(--diagnosis-outcome-card-shadow);
