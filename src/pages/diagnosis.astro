      gap: 8px;
      min-width: 0;
      margin: 0;
      padding: 0;
      border: 0;
    }
    .diagnosis-waiting-group legend {
      color: var(--heading);
      font-size: 12px;
      font-weight: 850;
    }
    .diagnosis-waiting-group div {
      display: flex;
      flex-wrap: wrap;
      gap: 7px;
    }
    .diagnosis-waiting-group .btn {
      min-height: 36px;
      padding: 7px 11px;
      border-radius: 999px;
      font-size: 11px;
    }
    .diagnosis-waiting-group .btn.active {
      border-color: var(--rose-border);
      background: var(--rose);
      color: #fff;
    }
    .diagnosis-main.has-account-result .diagnosis-hero,
    .diagnosis-main.has-account-result .diagnosis-outcomes,
    .diagnosis-main.has-account-result .diagnosis-banner {
      display: none;
    }
    .diagnosis-main.has-account-result .diagnosis-workspace {
      margin-top: 0;
    }
    .diagnosis-result-shell {
      display: grid;
      gap: 16px;
      margin-top: 24px;
    }
    .diagnosis-result-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(240px, 0.34fr);
      gap: 18px;
      align-items: start;
      padding: 28px;
      background:
        radial-gradient(
          circle at 14% 0,
          color-mix(in srgb, var(--rose) 10%, transparent),
          transparent 36%
        ),
        var(--bg-elevated);
    }
    .diagnosis-result-copy {
      display: grid;
      gap: 12px;
      min-width: 0;
    }
    .diagnosis-report-type {
      margin: -2px 0 0;
      color: var(--report-muted);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .diagnosis-result-copy h2 {
      margin: 0;
      max-width: 820px;
      color: var(--report-ink);
      font-family: var(--font-display);
      font-size: clamp(32px, 3.4vw, 48px);
      line-height: 1.08;
    }
    .diagnosis-result-copy p {
      margin: 0;
      max-width: 760px;
      color: var(--report-body);
      font-size: 15px;
      line-height: 1.7;
    }
    .diagnosis-result-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .diagnosis-result-chips span {
      display: grid;
      min-width: 116px;
      gap: 3px;
      padding: 10px 12px;
      border: 1px solid var(--report-card-border);
      border-radius: 12px;
      background: var(--report-card-bg);
    }
    .diagnosis-result-chips small {
      color: var(--report-muted);
      font-size: 11px;
    }
    .diagnosis-result-chips b {
      color: var(--report-ink);
      font-size: 13px;
    }
    .diagnosis-report-facts {
      min-width: 0;
      padding: 14px;
      border: 1px solid var(--report-card-border);
      border-radius: 18px;
      background: var(--report-card-bg);
    }
    .diagnosis-report-facts dl {
      display: grid;
      gap: 10px;
      margin: 0;
    }
    .diagnosis-report-facts div {
      display: grid;
      grid-template-columns: minmax(0, 0.8fr) minmax(0, 1fr);
      gap: 10px;
      align-items: baseline;
      padding-bottom: 9px;
      border-bottom: 1px solid var(--report-card-border);
    }
    .diagnosis-report-facts div:last-child {
      padding-bottom: 4px;
      border-bottom: 0;
    }
    .diagnosis-report-facts dt {
      color: var(--report-muted);
      font-size: 12px;
      font-weight: 750;
      line-height: 1.35;
    }
    .diagnosis-report-facts dd {
      margin: 0;
      color: var(--report-ink);
      font-size: 13px;
      font-weight: 800;
      line-height: 1.35;
      text-align: right;
      overflow-wrap: anywhere;
    }
    .diagnosis-result-actions {
      display: flex;
      grid-column: 1 / -1;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: flex-start;
      padding-top: 2px;
    }
    .diagnosis-section-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 16px;
      align-items: end;
      margin-bottom: 16px;
    }
    .diagnosis-section-head .panel-title {
      margin-top: 10px;
      font-family: var(--font-display);
      font-size: clamp(24px, 2.4vw, 34px);
      line-height: 1.12;
    }
    .diagnosis-section-head.compact {
      margin-bottom: 14px;
    }
    .diagnosis-executive,
    .diagnosis-analysis-panel,
    .diagnosis-routine-panel {
      padding: 24px;
    }
    .diagnosis-executive-grid {
      display: grid;
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1fr) minmax(
          280px,
          0.75fr
        );
      gap: 12px;
    }
    .diagnosis-summary-card {
      display: grid;
      min-width: 0;
      gap: 10px;
      padding: 18px;
      border: 1px solid var(--report-card-border);
      border-radius: 18px;
      background: var(--report-card-accent-rose);
    }
    .diagnosis-summary-card small {
      color: var(--report-muted);
      font-size: 12px;
      font-weight: 850;
      letter-spacing: 0.04em;
    }
    .diagnosis-summary-card strong {
      color: var(--report-ink);
      font-family: var(--font-display);
      font-size: clamp(24px, 2.2vw, 34px);
      line-height: 1.12;
    }
    .diagnosis-summary-card p {
      margin: 0;
      color: var(--report-body);
      font-size: 14px;
      line-height: 1.72;
    }
    .diagnosis-strategy-card {
      background: var(--report-card-accent-teal);
    }
    .diagnosis-palette-card {
      align-content: start;
    }
    .diagnosis-palette {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .palette-chip {
      display: inline-flex;
      min-width: 0;
      align-items: center;
      gap: 7px;
      padding: 7px 9px;
      border: 1px solid var(--report-card-border);
      border-radius: 999px;
      background: var(--report-card-bg);
      color: var(--report-body);
      font-size: 12px;
      font-weight: 800;
      line-height: 1.2;
    }
    .palette-chip i {
      display: block;
      width: 18px;
      height: 18px;
      flex: 0 0 auto;
      border-radius: 999px;
      background: #d89582;
      box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.05);
    }
    .palette-chip[data-tone="1"] i {
      background: #c98594;
    }
    .palette-chip[data-tone="2"] i {
      background: #b7775f;
    }
    .palette-chip[data-tone="3"] i {
      background: #e2ad85;
    }
    .palette-chip[data-tone="4"] i {
      background: #9f6a59;
    }
    .palette-chip[data-tone="5"] i {
      background: #d7b6a0;
    }
    .diagnosis-priority-recommend {
      padding: 24px;
    }
    .diagnosis-priority-recommend .recommend-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 12px;
      margin-top: 0;
    }
    .diagnosis-result-shell .recommend {
      min-width: 0;
      align-items: center;
      padding: 10px;
      border-radius: 14px;
      background: var(--report-card-bg);
    }
    .diagnosis-result-shell .recommend h3 {
      margin-top: 0;
    }
    .diagnosis-result-shell .recommend .btn {
      float: none;
      width: fit-content;
    }
    .diagnosis-insight-grid {
      display: grid;
      grid-template-columns: minmax(260px, 320px) minmax(0, 1fr);
      gap: 16px;
      align-items: start;
    }
    .diagnosis-profile-panel,
    .diagnosis-analysis-panel {
      min-width: 0;
    }
    .diagnosis-insight-grid .analysis-cards,
    .diagnosis-detail-cards {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
    .report-section-card {
      display: grid;
      min-width: 0;
      gap: 14px;
      padding: 18px;
      border: 1px solid var(--report-card-border);
      border-radius: 18px;
      background: var(--report-card-bg);
      box-shadow: var(--report-card-shadow);
    }
    .report-section-card h2 {
      margin: 0;
      color: var(--report-ink);
      font-size: 16px;
      line-height: 1.35;
      letter-spacing: 0.01em;
    }
    .report-section-card .analysis-row {
      padding-top: 12px;
      border-top: 1px solid var(--report-card-border);
    }
    .diagnosis-detail-panel {
      padding: 0;
      overflow: hidden;
    }
    .diagnosis-detail-panel summary {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 14px;
      align-items: center;
      min-height: 56px;
      padding: 18px 22px;
      cursor: pointer;
      color: var(--report-ink);
      font-weight: 900;
      list-style: none;
    }
    .diagnosis-detail-panel summary::-webkit-details-marker {
      display: none;
    }
    .diagnosis-detail-panel summary::after {
      content: "+";
      display: grid;
      width: 28px;
      height: 28px;
      place-items: center;
      border-radius: 50%;
      background: var(--surface-rose);
      color: var(--rose);
    }
    .diagnosis-detail-panel[open] summary::after {
      content: "-";
    }
    .diagnosis-detail-panel summary small {
      color: var(--report-muted);
      font-size: 12px;
      font-weight: 600;
    }
    .diagnosis-detail-cards {
      padding: 0 22px 22px;
    }
    .portrait-panel h3 {
      margin: 0 0 16px;
      color: var(--report-ink);
      font-size: 18px;
      font-weight: 850;
      letter-spacing: 0.01em;
    }
    .rule-strip {
      margin-top: 20px;
      padding: 12px 14px;
      border: 0;
      border-radius: 12px;
      background: var(--report-card-accent-rose);
      color: var(--report-muted);
      font-size: 11px;
      line-height: 1.6;
    }
    .analysis-card {
      min-width: 0;
    }
    .analysis-row {
      display: grid;
      grid-template-columns: 34px minmax(0, 1fr);
      gap: 10px;
      align-items: start;
    }
    .analysis-row i {
      display: grid;
      width: 34px;
      height: 34px;
      place-items: center;
      border-radius: 12px;
      background: var(--surface-rose);
      color: var(--rose);
      font-size: 12px;
      font-style: normal;
      font-weight: 900;
    }
    .analysis-row b {
      display: block;
      margin-bottom: 4px;
      color: var(--report-ink);
      font-size: 14px;
      font-weight: 700;
      line-height: 1.35;
    }
    .analysis-row span {
      display: block;
      color: var(--report-body);
      font-size: 13px;
      line-height: 1.7;
    }
    .diagnosis-routine-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }
    .routine-step {
      display: grid;
      grid-template-columns: 42px minmax(0, 1fr);
      gap: 12px;
      min-width: 0;
      padding: 16px;
      border: 1px solid var(--report-card-border);
      border-radius: 18px;
      background: var(--report-card-bg);
    }
    .routine-step > span {
      display: grid;
      width: 42px;
      height: 42px;
      place-items: center;
      border-radius: 14px;
      background: var(--teal-soft);
      color: var(--teal);
      font-size: 12px;
      font-weight: 900;
    }
    .routine-step h3 {
      margin: 0 0 6px;
      color: var(--report-ink);
      font-size: 15px;
      font-weight: 750;
      line-height: 1.35;
    }
    .routine-step p {
      margin: 0;
      color: var(--report-body);
      font-size: 13px;
      line-height: 1.7;
    }
    .diagnosis-scenario-block {
      display: grid;
      gap: 14px;
      margin-top: 24px;
      padding-top: 22px;
      border-top: 1px solid var(--report-card-border);
    }
    .diagnosis-scenario-block h3 {
      margin: 0 0 6px;
      color: var(--report-ink);
      font-family: var(--font-display);
      font-size: clamp(22px, 2.2vw, 30px);
      line-height: 1.18;
    }
    .diagnosis-scenario-block p {
      margin: 0;
      max-width: 720px;
      color: var(--report-muted);
      font-size: 13px;
      line-height: 1.7;
    }
    .diagnosis-scenario-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
    }
    .scenario-card {
      display: grid;
      min-width: 0;
      gap: 8px;
      padding: 16px;
      border: 1px solid var(--report-card-border);
      border-radius: 16px;
      background: var(--report-card-bg);
    }
    .scenario-card strong {
      color: var(--rose);
      font-size: 13px;
      font-weight: 850;
    }
    .scenario-card b {
      color: var(--report-ink);
      font-size: 15px;
      font-weight: 700;
      line-height: 1.35;
    }
    .scenario-card dl {
      display: grid;
      gap: 8px;
      margin: 0;
    }
    .scenario-card dt {
      color: var(--report-muted);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.04em;
    }
    .scenario-card dd {
      margin: 2px 0 0;
      color: var(--report-body);
      font-size: 13px;
      line-height: 1.6;
    }
    .report-recommend p b {
      color: var(--heading);
    }
    .recommend-watch {
      margin-top: 5px;
      color: var(--muted) !important;
    }
    @media (hover: hover) and (pointer: fine) {
      .keyword:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(184, 118, 103, 0.12);
      }
    }
    :global([data-theme="dark"]) .keyword {
      background: linear-gradient(
        135deg,
        var(--surface-warm),
        rgba(255, 255, 255, 0.04)
      );
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.18);
    }
    :global([data-theme="dark"]) .keyword i {
      background: linear-gradient(
        135deg,
        var(--gold-soft),
        rgba(240, 168, 50, 0.22)
      );
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
    }
    @media (prefers-color-scheme: dark) {
      :global(:root:not([data-theme="light"])) .keyword {
        background: linear-gradient(
          135deg,
          var(--surface-warm),
          rgba(255, 255, 255, 0.04)
        );
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.18);
      }
      :global(:root:not([data-theme="light"])) .keyword i {
        background: linear-gradient(
          135deg,
          var(--gold-soft),
          rgba(240, 168, 50, 0.22)
        );
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.08);
      }
    }
    .recommend {
      min-width: 0;
    }
    .recommend img {
      width: 92px;
    }
    .diagnosis-history {
      margin-top: 24px;
      padding: 24px;
      overflow: hidden;
    }
    .diagnosis-history-header {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 18px;
      align-items: end;
      padding-bottom: 18px;
      border-bottom: 1px solid var(--line);
    }
    .diagnosis-history-header h2 {
      margin: 9px 0 8px;
      color: var(--heading);
      font-family: var(--font-display);
      font-size: clamp(26px, 3vw, 36px);
      line-height: 1.12;
    }
    .diagnosis-history-header p {
      margin: 0;
      max-width: 680px;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.7;
    }
    .diag-history-list {
      display: grid;
      gap: 12px;
      margin-top: 18px;
    }
    .diag-history-skeleton {
      display: grid;
      gap: 10px;
      padding: 18px;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--soft);
      color: var(--muted);
      font-size: 13px;
    }
    .diag-history-skeleton i {
      display: block;
      height: 14px;
      max-width: 520px;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--line), transparent);
    }
    .diag-history-skeleton i:last-child {
      max-width: 360px;
    }
    :global(.diag-history-empty) {
      display: grid;
      gap: 18px;
      padding: 22px;
      border: 1px solid var(--line);
      border-radius: 16px;
      background: linear-gradient(135deg, var(--surface-rose), var(--soft));
    }
    :global(.diag-history-empty.compact) {
      background: var(--soft);
    }
    :global(.history-empty-main) {
      display: grid;
      grid-template-columns: 52px minmax(0, 1fr);
      gap: 14px;
      align-items: start;
    }
    :global(.history-empty-mark),
    :global(.diag-history-marker) {
      display: grid;
      place-items: center;
      border-radius: 16px;
      background: var(--teal-soft);
      color: var(--teal);
      font-size: 12px;
      font-weight: 900;
    }
    :global(.history-empty-mark) {
      width: 52px;
      height: 52px;
    }
    :global(.history-empty-main b) {
      display: block;
      margin-bottom: 7px;
      color: var(--heading);
      font-size: 20px;
    }
    :global(.history-empty-main p) {
      margin: 0;
      max-width: 720px;
      color: var(--text);
      font-size: 14px;
      line-height: 1.7;
    }
    :global(.history-empty-actions) {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    :global(.history-empty-meta) {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }
    :global(.history-empty-meta span) {
      min-width: 0;
      padding-top: 12px;
      border-top: 1px solid var(--line);
    }
    :global(.history-empty-meta strong) {
      display: block;
      margin-bottom: 5px;
      color: var(--heading);
      font-size: 13px;
    }
    :global(.history-empty-meta small) {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.55;
    }
    :global(.diag-history-item) {
      display: grid;
      grid-template-columns: 44px minmax(0, 1fr) auto;
      gap: 14px;
      align-items: center;
      padding: 16px;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--soft);
    }
    :global(.diag-history-marker) {
      width: 44px;
      height: 44px;
    }
    :global(.diag-history-head) {
      display: flex;
      justify-content: space-between;
      gap: 14px;
      align-items: flex-start;
    }
    :global(.diag-history-head b) {
      display: block;
      color: var(--heading);
      font-size: 15px;
      font-weight: 750;
      line-height: 1.35;
    }
    :global(.diag-history-head p) {
      margin: 5px 0 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.5;
    }
    :global(.diag-history-head time) {
      flex: 0 0 auto;
      color: var(--muted);
      font-size: 12px;
    }
    :global(.diag-history-tags) {
      display: flex;
      min-height: 24px;
      margin-top: 9px;
      gap: 6px;
      flex-wrap: wrap;
    }
    :global(.diag-history-actions) {
      display: flex;
      gap: 8px;
    }
    :global(.btn-sm) {
      font-size: 0.85rem;
      padding: 6px 14px;
      min-height: 34px;
      border-radius: 8px;
    }
    :global(.diag-history-tags .pill) {
      background: var(--neutral-pill-bg);
      color: var(--neutral-pill-text);
    }

    @media (max-width: 980px) {
      .diagnosis-hero,
      .diagnosis-new,
      .diagnosis-banner {
        grid-template-columns: 1fr;
      }
      .diagnosis-hero {
        min-height: auto;
      }
      .diagnosis-report-preview {
        justify-self: start;
        max-width: 500px;
      }
      .diagnosis-outcome-grid {
        grid-template-columns: 1fr;
      }
      .diagnosis-credit {
        width: 100%;
      }
      .diagnosis-result-hero,
      .diagnosis-section-head,
      .diagnosis-insight-grid,
      .diagnosis-executive-grid {
        grid-template-columns: 1fr;
      }
      .diagnosis-result-actions {
        justify-content: flex-start;
      }
      .diagnosis-insight-grid .analysis-cards,
      .diagnosis-detail-cards {
        grid-template-columns: 1fr;
      }
      .diagnosis-routine-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .diagnosis-scenario-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 700px) {
      .diagnosis-main {
        padding-top: 20px;
      }
      .diagnosis-hero {
        gap: 18px;
        padding: 22px 0 12px;
      }
      .diagnosis-hero-copy {
        gap: 13px;
      }
      .diagnosis-hero-copy h1 {
        font-size: clamp(34px, 10vw, 44px);
      }
      .diagnosis-hero-copy > p,
      .diagnosis-outcomes p,
      .diagnosis-banner p,
      .diagnosis-upload-copy p {
        font-size: 14px;
        line-height: 1.68;
      }
      .diagnosis-hero-actions {
        display: grid;
        grid-template-columns: 1fr;
      }
      .diagnosis-hero-trust {
        grid-template-columns: 1fr;
        gap: 8px;
      }
      .diagnosis-hero-trust > div {
        padding: 10px 12px;
      }
      .diagnosis-report-preview {
