      color: var(--heading);
      font-size: 18px;
      line-height: 1.25;
    }
    .report-preview-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
    }
    .report-preview-stats div {
      min-width: 0;
