---
import SiteHeader from "../components/SiteHeader.astro";
import { resolveLookCatalog } from "../data/makeup/resolveCatalog";
import { resolvePageAssets } from "../data/makeup/resolvePageAssets";
import { getLocalizedAppHref, resolveLocaleRoute } from "../i18n/routing";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCurrentLocale } from "../lib/i18n";
import {
  getDiagnosisResultLabels,
  getLocalizedDiagnosisContent,
} from "../data/diagnosisContent";

const currentLocale = getCurrentLocale();
const currentPathname = Astro.originPathname || Astro.url.pathname;
const currentRoute =
  Astro.locals.localeRoute ?? resolveLocaleRoute(currentPathname);
const localizeAppHref = (href: string) =>
  getLocalizedAppHref(href, currentRoute.language.slug);
const currentReturnPath = `${currentPathname}${Astro.url.search}`;
const pricingHref = localizeAppHref(
  `/pricing?return_to=${encodeURIComponent(currentReturnPath)}`,
);
const discoverHref = localizeAppHref("/discover");
const loginHref = localizeAppHref("/login");
const tryOnFreeHref = localizeAppHref("/tryon-free");
const tryLookHref = (slug: string) =>
  localizeAppHref(`/tryon-free?look=${encodeURIComponent(slug)}`);
const isEnglish = !currentLocale.startsWith("zh");
const audienceContext = Astro.locals.audienceContext;
const resolvedLooks = resolveLookCatalog(audienceContext);
const diagnosisPageAssets = resolvePageAssets("diagnosis", audienceContext);
const diagnosisPreviewImage =
  diagnosisPageAssets.exampleImages?.[0] ?? "/images/diagnosis-preview.webp";
const defaultRecommends = [
  "commute",
  "interview-ready",
  "rose-milk-date",
  "mature-skin-radiance",
]
  .map((slug) => resolvedLooks.find((look) => look.slug === slug))
  .filter(Boolean) as typeof resolvedLooks;

const fallbackDiagnosisCopy = isEnglish
  ? {
      metaTitle: "AI Facial Diagnosis | AI Beauty Stylist",
      metaDescription:
        "Analyze skin tone, face structure, color direction, and makeup fit before generating an AI try-on.",
      kicker: "AI Facial Diagnosis",
      title: "Understand your face before trying a look",
      titleLines: ["Understand your face", "before trying a look"],
      subtitle:
        "Upload one clear selfie after consent. The report turns facial features, undertone, and scenario needs into concrete makeup direction.",
      startCta: "Start diagnosis",
      plansCta: "View plans",
      trust: [
        [
          "One credit",
          "Diagnosis and try-on use the same monthly generation credits.",
        ],
        ["Private flow", "Selfies are processed only after explicit consent."],
        ["Actionable", "Every report leads to looks you can try immediately."],
      ],
      previewLabel: "Sample report",
      previewTitle: "Warm-neutral skin with soft rose direction",
      previewAlt:
        "AI beauty diagnosis sample portrait with refined rose makeup",
      previewStats: [
        ["Undertone", "Neutral warm"],
        ["Face focus", "Soft structure"],
        ["Best finish", "Satin rose"],
      ],
      previewNotes: [
        "Keep base thin and preserve real skin texture.",
        "Use muted rose on lips and cheeks to lift tiredness.",
        "Avoid heavy cool gray eye shadow for daytime looks.",
      ],
      outcomeTitle: "What the report gives you",
      outcomeSubtitle:
        "The diagnosis is useful only when it helps you choose and judge makeup faster.",
      outcomes: [
        [
          "Tone",
          "Skin depth, undertone, and color-season direction for base and lip-cheek color.",
        ],
        [
          "Structure",
          "Face and eye-shape cues that affect brows, liner, contour, and highlight.",
        ],
        [
          "Direction",
          "Three makeup directions with palette anchors and caution notes.",
        ],
      ],
      quotaTitle: "Monthly generation credits",
      quotaLoading: "Loading...",
      uploadTitle: "Start a new diagnosis",
      uploadSubtitle:
        "Use a front-facing selfie in natural light. Avoid heavy filters, sunglasses, masks, or extreme side angles.",
      guideTitle: "Photo checklist",
      guide: [
        "Face the camera with both eyes visible",
        "Use clean light and avoid color filters",
        "Keep hair away from the main face outline",
      ],
      consent: "I understand and agree to this photo processing notice",
      uploadCta: "Upload selfie and diagnose",
      resultKeywords: "Your beauty keywords",
      resultNotice:
        "AI suggestions are for beauty reference only. They are not medical or professional advice, and results vary by lighting, device, and personal conditions.",
      recommendTitle: "Looks matched to this diagnosis",
      recommendSubtitle: "Try a look that fits the report instead of guessing.",
      recommendMore: "Open look library",
      tryLook: "Try this look",
      historyKicker: "Saved reports",
      historyTitle: "Diagnosis history",
      historySubtitle: "Previous reports stay available until you delete them.",
      historyLoading: "Loading...",
      historyEmptyTitle: "No saved diagnosis reports yet",
      historyEmptyBody:
        "Complete one diagnosis and this area will become your personal reference shelf for undertone, structure, color direction, and matched looks.",
      historyEmptyCta: "Start a diagnosis",
      historyEmptySecondary: "Browse looks first",
      historyEmptyMeta: [
        ["Stored context", "Review your latest report before choosing a look."],
        [
          "Fast comparison",
          "Compare undertone, face focus, and style direction.",
        ],
        [
          "You control it",
          "Delete records whenever they are no longer useful.",
        ],
      ],
      client: {
        quotaGuest: "Sign in to view",
        quotaGuestNote: "Sign in to use monthly generation credits",
        quotaRemainingPrefix: "Remaining this month: ",
        quotaRemainingSuffix: " credits",
        quotaExhausted: "Monthly credits used up",
        quotaExhaustedNote:
          "Monthly generation credits are used up. Share or upgrade to get more credits.",
        quotaExhaustedCta: "Monthly credits used up",
        loginCta: "Sign in to start diagnosis",
        uploadCta: "Upload selfie and diagnose",
        tryLook: "Try this look",
        uploadFlowNotReady:
          "Upload flow is not ready. Please refresh and try again.",
        uploading: "Uploading...",
        confirming: "Confirming photo processing notice...",
        creating: "Creating diagnosis task...",
        analyzing: "AI is analyzing facial features...",
        generating: "Generating makeup preview...",
        running: "AI analyzing...",
        complete: "Diagnosis complete",
        timeout: "Task timed out. Please retry.",
        failed: "Diagnosis failed. Credit has been refunded.",
        historyFailed: "Failed to load history. Please refresh and try again.",
        viewDetail: "View report",
        delete: "Delete",
        confirmDelete: "Delete this diagnosis record? This cannot be undone.",
        reportTitle: "Diagnosis report",
      },
    }
  : {
      metaTitle: "AI 妆容诊断报告 | AI Beauty Stylist",
      metaDescription:
        "分析自拍中的肤色方向、五官位置和妆容适配建议，帮助你在 AI 试妆前更快缩小选择范围。",
      kicker: "AI 妆容诊断",
      title: "先看适配方向，再选择要试的妆",
      titleLines: ["先看适配方向", "再选择要试的妆"],
      subtitle:
        "在明确授权后上传一张清晰自拍，系统会把肤色方向、五官位置和场景需求整理成可执行的妆容建议。",
      startCta: "开始诊断",
      plansCta: "查看会员",
      trust: [
        ["统一额度", "诊断和试妆都消耗同一套月度生成额度。"],
        ["私密流程", "自拍只会在你明确同意后进入处理流程。"],
        ["可执行", "每份报告都会连接到可立即试妆的风格。"],
      ],
      previewLabel: "报告示例",
      previewTitle: "暖中性肤色方向，适合低饱和玫瑰妆",
      previewAlt: "AI 美妆诊断示例人像，呈现自然玫瑰妆效",
      previewStats: [
        ["肤色方向", "中性偏暖"],
        ["妆容重点", "柔和轮廓"],
        ["推荐妆感", "缎光玫瑰"],
      ],
      previewNotes: [
        "底妆保留皮肤纹理，不要过度磨皮。",
        "唇颊使用低饱和玫瑰色，先改善疲惫感。",
        "日间场景避免大面积冷灰眼影。",
      ],
      outcomeTitle: "诊断真正帮你判断什么",
      outcomeSubtitle:
        "不是给人贴标签，而是帮你更快判断哪些妆容值得先试、哪些方向可以暂时避开。",
      outcomes: [
        ["肤色", "参考肤色深浅和冷暖倾向，辅助底妆、唇色和腮红选择。"],
        ["位置", "结合眉眼、面中和轮廓位置，提示妆容重心和上妆区域。"],
        ["方向", "输出 3 个妆容方向，包含推荐色、适合场景和慎选提醒。"],
      ],
      quotaTitle: "本月生成额度",
      quotaLoading: "加载中...",
      uploadTitle: "开始新的诊断",
      uploadSubtitle:
        "请使用自然光下的正面清晰自拍，避免浓滤镜、墨镜、口罩或大角度侧脸。",
      guideTitle: "照片检查",
      guide: [
        "正对镜头，双眼和脸部轮廓清楚",
        "使用干净光线，避免强滤镜和偏色灯光",
        "头发不要遮挡主要脸型边界",
      ],
      consent: "我已了解并同意本次照片处理说明",
      uploadCta: "上传自拍开始诊断",
      resultKeywords: "你的美妆关键词",
      resultNotice:
        "AI 建议仅供美妆参考，不构成医疗或专业意见；实际效果因光线、设备和个人条件而异。",
      recommendTitle: "可以优先尝试的妆容",
      recommendSubtitle: "从和报告方向接近的妆容开始，比盲选更省时间。",
      recommendMore: "进入妆容库",
      tryLook: "试这个妆",
      historyKicker: "我的报告",
      historyTitle: "历史诊断记录",
      historySubtitle: "你之前的报告会保留在这里，可随时查看或删除。",
      historyLoading: "加载中...",
      historyEmptyTitle: "还没有可回看的诊断报告",
      historyEmptyBody:
        "完成一次诊断后，这里会保留肤色方向、妆容重点和匹配妆容，方便下次直接对照。",
      historyEmptyCta: "开始一次诊断",
      historyEmptySecondary: "先看妆容库",
      historyEmptyMeta: [
        ["保留上下文", "下次试妆前可以先回看报告。"],
        ["方便对比", "快速比较肤色方向、妆容重点和推荐方向。"],
        ["可控记录", "不需要的报告可以随时删除。"],
      ],
      client: {
        quotaGuest: "登录后查看",
        quotaGuestNote: "登录后可使用月度生成额度",
        quotaRemainingPrefix: "本月还可生成 ",
        quotaRemainingSuffix: " 次",
        quotaExhausted: "本月额度已用完",
        quotaExhaustedNote: "本月生成额度已用完，可分享或升级获取更多额度。",
        quotaExhaustedCta: "本月额度已用完",
        loginCta: "登录后开始诊断",
        uploadCta: "上传自拍开始诊断",
        tryLook: "试这个妆",
        uploadFlowNotReady: "上传流程尚未就绪，请刷新页面后重试",
        uploading: "上传中...",
        confirming: "正在确认照片处理说明...",
        creating: "创建诊断任务...",
        analyzing: "AI 正在分析照片中的肤色与妆容位置...",
        generating: "正在生成妆效预览...",
        running: "AI 正在分析...",
        complete: "诊断完成",
        timeout: "任务超时，请重试",
        failed: "诊断失败，额度已自动返还",
        historyFailed: "加载失败，请刷新重试。",
        viewDetail: "查看报告",
        delete: "删除",
        confirmDelete: "确定删除此诊断记录？此操作无法撤销。",
        reportTitle: "诊断报告",
      },
    };
const diagnosisCopy =
  getLocalizedDiagnosisContent(currentLocale) ?? fallbackDiagnosisCopy;

const diagnosisClientCopy = {
  ...diagnosisCopy.client,
  resultLabels: getDiagnosisResultLabels(currentLocale),
  recommendMore: diagnosisCopy.recommendMore,
  historyEmptyTitle: diagnosisCopy.historyEmptyTitle,
  historyEmptyBody: diagnosisCopy.historyEmptyBody,
  historyEmptyCta: diagnosisCopy.historyEmptyCta,
  historyEmptySecondary: diagnosisCopy.historyEmptySecondary,
  historyEmptyMeta: diagnosisCopy.historyEmptyMeta,
};
---

<BaseLayout
  title={diagnosisCopy.metaTitle}
  description={diagnosisCopy.metaDescription}
  bodyClass="diagnosis-body"
>
  <SiteHeader active="diagnosis" />
  <main class="diagnosis-main" data-diagnosis-main>
    <section class="diagnosis-hero shell" aria-labelledby="diagnosis-title">
      <div class="diagnosis-hero-copy">
        <span class="section-eyebrow">{diagnosisCopy.kicker}</span>
        <h1 id="diagnosis-title" aria-label={diagnosisCopy.title}>
          {diagnosisCopy.titleLines.map((line) => <span>{line}</span>)}
        </h1>
        <p>{diagnosisCopy.subtitle}</p>
        <div class="diagnosis-hero-actions">
          <a class="btn btn-primary" href="#diagnosis-new"
            >{diagnosisCopy.startCta}</a
          >
          <a class="btn" href={pricingHref}>{diagnosisCopy.plansCta}</a>
        </div>
        <div class="diagnosis-hero-trust" aria-label={diagnosisCopy.kicker}>
          {
            diagnosisCopy.trust.map(([title, text]) => (
              <div>
                <b>{title}</b>
                <span>{text}</span>
              </div>
            ))
          }
        </div>
      </div>
      <aside class="diagnosis-report-preview panel">
        <div class="report-preview-media">
          <img
            src={diagnosisPreviewImage}
            alt={diagnosisCopy.previewAlt}
            width="720"
            height="720"
          />
          <div class="report-preview-overlay">
            <span class="report-preview-label"
              >{diagnosisCopy.previewLabel}</span
            >
            <div class="report-preview-stats">
              {
                diagnosisCopy.previewStats.map(([label, value]) => (
                  <div>
                    <small>{label}</small>
                    <b>{value}</b>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
        <div class="report-preview-summary">
          <h2>{diagnosisCopy.previewTitle}</h2>
          <ul>
            {
              diagnosisCopy.previewNotes
                .slice(0, 2)
                .map((item) => <li>{item}</li>)
            }
          </ul>
        </div>
      </aside>
    </section>

    <section class="diagnosis-outcomes shell" aria-labelledby="outcome-title">
      <div class="home-section-head-split">
        <div>
          <span class="section-eyebrow">{diagnosisCopy.kicker}</span>
          <h2 id="outcome-title">{diagnosisCopy.outcomeTitle}</h2>
          <p>{diagnosisCopy.outcomeSubtitle}</p>
        </div>
      </div>
      <div class="diagnosis-outcome-grid">
        {
          diagnosisCopy.outcomes.map(([title, text]) => (
            <article class="diagnosis-outcome-card">
              <span>{title}</span>
              <p>{text}</p>
            </article>
          ))
        }
      </div>
    </section>

    <div class="diagnosis-workspace shell">
      <section class="diagnosis-banner panel">
        <div>
          <span class="section-eyebrow">{diagnosisCopy.quotaTitle}</span>
          <h2>{diagnosisCopy.uploadTitle}</h2>
          <p>{diagnosisCopy.uploadSubtitle}</p>
        </div>
        <div class="diagnosis-credit" data-diagnosis-quota>
          <span aria-hidden="true">AI</span>
          <div>
            <b data-diagnosis-quota-text>—</b>
            <div class="small muted" data-diagnosis-quota-note>
              {diagnosisCopy.quotaLoading}
            </div>
          </div>
        </div>
      </section>

      <section class="diagnosis-new panel" id="diagnosis-new" tabindex="-1">
        <div class="diagnosis-upload-copy">
          <span class="section-eyebrow">{diagnosisCopy.guideTitle}</span>
          <h2>{diagnosisCopy.uploadTitle}</h2>
          <p>{diagnosisCopy.uploadSubtitle}</p>
        </div>
        <div class="diagnosis-upload-area">
          <div class="privacy-promise">
            {
              diagnosisCopy.guide.map((item) => (
                <span>
                  <i aria-hidden="true" />
                  {item}
                </span>
              ))
            }
          </div>
          <label class="privacy-consent">
            <input type="checkbox" data-diag-consent />
            <span>{diagnosisCopy.consent}</span>
          </label>
          <button class="btn btn-primary" id="diag-upload-btn" disabled>
            {diagnosisCopy.uploadCta}
          </button>
          <div class="upload-task-status" id="diag-task-status" hidden>
            <div class="upload-task-head">
              <span id="diag-status-text">{diagnosisCopy.quotaLoading}</span>
              <b id="diag-percent">0%</b>
            </div>
            <div class="meter"><i id="diag-progress" style="width:0%"></i></div>
          </div>
        </div>
      </section>

      <!-- 诊断结果区（JS 动态填充） -->
      <div class="diagnosis-result-shell" id="diagnosis-result" hidden>
        <section class="diagnosis-result-hero panel">
          <div class="diagnosis-result-copy">
            <span class="section-eyebrow" id="diag-result-meta"
              >{diagnosisCopy.historyKicker}</span
            >
            <h2 id="diag-result-title">{diagnosisCopy.resultKeywords}</h2>
            <p id="diag-result-summary">{diagnosisCopy.resultNotice}</p>
            <div class="diagnosis-result-chips" id="diag-result-chips"></div>
          </div>
          <div class="diagnosis-result-actions">
            <a
              class="btn btn-primary"
              id="diag-primary-look"
              href={discoverHref}>{diagnosisCopy.tryLook}</a
            >
            <a class="btn" href="#diagnosis-new">
              {diagnosisCopy.historyEmptyCta}
            </a>
          </div>
        </section>

        <section class="recommend-panel panel diagnosis-priority-recommend">
          <div class="diagnosis-section-head">
            <div>
              <span class="section-eyebrow">{diagnosisCopy.recommendTitle}</span
              >
              <h2 class="panel-title">{diagnosisCopy.recommendTitle}</h2>
              <p class="panel-subtitle">{diagnosisCopy.recommendSubtitle}</p>
            </div>
            <a class="btn" href={discoverHref}>{diagnosisCopy.recommendMore}</a>
          </div>
          <div class="recommend-list" id="diag-recommends">
            {
              defaultRecommends.map((look) => (
                <article class="recommend">
                  <img src={look.image} alt={look.title} />
                  <div>
                    <h3>{look.title}</h3>
                    <p>{look.scenarios.join(" / ")}</p>
                    <a class="btn btn-primary" href={tryLookHref(look.slug)}>
                      {diagnosisCopy.tryLook}
                    </a>
                  </div>
                </article>
              ))
            }
          </div>
        </section>

        <section class="diagnosis-insight-grid">
          <aside class="portrait-panel panel">
            <img id="diag-selfie" src="" alt="用户诊断自拍" hidden />
            <h3>{diagnosisCopy.resultKeywords}</h3>
            <div id="diag-keywords"></div>
            <div class="rule-strip" id="diag-disclaimer">
              {diagnosisCopy.resultNotice}
            </div>
          </aside>
          <section class="analysis-cards" id="diag-cards"></section>
        </section>

        <details class="diagnosis-detail-panel panel" id="diag-detail-panel">
          <summary>
            <span>完整分析细节</span>
            <small>置信度、局限和慎选提醒</small>
          </summary>
          <div
            class="analysis-cards diagnosis-detail-cards"
            id="diag-detail-cards"
          >
          </div>
        </details>
      </div>

      <section
        class="diagnosis-history panel"
        id="diagnosis-history"
        aria-labelledby="diagnosis-history-title"
      >
        <div class="diagnosis-history-header">
          <div>
            <span class="section-eyebrow">{diagnosisCopy.historyKicker}</span>
            <h2 id="diagnosis-history-title">{diagnosisCopy.historyTitle}</h2>
            <p>{diagnosisCopy.historySubtitle}</p>
          </div>
          <a class="btn btn-primary" href="#diagnosis-new">
            {diagnosisCopy.historyEmptyCta}
          </a>
        </div>
        <div
          id="diag-history-list"
          class="diag-history-list"
          aria-live="polite"
        >
          <div class="diag-history-skeleton" role="status">
            <span>{diagnosisCopy.historyLoading}</span>
            <i></i>
            <i></i>
          </div>
        </div>
      </section>
    </div>
  </main>

  <script
    is:inline
    define:vars={{
      diagnosisClientCopy,
      discoverHref,
      loginHref,
      tryOnFreeHref,
    }}
  >
    (function () {
      const copy = diagnosisClientCopy;
      // === 配置 ===
      const POLL_INTERVAL = 2000;
      const POLL_MAX = 60;

      // === DOM 引用 ===
      const consentBox = document.querySelector("[data-diag-consent]");
      const diagnosisMain = document.querySelector("[data-diagnosis-main]");
      const uploadBtn = document.getElementById("diag-upload-btn");
      const taskStatus = document.getElementById("diag-task-status");
      const statusText = document.getElementById("diag-status-text");
      const percentText = document.getElementById("diag-percent");
      const progressBar = document.getElementById("diag-progress");
      const resultSection = document.getElementById("diagnosis-result");
      const newSection = document.getElementById("diagnosis-new");
      const cardsContainer = document.getElementById("diag-cards");
      const detailCardsContainer = document.getElementById("diag-detail-cards");
      const detailPanel = document.getElementById("diag-detail-panel");
      const keywordsContainer = document.getElementById("diag-keywords");
      const resultMeta = document.getElementById("diag-result-meta");
      const resultTitle = document.getElementById("diag-result-title");
      const resultSummary = document.getElementById("diag-result-summary");
      const resultChips = document.getElementById("diag-result-chips");
      const primaryLook = document.getElementById("diag-primary-look");
      const historyList = document.getElementById("diag-history-list");
      const quotaCard = document.querySelector("[data-diagnosis-quota]");
      const quotaText = document.querySelector("[data-diagnosis-quota-text]");
      const quotaNote = document.querySelector("[data-diagnosis-quota-note]");
      const recommendsContainer = document.getElementById("diag-recommends");
      const START_HASH = "#diagnosis-new";
      let isAccountUser = false;
      let wantsNewDiagnosis = location.hash === START_HASH;
      let quotaSnapshot = null;

      function scrollToDiagnosisStart() {
        if (!newSection) return;
        wantsNewDiagnosis = true;
        newSection.hidden = false;
        if (resultSection) resultSection.hidden = true;
        if (taskStatus) taskStatus.hidden = true;
        newSection.scrollIntoView({ behavior: "smooth", block: "start" });
        window.history.replaceState(null, "", START_HASH);

        const focusTarget =
          uploadBtn && !uploadBtn.disabled
            ? uploadBtn
            : consentBox && !consentBox.disabled
              ? consentBox
              : newSection;
        requestAnimationFrame(() => {
          focusTarget?.focus?.({ preventScroll: true });
        });
      }

      document.addEventListener("click", (event) => {
        if (!(event.target instanceof Element)) return;
        const startLink = event.target.closest('a[href="#diagnosis-new"]');
        if (!startLink) return;
        event.preventDefault();
        scrollToDiagnosisStart();
      });

      if (location.hash === START_HASH) {
        requestAnimationFrame(scrollToDiagnosisStart);
      }

      function loginUrl() {
        return (
          loginHref +
          "?next=" +
          encodeURIComponent(
            location.pathname + location.search + location.hash,
          )
        );
      }

      function quotaRemainingValue() {
        if (!quotaSnapshot) return null;
        const remaining = Number(quotaSnapshot.remaining);
        return Number.isFinite(remaining) ? remaining : null;
      }

      function isQuotaExhausted() {
        const remaining = quotaRemainingValue();
        return isAccountUser && remaining !== null && remaining <= 0;
      }

      function renderQuota(q) {
        const remaining = Number(q?.remaining ?? 0);
        const total = Number(q?.total ?? 0);
        const safeRemaining = Number.isFinite(remaining)
          ? Math.max(0, remaining)
          : 0;
        const safeTotal = Number.isFinite(total) ? Math.max(0, total) : 0;
        const quotaLabel = safeRemaining + "/" + safeTotal;
        const exhausted = safeRemaining <= 0;
        if (quotaText) quotaText.textContent = quotaLabel;
        if (quotaNote) {
          quotaNote.textContent = exhausted
            ? copy.quotaExhaustedNote ||
              copy.quotaExhausted ||
              copy.quotaLoading
            : (copy.quotaRemainingPrefix || "") +
              quotaLabel +
              (copy.quotaRemainingSuffix || "");
        }
        quotaCard?.classList.toggle("is-exhausted", exhausted);
      }

      function syncUploadAvailability() {
        if (!uploadBtn) return;
        if (!isAccountUser) {
          uploadBtn.disabled = false;
          uploadBtn.textContent = copy.loginCta;
          return;
        }
        if (isQuotaExhausted()) {
          uploadBtn.disabled = true;
          uploadBtn.textContent =
            copy.quotaExhaustedCta || copy.quotaExhausted || copy.uploadCta;
          return;
        }
        uploadBtn.disabled = !consentBox?.checked;
        uploadBtn.textContent = copy.uploadCta;
      }

      function showQuotaExhaustedState() {
        if (taskStatus) taskStatus.hidden = true;
        quotaSnapshot = {
          ...(quotaSnapshot || { total: 0 }),
          remaining: 0,
        };
        renderQuota(quotaSnapshot);
        syncUploadAvailability();
      }

      function isQuotaError(err) {
        const value = String(
          [
            err?.code,
            err?.errorCode,
            err?.name,
            err?.message,
            typeof err === "string" ? err : "",
          ]
            .filter(Boolean)
            .join(" "),
        );
        return /QUOTA_EXHAUSTED|额度已用完|額度已用完|credits? (exhausted|used up)/i.test(
          value,
        );
      }

      // === 同意控制 ===
      if (consentBox && uploadBtn) {
        consentBox.addEventListener("change", () => {
          syncUploadAvailability();
        });
      }

      // === 上传 + 创建任务 ===
      let currentJobId = null;
      if (uploadBtn) {
        uploadBtn.addEventListener("click", async () => {
          if (!isAccountUser) {
            window.location.href = loginUrl();
            return;
          }
          if (isQuotaExhausted()) {
            showQuotaExhaustedState();
            return;
          }
          const input = document.createElement("input");
          input.type = "file";
          input.accept =
            "image/jpeg,image/png,image/webp,image/heic,image/heif";
          input.onchange = async () => {
            const file = input.files?.[0];
            if (!file) return;
            try {
              const createTryOnJob = window.__absCreateTryOnJob;
              if (typeof createTryOnJob !== "function") {
                throw new Error(copy.uploadFlowNotReady);
              }
              uploadBtn.disabled = true;
              taskStatus.hidden = false;
              updateProgress(copy.uploading, 10);
              updateProgress(copy.confirming, 18);
              const result = await createTryOnJob({
                file,
                lookSlug: "commute",
                purpose: "diagnosis",
                idempotencyKey:
                  "diag-" +
                  Date.now() +
                  "-" +
                  Math.random().toString(36).slice(2),
              });
              updateProgress(copy.creating, 25);
              currentJobId = result.job.id;
              updateProgress(copy.analyzing, 40);

              // 3. 轮询
              pollJob(currentJobId);
            } catch (err) {
              if (isQuotaError(err)) {
                showQuotaExhaustedState();
                return;
              }
              const message =
                err instanceof Error ? err.message : String(err || "");
              updateProgress(message || copy.failed, 0);
              syncUploadAvailability();
            }
          };
          input.click();
        });
      }

      function updateProgress(text, pct) {
        if (statusText) statusText.textContent = text;
        if (percentText) percentText.textContent = pct + "%";
        if (progressBar) progressBar.style.width = pct + "%";
      }

      async function pollJob(jobId) {
        let attempt = 0;
        const interval = setInterval(async () => {
          attempt++;
          if (attempt > POLL_MAX) {
            clearInterval(interval);
            updateProgress(copy.timeout, 0);
            syncUploadAvailability();
            return;
          }
          try {
            const res = await fetch("/api/tryon-jobs/" + jobId);
            const data = await res.json();
            if (!data.ok) return;
            const job = data.data;
            if (job.status === "diagnosis_running") {
              updateProgress(copy.running, 50 + attempt);
            } else if (job.status === "image_running") {
              updateProgress(copy.generating, 70 + attempt);
            } else if (job.status === "succeeded") {
              clearInterval(interval);
              updateProgress(copy.complete, 100);
              // 加载诊断结果
              loadDiagnosisResult(jobId);
            } else if (job.status === "failed" || job.status === "timed_out") {
              clearInterval(interval);
              updateProgress(
                job.errorCode
                  ? copy.failed + "：" + job.errorCode
                  : copy.failed,
                0,
              );
              syncUploadAvailability();
            }
          } catch {
            /* ignore */
          }
        }, POLL_INTERVAL);
      }

      // === 加载诊断结果 ===
      async function loadDiagnosisResult(jobId) {
        try {
          const res = await fetch("/api/diagnoses");
          const data = await res.json();
          if (!data.ok) return false;
          const item = data.data.items.find((i) => i.jobId === jobId);
          if (item?.diagnosis) {
            renderDiagnosis(item.diagnosis, item);
          }
        } catch {
          /* ignore */
        }
      }

      const resultLabels = copy.resultLabels || {};
      const valueMaps = resultLabels.valueMaps || {};
      const keywordIcons = resultLabels.keywordIcons || {};

      function labelFrom(map, key, fallback) {
        return (key && map?.[key]) || fallback || key || "";
      }

      function joinEvidence(items) {
        return Array.isArray(items)
          ? items.join(resultLabels.paletteJoiner || ", ")
          : "";
      }

      function titleWithValue(label, value) {
        return value ? label + ": " + value : label;
      }

      function paletteSuffix(palette) {
        if (!Array.isArray(palette) || palette.length === 0) return "";
        return (
          (resultLabels.paletteOpen || " (") +
          (resultLabels.palettePrefix || "Palette: ") +
          palette.join(resultLabels.paletteJoiner || ", ") +
          (resultLabels.paletteClose || ")")
        );
      }

      function renderDiagnosis(d, record) {
        if (!resultSection || !cardsContainer || !keywordsContainer) return;
        wantsNewDiagnosis = false;
        diagnosisMain?.classList.add("has-account-result");
        newSection.hidden = true;
        resultSection.hidden = false;

        const skinLabel = labelFrom(
          valueMaps.undertone,
          d.skinTone?.undertone,
          resultLabels.defaultSkinTone,
        );
        const faceLabel = labelFrom(
          valueMaps.faceShape,
          d.faceShape?.primary,
          resultLabels.defaultFaceShape,
        );
        const eyeLabel = labelFrom(
          valueMaps.eyeShape,
          d.eyeShape?.primary,
          resultLabels.defaultEyeShape,
        );
        const seasonLabel =
          (d.colorSeason &&
            labelFrom(
              valueMaps.season,
              d.colorSeason.season,
              d.colorSeason.season,
            )) ||
          resultLabels.colorDirection;
        const primaryDirection = d.makeupDirections?.[0];
        const resultHeading =
          primaryDirection?.title || d.skinTone?.summary || copy.reportTitle;
        const summaryText =
          primaryDirection?.rationale ||
          d.skinTone?.summary ||
          d.colorSeason?.rationale ||
          "";

        if (resultMeta) {
          const dateLabel = record?.createdAt
            ? new Date(record.createdAt).toLocaleDateString(
                document.documentElement.lang || "zh-CN",
                { month: "2-digit", day: "2-digit" },
              )
            : "";
          resultMeta.textContent = dateLabel
            ? (resultLabels.latestDiagnosis || copy.reportTitle) +
              " · " +
              dateLabel
            : resultLabels.latestDiagnosis || copy.reportTitle;
        }
        if (resultTitle) resultTitle.textContent = resultHeading;
        if (resultSummary) resultSummary.textContent = summaryText;
        if (primaryLook) {
          primaryLook.href = discoverHref;
          primaryLook.textContent = copy.recommendMore || copy.tryLook;
        }

        const resultChipRows = [
          [resultLabels.skinTone, skinLabel],
          [resultLabels.facialFocus, `${faceLabel} / ${eyeLabel}`],
          [resultLabels.colorDirection, seasonLabel],
        ];
        if (d.confidence?.overall) {
          resultChipRows.push([
            resultLabels.confidence,
            `${labelFrom(valueMaps.band, d.confidence.band, d.confidence.band)} ${Math.round(
              d.confidence.overall * 100,
            )}%`.trim(),
          ]);
        }
        if (quotaSnapshot) {
          resultChipRows.push([
            resultLabels.monthlyQuota,
            `${quotaSnapshot.remaining}/${quotaSnapshot.total}`,
          ]);
        }
        if (resultChips) {
          resultChips.innerHTML = resultChipRows
            .map(
              ([label, value]) =>
                `<span><small>${escapeHtml(label)}</small><b>${escapeHtml(value)}</b></span>`,
            )
            .join("");
        }

        const kw = [
          {
            icon: keywordIcons.skin || "S",
            title: skinLabel,
            desc: d.skinTone?.summary || "",
          },
          {
            icon: keywordIcons.face || "F",
            title: faceLabel,
            desc: joinEvidence(d.faceShape?.evidence),
          },
          {
            icon: keywordIcons.color || "C",
            title: seasonLabel,
            desc: d.colorSeason?.rationale || "",
          },
        ];
        keywordsContainer.innerHTML = kw
          .map(
            (k) => `
      <div class="keyword"><i>${escapeHtml(k.icon)}</i><div><b>${escapeHtml(k.title)}</b><span>${escapeHtml(k.desc)}</span></div></div>
    `,
          )
          .join("");

        const insightCards = [];

        insightCards.push(
          buildCard(resultLabels.sections?.whyRecommended, [
            {
              icon: keywordIcons.face || "F",
              title: titleWithValue(resultLabels.rows?.faceShape, faceLabel),
              desc: joinEvidence(d.faceShape?.evidence),
            },
            {
              icon: keywordIcons.eye || "E",
              title: titleWithValue(resultLabels.rows?.eyeShape, eyeLabel),
              desc: joinEvidence(d.eyeShape?.evidence),
            },
            ...(d.strengths || []).slice(0, 2).map((s) => ({
              icon: keywordIcons.strength || "+",
              title: resultLabels.rows?.strengthenPoint,
              desc: s,
            })),
          ]),
        );

        insightCards.push(
          buildCard(resultLabels.sections?.skinAndColor, [
            {
              icon: keywordIcons.depth || "D",
              title: resultLabels.rows?.skinDepth,
              desc: labelFrom(
                valueMaps.skinDepth,
                d.skinTone?.depth,
                d.skinTone?.depth,
              ),
            },
            {
              icon: keywordIcons.tone || "T",
              title: resultLabels.rows?.undertone,
              desc: [skinLabel, d.skinTone?.summary]
                .filter(Boolean)
                .join(" - "),
            },
            {
              icon: keywordIcons.season || "C",
              title: resultLabels.rows?.colorSeason,
              desc: [seasonLabel, d.colorSeason?.rationale]
                .filter(Boolean)
                .join(": "),
            },
          ]),
        );

        if (d.makeupDirections?.length) {
          const rows = d.makeupDirections.map((dir) => ({
            icon: keywordIcons.makeup || "M",
            title: dir.title,
            desc: (dir.rationale || "") + paletteSuffix(dir.palette),
          }));
          insightCards.push(
            buildCard(resultLabels.sections?.makeupDirections, rows),
          );
        }

        cardsContainer.innerHTML = insightCards.join("");

        const detailCards = [];
        const conf = d.confidence;
        if (conf) {
          detailCards.push(
            buildCard(resultLabels.sections?.analysisConfidence, [
              {
                icon: keywordIcons.percent || "%",
                title: labelFrom(valueMaps.band, conf.band, conf.band),
                desc:
                  resultLabels.rows?.overallConfidence +
                  " " +
                  Math.round((conf.overall || 0) * 100) +
                  "%",
              },
              ...(conf.limitations || []).map((l) => ({
                icon: keywordIcons.limit || "L",
                title: resultLabels.rows?.limitation,
                desc: l,
              })),
            ]),
          );
        }
        if (d.cautions?.length) {
          detailCards.push(
            buildCard(
              resultLabels.sections?.cautions,
              d.cautions.map((c) => ({
                icon: keywordIcons.caution || "!",
                title: resultLabels.rows?.suggestion,
                desc: c,
              })),
            ),
          );
        }
        if (detailCardsContainer)
          detailCardsContainer.innerHTML = detailCards.join("");
        if (detailPanel) detailPanel.hidden = detailCards.length === 0;

        if (d.makeupDirections?.length && recommendsContainer) {
          try {
            fetch("/api/looks")
              .then((r) => r.json())
              .then((looksData) => {
                if (!looksData.ok) return;
                const allLooks = looksData.data?.looks || [];
                const matched = matchRecommends(d.makeupDirections, allLooks);
                if (matched.length > 0) {
                  const primary = matched[0];
                  if (primaryLook && primary) {
                    primaryLook.href = `${tryOnFreeHref}?look=${encodeURIComponent(primary.slug)}`;
                    primaryLook.textContent = copy.tryLook;
                  }
                  recommendsContainer.innerHTML = matched
                    .slice(0, 4)
                    .map(
                      (m) => `
              <article class="recommend">
                <img src="${escapeHtml(m.image)}" alt="${escapeHtml(m.title)}" />
                <div>
                  <h3>${escapeHtml(m.title)}&nbsp; <span class="pill pill-rose">${escapeHtml(resultLabels.recommendationScore)} ${escapeHtml(m.score)}%</span></h3>
                  <p>${escapeHtml(m.reason)}</p>
                  <a class="btn btn-primary" href="${escapeHtml(tryOnFreeHref)}?look=${encodeURIComponent(m.slug)}">${escapeHtml(copy.tryLook)}</a>
                </div>
              </article>
            `,
                    )
                    .join("");
                }
              });
          } catch {
            /* ignore */
          }
        }
      }

      function buildCard(title, rows) {
        return `<article class="analysis-card panel"><h2>${escapeHtml(title)}</h2>${rows
          .filter((r) => r.title || r.desc)
          .map(
            (r) =>
              `<div class="analysis-row"><i>${escapeHtml(r.icon)}</i><div><b>${escapeHtml(r.title)}</b><span>${escapeHtml(r.desc)}</span></div></div>`,
          )
          .join("")}</article>`;
      }

      function matchRecommends(directions, allLooks) {
        // 简单关键词匹配：用 direction.title 和 palette 作为搜索词
        const keywords = directions.flatMap((d) => [
          d.title.toLowerCase(),
          ...(d.palette || []).map((p) => p.toLowerCase()),
        ]);
        return allLooks
          .map((look) => {
            const haystack = [
              look.title,
              look.intent,
              ...(look.scenarios || []),
              ...(look.finish || []),
            ]
              .join(" ")
              .toLowerCase();
            const hits = keywords.filter((kw) => haystack.includes(kw)).length;
            return {
              ...look,
              score: Math.min(95, 70 + hits * 8),
              reason: directions[0]?.rationale || "",
            };
          })
          .filter((l) => l.score > 70)
          .sort((a, b) => b.score - a.score);
      }

      // === 加载额度 ===
      async function loadQuota() {
        try {
          const res = await fetch("/api/session");
          const data = await res.json();
          if (!data.ok) return false;
          isAccountUser = data.data.user?.kind === "account";
          if (!isAccountUser) {
            quotaSnapshot = null;
            quotaCard?.classList.remove("is-exhausted");
            if (quotaText) quotaText.textContent = copy.quotaGuest;
            if (quotaNote) quotaNote.textContent = copy.quotaGuestNote;
            if (consentBox) {
              consentBox.checked = false;
              consentBox.disabled = true;
            }
            syncUploadAvailability();
            return false;
          }
          if (consentBox) consentBox.disabled = false;
          const q = data.data.quota;
          quotaSnapshot = q;
          renderQuota(q);
          if (isQuotaExhausted() && taskStatus) taskStatus.hidden = true;
          syncUploadAvailability();
          return true;
        } catch {
          return false;
        }
      }

      function escapeHtml(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      function renderHistoryEmpty() {
        if (!historyList) return;
        diagnosisMain?.classList.remove("has-account-result");
        historyList.classList.remove("has-items");
        historyList.classList.add("is-empty");
        historyList.innerHTML = `
        <div class="diag-history-empty">
          <div class="history-empty-main">
            <span class="history-empty-mark" aria-hidden="true">AI</span>
            <div>
              <b>${escapeHtml(copy.historyEmptyTitle)}</b>
              <p>${escapeHtml(copy.historyEmptyBody)}</p>
            </div>
          </div>
          <div class="history-empty-actions">
            <a class="btn btn-primary" href="#diagnosis-new">${escapeHtml(copy.historyEmptyCta)}</a>
            <a class="btn" href="${escapeHtml(discoverHref)}">${escapeHtml(copy.historyEmptySecondary)}</a>
          </div>
          <div class="history-empty-meta">
            ${copy.historyEmptyMeta
              .map(
                ([title, text]) => `
                  <span>
                    <strong>${escapeHtml(title)}</strong>
                    <small>${escapeHtml(text)}</small>
                  </span>
                `,
              )
              .join("")}
          </div>
        </div>
      `;
      }

      async function loadHistory() {
        try {
          const res = await fetch("/api/diagnoses");
          const data = await res.json();
          if (!data.ok || !data.data.items.length) {
            renderHistoryEmpty();
            return;
          }
          if (historyList) {
            historyList.classList.remove("is-empty");
            historyList.classList.add("has-items");
            historyList.innerHTML = data.data.items
              .map((item) => {
                const diagnosis = item.diagnosis;
                const title = diagnosis?.skinTone?.summary || copy.reportTitle;
                const date = new Date(item.createdAt).toLocaleDateString(
                  document.documentElement.lang || "en",
                );
                const tags = diagnosis
                  ? [
                      labelFrom(
                        valueMaps.faceShape,
                        diagnosis.faceShape?.primary,
                        "",
                      ),
                      labelFrom(
                        valueMaps.eyeShape,
                        diagnosis.eyeShape?.primary,
                        "",
                      ),
                      labelFrom(
                        valueMaps.season,
                        diagnosis.colorSeason?.season,
                        "",
                      ),
                    ].filter(Boolean)
                  : [];
                const note =
                  diagnosis?.makeupDirections?.[0]?.title ||
                  diagnosis?.colorSeason?.season ||
                  "";
                const jobId = escapeHtml(item.jobId);
                return `
                  <article class="diag-history-item" data-job-id="${jobId}">
                    <div class="diag-history-marker" aria-hidden="true">AI</div>
                    <div class="diag-history-content">
                      <div class="diag-history-head">
                        <div>
                          <b>${escapeHtml(title)}</b>
                          ${note ? `<p>${escapeHtml(note)}</p>` : ""}
                        </div>
                        <time datetime="${escapeHtml(item.createdAt)}">${escapeHtml(date)}</time>
                      </div>
                      <div class="diag-history-tags">
                        ${tags.map((tag) => `<span class="pill">${escapeHtml(tag)}</span>`).join("")}
                      </div>
                    </div>
                    <div class="diag-history-actions">
                      <button class="btn btn-sm" type="button" data-history-action="view">${escapeHtml(copy.viewDetail)}</button>
                      <button class="btn btn-sm btn-outline-rose" type="button" data-history-action="delete">${escapeHtml(copy.delete)}</button>
                    </div>
                  </article>
                `;
              })
              .join("");
          }

          const latest = data.data.items[0];
          if (!wantsNewDiagnosis && latest?.diagnosis) {
            renderDiagnosis(latest.diagnosis, latest);
          }
        } catch {
          if (historyList) {
            historyList.classList.remove("has-items");
            historyList.classList.add("is-empty");
            historyList.innerHTML = `
            <div class="diag-history-empty compact" role="alert">
              <div class="history-empty-main">
                <span class="history-empty-mark" aria-hidden="true">!</span>
                <div>
                  <b>${escapeHtml(copy.historyFailed)}</b>
                  <p>${escapeHtml(copy.historyEmptyBody)}</p>
                </div>
              </div>
            </div>
          `;
          }
        }
      }

      // 全局：查看诊断
      window.viewDiagnosis = async function (jobId) {
        try {
          const res = await fetch("/api/diagnoses");
          const data = await res.json();
          if (!data.ok) return;
          const item = data.data.items.find((i) => i.jobId === jobId);
          if (item?.diagnosis) renderDiagnosis(item.diagnosis, item);
          window.scrollTo({ top: 0, behavior: "smooth" });
        } catch {
          /* ignore */
        }
      };

      // 全局：删除诊断
      window.deleteDiagnosis = async function (jobId) {
        const confirmed =
          typeof window.absConfirm === "function"
            ? await window.absConfirm(copy.confirmDelete, { variant: "danger" })
            : confirm(copy.confirmDelete);
        if (!confirmed) return;
        try {
          await fetch("/api/tryon-jobs/" + jobId, { method: "DELETE" });
          loadHistory();
        } catch {
          /* ignore */
        }
      };

      historyList?.addEventListener("click", (event) => {
        if (!(event.target instanceof Element)) return;
        const actionButton = event.target.closest("[data-history-action]");
        if (!actionButton || !historyList.contains(actionButton)) return;

        const historyItem = actionButton.closest(".diag-history-item");
        const jobId = historyItem?.getAttribute("data-job-id");
        if (!jobId) return;

        const action = actionButton.getAttribute("data-history-action");
        if (action === "view") window.viewDiagnosis(jobId);
        if (action === "delete") window.deleteDiagnosis(jobId);
      });

      // === 初始化 ===
      loadQuota().then((accountUser) => {
        if (accountUser) loadHistory();
        else renderHistoryEmpty();
      });
    })();
  </script>

  <style>
    :global(.diagnosis-body) {
      --diagnosis-outcome-card-bg:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.86),
          rgba(255, 255, 255, 0.7)
        ),
        rgba(255, 255, 255, 0.72);
      --diagnosis-outcome-card-border: rgba(223, 229, 238, 0.92);
      --diagnosis-outcome-card-copy: var(--text);
      --diagnosis-outcome-card-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.8),
        0 12px 28px rgba(26, 49, 84, 0.05);
      --diagnosis-outcome-card-hover-border: rgba(21, 151, 140, 0.26);
      --diagnosis-outcome-card-hover-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.9),
        0 16px 34px rgba(26, 49, 84, 0.08);
      --diagnosis-outcome-card-wash:
        radial-gradient(
          circle at 18px 0,
          rgba(21, 151, 140, 0.14),
          transparent 36%
        ),
        linear-gradient(
          135deg,
          rgba(21, 151, 140, 0.07),
          transparent 48%,
          rgba(200, 62, 104, 0.05)
        );
      --diagnosis-outcome-mark-bg: var(--teal-soft);
      --diagnosis-outcome-mark-border: rgba(21, 151, 140, 0.14);
      --diagnosis-outcome-mark-color: var(--teal);
      --diagnosis-outcome-mark-shadow: none;
      background:
        linear-gradient(
          180deg,
          rgba(255, 248, 246, 0.9),
          rgba(248, 252, 252, 0.72) 42%,
          var(--page-surface)
        ),
        var(--page-surface);
    }
    :global([data-theme="dark"] .diagnosis-body) {
      --diagnosis-outcome-card-bg:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.075),
          rgba(255, 255, 255, 0.035)
        ),
        rgba(18, 26, 39, 0.86);
      --diagnosis-outcome-card-border: rgba(255, 255, 255, 0.12);
      --diagnosis-outcome-card-copy: var(--body-secondary);
      --diagnosis-outcome-card-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.07), 0 18px 42px rgba(0, 0, 0, 0.28);
