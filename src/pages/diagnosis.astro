      border: 1px solid rgba(255, 255, 255, 0.62);
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.7);
    }
    .report-preview-stats small {
      display: block;
      color: var(--muted);
      font-size: 11px;
    }
    .report-preview-stats b {
      display: block;
      margin-top: 4px;
      color: var(--heading);
      font-size: 13px;
    }
    .report-preview-summary ul {
      display: grid;
      gap: 6px;
      margin: 0;
      padding: 0;
      list-style: none;
    }
    .report-preview-summary li {
      position: relative;
      padding-left: 18px;
      color: var(--text);
      font-size: 12px;
      line-height: 1.5;
    }
    .report-preview-summary li::before {
      content: "";
      position: absolute;
      top: 0.72em;
      left: 0;
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--teal);
    }
    :global([data-theme="dark"]) .report-preview-overlay {
      border-color: rgba(255, 255, 255, 0.16);
      background: rgba(15, 23, 35, 0.84);
      box-shadow: 0 20px 44px rgba(0, 0, 0, 0.34);
    }
    :global([data-theme="dark"]) .report-preview-stats div {
      border-color: rgba(255, 255, 255, 0.13);
      background: rgba(255, 255, 255, 0.07);
    }
    :global([data-theme="dark"]) .report-preview-summary {
      background:
        linear-gradient(135deg, rgba(62, 201, 189, 0.1), transparent 52%),
