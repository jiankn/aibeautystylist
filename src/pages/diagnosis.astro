      color: var(--rose);
      font-size: 12px;
      font-weight: 800;
    }
    .diagnosis-hero {
      display: grid;
      grid-template-columns: minmax(0, 0.98fr) minmax(360px, 0.62fr);
      gap: clamp(24px, 4vw, 54px);
