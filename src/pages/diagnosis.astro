    .diagnosis-report-preview {
      position: relative;
      display: grid;
      justify-self: end;
      width: min(100%, 500px);
      overflow: hidden;
      border-radius: 22px;
      background: var(--bg-elevated);
      box-shadow: 0 20px 54px rgba(82, 38, 48, 0.14);
    }
    .report-preview-media {
      position: relative;
      aspect-ratio: 4 / 3.25;
      overflow: hidden;
      background: var(--soft);
    }
    .report-preview-media::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(
        180deg,
        rgba(8, 18, 34, 0.02) 38%,
        rgba(8, 18, 34, 0.32) 66%,
        rgba(8, 18, 34, 0.58)
      );
      pointer-events: none;
    }
    .report-preview-media img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: 50% 34%;
    }
    .report-preview-overlay {
      position: absolute;
      right: 14px;
      bottom: 14px;
      left: 14px;
      z-index: 1;
      display: grid;
      gap: 9px;
      padding: 12px;
      border: 1px solid rgba(255, 255, 255, 0.54);
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.84);
      box-shadow: 0 16px 34px rgba(9, 20, 35, 0.16);
      backdrop-filter: blur(18px) saturate(150%);
      -webkit-backdrop-filter: blur(18px) saturate(150%);
    }
    .report-preview-label {
      width: fit-content;
      color: var(--rose);
      font-size: 12px;
      font-weight: 900;
