    }
    :global([data-theme="dark"]) .diagnosis-result-chips span {
      border-color: rgba(255, 255, 255, 0.13);
      background: rgba(255, 255, 255, 0.07);
    }
    @media (prefers-color-scheme: dark) {
      :global(:root:not([data-theme="light"])) .report-preview-overlay {
        border-color: rgba(255, 255, 255, 0.16);
        background: rgba(15, 23, 35, 0.84);
        box-shadow: 0 20px 44px rgba(0, 0, 0, 0.34);
      }
      :global(:root:not([data-theme="light"])) .report-preview-stats div {
        border-color: rgba(255, 255, 255, 0.13);
        background: rgba(255, 255, 255, 0.07);
      }
      :global(:root:not([data-theme="light"])) .report-preview-summary {
        background:
          linear-gradient(135deg, rgba(62, 201, 189, 0.1), transparent 52%),
