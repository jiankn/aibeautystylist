            class="btn btn-primary"
            href="#diagnosis-new"
            data-diagnosis-history-cta
            hidden
          >
            {diagnosisCopy.historyNewCta}
          </a>
        </div>
        <div
          id="diag-history-list"
          class="diag-history-list"
          aria-live="polite"
        >
          <div class="diag-history-skeleton" role="status">
