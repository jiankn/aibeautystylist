---
import MobileBottomNav from "../components/MobileBottomNav.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { getLocalizedAppHref, resolveLocaleRoute } from "../i18n/routing";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCurrentLocale } from "../lib/i18n";
import {
  REFERENCE_TRYON_POLL_INTERVAL_MS,
  REFERENCE_TRYON_POLL_MAX_ATTEMPTS,
} from "../lib/referenceTryOn";
import { PRIVATE_REFERENCE_TRYON_CREDIT_COST } from "../lib/tryonCosts";
import { PHOTO_CONSENT_VERSION } from "../lib/uploads";

const locale = getCurrentLocale();
const isZh = locale.startsWith("zh");
const currentPathname = Astro.originPathname || Astro.url.pathname;
const currentRoute =
  Astro.locals.localeRoute ?? resolveLocaleRoute(currentPathname);
const localizeAppHref = (href: string) =>
  getLocalizedAppHref(href, currentRoute.language.slug);
const pageHref = localizeAppHref("/reference-tryon");
const copy = isZh
  ? {
      title: "参考图试妆 · Premium | AI Beauty Stylist",
      description:
        "上传喜欢的妆容参考图和自己的自拍，私有生成妆容上脸效果。仅限 Premium 用户。",
      eyebrow: "Premium 私有功能",
      heading: "把喜欢的妆容，试到自己的脸上",
      intro:
        "参考图只提供妆容颜色、位置和质感；自拍是唯一身份来源。生成结果和参考图默认只有你能看到。",
      referenceTitle: "1. 选择妆容参考",
      referenceHelp: "清晰单人正脸、妆容完整、无遮挡的图片效果最好。",
      referenceLabel: "上传新的参考图",
      referenceFormat: "JPG、PNG 或 WebP，上传后自动压缩至 4MB 以内",
      referenceRequired: "请上传一张妆容参考图，或选择一个已保存的参考妆容。",
      referenceInvalid:
        "参考图无法处理，请重新选择清晰的 JPG、PNG 或 WebP 图片。",
      referenceTooLarge: "参考图压缩后仍超过 4MB，请换一张尺寸更小的图片。",
      templateCreateFailed: "参考妆容暂时无法保存，请检查网络后重试。",
      templateName: "模板名称（可选）",
      templatePlaceholder: "例如：暖棕烟熏妆",
      savedTitle: "或者使用已保存的参考妆容",
      noSaved: "还没有保存的参考妆容。",
      templateLoadFailed: "已保存的参考妆容暂时无法加载，你仍可上传新图片。",
      selfieTitle: "2. 上传自己的自拍",
      selfieHelp: "请使用自然光、正脸、面部无遮挡的清晰自拍。",
      selfieLabel: "选择自拍",
      selfieFormat: "JPG、PNG 或 WebP，上传后自动优化",
      selfieRequired: "请上传一张自己的清晰正脸自拍。",
      selfieInvalid: "自拍无法处理，请重新选择清晰的 JPG、PNG 或 WebP 图片。",
      selfieUploadFailed: "自拍暂时无法上传，请检查网络后重试。",
      rights: "我确认有权将参考图片用于个人私有试妆，不会用于公开传播。",
      rightsRequired: "请确认你有权将这张参考图用于个人私有试妆。",
      consent: "我同意按照照片处理说明上传自拍并生成试妆结果。",
      consentRequired: "请先同意照片处理说明。",
      generate: "生成我的参考图试妆",
      generating: "正在准备照片并创建私有试妆任务…",
      generatingButton: "正在创建任务…",
      loadingAccount: "正在检查账户与会员状态…",
      retry: "重新加载",
      fixErrors: "请先修正上方标出的内容。",
      costNote:
        "本次生成消耗 2 次额度，通常需要 1–3 分钟；失败、取消或超时会自动返还。",
      costWithQuota:
        "本次生成消耗 2 次额度，当前剩余 {remaining}/{total}；通常需要 1–3 分钟，失败、取消或超时会自动返还。",
      noCredits: "当前额度不足 2 次，请先购买额度后再继续。",
      buyCredits: "购买额度",
      backgroundTitle: "参考图私有试妆",
      backgroundRunning: "任务正在后台生成，你可以继续浏览；完成后会通知你。",
      backgroundNetwork:
        "任务已创建，但当前网络不稳定。任务会继续在后台运行，请从任务卡片或历史记录查看结果。",
      viewProgress: "查看任务进度",
      privacyTitle: "默认私有",
      privacy:
        "参考图存放在私有空间，不进入 Discover，也不提供公开分享。你可以随时删除模板和生成记录。",
      loginTitle: "登录后使用参考图试妆",
      loginBody: "此功能需要登录，并且只向 Premium 用户开放。",
      loginCta: "登录",
      premiumTitle: "这是 Premium 专属功能",
      premiumBody:
        "Pro 可以使用妆容库试妆；Premium 额外支持上传任意参考妆容并私有复刻。",
      premiumCta: "查看 Premium 权益",
      manageExisting: "管理以前保存的私有参考妆容",
      resultTitle: "你的私有试妆已完成",
      resultNote:
        "结果仅供妆容方向参考，真实产品质感会受到光线和上妆方式影响。",
      history: "查看历史记录",
      again: "继续试另一个妆容",
      delete: "删除",
      deleting: "正在删除…",
      deleteConfirm: "删除后无法恢复。确定删除这个私有参考妆容吗？",
      deleteFailed: "删除失败，请检查网络后重试。",
      deleted: "私有参考妆容已删除。",
      selected: "已选择",
      failed: "生成失败，额度已自动返还，请检查图片后重试。",
      qualityFailed:
        "生成妆效与参考妆容差异过大，系统已自动重试并返还额度。请换一张妆容特征更清晰的参考图后重试。",
      cancelled: "任务已取消，额度已自动返还。你可以修改图片后重新生成。",
      timedOut: "任务处理超时，额度已自动返还。请稍后重试。",
      createFailed: "暂时无法创建生成任务，请检查网络后重试。",
      requestChanged:
        "所选参考妆容或自拍已发生变化，请确认当前选择后重新生成。",
      loadFailed: "暂时无法加载账户信息，请重试。",
    }
  : {
      title: "Reference Makeup Try-On · Premium | AI Beauty Stylist",
      description:
        "Upload a makeup reference and your selfie to privately generate the look on your own face. Available with Premium.",
      eyebrow: "Premium private feature",
      heading: "Try any makeup reference on your own face",
      intro:
        "The reference supplies makeup color, placement, and finish. Your selfie remains the only identity source. References and results stay private to your account.",
      referenceTitle: "1. Choose a makeup reference",
      referenceHelp:
        "A clear, front-facing photo with one visible face and complete makeup works best.",
      referenceLabel: "Upload a new reference",
      referenceFormat: "JPG, PNG, or WebP; automatically compressed below 4 MB",
      referenceRequired:
        "Upload a makeup reference or choose one of your saved references.",
      referenceInvalid:
        "We could not process this reference. Choose a clear JPG, PNG, or WebP image.",
      referenceTooLarge:
        "The compressed reference is still over 4 MB. Choose a smaller image.",
      templateCreateFailed:
        "Unable to save this reference. Check your connection and retry.",
      templateName: "Template name (optional)",
      templatePlaceholder: "Example: warm brown smoky eye",
      savedTitle: "Or reuse a saved private reference",
      noSaved: "You have no saved private references yet.",
      templateLoadFailed:
        "Saved references are temporarily unavailable. You can still upload a new image.",
      selfieTitle: "2. Upload your selfie",
      selfieHelp:
        "Use a clear, front-facing selfie in natural light with no face obstruction.",
      selfieLabel: "Choose selfie",
      selfieFormat: "JPG, PNG, or WebP; automatically optimized after upload",
      selfieRequired: "Upload a clear, front-facing selfie of yourself.",
      selfieInvalid:
        "We could not process this selfie. Choose a clear JPG, PNG, or WebP image.",
      selfieUploadFailed:
        "Unable to upload this selfie. Check your connection and retry.",
      rights:
        "I have the right to use this reference for personal, private try-on and will not publish it.",
      rightsRequired:
        "Confirm that you have the right to use this reference for private try-on.",
      consent:
        "I agree to the photo processing notice for uploading my selfie and generating this result.",
      consentRequired:
        "Agree to the photo processing notice before generating.",
      generate: "Generate my reference try-on",
      generating: "Preparing your photos and creating a private try-on task…",
      generatingButton: "Creating task…",
      loadingAccount: "Checking your account and membership…",
      retry: "Try again",
      fixErrors: "Correct the highlighted items above.",
      costNote:
        "Uses 2 generation credits and usually takes 1–3 minutes. Failed, canceled, or timed-out tasks return both credits automatically.",
      costWithQuota:
        "Uses 2 generation credits. {remaining}/{total} remaining. Usually takes 1–3 minutes; failed, canceled, or timed-out tasks return both credits automatically.",
      noCredits:
        "You need at least 2 generation credits. Buy credits to continue.",
      buyCredits: "Buy credits",
      backgroundTitle: "Private reference try-on",
      backgroundRunning:
        "Your task is generating in the background. You can keep browsing and we will notify you when it is ready.",
      backgroundNetwork:
        "The task was created, but the connection is unstable. It will continue in the background; check the task card or history for the result.",
      viewProgress: "View task progress",
      privacyTitle: "Private by default",
      privacy:
        "References stay in private storage, never enter Discover, and cannot be publicly shared. Delete templates and results whenever you want.",
      loginTitle: "Sign in to use reference try-on",
      loginBody: "This feature requires an account and a Premium plan.",
      loginCta: "Sign in",
      premiumTitle: "Premium exclusive",
      premiumBody:
        "Pro includes catalog try-on. Premium additionally lets you upload any makeup reference and privately transfer it to your selfie.",
      premiumCta: "View Premium benefits",
      manageExisting: "Manage previously saved private references",
      resultTitle: "Your private try-on is ready",
      resultNote:
        "Use this as a makeup direction. Real product texture varies with lighting, skin preparation, and application.",
      history: "View history",
      again: "Try another reference",
      delete: "Delete",
      deleting: "Deleting…",
      deleteConfirm:
        "This cannot be undone. Delete this private makeup reference?",
      deleteFailed:
        "Unable to delete this reference. Check your connection and retry.",
      deleted: "Private reference deleted.",
      selected: "Selected",
      failed:
        "Generation failed and the credit was returned. Check both photos and try again.",
      qualityFailed:
        "The generated makeup differed too much from the reference after an automatic retry. Your credit was returned; use a clearer reference and try again.",
      cancelled:
        "The task was canceled and the credit was returned. Adjust the photos and try again.",
      timedOut:
        "The task timed out and the credit was returned. Please try again later.",
      createFailed:
        "Unable to create the generation task. Check your connection and retry.",
      requestChanged:
        "The selected reference or selfie changed. Confirm the current selection and generate again.",
      loadFailed: "Unable to load your account. Try again.",
    };

const pricingHref = localizeAppHref("/pricing");
const hrefs = {
  login: localizeAppHref(
    `/login?mode=login&next=${encodeURIComponent(pageHref)}`,
  ),
  pricing: `${pricingHref}?return_to=${encodeURIComponent(pageHref)}#pricing-comparison`,
  history: localizeAppHref("/history"),
  page: pageHref,
  resultBase: localizeAppHref("/result"),
  credits: `${localizeAppHref("/subscription")}#credit-packs`,
};
---

<BaseLayout
  title={copy.title}
  description={copy.description}
  bodyClass="reference-tryon-body"
  robots="noindex,follow"
>
  <SiteHeader active="tryOn" />
  <main
    class="reference-tryon-main"
    data-reference-tryon
    data-photo-consent-version={PHOTO_CONSENT_VERSION}
  >
    <!-- 背景装饰光晕 -->
    <div class="rt-glow rt-glow--rose" aria-hidden="true"></div>
    <div class="rt-glow rt-glow--gold" aria-hidden="true"></div>

    <section class="reference-hero">
      <div>
        <span class="rt-eyebrow">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            ><polygon
              points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
            ></polygon></svg
          >
          {copy.eyebrow}
        </span>
        <h1>{copy.heading}</h1>
        <p>{copy.intro}</p>
      </div>
      <aside class="rt-privacy-card">
        <svg
          class="rt-privacy-icon"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          ><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path
            d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg
        >
        <strong>{copy.privacyTitle}</strong>
        <p>{copy.privacy}</p>
      </aside>
    </section>

    <!-- 加载/检查账户状态 -->
    <section
      class="reference-state"
      data-loading-state
      role="status"
      aria-live="polite"
    >
      <div class="rt-loader-ring" data-loading-spinner aria-hidden="true">
        <svg viewBox="0 0 80 80" width="64" height="64">
          <circle
            cx="40"
            cy="40"
            r="34"
            fill="none"
            stroke="var(--line)"
            stroke-width="4"
            opacity="0.3"></circle>
          <circle
            class="rt-loader-arc"
            cx="40"
            cy="40"
            r="34"
            fill="none"
            stroke="url(#rt-grad)"
            stroke-width="4"
            stroke-linecap="round"
            stroke-dasharray="160 54"></circle>
          <defs
            ><linearGradient id="rt-grad" x1="0%" y1="0%" x2="100%" y2="0%"
              ><stop offset="0%" stop-color="var(--rose)"></stop><stop
                offset="100%"
                stop-color="var(--gold)"></stop></linearGradient
            ></defs
          >
        </svg>
      </div>
      <p data-loading-message>{copy.loadingAccount}</p>
      <button class="btn btn-outline" type="button" data-loading-retry hidden>
        {copy.retry}
      </button>
    </section>

    <!-- 登录门控 -->
    <section class="reference-gate" data-login-gate hidden>
      <svg
        class="rt-gate-icon"
        width="48"
        height="48"
        viewBox="0 0 24 24"
        fill="none"
        stroke="var(--rose)"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle
          cx="12"
          cy="7"
          r="4"></circle></svg
      >
      <h2>{copy.loginTitle}</h2>
      <p>{copy.loginBody}</p>
      <a class="btn btn-primary" href={hrefs.login}>{copy.loginCta}</a>
    </section>

    <!-- Premium 门控 -->
    <section class="reference-gate reference-premium" data-premium-gate hidden>
      <span>Premium</span>
      <h2>{copy.premiumTitle}</h2>
      <p>{copy.premiumBody}</p>
      <a class="btn btn-gold" href={hrefs.pricing}>{copy.premiumCta}</a>
      <div class="premium-template-manager" data-template-manager hidden>
        <h3>{copy.manageExisting}</h3>
        <div class="saved-reference-list" data-template-list></div>
        <p class="saved-reference-status" data-template-status role="status">
        </p>
      </div>
    </section>

    <!-- 主工作流表单 -->
    <form class="reference-workflow" data-reference-form hidden novalidate>
      <!-- 步骤进度条 -->
      <nav class="rt-stepper" aria-label="Progress">
        <div class="rt-stepper-node rt-stepper-node--active" data-step-node="1">
          <span class="rt-stepper-dot">1</span>
          <span class="rt-stepper-label">{isZh ? "选择参考" : "Reference"}</span
          >
        </div>
        <div class="rt-stepper-line">
          <span class="rt-stepper-line-fill"></span>
        </div>
        <div class="rt-stepper-node" data-step-node="2">
          <span class="rt-stepper-dot">2</span>
          <span class="rt-stepper-label">{isZh ? "上传自拍" : "Selfie"}</span>
        </div>
        <div class="rt-stepper-line">
          <span class="rt-stepper-line-fill"></span>
        </div>
        <div class="rt-stepper-node" data-step-node="3">
          <span class="rt-stepper-dot">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg
            >
          </span>
          <span class="rt-stepper-label">{isZh ? "生成妆效" : "Generate"}</span>
        </div>
      </nav>

      <!-- 步骤 1：选择妆容参考 -->
      <section class="reference-step rt-glass-card">
        <div class="reference-step-heading">
          <div>
            <h2>{copy.referenceTitle}</h2>
            <p>{copy.referenceHelp}</p>
          </div>
          <span class="rt-step-number">01</span>
        </div>
        <div class="reference-upload-grid">
          <label class="reference-dropzone">
            <input
              type="file"
              accept="image/jpeg,image/png,image/webp"
              aria-describedby="reference-file-help reference-file-error"
              data-reference-input
            />
            <svg
              class="rt-upload-icon"
              width="40"
              height="40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><rect x="3" y="3" width="18" height="18" rx="2" ry="2"
              ></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline
                points="21 15 16 10 5 21"></polyline></svg
            >
            <span>{copy.referenceLabel}</span>
            <small id="reference-file-help">{copy.referenceFormat}</small>
            <img data-reference-preview alt="" hidden />
          </label>
          <label class="reference-name">
            <span>{copy.templateName}</span>
            <input
              type="text"
              maxlength="60"
              placeholder={copy.templatePlaceholder}
              data-template-title
            />
          </label>
        </div>
        <p
          class="reference-field-error"
          id="reference-file-error"
          data-error="reference"
          role="alert"
          hidden
        >
        </p>
        <label class="reference-check">
          <input
            type="checkbox"
            aria-describedby="reference-rights-error"
            data-rights-check
          />
          <span>{copy.rights}</span>
        </label>
        <p
          class="reference-field-error"
          id="reference-rights-error"
          data-error="rights"
          role="alert"
          hidden
        >
        </p>
        <div class="saved-reference-block">
          <h3>{copy.savedTitle}</h3>
          <div class="saved-reference-list" data-template-list>
            <p>{copy.noSaved}</p>
          </div>
          <p class="saved-reference-status" data-template-status role="status">
          </p>
        </div>
      </section>

      <!-- 步骤 2：上传自拍 -->
      <section class="reference-step rt-glass-card">
        <div class="reference-step-heading">
          <div>
            <h2>{copy.selfieTitle}</h2>
            <p>{copy.selfieHelp}</p>
          </div>
          <span class="rt-step-number">02</span>
        </div>
        <label class="reference-dropzone reference-selfie">
          <input
            type="file"
            accept="image/jpeg,image/png,image/webp"
            aria-describedby="selfie-file-help selfie-file-error"
            data-selfie-input
            required
          />
          <svg
            class="rt-upload-icon rt-upload-icon--selfie"
            width="40"
            height="40"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            ><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle
              cx="12"
              cy="7"
              r="4"></circle></svg
          >
          <span>{copy.selfieLabel}</span>
          <small id="selfie-file-help">{copy.selfieFormat}</small>
          <img data-selfie-preview alt="" hidden />
        </label>
        <p
          class="reference-field-error"
          id="selfie-file-error"
          data-error="selfie"
          role="alert"
          hidden
        >
        </p>
        <label class="reference-check">
          <input
            type="checkbox"
            aria-describedby="selfie-consent-error"
            data-consent-check
            required
          />
          <span>{copy.consent}</span>
        </label>
        <p
          class="reference-field-error"
          id="selfie-consent-error"
          data-error="consent"
          role="alert"
          hidden
        >
        </p>
      </section>

      <!-- 生成按钮区域 -->
      <div class="reference-submit">
        <p class="reference-cost-note" data-cost-note>{copy.costNote}</p>
        <a
          class="reference-credit-link"
          href={hrefs.credits}
          data-credit-link
          hidden
        >
          {copy.buyCredits}
        </a>
        <button class="btn rt-generate-btn" type="submit" data-generate>
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            ><path
              d="M12 3v1m0 16v1m-8-9H3m18 0h-1M5.6 5.6l.7.7m12.1 12.1l.7.7M5.6 18.4l.7-.7M18.4 5.6l.7-.7"
            ></path><circle cx="12" cy="12" r="4"></circle></svg
          >
          {copy.generate}
        </button>
        <p data-reference-status role="status"></p>
        <a
          class="reference-progress-link"
          href={hrefs.history}
          data-progress-link
          hidden
        >
          {copy.viewProgress}
        </a>
      </div>
    </form>

    <!-- 结果展示 -->
    <section class="reference-result" data-result hidden>
      <div class="reference-result-info">
        <span class="rt-result-badge">Premium · Private</span>
        <h2>{copy.resultTitle}</h2>
        <p>{copy.resultNote}</p>
        <div class="reference-result-actions">
          <a class="btn btn-primary" href={hrefs.history}>{copy.history}</a>
          <button class="btn btn-outline" type="button" data-again>
            {copy.again}
          </button>
        </div>
      </div>
      <figure class="reference-result-figure">
        <img data-result-image alt={copy.resultTitle} />
      </figure>
    </section>
  </main>
  <MobileBottomNav active="tryon" />

  <script
    is:inline
    define:vars={{
      copy,
      hrefs,
      isZh,
      pollIntervalMs: REFERENCE_TRYON_POLL_INTERVAL_MS,
      pollMaxAttempts: REFERENCE_TRYON_POLL_MAX_ATTEMPTS,
      privateReferenceCreditCost: PRIVATE_REFERENCE_TRYON_CREDIT_COST,
    }}
  >
    (() => {
      const root = document.querySelector("[data-reference-tryon]");
      if (!root) return;
      const loading = root.querySelector("[data-loading-state]");
      const loadingSpinner = root.querySelector("[data-loading-spinner]");
      const loadingMessage = root.querySelector("[data-loading-message]");
      const loadingRetry = root.querySelector("[data-loading-retry]");
      const loginGate = root.querySelector("[data-login-gate]");
      const premiumGate = root.querySelector("[data-premium-gate]");
      const form = root.querySelector("[data-reference-form]");
      const result = root.querySelector("[data-result]");
      const status = root.querySelector("[data-reference-status]");
      const progressLink = root.querySelector("[data-progress-link]");
      const generate = root.querySelector("[data-generate]");
      const referenceInput = root.querySelector("[data-reference-input]");
      const selfieInput = root.querySelector("[data-selfie-input]");
      const referencePreview = root.querySelector("[data-reference-preview]");
      const selfiePreview = root.querySelector("[data-selfie-preview]");
      const rightsCheck = root.querySelector("[data-rights-check]");
      const consentCheck = root.querySelector("[data-consent-check]");
      const templateTitle = root.querySelector("[data-template-title]");
      const costNote = root.querySelector("[data-cost-note]");
      const creditLink = root.querySelector("[data-credit-link]");
      const errorNodes = Object.fromEntries(
        Array.from(root.querySelectorAll("[data-error]")).map((node) => [
          node.dataset.error,
          node,
        ]),
      );
      const errorControls = {
        reference: referenceInput,
        rights: rightsCheck,
        selfie: selfieInput,
        consent: consentCheck,
      };
      const templateLists = Array.from(
        root.querySelectorAll("[data-template-list]"),
      );
      const templateStatuses = Array.from(
        root.querySelectorAll("[data-template-status]"),
      );
      const templateManager = root.querySelector("[data-template-manager]");
      let selectedTemplateId = "";
      let templates = [];
      let isPremium = false;
      let quotaExhausted = false;
      let activeJobId = "";
      let pendingTemplateId = "";
      let pendingUploadId = "";
      let pendingIdempotencyKey = "";

      /* ── 步骤进度条管理 ── */
      const stepperNodes = [
        root.querySelector('[data-step-node="1"]'),
        root.querySelector('[data-step-node="2"]'),
        root.querySelector('[data-step-node="3"]'),
      ];
      const stepperLines = root.querySelectorAll(".rt-stepper-line");

      function updateStepper() {
        const hasRef = !!(selectedTemplateId || referenceInput.files?.[0]);
        const hasSelfie = !!selfieInput.files?.[0];
        const currentStep = !hasRef ? 1 : !hasSelfie ? 2 : 3;

        stepperNodes.forEach((node, i) => {
          if (!node) return;
          const step = i + 1;
          node.classList.toggle(
            "rt-stepper-node--active",
            step === currentStep,
          );
          node.classList.toggle("rt-stepper-node--done", step < currentStep);
        });
        stepperLines.forEach((line, i) => {
          if (!line) return;
          const filled = i < currentStep - 1;
          line.classList.toggle("rt-stepper-line--active", filled);
        });
      }

      const showOnly = (target) => {
        [loading, loginGate, premiumGate, form, result].forEach((node) => {
          if (node) node.hidden = node !== target;
        });
      };

      function setLoadingState(message, failed = false) {
        showOnly(loading);
        if (loadingMessage) loadingMessage.textContent = message;
        if (loadingSpinner) loadingSpinner.hidden = failed;
        if (loadingRetry) loadingRetry.hidden = !failed;
      }

      function setTemplateStatus(message) {
        templateStatuses.forEach((node) => {
          node.textContent = message;
        });
      }

      function clearFieldError(field) {
        const node = errorNodes[field];
        const control = errorControls[field];
        if (node) {
          node.textContent = "";
          node.hidden = true;
        }
        control?.removeAttribute("aria-invalid");
      }

      function clearFieldErrors() {
        Object.keys(errorNodes).forEach(clearFieldError);
      }

      function markFieldError(field, message) {
        const node = errorNodes[field];
        const control = errorControls[field];
        if (node) {
          node.textContent = message;
          node.hidden = false;
        }
        control?.setAttribute("aria-invalid", "true");
      }

      function fieldError(field, message) {
        const error = new Error(message);
        error.field = field;
        return error;
      }

      function focusField(field) {
        errorControls[field]?.focus();
      }

      function validateForm() {
        clearFieldErrors();
        const failures = [];
        if (!selectedTemplateId && !referenceInput.files?.[0]) {
          failures.push(["reference", copy.referenceRequired]);
        }
        if (!selectedTemplateId && !rightsCheck.checked) {
          failures.push(["rights", copy.rightsRequired]);
        }
        if (!selfieInput.files?.[0]) {
          failures.push(["selfie", copy.selfieRequired]);
        }
        if (!consentCheck.checked) {
          failures.push(["consent", copy.consentRequired]);
        }
        failures.forEach(([field, message]) => markFieldError(field, message));
        if (failures.length) {
          status.textContent = copy.fixErrors;
          focusField(failures[0][0]);
          return false;
        }
        return true;
      }

      function setGenerating(active) {
        generate.disabled = active || quotaExhausted;
        generate.setAttribute("aria-busy", String(active));
        generate.textContent = active ? copy.generatingButton : copy.generate;
      }

      function updateQuota(quota) {
        const remaining = Number(quota?.remaining);
        const total = Number(quota?.total);
        const hasQuota =
          Number.isFinite(remaining) &&
          Number.isFinite(total) &&
          remaining >= 0 &&
          total >= 0;
        quotaExhausted =
          hasQuota && remaining < Number(privateReferenceCreditCost || 2);
        if (costNote) {
          costNote.textContent = quotaExhausted
            ? copy.noCredits
            : hasQuota
              ? copy.costWithQuota
                  .replace("{remaining}", String(remaining))
                  .replace("{total}", String(total))
              : copy.costNote;
        }
        if (creditLink) creditLink.hidden = !quotaExhausted;
        setGenerating(false);
      }

      function apiError(body, fallback) {
        const message =
          isZh && body?.error?.message ? body.error.message : fallback;
        const error = new Error(message || copy.createFailed);
        error.code = body?.error?.code || "";
        return error;
      }

      async function readJson(response, fallback) {
        const body = await response.json().catch(() => null);
        if (!response.ok || !body?.ok) {
          throw apiError(body, fallback);
        }
        return body.data;
      }

      async function loadSession() {
        setLoadingState(copy.loadingAccount);
        setTemplateStatus("");
        try {
          const data = await readJson(
            await fetch("/api/session"),
            copy.loadFailed,
          );
          if (data?.user?.kind !== "account") {
            showOnly(loginGate);
            return;
          }
          updateQuota(data.quota);
          isPremium = data.plan === "premium";
          if (data.plan !== "premium") {
            showOnly(premiumGate);
            try {
              await loadTemplates();
              if (templateManager)
                templateManager.hidden = templates.length === 0;
            } catch {
              if (templateManager) templateManager.hidden = false;
              setTemplateStatus(copy.templateLoadFailed);
            }
            return;
          }
          showOnly(form);
          updateStepper();
          try {
            await loadTemplates();
          } catch {
            templates = [];
            renderTemplates();
            setTemplateStatus(copy.templateLoadFailed);
          }
        } catch {
          setLoadingState(copy.loadFailed, true);
        }
      }

      async function loadTemplates() {
        const data = await readJson(
          await fetch("/api/private-look-templates"),
          copy.templateLoadFailed,
        );
        templates = data.items || [];
        renderTemplates();
      }

      function renderTemplates() {
        templateLists.forEach((templateList) => {
          templateList.replaceChildren();
          if (!templates.length) {
            const empty = document.createElement("p");
            empty.textContent = copy.noSaved;
            templateList.append(empty);
            return;
          }
          templates.forEach((template) => {
            const card = document.createElement("article");
            card.className = "saved-reference-card";
            card.dataset.selected = String(template.id === selectedTemplateId);

            const choose = document.createElement("button");
            choose.type = "button";
            choose.className = "saved-reference-choose";
            choose.disabled = !isPremium;
            choose.setAttribute(
              "aria-pressed",
              String(template.id === selectedTemplateId),
            );
            const image = document.createElement("img");
            image.src = template.image;
            image.alt = template.title;
            const title = document.createElement("strong");
            title.textContent = template.title;
            const state = document.createElement("small");
            state.textContent =
              template.id === selectedTemplateId ? copy.selected : "";
            choose.append(image, title, state);
            choose.addEventListener("click", () => {
              if (!isPremium) return;
              if (selectedTemplateId !== template.id) {
                pendingIdempotencyKey = "";
              }
              selectedTemplateId = template.id;
              pendingTemplateId = template.id;
              referenceInput.value = "";
              referencePreview.hidden = true;
              rightsCheck.checked = false;
              clearFieldError("reference");
              clearFieldError("rights");
              renderTemplates();
              updateStepper();
            });

            const remove = document.createElement("button");
            remove.type = "button";
            remove.className = "saved-reference-delete";
            remove.textContent = copy.delete;
            remove.setAttribute(
              "aria-label",
              `${copy.delete}: ${template.title}`,
            );
            remove.addEventListener("click", async () => {
              const confirmed =
                typeof window.absConfirm === "function"
                  ? await window.absConfirm(copy.deleteConfirm, {
                      variant: "danger",
                    })
                  : window.confirm(copy.deleteConfirm);
              if (!confirmed) return;
              setTemplateStatus("");
              remove.disabled = true;
              remove.textContent = copy.deleting;
              try {
                await readJson(
                  await fetch(
                    `/api/private-look-templates/${encodeURIComponent(template.id)}`,
                    { method: "DELETE" },
                  ),
                  copy.deleteFailed,
                );
                templates = templates.filter((item) => item.id !== template.id);
                if (selectedTemplateId === template.id) selectedTemplateId = "";
                if (pendingTemplateId === template.id) pendingTemplateId = "";
                if (templateManager) {
                  templateManager.hidden = templates.length === 0;
                }
                renderTemplates();
                setTemplateStatus(copy.deleted);
              } catch (error) {
                setTemplateStatus(error?.message || copy.deleteFailed);
                remove.disabled = false;
                remove.textContent = copy.delete;
              }
            });
            card.append(choose, remove);
            templateList.append(card);
          });
        });
      }

      function previewFile(input, image) {
        const file = input.files?.[0];
        if (image.dataset.objectUrl) {
          URL.revokeObjectURL(image.dataset.objectUrl);
          delete image.dataset.objectUrl;
        }
        if (!file) {
          image.hidden = true;
          return;
        }
        const objectUrl = URL.createObjectURL(file);
        image.dataset.objectUrl = objectUrl;
        image.src = objectUrl;
        image.hidden = false;
      }

      referenceInput.addEventListener("change", () => {
        pendingIdempotencyKey = "";
        selectedTemplateId = "";
        pendingTemplateId = "";
        rightsCheck.checked = false;
        clearFieldError("reference");
        clearFieldError("rights");
        renderTemplates();
        previewFile(referenceInput, referencePreview);
        updateStepper();
      });
      selfieInput.addEventListener("change", () => {
        pendingIdempotencyKey = "";
        pendingUploadId = "";
        consentCheck.checked = false;
        clearFieldError("selfie");
        clearFieldError("consent");
        previewFile(selfieInput, selfiePreview);
        updateStepper();
      });
      rightsCheck.addEventListener("change", () => clearFieldError("rights"));
      consentCheck.addEventListener("change", () => clearFieldError("consent"));

      async function compressToWebp(file, maxSide, quality) {
        let bitmap;
        try {
          bitmap = await createImageBitmap(file);
        } catch {
          throw new Error("IMAGE_DECODE_FAILED");
        }
        const scale = Math.min(
          1,
          maxSide / Math.max(bitmap.width, bitmap.height),
        );
        const width = Math.max(1, Math.round(bitmap.width * scale));
        const height = Math.max(1, Math.round(bitmap.height * scale));
        const canvas = document.createElement("canvas");
        canvas.width = width;
        canvas.height = height;
        const context = canvas.getContext("2d", { alpha: false });
        context.drawImage(bitmap, 0, 0, width, height);
        bitmap.close?.();
        const blob = await new Promise((resolve, reject) => {
          canvas.toBlob(
            (value) =>
              value
                ? resolve(value)
                : reject(new Error("WEBP_COMPRESS_FAILED")),
            "image/webp",
            quality,
          );
        });
        return blob;
      }

      async function createTemplate() {
        if (pendingTemplateId) return pendingTemplateId;
        if (selectedTemplateId) return selectedTemplateId;
        const file = referenceInput.files?.[0];
        if (!file) throw fieldError("reference", copy.referenceRequired);
        if (!rightsCheck.checked)
          throw fieldError("rights", copy.rightsRequired);
        let webp;
        try {
          webp = await compressToWebp(file, 1600, 0.84);
        } catch {
          throw fieldError("reference", copy.referenceInvalid);
        }
        if (webp.size > 4 * 1024 * 1024) {
          throw fieldError("reference", copy.referenceTooLarge);
        }
        const data = new FormData();
        data.set("reference", webp, "reference.webp");
        data.set("title", templateTitle.value.trim());
        data.set("rightsAccepted", "true");
        const template = await readJson(
          await fetch("/api/private-look-templates", {
            method: "POST",
            body: data,
          }),
          copy.templateCreateFailed,
        );
        selectedTemplateId = template.id;
        pendingTemplateId = template.id;
        templates.unshift(template);
        renderTemplates();
        return template.id;
      }

      async function uploadSelfie() {
        if (pendingUploadId) return { id: pendingUploadId };
        const file = selfieInput.files?.[0];
        if (!file) throw fieldError("selfie", copy.selfieRequired);
        if (!consentCheck.checked)
          throw fieldError("consent", copy.consentRequired);
        let webp;
        try {
          webp = await compressToWebp(file, 1800, 0.86);
        } catch {
          throw fieldError("selfie", copy.selfieInvalid);
        }
        const data = new FormData();
        data.set("photo", webp, "selfie.webp");
        data.set("consentVersion", root.dataset.photoConsentVersion || "");
        const upload = await readJson(
          await fetch("/api/uploads", { method: "POST", body: data }),
          copy.selfieUploadFailed,
        );
        pendingUploadId = upload.id;
        return upload;
      }

      function statusProgress(jobStatus) {
        if (jobStatus === "created") return 34;
        if (jobStatus === "upload_validating") return 46;
        if (jobStatus === "diagnosis_running") return 68;
        if (jobStatus === "image_running") return 88;
        if (jobStatus === "succeeded") return 100;
        if (["failed", "cancelled", "timed_out"].includes(jobStatus)) return 0;
        return 24;
      }

      function upsertBackgroundTask(job, stage = "") {
        if (!job?.id) return;
        const task = {
          id: job.id,
          type: "tryon",
          title: copy.backgroundTitle,
          status: job.status || "running",
          errorCode: job.errorCode || "",
          progress: statusProgress(job.status),
          stage:
            stage ||
            (["failed", "cancelled", "timed_out"].includes(job.status)
              ? ""
              : copy.backgroundRunning),
          href: hrefs.page,
          resultHref: `${hrefs.resultBase}/${encodeURIComponent(job.id)}`,
          persist: true,
        };
        if (window.__absBackgroundTasks?.upsert) {
          window.__absBackgroundTasks.upsert(task);
        } else {
          document.dispatchEvent(
            new CustomEvent("abs:background-task", {
              detail: { action: "upsert", task },
            }),
          );
        }
      }

      function terminalJobError(job) {
        const message =
          job.status === "cancelled"
            ? copy.cancelled
            : job.status === "timed_out"
              ? copy.timedOut
              : job.errorCode === "MAKEUP_TRANSFER_QUALITY_FAILED"
                ? copy.qualityFailed
                : copy.failed;
        const error = new Error(message);
        error.terminalStatus = job.status;
        return error;
      }

      async function pollJob(jobId) {
        let networkFailures = 0;
        for (let attempt = 0; attempt < pollMaxAttempts; attempt += 1) {
          try {
            const job = await readJson(
              await fetch(`/api/tryon-jobs/${encodeURIComponent(jobId)}`),
              copy.backgroundNetwork,
            );
            if (job.quota) updateQuota(job.quota);
            networkFailures = 0;
            upsertBackgroundTask(job);
            if (job.status === "succeeded") return job;
            if (["failed", "cancelled", "timed_out"].includes(job.status)) {
              throw terminalJobError(job);
            }
          } catch (error) {
            if (error?.terminalStatus) throw error;
            networkFailures += 1;
            if (networkFailures >= 3) {
              upsertBackgroundTask(
                { id: jobId, status: "running" },
                copy.backgroundNetwork,
              );
              status.textContent = copy.backgroundNetwork;
              progressLink.hidden = false;
            }
          }
          await new Promise((resolve) => setTimeout(resolve, pollIntervalMs));
        }
        return { id: jobId, pending: true };
      }

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        if (activeJobId) {
          status.textContent = copy.backgroundRunning;
          progressLink.hidden = false;
          return;
        }
        if (quotaExhausted || !validateForm()) return;
        setGenerating(true);
        status.textContent = copy.generating;
        progressLink.hidden = true;
        try {
          const templateId = await createTemplate();
          const upload = await uploadSelfie();
          pendingIdempotencyKey ||= crypto.randomUUID();
          const job = await readJson(
            await fetch("/api/tryon-jobs", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                uploadId: upload.id,
                privateTemplateId: templateId,
                idempotencyKey: pendingIdempotencyKey,
                requiredPlan: "premium",
                purpose: "tryon",
              }),
            }),
            copy.createFailed,
          );
          assertPrivateJobMatches(job, templateId, upload.id);
          if (job.quota) updateQuota(job.quota);
          activeJobId = job.id;
          upsertBackgroundTask(job);
          status.textContent = copy.backgroundRunning;
          progressLink.hidden = false;
          const completed = await pollJob(job.id);
          if (completed.pending) {
            status.textContent = copy.backgroundNetwork;
            return;
          }
          assertPrivateJobMatches(completed, templateId, upload.id);
          root.querySelector("[data-result-image]").src = completed.resultImage;
          activeJobId = "";
          pendingUploadId = "";
          pendingIdempotencyKey = "";
          showOnly(result);
        } catch (error) {
          if (error?.field) {
            markFieldError(error.field, error.message);
            focusField(error.field);
            status.textContent = copy.fixErrors;
          } else {
            status.textContent = error?.message || copy.createFailed;
          }
          if (error?.terminalStatus) {
            activeJobId = "";
            pendingUploadId = "";
            pendingIdempotencyKey = "";
            progressLink.hidden = false;
          }
        } finally {
          if (!activeJobId) setGenerating(false);
        }
      });

      function assertPrivateJobMatches(job, templateId, uploadId) {
        if (
          job?.lookSource !== "private-template" ||
          job?.privateTemplateId !== templateId ||
          (selectedTemplateId !== templateId &&
            pendingTemplateId !== templateId) ||
          pendingUploadId !== uploadId
        ) {
          pendingIdempotencyKey = "";
          activeJobId = "";
          throw new Error(copy.requestChanged);
        }
      }

      root.querySelector("[data-again]")?.addEventListener("click", () => {
        selectedTemplateId = "";
        pendingTemplateId = "";
        pendingUploadId = "";
        pendingIdempotencyKey = "";
        activeJobId = "";
        referenceInput.value = "";
        selfieInput.value = "";
        rightsCheck.checked = false;
        consentCheck.checked = false;
        templateTitle.value = "";
        referencePreview.hidden = true;
        selfiePreview.hidden = true;
        status.textContent = "";
        progressLink.hidden = true;
        clearFieldErrors();
        renderTemplates();
        showOnly(form);
        updateStepper();
        window.scrollTo({
          top: 0,
          behavior: window.matchMedia("(prefers-reduced-motion: reduce)")
            .matches
            ? "auto"
            : "smooth",
        });
      });

      loadingRetry?.addEventListener("click", loadSession);
      loadSession();
    })();
  </script>
</BaseLayout>

<style>
  /* ══════════════════════════════════════════
     背景装饰光晕
     ══════════════════════════════════════════ */
  .reference-tryon-main {
    position: relative;
    width: min(calc(100% - 2rem), 1080px);
    min-height: 72vh;
    margin: 0 auto;
    padding: 3rem 0 6rem;
    overflow: hidden;
  }
  .rt-glow {
    position: absolute;
    width: 420px;
    height: 420px;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.18;
    pointer-events: none;
    z-index: 0;
  }
  .rt-glow--rose {
    top: -80px;
    left: -100px;
    background: var(--rose);
  }
  .rt-glow--gold {
    bottom: 120px;
    right: -140px;
    background: var(--gold);
  }

  /* ══════════════════════════════════════════
     Hero 区域
     ══════════════════════════════════════════ */
  .reference-hero {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(260px, 0.7fr);
    gap: 2rem;
    align-items: end;
    margin-bottom: 2.5rem;
  }
  .rt-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.85rem;
    border: 1px solid var(--gold-border);
    border-radius: 999px;
    background: var(--surface-gold);
    color: var(--gold-text);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .rt-eyebrow svg {
    flex-shrink: 0;
    color: var(--gold);
  }
  .reference-hero h1 {
    max-width: 15ch;
    margin: 0.75rem 0 1rem;
    color: var(--heading);
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 4rem);
    line-height: 1.05;
  }
  .reference-hero p,
  .reference-step-heading p,
  .reference-gate p,
  .reference-result p {
    color: var(--body-secondary);
    line-height: 1.65;
  }

  /* 隐私卡片 — 磨砂玻璃效果 */
  .rt-privacy-card {
    display: grid;
    gap: 0.35rem;
    padding: 1.25rem;
    border: 1px solid var(--warm-border);
    border-radius: 14px;
    background: color-mix(in srgb, var(--bg-elevated) 85%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
  .rt-privacy-icon {
    color: var(--gold);
    margin-bottom: 0.15rem;
  }
  .rt-privacy-card strong {
    color: var(--heading);
    font-size: 0.95rem;
  }
  .rt-privacy-card p {
    margin: 0;
    font-size: 0.88rem;
  }

  /* ══════════════════════════════════════════
     加载状态 — SVG 环形动画
     ══════════════════════════════════════════ */
  .reference-state,
  .reference-gate {
    position: relative;
    z-index: 1;
    min-height: 280px;
    display: grid;
    place-items: center;
    align-content: center;
    gap: 0.75rem;
    padding: 2.5rem;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: color-mix(in srgb, var(--bg-elevated) 80%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    text-align: center;
  }
  .reference-state p {
    margin: 0;
