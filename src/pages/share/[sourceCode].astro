const hrefs = {
  home: localizeAppHref("/"),
  tryonFree: localizeAppHref("/tryon-free"),
};
---

<BaseLayout
  title={`${copy.title} | AI Beauty Stylist`}
  description={copy.description}
  bodyClass="public-share-body"
  robots="noindex,follow"
>
  <main
    class="public-share-main"
    data-public-share
    data-source-code={sourceCode}
  >
    <article
      class="public-share-card"
      aria-label={copy.cardAria}
      aria-live="polite"
    >
      <header class="public-share-top">
        <h1>{copy.heading}</h1>
        <div class="public-share-look" data-share-title>{copy.loading}</div>
        <div class="public-share-brand">{copy.brand}</div>
      </header>
      <div class="public-share-media" data-share-media>
        <div class="public-share-loading" role="status">{copy.loading}</div>
      </div>
      <section class="public-share-benefits">
        <div>
          <b>{copy.benefitTryon}</b>
          <span>{copy.benefitTryonDesc}</span>
        </div>
        <div>
          <b>{copy.benefitScenario}</b>
          <span>{copy.benefitScenarioDesc}</span>
        </div>
        <div>
          <b>{copy.benefitBonus}</b>
          <span>{copy.benefitBonusDesc}</span>
        </div>
      </section>
      <footer class="public-share-copy">
        <h2>
          <span>{copy.ctaTitle}</span>
          <strong>{copy.ctaBody}</strong>
        </h2>
        <div class="public-share-actions">
          <a class="btn btn-primary" href={hrefs.tryonFree} data-share-try>
            {copy.tryIt}
          </a>
          <button class="btn" type="button" data-share-copy>
            {copy.copy}
          </button>
          <a class="btn btn-outline" href={hrefs.home}>{copy.home}</a>
        </div>
        <a
          class="public-share-brand-link"
          href={hrefs.home}
          data-public-share-link
        >
          <span>{copy.brand}</span>
          <small data-public-share-url>aibeautystylist.com</small>
        </a>
      </footer>
    </article>
    <section class="public-share-empty panel" data-share-empty hidden>
      <h1>{copy.missingTitle}</h1>
      <p>{copy.missingBody}</p>
      <a class="btn btn-primary" href={hrefs.tryonFree}>{copy.tryIt}</a>
    </section>
  </main>

  <script is:inline define:vars={{ copy, hrefs }}>
    (() => {
      const root = document.querySelector("[data-public-share]");
      if (!root) return;
      const sourceCode = root.dataset.sourceCode;
      const card = root.querySelector(".public-share-card");
      const media = root.querySelector("[data-share-media]");
      const title = root.querySelector("[data-share-title]");
      const tryLink = root.querySelector("[data-share-try]");
      const copyButton = root.querySelector("[data-share-copy]");
      const empty = root.querySelector("[data-share-empty]");
      const shareUrlText = root.querySelector("[data-public-share-url]");
      const shareUrlLink = root.querySelector("[data-public-share-link]");

      function formatShareDisplayUrl(value) {
        try {
          const url = new URL(value, location.origin);
          return url.hostname.replace(/^www\./, "") + url.pathname;
        } catch {
          return "aibeautystylist.com";
        }
      }

      if (shareUrlText)
        shareUrlText.textContent = formatShareDisplayUrl(location.href);
      if (shareUrlLink) shareUrlLink.href = location.href;

      function showEmpty() {
        if (card) card.hidden = true;
        if (empty) empty.hidden = false;
      }

      async function loadShare() {
        const response = await fetch(
          `/api/shares/${encodeURIComponent(sourceCode)}`,
        );
        const body = await response.json().catch(() => null);
        if (!response.ok || !body?.ok || !body.data)
          throw new Error("NOT_FOUND");
        return body.data;
      }

      function renderShare(job) {
        if (title) title.textContent = job.lookTitle || copy.defaultLook;
        if (tryLink) {
          const url = new URL(hrefs.tryonFree, location.origin);
          if (job.lookSlug) url.searchParams.set("look", job.lookSlug);
          url.searchParams.set("source", "shared_result");
          tryLink.href = `${url.pathname}${url.search}`;
        }
        if (media) {
          media.classList.add("is-loading");
          const image = document.createElement("img");
          image.src = job.resultImage;
          image.alt = job.lookTitle || copy.defaultLook;
          image.loading = "eager";
          image.decoding = "async";
          const label = document.createElement("span");
          label.className = "public-share-label";
          label.textContent = copy.after;
          image.addEventListener(
            "load",
            () => media.classList.remove("is-loading"),
            { once: true },
          );
          image.addEventListener(
            "error",
            () => media.classList.remove("is-loading"),
            { once: true },
          );
          media.replaceChildren(image, label);
          if (image.complete)
            requestAnimationFrame(() => media.classList.remove("is-loading"));
        }
      }

      copyButton?.addEventListener("click", async () => {
        try {
          await navigator.clipboard?.writeText(location.href);
          copyButton.textContent = copy.copied;
          window.setTimeout(() => {
            copyButton.textContent = copy.copy;
          }, 2200);
        } catch {
          /* no clipboard support */
        }
      });

      if (!sourceCode) {
        showEmpty();
        return;
      }

      loadShare().then(renderShare).catch(showEmpty);
    })();
  </script>

  <style>
    .public-share-main {
      display: grid;
      min-height: 100dvh;
      place-items: center;
      padding: 40px 24px;
      background: linear-gradient(
        180deg,
        var(--page-surface-alt),
        var(--page-surface)
      );
    }

    .public-share-card {
      width: min(100%, 720px);
      overflow: hidden;
      border: 1px solid color-mix(in srgb, var(--line) 86%, transparent);
      border-radius: 22px;
      background: linear-gradient(160deg, #fff8fa 0%, #f8fcfb 52%, #fff 100%);
      color: var(--text);
      box-shadow: 0 25px 70px rgba(31, 45, 65, 0.14);
    }

    .public-share-top {
      padding: 48px 56px 22px;
    }

    .public-share-top h1 {
      margin: 0;
      color: var(--heading);
      font-size: 52px;
      line-height: 1.06;
      letter-spacing: 0;
    }

    .public-share-look {
      margin: 14px 0 10px;
      color: var(--rose);
      font-size: 28px;
      font-weight: 800;
      line-height: 1.18;
    }

    .public-share-brand {
      color: #4f8f8a;
      font-size: 20px;
      font-weight: 800;
    }

    .public-share-media {
      position: relative;
      display: grid;
      aspect-ratio: 936 / 760;
      margin: 18px 48px 0;
      overflow: hidden;
      place-items: center;
      border-radius: 22px;
      background: #f5f2f1;
      box-shadow: 0 18px 40px rgba(31, 45, 65, 0.1);
      contain: layout paint;
    }

    .public-share-media.is-loading::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(
        110deg,
        #f5f2f1 8%,
        var(--bg-elevated) 18%,
        #f5f2f1 33%
      );
      background-size: 200% 100%;
      animation: result-image-loading 1.1s ease-in-out infinite;
    }

    .public-share-media img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: contain;
      object-position: center center;
      filter: saturate(1.02);
    }

    .public-share-label {
      position: absolute;
      right: 22px;
      bottom: 22px;
      z-index: 2;
      padding: 10px 18px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.9);
      color: var(--heading);
      font-weight: 900;
      box-shadow: 0 12px 26px rgba(31, 45, 65, 0.12);
    }

    .public-share-loading {
      color: var(--muted);
      font-size: 14px;
      font-weight: 800;
    }

    .public-share-benefits {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin: 28px 48px 0;
    }

    .public-share-benefits div {
      min-width: 0;
      padding: 20px 22px;
      border: 1px solid color-mix(in srgb, var(--line) 82%, transparent);
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.84);
      box-shadow: 0 14px 32px rgba(31, 45, 65, 0.06);
    }

    .public-share-benefits b {
      display: block;
      color: var(--heading);
      font-size: 17px;
      line-height: 1.3;
    }

    .public-share-benefits span {
      display: block;
      margin-top: 8px;
      color: var(--body-secondary);
      font-size: 14px;
      line-height: 1.42;
    }

    .public-share-copy {
      display: grid;
      gap: 18px;
      padding: 36px 56px 46px;
    }

    .public-share-copy h2 {
      display: grid;
      gap: 8px;
      margin: 0;
      color: var(--heading);
      font-size: 34px;
      line-height: 1.15;
    }

    .public-share-copy h2 span {
      font-weight: 900;
    }

    .public-share-copy h2 strong {
      color: var(--rose);
      font-size: 22px;
      line-height: 1.32;
    }

    .public-share-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 2px;
    }

    .public-share-actions .btn {
      min-height: 44px;
      justify-content: center;
    }

    .public-share-brand-link {
      display: inline-grid;
      width: fit-content;
      gap: 2px;
      color: var(--heading);
      font-size: 18px;
      font-weight: 900;
      text-decoration: none;
    }

