  cardAria: string;
  benefitTryon: string;
  benefitTryonDesc: string;
  benefitScenario: string;
  benefitScenarioDesc: string;
  benefitBonus: string;
  benefitBonusDesc: string;
  ctaTitle: string;
  ctaBody: string;
  after: string;
  defaultLook: string;
