    <header class="share-mobile-nav" aria-label={copy.navLabel}>
      <a class="share-mobile-home" href={homeHref} aria-label={copy.navHome}>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M3 10.8 12 3l9 7.8"></path>
          <path d="M5.5 10.2V21h13V10.2"></path>
          <path d="M9.5 21v-6h5v6"></path>
