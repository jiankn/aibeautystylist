    benefitTryonDesc: "Pré-visualize o look no seu rosto",
    benefitScenario: "Looks por ocasião",
    benefitScenarioDesc: "Teste trabalho, encontro e fotos",
    benefitFree: "Teste grátis",
    benefitFreeDesc: "3 gerações grátis por mês",
    ctaTitle: "Enviar selfie",
    ctaHighlight: "Teste 3 vezes grátis por mês",
    ctaBody:
      "Crie um cartão real de antes e depois para salvar ou compartilhar.",
    download: "Salvar cartão",
    cleanDownload: "Baixar imagem limpa",
    share: "Compartilhar cartão",
    copyLink: "Copiar link",
    reward: "Receber recompensa (+1 crédito)",
    emptyTitle: "Ainda não há resultado de teste",
    emptyBody:
      "Conclua um teste primeiro para gerar um resultado compartilhável.",
    emptyCta: "Testar maquiagem",
    emptyHome: "Voltar ao início",
    defaultLook: "Resultado de maquiagem",
    resultAltSuffix: " resultado do teste",
    originalAltSuffix: " selfie original",
    before: "Antes",
    after: "Depois",
    shareTitle: "Meu resultado de maquiagem IA",
    shareText: "Veja meu resultado de referência de maquiagem IA.",
    shareCopied: "✓ Link copiado",
    copied: "✓ Copiado",
    rewardSuccess: "✓ Crédito +1, recompensa recebida",
    rewardAlready: "Já recebida hoje",
    rewardFailed: "× Falha ao receber. Tente novamente",
  },
} satisfies Record<string, ShareCardCopy>;

const copy = shareCopyByLocale[currentLocale] ?? shareCopyByLocale.en;
---

<BaseLayout
  title={copy.title}
  description={copy.description}
  robots="noindex,follow"
>
  <div class="share-route">
    <nav class="share-nav" aria-label={copy.navLabel}>
      <a class="share-nav-brand" href={homeHref}>
        <img
          class="brand-logo-img"
          src="/images/logo-ui.webp"
          alt=""
          aria-hidden="true"
          width="34"
          height="34"
        />
        <span>AI Beauty Stylist</span>
      </a>
      <div class="share-nav-links">
        <a href={homeHref}>{copy.navHome}</a>
        <a href={discoverHref}>{copy.navDiscover}</a>
        <a href={tryOnHref}>{copy.navTryOn}</a>
      </div>
      <a class="btn btn-primary share-nav-cta" href={tryOnHref}>
        {copy.navTryCta}
      </a>
