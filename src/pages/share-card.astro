---
import { getLocalizedAppHref, resolveLocaleRoute } from "../i18n/routing";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCurrentLocale } from "../lib/i18n";

const currentLocale = getCurrentLocale();
const currentPathname = Astro.originPathname || Astro.url.pathname;
const currentRoute =
  Astro.locals.localeRoute ?? resolveLocaleRoute(currentPathname);
const localizeAppHref = (href: string) =>
  getLocalizedAppHref(href, currentRoute.language.slug);
const homeHref = localizeAppHref("/");
const discoverHref = localizeAppHref("/discover");
const tryOnHref = localizeAppHref("/tryon-free");
const shareCardHref = localizeAppHref("/share-card");
const shareBaseHref = localizeAppHref("/share");

