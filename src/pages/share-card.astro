>;
const posterCopy =
  posterCopyByLocale[currentLocale as keyof typeof posterCopyByLocale] ??
  posterCopyByLocale.en;
---

<BaseLayout
  title={copy.title}
  description={copy.description}
  robots="noindex,follow"
>
  <div class="share-route">
    <nav class="share-nav" aria-label={copy.navLabel}>
      <a class="share-nav-brand" href={homeHref}>
        <img
          class="brand-logo-img"
          src="/images/logo-ui.webp"
          alt=""
          aria-hidden="true"
          width="34"
          height="34"
        />
        <span>AI Beauty Stylist</span>
      </a>
      <div class="share-nav-links">
        <a href={homeHref}>{copy.navHome}</a>
        <a href={discoverHref}>{copy.navDiscover}</a>
        <a href={tryOnHref}>{copy.navTryOn}</a>
      </div>
      <a class="btn btn-primary share-nav-cta" href={tryOnHref}>
        {copy.navTryCta}
      </a>
    </nav>

    <header class="share-mobile-nav" aria-label={copy.navLabel}>
      <a class="share-mobile-home" href={homeHref} aria-label={copy.navHome}>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M3 10.8 12 3l9 7.8"></path>
          <path d="M5.5 10.2V21h13V10.2"></path>
          <path d="M9.5 21v-6h5v6"></path>
        </svg>
      </a>
      <strong>{copy.navTitle}</strong>
      <a class="share-mobile-tryon" href={tryOnHref}>{copy.navTryShort}</a>
    </header>

    <main class="share-page">
      <article
        class="share-card share-poster"
        aria-label={copy.cardAria}
        id="share-card"
      >
        <div class="share-poster-media" id="share-image-area">
          <div class="share-loading">{copy.cardLoading}</div>
        </div>
        <div class="share-poster-scrim" aria-hidden="true"></div>
        <header class="share-poster-top">
          <a class="share-poster-brand" href={homeHref}>
            <img
              class="brand-logo-img share-brand-logo"
              src="/images/logo-ui.webp"
              alt=""
              aria-hidden="true"
            />
            <span>AI Beauty Stylist</span>
          </a>
          <span class="share-poster-badge">{copy.after}</span>
        </header>
        <footer class="share-poster-copy">
          <div class="share-poster-eyebrow">
            <span aria-hidden="true"></span>
            {posterCopy.eyebrow}
          </div>
          <h1>
            <span>{posterCopy.prefix}</span>
            <strong id="share-look-name">{copy.loading}</strong>
          </h1>
          <p>{posterCopy.subtext}</p>
          <div class="share-poster-action-row">
            <a
              class="btn btn-primary share-poster-cta"
              href={tryOnHref}
              id="share-try-link"
            >
              {copy.navTryCta}
            </a>
            <p class="share-poster-reward">
              <span>{posterCopy.rewardTop}</span>
              <strong>{posterCopy.rewardBottom}</strong>
            </p>
          </div>
        </footer>
      </article>

      <!-- 操作按钮 -->
      <div class="share-actions" id="share-actions">
        <button class="btn btn-primary" id="share-download-btn">
          ↓&nbsp; {copy.download}</button
        >
        <button class="btn" id="share-web-btn">↗&nbsp; {copy.share}</button>
        <button class="btn" id="share-copy-btn">⌘&nbsp; {copy.copyLink}</button>
        <button class="btn btn-outline-rose" id="share-reward-btn">
          +&nbsp; {copy.reward}</button
        >
      </div>

      <!-- 无结果时展示 -->
      <div class="panel share-empty" id="share-empty" hidden>
        <h2>{copy.emptyTitle}</h2>
        <p>{copy.emptyBody}</p>
        <div class="share-empty-actions">
          <a class="btn btn-primary" href={tryOnHref}>{copy.emptyCta}</a>
          <a class="btn" href={homeHref}>{copy.emptyHome}</a>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>

<script
  is:inline
  define:vars={{ copy, posterCopy, shareBaseHref, shareCardHref, tryOnHref }}
>
  (function () {
    const params = new URLSearchParams(location.search);
    const jobId = params.get("jobId");
    const lookNameEl = document.getElementById("share-look-name");
    const imageArea = document.getElementById("share-image-area");
    const emptyEl = document.getElementById("share-empty");
    const actionsEl = document.getElementById("share-actions");
    const cardEl = document.getElementById("share-card");
    const rewardBtn = document.getElementById("share-reward-btn");
    const downloadBtn = document.getElementById("share-download-btn");
    const webShareBtn = document.getElementById("share-web-btn");
    const copyBtn = document.getElementById("share-copy-btn");
    const tryLink = document.getElementById("share-try-link");
    let currentPlan = "free";
    let currentJob = null;
    let publicShareUrl;

    if (!jobId) {
      cardEl.hidden = true;
      actionsEl.hidden = true;
      emptyEl.hidden = false;
      return;
    }

    function shareClaimStorageKey(value) {
      return "abs:share-claim:" + value;
    }

    function getStoredShareClaim() {
      try {
        const raw = sessionStorage.getItem(shareClaimStorageKey(jobId));
        if (!raw) return null;
        const claim = JSON.parse(raw);
        if (!claim?.claimToken || !claim?.expiresAt) return null;
        if (claim.expiresAt <= new Date().toISOString()) {
          sessionStorage.removeItem(shareClaimStorageKey(jobId));
          return null;
        }
        return claim;
      } catch {
        return null;
      }
    }

    function storeShareClaim(claim) {
      try {
        sessionStorage.setItem(
          shareClaimStorageKey(jobId),
          JSON.stringify(claim),
        );
      } catch {
        /* ignore private storage failures */
      }
    }

    async function createShareClaim(method) {
      const res = await fetch("/api/shares/intent", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ jobId, method }),
      });
      const data = await res.json();
      if (!res.ok || !data.ok || !data.data?.claimToken) {
        throw new Error(data?.error?.message || "SHARE_INTENT_FAILED");
      }
      storeShareClaim(data.data);
      refreshRewardButtonState();
      return data.data;
    }

    async function createPublicShareUrl() {
      if (publicShareUrl) return publicShareUrl;
      const res = await fetch("/api/shares", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ jobId }),
      });
      const data = await res.json();
      if (!res.ok || !data.ok || !data.data?.sourceCode) {
        throw new Error(data?.error?.message || "SHARE_FAILED");
      }
      const base = String(shareBaseHref || "/share").replace(/\/+$/, "");
      publicShareUrl = new URL(
        `${base}/${encodeURIComponent(data.data.sourceCode)}`,
        location.origin,
      ).toString();
      return publicShareUrl;
    }

    function refreshRewardButtonState() {
      if (!rewardBtn) return;
      rewardBtn.disabled = !getStoredShareClaim();
    }

    function updateTryLink(job) {
      if (!tryLink) return;
      const url = new URL(tryOnHref || "/tryon-free", location.origin);
      if (job?.lookSlug) url.searchParams.set("look", job.lookSlug);
      url.searchParams.set("source", "share_card");
      tryLink.href = `${url.pathname}${url.search}`;
    }

    refreshRewardButtonState();
    loadSessionPlan();

    function normalizePlan(plan) {
      return plan === "premium" ? "premium" : plan === "pro" ? "pro" : "free";
    }

    function isPaidPlan() {
      return currentPlan === "pro" || currentPlan === "premium";
    }

    async function loadSessionPlan() {
      try {
        const res = await fetch("/api/session");
        const data = await res.json();
        if (data.ok) currentPlan = normalizePlan(data.data?.plan);
      } catch {
        currentPlan = "free";
      }
      updateDownloadButtonLabel();
    }

    function updateDownloadButtonLabel() {
      if (!downloadBtn) return;
      downloadBtn.textContent =
        "↓  " +
        (isPaidPlan() ? copy.cleanDownload || copy.download : copy.download);
    }

    fetch("/api/tryon-jobs/" + jobId)
      .then((r) => r.json())
      .then((data) => {
        if (!data.ok || data.data.status !== "succeeded") {
          cardEl.hidden = true;
          actionsEl.hidden = true;
          emptyEl.hidden = false;
          return;
        }
        const job = data.data;
        currentJob = job;
        updateTryLink(job);
        if (lookNameEl)
          lookNameEl.textContent = job.lookTitle || copy.defaultLook;
        if (imageArea && job.resultImage) {
          const lookTitle = job.lookTitle || copy.defaultLook;
          const resultAlt = lookTitle + copy.resultAltSuffix;
          imageArea.innerHTML = `
            <img src="${escapeHtml(job.resultImage)}" alt="${escapeHtml(resultAlt)}" loading="eager" data-share-result-img />
          `;
        }
        createPublicShareUrl().catch(() => {});
      })
      .catch(() => {
        cardEl.hidden = true;
        actionsEl.hidden = true;
        emptyEl.hidden = false;
      });

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    }

    function loadImage(src) {
      return new Promise((resolve, reject) => {
        const img = new Image();
        img.onload = () => resolve(img);
        img.onerror = reject;
        img.src = src;
      });
    }

    function roundedRect(ctx, x, y, width, height, radius) {
      const r = Math.min(radius, width / 2, height / 2);
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.lineTo(x + width - r, y);
      ctx.quadraticCurveTo(x + width, y, x + width, y + r);
      ctx.lineTo(x + width, y + height - r);
      ctx.quadraticCurveTo(x + width, y + height, x + width - r, y + height);
      ctx.lineTo(x + r, y + height);
      ctx.quadraticCurveTo(x, y + height, x, y + height - r);
      ctx.lineTo(x, y + r);
      ctx.quadraticCurveTo(x, y, x + r, y);
      ctx.closePath();
    }

    function drawImageCover(ctx, img, x, y, width, height, focusY = 0.38) {
      const scale = Math.max(
        width / img.naturalWidth,
        height / img.naturalHeight,
      );
      const sw = width / scale;
      const sh = height / scale;
      const sx = Math.max(0, (img.naturalWidth - sw) / 2);
      const sy = Math.max(0, (img.naturalHeight - sh) * focusY);
      ctx.drawImage(img, sx, sy, sw, sh, x, y, width, height);
    }

    function drawWrappedText(ctx, text, x, y, maxWidth, lineHeight, maxLines) {
      const source = String(text || "");
      const hasSpaces = /\s/.test(source);
      const words = hasSpaces ? source.split(/\s+/) : Array.from(source);
      const joiner = hasSpaces ? " " : "";
      const lines = [];
      let line = "";
      for (const word of words) {
        const next = line ? line + joiner + word : word;
        if (ctx.measureText(next).width > maxWidth && line) {
          lines.push(line);
          line = word;
        } else {
          line = next;
        }
        if (lines.length >= maxLines) break;
      }
      if (line && lines.length < maxLines) lines.push(line);
      lines.forEach((entry, index) =>
        ctx.fillText(entry, x, y + index * lineHeight),
      );
      return y + lines.length * lineHeight;
    }

    async function createShareCardBlob() {
      const imgEl = imageArea?.querySelector("[data-share-result-img]");
      const resultSrc = imgEl?.src || currentJob?.resultImage;
      if (!resultSrc) return null;
      const resultImage = await loadImage(resultSrc);
      const logoImage = await loadImage("/images/logo-256.png").catch(
        () => null,
      );
      const canvas = document.createElement("canvas");
      canvas.width = 1080;
      canvas.height = 1440;
      const ctx = canvas.getContext("2d");
      if (!ctx) return null;

      ctx.fillStyle = "#181114";
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      drawImageCover(ctx, resultImage, 0, 0, 1080, 1440, 0.34);

      const topScrim = ctx.createLinearGradient(0, 0, 0, 520);
      topScrim.addColorStop(0, "rgba(17,10,13,0.42)");
      topScrim.addColorStop(0.52, "rgba(17,10,13,0.02)");
      topScrim.addColorStop(1, "rgba(17,10,13,0)");
      ctx.fillStyle = topScrim;
      ctx.fillRect(0, 0, 1080, 520);

      const bottomScrim = ctx.createLinearGradient(0, 620, 0, 1440);
      bottomScrim.addColorStop(0, "rgba(35,18,25,0)");
      bottomScrim.addColorStop(0.45, "rgba(35,18,25,0.74)");
      bottomScrim.addColorStop(1, "rgba(16,8,11,0.96)");
      ctx.fillStyle = bottomScrim;
      ctx.fillRect(0, 620, 1080, 820);

      ctx.textBaseline = "alphabetic";
      ctx.textAlign = "left";

      const brandText = "AI Beauty Stylist";
      ctx.font = "900 27px Inter, Arial, sans-serif";
      const brandWidth = Math.min(410, ctx.measureText(brandText).width + 104);
      ctx.fillStyle = "rgba(255,255,255,0.86)";
      roundedRect(ctx, 58, 58, brandWidth, 74, 37);
      ctx.fill();
      if (logoImage) {
        ctx.save();
        roundedRect(ctx, 76, 73, 44, 44, 22);
        ctx.clip();
        ctx.drawImage(logoImage, 76, 73, 44, 44);
        ctx.restore();
      }
      ctx.fillStyle = "#241920";
      ctx.fillText(brandText, 136, 105);

      ctx.font = "900 26px Inter, Arial, sans-serif";
      const afterWidth = Math.max(128, ctx.measureText(copy.after).width + 58);
      ctx.fillStyle = "rgba(191,45,98,0.94)";
      roundedRect(ctx, 1022 - afterWidth, 58, afterWidth, 70, 35);
      ctx.fill();
      ctx.fillStyle = "#ffffff";
      ctx.textAlign = "center";
      ctx.fillText(copy.after, 1022 - afterWidth / 2, 103);
      ctx.textAlign = "left";

      ctx.strokeStyle = "rgba(255,255,255,0.72)";
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.moveTo(64, 948);
      ctx.lineTo(122, 948);
      ctx.stroke();
      ctx.fillStyle = "rgba(255,255,255,0.92)";
      ctx.font = "900 29px Inter, Arial, sans-serif";
      ctx.fillText(posterCopy.eyebrow, 136, 958);

      const lookTitle = currentJob?.lookTitle || copy.defaultLook;
      const posterTitle = `${posterCopy.prefix} ${lookTitle}`.trim();
      ctx.fillStyle = "#ffffff";
      ctx.font =
        posterTitle.length > 28
          ? "900 84px Inter, Arial, sans-serif"
          : "900 104px Inter, Arial, sans-serif";
      drawWrappedText(ctx, posterTitle, 64, 1066, 850, 100, 3);

      ctx.fillStyle = "rgba(255,255,255,0.9)";
      ctx.font = "900 32px Inter, Arial, sans-serif";
      drawWrappedText(ctx, posterCopy.subtext, 64, 1248, 760, 40, 2);

      ctx.fillStyle = "#ffffff";
      roundedRect(ctx, 64, 1290, 632, 92, 46);
      ctx.fill();
      ctx.fillStyle = "#b92f62";
      ctx.font = "900 36px Inter, Arial, sans-serif";
      ctx.textAlign = "center";
      ctx.fillText(copy.navTryCta, 380, 1349);

      ctx.textAlign = "right";
      ctx.fillStyle = "rgba(255,255,255,0.88)";
      ctx.font = "900 25px Inter, Arial, sans-serif";
      ctx.fillText(posterCopy.rewardTop, 1016, 1330);
      ctx.fillText(posterCopy.rewardBottom, 1016, 1364);
      ctx.textAlign = "left";

      return new Promise((resolve) => {
        canvas.toBlob((blob) => resolve(blob), "image/png", 0.95);
      });
    }

    function downloadBlob(blob, filename) {
      if (!blob) return;
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = filename;
      a.click();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    }

    function downloadCleanResultImage() {
      const img = imageArea?.querySelector("[data-share-result-img]");
      if (!img?.src) return;
      const a = document.createElement("a");
      a.href = img.src;
      a.download = "ai-beauty-stylist-result.png";
      a.click();
    }

    if (downloadBtn) {
      downloadBtn.addEventListener("click", async () => {
        try {
          if (isPaidPlan()) {
            downloadCleanResultImage();
            return;
          }
          const blob = await createShareCardBlob();
          downloadBlob(blob, "ai-beauty-stylist-share-card.png");
        } catch {
          /* ignore */
        }
      });
    }

    if (webShareBtn) {
      webShareBtn.addEventListener("click", async () => {
        try {
          const shareUrl = await createPublicShareUrl();
          if (navigator.share) {
            const sharePayload = {
              title: copy.shareTitle,
              text: copy.shareText,
              url: shareUrl,
            };
            const blob = await createShareCardBlob();
            const file =
              blob &&
              new File([blob], "ai-beauty-stylist-share-card.png", {
                type: "image/png",
              });
            if (file && navigator.canShare?.({ files: [file] })) {
              try {
                await navigator.share({ ...sharePayload, files: [file] });
              } catch {
                await navigator.share(sharePayload);
              }
            } else {
              await navigator.share(sharePayload);
            }
            await createShareClaim("web_share");
          } else if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(shareUrl);
            await createShareClaim("copy_link");
            webShareBtn.textContent = copy.shareCopied;
            setTimeout(() => {
              webShareBtn.textContent = "↗  " + copy.share;
            }, 2000);
          }
        } catch {
          /* user cancelled or sharing unavailable */
        }
      });
    }

    if (copyBtn) {
      copyBtn.addEventListener("click", async () => {
        if (!navigator.clipboard?.writeText) return;
        try {
          const shareUrl = await createPublicShareUrl();
          await navigator.clipboard.writeText(shareUrl);
        } catch {
          return;
        }
        try {
          await createShareClaim("copy_link");
        } catch {
          /* keep copy action best-effort */
        }
        copyBtn.textContent = copy.copied;
        setTimeout(() => {
          copyBtn.textContent = "⌘  " + copy.copyLink;
        }, 2000);
      });
    }

    if (rewardBtn) {
      rewardBtn.addEventListener("click", async () => {
        try {
          const claim = getStoredShareClaim();
          if (!claim) {
            refreshRewardButtonState();
            return;
          }
          rewardBtn.disabled = true;
          const res = await fetch("/api/shares/reward", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              jobId,
              shareClaimToken: claim.claimToken,
            }),
          });
          const data = await res.json();
          if (data.ok && data.data.rewarded) {
            rewardBtn.textContent = copy.rewardSuccess;
            rewardBtn.classList.add("btn-primary");
          } else {
            rewardBtn.textContent =
              "i " + (data.data?.reason || copy.rewardAlready);
          }
        } catch {
          rewardBtn.textContent = copy.rewardFailed;
          rewardBtn.disabled = false;
        }
      });
    }
  })();
</script>

