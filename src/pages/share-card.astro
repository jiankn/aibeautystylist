      <!-- 操作按钮 -->
      <div class="share-actions" id="share-actions">
        <button class="btn btn-primary" id="share-download-btn">
          ↓&nbsp; {copy.download}</button
        >
        <button class="btn" id="share-web-btn">↗&nbsp; {copy.share}</button>
        <button class="btn" id="share-copy-btn">⌘&nbsp; {copy.copyLink}</button>
        <button class="btn btn-outline-rose" id="share-reward-btn">
          +&nbsp; {copy.reward}</button
        >
      </div>

      <!-- 无结果时展示 -->
      <div class="panel share-empty" id="share-empty" hidden>
        <h2>{copy.emptyTitle}</h2>
        <p>{copy.emptyBody}</p>
        <div class="share-empty-actions">
          <a class="btn btn-primary" href={tryOnHref}>{copy.emptyCta}</a>
          <a class="btn" href={homeHref}>{copy.emptyHome}</a>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>

<script is:inline define:vars={{ copy, shareBaseHref, shareCardHref }}>
  (function () {
    const params = new URLSearchParams(location.search);
    const jobId = params.get("jobId");
    const lookNameEl = document.getElementById("share-look-name");
    const imageArea = document.getElementById("share-image-area");
    const emptyEl = document.getElementById("share-empty");
    const actionsEl = document.getElementById("share-actions");
    const cardEl = document.getElementById("share-card");
    const rewardBtn = document.getElementById("share-reward-btn");
    const downloadBtn = document.getElementById("share-download-btn");
    const webShareBtn = document.getElementById("share-web-btn");
    const copyBtn = document.getElementById("share-copy-btn");
    let currentPlan = "free";
    let currentJob = null;
    let publicShareUrl;

    if (!jobId) {
      cardEl.hidden = true;
      actionsEl.hidden = true;
      emptyEl.hidden = false;
      return;
    }

    function shareClaimStorageKey(value) {
      return "abs:share-claim:" + value;
    }

    function getStoredShareClaim() {
      try {
        const raw = sessionStorage.getItem(shareClaimStorageKey(jobId));
        if (!raw) return null;
        const claim = JSON.parse(raw);
        if (!claim?.claimToken || !claim?.expiresAt) return null;
        if (claim.expiresAt <= new Date().toISOString()) {
          sessionStorage.removeItem(shareClaimStorageKey(jobId));
          return null;
        }
        return claim;
      } catch {
        return null;
      }
    }

    function storeShareClaim(claim) {
      try {
        sessionStorage.setItem(
          shareClaimStorageKey(jobId),
          JSON.stringify(claim),
        );
      } catch {
        /* ignore private storage failures */
      }
    }

    async function createShareClaim(method) {
      const res = await fetch("/api/shares/intent", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ jobId, method }),
      });
      const data = await res.json();
      if (!res.ok || !data.ok || !data.data?.claimToken) {
        throw new Error(data?.error?.message || "SHARE_INTENT_FAILED");
      }
      storeShareClaim(data.data);
      refreshRewardButtonState();
      return data.data;
    }

    async function createPublicShareUrl() {
      if (publicShareUrl) return publicShareUrl;
      const res = await fetch("/api/shares", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ jobId }),
      });
      const data = await res.json();
      if (!res.ok || !data.ok || !data.data?.sourceCode) {
        throw new Error(data?.error?.message || "SHARE_FAILED");
      }
      const base = String(shareBaseHref || "/share").replace(/\/+$/, "");
      publicShareUrl = new URL(
        `${base}/${encodeURIComponent(data.data.sourceCode)}`,
        location.origin,
      ).toString();
      return publicShareUrl;
    }

    function refreshRewardButtonState() {
      if (!rewardBtn) return;
      rewardBtn.disabled = !getStoredShareClaim();
    }

    refreshRewardButtonState();
    loadSessionPlan();

    function normalizePlan(plan) {
      return plan === "premium" ? "premium" : plan === "pro" ? "pro" : "free";
    }

    function isPaidPlan() {
      return currentPlan === "pro" || currentPlan === "premium";
    }

    async function loadSessionPlan() {
      try {
        const res = await fetch("/api/session");
        const data = await res.json();
        if (data.ok) currentPlan = normalizePlan(data.data?.plan);
      } catch {
        currentPlan = "free";
      }
      updateDownloadButtonLabel();
    }

    function updateDownloadButtonLabel() {
      if (!downloadBtn) return;
      downloadBtn.textContent =
        "↓  " +
        (isPaidPlan() ? copy.cleanDownload || copy.download : copy.download);
    }

    fetch("/api/tryon-jobs/" + jobId)
      .then((r) => r.json())
      .then((data) => {
        if (!data.ok || data.data.status !== "succeeded") {
          cardEl.hidden = true;
          actionsEl.hidden = true;
          emptyEl.hidden = false;
          return;
        }
        const job = data.data;
        currentJob = job;
        if (lookNameEl)
          lookNameEl.textContent = job.lookTitle || copy.defaultLook;
        if (imageArea && job.resultImage) {
          const lookTitle = job.lookTitle || copy.defaultLook;
          const resultAlt = lookTitle + copy.resultAltSuffix;
          imageArea.classList.remove("has-comparison");
          imageArea.classList.add("is-single");
          imageArea.innerHTML = `
            <img src="${escapeHtml(job.resultImage)}" alt="${escapeHtml(resultAlt)}" loading="eager" data-share-result-img />
            <span class="compare-label after">${escapeHtml(copy.after)}</span>
          `;
        }
      })
      .catch(() => {
        cardEl.hidden = true;
        actionsEl.hidden = true;
        emptyEl.hidden = false;
      });

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    }

    function loadImage(src) {
      return new Promise((resolve, reject) => {
        const img = new Image();
        img.onload = () => resolve(img);
        img.onerror = reject;
        img.src = src;
      });
    }

    function roundedRect(ctx, x, y, width, height, radius) {
      const r = Math.min(radius, width / 2, height / 2);
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.lineTo(x + width - r, y);
      ctx.quadraticCurveTo(x + width, y, x + width, y + r);
      ctx.lineTo(x + width, y + height - r);
      ctx.quadraticCurveTo(x + width, y + height, x + width - r, y + height);
      ctx.lineTo(x + r, y + height);
      ctx.quadraticCurveTo(x, y + height, x, y + height - r);
      ctx.lineTo(x, y + r);
      ctx.quadraticCurveTo(x, y, x + r, y);
      ctx.closePath();
    }

    function drawImageCover(ctx, img, x, y, width, height) {
      const scale = Math.max(
        width / img.naturalWidth,
        height / img.naturalHeight,
      );
      const sw = width / scale;
      const sh = height / scale;
      const sx = (img.naturalWidth - sw) / 2;
      const sy = (img.naturalHeight - sh) / 2;
      ctx.drawImage(img, sx, sy, sw, sh, x, y, width, height);
    }

    function drawWrappedText(ctx, text, x, y, maxWidth, lineHeight, maxLines) {
      const source = String(text || "");
      const hasSpaces = /\s/.test(source);
      const words = hasSpaces ? source.split(/\s+/) : Array.from(source);
      const joiner = hasSpaces ? " " : "";
      const lines = [];
      let line = "";
      for (const word of words) {
        const next = line ? line + joiner + word : word;
        if (ctx.measureText(next).width > maxWidth && line) {
          lines.push(line);
          line = word;
        } else {
          line = next;
        }
        if (lines.length >= maxLines) break;
      }
      if (line && lines.length < maxLines) lines.push(line);
      lines.forEach((entry, index) =>
        ctx.fillText(entry, x, y + index * lineHeight),
      );
      return y + lines.length * lineHeight;
    }

    async function createShareCardBlob() {
      const imgEl = imageArea?.querySelector("[data-share-result-img]");
      const resultSrc = imgEl?.src || currentJob?.resultImage;
      if (!resultSrc) return null;
      const resultImage = await loadImage(resultSrc);
      const canvas = document.createElement("canvas");
      canvas.width = 1080;
      canvas.height = 1440;
      const ctx = canvas.getContext("2d");
      if (!ctx) return null;

      const gradient = ctx.createLinearGradient(0, 0, 1080, 1440);
      gradient.addColorStop(0, "#fff7f8");
      gradient.addColorStop(0.52, "#f7fbfb");
      gradient.addColorStop(1, "#ffffff");
      ctx.fillStyle = gradient;
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      ctx.fillStyle = "#3a2d2f";
      ctx.font = "700 58px Inter, Arial, sans-serif";
      ctx.fillText(copy.heading, 72, 116);
      ctx.fillStyle = "#b85c70";
      ctx.font = "600 38px Inter, Arial, sans-serif";
      ctx.fillText(currentJob?.lookTitle || copy.defaultLook, 72, 174);
      ctx.fillStyle = "#4f8f8a";
      ctx.font = "600 28px Inter, Arial, sans-serif";
      ctx.fillText("AI Beauty Stylist", 72, 222);

      ctx.save();
      roundedRect(ctx, 72, 270, 936, 760, 36);
      ctx.clip();
      drawImageCover(ctx, resultImage, 72, 270, 936, 760);
      ctx.restore();
      ctx.fillStyle = "rgba(255,255,255,0.9)";
      roundedRect(ctx, 812, 946, 148, 52, 26);
      ctx.fill();
      ctx.fillStyle = "#3a2d2f";
      ctx.font = "700 25px Inter, Arial, sans-serif";
      ctx.fillText(copy.after, 838, 981);

      const benefits = [
        [copy.benefitTryon, copy.benefitTryonDesc],
        [copy.benefitScenario, copy.benefitScenarioDesc],
        [copy.benefitFree, copy.benefitFreeDesc],
      ];
      let x = 72;
      for (const [title, body] of benefits) {
        ctx.fillStyle = "#ffffff";
        roundedRect(ctx, x, 1074, 292, 142, 24);
        ctx.fill();
        ctx.fillStyle = "#3a2d2f";
        ctx.font = "700 27px Inter, Arial, sans-serif";
        ctx.fillText(title, x + 24, 1128);
        ctx.fillStyle = "#6e6265";
        ctx.font = "400 22px Inter, Arial, sans-serif";
        drawWrappedText(ctx, body, x + 24, 1172, 236, 28, 2);
        x += 322;
      }

      ctx.fillStyle = "#3a2d2f";
      ctx.font = "700 40px Inter, Arial, sans-serif";
      ctx.fillText(copy.ctaHighlight, 72, 1304);
      ctx.fillStyle = "#6e6265";
      ctx.font = "400 26px Inter, Arial, sans-serif";
      drawWrappedText(ctx, copy.ctaBody, 72, 1350, 600, 34, 2);
      ctx.fillStyle = "#b85c70";
      ctx.font = "700 30px Inter, Arial, sans-serif";
      ctx.fillText("aibeautystylist.com", 720, 1368);

      return new Promise((resolve) => {
        canvas.toBlob((blob) => resolve(blob), "image/png", 0.95);
      });
    }

    function downloadBlob(blob, filename) {
      if (!blob) return;
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = filename;
      a.click();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    }

    function downloadCleanResultImage() {
      const img = imageArea?.querySelector("[data-share-result-img]");
      if (!img?.src) return;
      const a = document.createElement("a");
      a.href = img.src;
      a.download = "ai-beauty-stylist-result.png";
      a.click();
    }

    if (downloadBtn) {
      downloadBtn.addEventListener("click", async () => {
        try {
          if (isPaidPlan()) {
            downloadCleanResultImage();
            return;
          }
          const blob = await createShareCardBlob();
          downloadBlob(blob, "ai-beauty-stylist-share-card.png");
        } catch {
          /* ignore */
        }
      });
    }

    if (webShareBtn) {
      webShareBtn.addEventListener("click", async () => {
        try {
          const shareUrl = await createPublicShareUrl();
          if (navigator.share) {
            const blob = await createShareCardBlob();
            const file =
              blob &&
              new File([blob], "ai-beauty-stylist-share-card.png", {
                type: "image/png",
              });
            if (file && navigator.canShare?.({ files: [file] })) {
              await navigator.share({
                title: copy.shareTitle,
                text: copy.shareText,
                files: [file],
              });
            } else {
              await navigator.share({
                title: copy.shareTitle,
                text: copy.shareText,
                url: shareUrl,
              });
            }
            await createShareClaim("web_share");
          } else if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(shareUrl);
            await createShareClaim("copy_link");
            webShareBtn.textContent = copy.shareCopied;
            setTimeout(() => {
              webShareBtn.textContent = "↗  " + copy.share;
            }, 2000);
          }
        } catch {
          /* user cancelled or sharing unavailable */
        }
      });
    }

    if (copyBtn) {
      copyBtn.addEventListener("click", async () => {
        if (!navigator.clipboard?.writeText) return;
        try {
          const shareUrl = await createPublicShareUrl();
          await navigator.clipboard.writeText(shareUrl);
        } catch {
          return;
        }
        try {
          await createShareClaim("copy_link");
        } catch {
          /* keep copy action best-effort */
        }
        copyBtn.textContent = copy.copied;
        setTimeout(() => {
          copyBtn.textContent = "⌘  " + copy.copyLink;
        }, 2000);
      });
    }

    if (rewardBtn) {
      rewardBtn.addEventListener("click", async () => {
        try {
          const claim = getStoredShareClaim();
          if (!claim) {
            refreshRewardButtonState();
            return;
          }
          rewardBtn.disabled = true;
          const res = await fetch("/api/shares/reward", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              jobId,
              shareClaimToken: claim.claimToken,
            }),
          });
          const data = await res.json();
          if (data.ok && data.data.rewarded) {
            rewardBtn.textContent = copy.rewardSuccess;
            rewardBtn.classList.add("btn-primary");
          } else {
            rewardBtn.textContent =
              "i " + (data.data?.reason || copy.rewardAlready);
          }
        } catch {
          rewardBtn.textContent = copy.rewardFailed;
          rewardBtn.disabled = false;
        }
      });
    }
  })();
</script>

<style>
  .share-route {
    min-height: 100dvh;
    background: var(--page-surface-alt);
  }
  .share-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    display: grid;
    min-height: 64px;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: 20px;
    padding: 10px clamp(24px, 5vw, 64px);
    border-bottom: 1px solid color-mix(in srgb, var(--line) 76%, transparent);
    background: color-mix(in srgb, var(--bg-elevated) 92%, transparent);
    backdrop-filter: blur(16px);
  }
  .share-nav-brand,
  .share-nav-links {
    display: inline-flex;
    align-items: center;
  }
  .share-nav-brand {
    min-width: 0;
    gap: 8px;
    color: var(--heading);
    font-size: 15px;
    font-weight: 900;
    text-decoration: none;
  }
  .share-nav-brand img {
    width: 34px;
    height: 34px;
    flex: 0 0 34px;
  }
  .share-nav-links {
    justify-content: center;
    gap: 6px;
  }
  .share-nav-links a {
    display: inline-flex;
    min-height: 38px;
    align-items: center;
    padding: 0 12px;
    border-radius: 999px;
    color: var(--nav-link);
    font-size: 13px;
    font-weight: 800;
    text-decoration: none;
  }
  .share-nav-links a:hover,
  .share-nav-links a:focus-visible {
    background: var(--rose-soft);
    color: var(--rose);
    outline: 0;
  }
  .share-nav-cta {
    min-height: 38px;
    justify-self: end;
    padding-inline: 15px;
  }
  .share-mobile-nav {
    display: none;
  }
  :global(.share-page) {
    min-height: calc(100dvh - 64px);
  }
  .share-cta-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .share-cta-button {
    border-color: rgba(255, 255, 255, 0.72);
    background: #fff;
    color: var(--rose-dark);
    box-shadow:
      0 12px 26px rgba(56, 10, 28, 0.16),
      inset 0 1px 0 rgba(255, 255, 255, 0.5);
  }
  .share-actions {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
    margin: 24px auto;
    max-width: 600px;
  }
  .share-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 200px;
    color: var(--muted);
  }
  .share-empty {
    max-width: min(100%, 560px);
    margin: 0 auto;
    padding: 40px;
    text-align: center;
  }
  .share-empty-actions {
    display: flex;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 18px;
  }
  @media (max-width: 700px) {
    .share-nav {
      display: none;
    }
    .share-mobile-nav {
      position: sticky;
      top: 0;
      z-index: 20;
      display: grid;
      min-height: 56px;
      grid-template-columns: 44px minmax(0, 1fr) auto;
      align-items: center;
      gap: 8px;
      padding: 6px max(12px, env(safe-area-inset-left)) 6px
        max(12px, env(safe-area-inset-right));
      border-bottom: 1px solid color-mix(in srgb, var(--line) 72%, transparent);
      background: color-mix(in srgb, var(--bg-elevated) 94%, transparent);
      backdrop-filter: blur(16px);
    }
    .share-mobile-nav strong {
      min-width: 0;
      overflow: hidden;
      color: var(--heading);
      font-size: 16px;
      font-weight: 900;
      text-align: center;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .share-mobile-home,
    .share-mobile-tryon {
      display: inline-flex;
      min-height: 44px;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      text-decoration: none;
    }
    .share-mobile-home {
      width: 44px;
      color: var(--heading);
    }
    .share-mobile-home svg {
      width: 21px;
