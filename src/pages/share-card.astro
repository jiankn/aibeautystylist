    <main class="share-page">
      <article class="share-card" aria-label={copy.cardAria} id="share-card">
        <header class="share-top">
          <h1>{copy.heading}&nbsp; ✦</h1>
          <div class="share-look" id="share-look-name">{copy.loading}</div>
          <div class="share-brand">AI Beauty Stylist</div>
        </header>
        <div class="share-image" id="share-image-area">
          <div class="share-loading">{copy.cardLoading}</div>
        </div>
        <section class="benefit-row" id="share-benefits">
          <div class="benefit">
            <AppIconBadge icon="tryon" tone="rose" /><div>
              <b>{copy.benefitTryon}</b><span>{copy.benefitTryonDesc}</span>
            </div>
          </div>
          <div class="benefit">
            <AppIconBadge icon="guides" tone="teal" /><div>
              <b>{copy.benefitScenario}</b><span
                >{copy.benefitScenarioDesc}</span
              >
            </div>
          </div>
          <div class="benefit">
            <AppIconBadge icon="credits" tone="gold" /><div>
              <b>{copy.benefitFree}</b><span>{copy.benefitFreeDesc}</span>
            </div>
          </div>
        </section>
        <footer class="share-cta">
          <div>
            <h2>
              <span>{copy.ctaTitle}</span>
