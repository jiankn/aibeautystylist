            </h2>
            <p>{copy.ctaBody}</p>
            <div class="share-cta-actions">
              <a class="btn btn-primary share-cta-button" href={tryOnHref}>
                {copy.navTryCta}
              </a>
              <a class="brand" href={homeHref}>
                <img
                  class="brand-logo-img share-brand-logo"
                  src="/images/logo-ui.webp"
                  alt=""
                  aria-hidden="true"
                />
                <span
                  >AI Beauty Stylist<br /><small style="font-weight:400"
                    >aibeautystylist.com</small
                  ></span
                >
              </a>
