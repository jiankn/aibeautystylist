      height: 100%;
      max-width: 100%;
      max-height: 100%;
      object-fit: contain;
    }

    .result-loading {
      color: var(--muted);
      font-size: 14px;
      font-weight: 800;
    }

    .result-side {
      display: grid;
      align-content: start;
      gap: 14px;
      min-width: 0;
      padding: 10px 4px 10px 0;
    }

    .result-side h1 {
      margin: 0;
      color: var(--navy);
      font-size: clamp(28px, 4vw, 42px);
      line-height: 1.08;
      letter-spacing: 0;
