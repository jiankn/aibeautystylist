      color: var(--muted);
      font-size: 14px;
      line-height: 1.65;
    }

    .result-meta {
      display: grid;
      gap: 8px;
      margin: 0;
    }

    .result-meta div {
      display: grid;
      grid-template-columns: 92px minmax(0, 1fr);
      gap: 10px;
      padding: 10px 0;
      border-bottom: 1px solid var(--line);
    }

    .result-meta dt {
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
    }

    .result-meta dd {
      min-width: 0;
      margin: 0;
      color: var(--navy);
