};
const copy =
  copyByLocale[locale as keyof typeof copyByLocale] ??
  (locale === "es-419" ? copyByLocale["es-ES"] : undefined) ??
  copyByLocale.en;
const resultHref = localizeAppHref(`/result/${encodeURIComponent(jobId)}`);
const hrefs = {
  history: localizeAppHref("/history"),
  login: localizeAppHref(
    `/login?mode=login&next=${encodeURIComponent(resultHref)}`,
  ),
  shareCard: localizeAppHref("/share-card"),
  tryonFree: localizeAppHref("/tryon"),
};
---

<BaseLayout
  title={`${copy.title} | AI Beauty Stylist`}
  description={copy.description}
  bodyClass="result-body"
  robots="noindex,follow"
>
  <SiteHeader active="tryOn" mobileHidden />
  <MobileAppTopBar title={copy.title} backHref={hrefs.history} />
  <main class="result-main" data-result-page data-job-id={jobId}>
    <section class="result-shell panel" aria-labelledby="result-title">
      <div class="result-viewer" data-result-viewer>
        <div class="result-loading" role="status">{copy.loading}</div>
      </div>
      <aside class="result-side">
        <span class="section-kicker">{copy.eyebrow}</span>
        <h1 id="result-title">{copy.heading}</h1>
        <p data-result-summary>{copy.loading}</p>
        <dl class="result-meta">
          <div>
            <dt>{copy.labelStatus}</dt>
            <dd data-result-status>-</dd>
          </div>
          <div>
            <dt>{copy.labelLook}</dt>
            <dd data-result-look>{copy.defaultLook}</dd>
          </div>
          <div>
            <dt>{copy.labelDate}</dt>
            <dd data-result-date>-</dd>
          </div>
        </dl>
        <div class="result-actions" data-result-actions hidden>
          <a class="btn btn-primary" href="#" data-result-share>
            {copy.share}
          </a>
          <a class="btn" href="#" data-result-download download>
            {copy.download}
          </a>
          <button class="btn" type="button" data-result-save>
            {copy.save}
          </button>
          <a class="btn btn-outline" href={hrefs.tryonFree} data-result-retry>
            {copy.retry}
          </a>
          <a class="btn btn-outline" href={hrefs.history}>
            {copy.backHistory}
          </a>
        </div>
        <div class="result-empty" data-result-empty hidden>
          <strong>{copy.missingTitle}</strong>
          <span>{copy.missingBody}</span>
          <div>
            <a class="btn btn-primary" href={hrefs.login}>{copy.login}</a>
            <a class="btn" href={hrefs.history}>{copy.backHistory}</a>
          </div>
        </div>
      </aside>
    </section>
  </main>
  <MobileBottomNav active="history" />

  <script is:inline define:vars={{ copy, hrefs }}>
    (() => {
      const root = document.querySelector("[data-result-page]");
      if (!root) return;
      const jobId = root.dataset.jobId;
      const viewer = root.querySelector("[data-result-viewer]");
      const actions = root.querySelector("[data-result-actions]");
      const empty = root.querySelector("[data-result-empty]");
      const summary = root.querySelector("[data-result-summary]");
      const status = root.querySelector("[data-result-status]");
      const look = root.querySelector("[data-result-look]");
      const date = root.querySelector("[data-result-date]");
      const shareBtn = root.querySelector("[data-result-share]");
      const download = root.querySelector("[data-result-download]");
      const saveBtn = root.querySelector("[data-result-save]");
      const retry = root.querySelector("[data-result-retry]");
      let currentJob;

      function showFeedback(message) {
        window.showToast?.(message);
      }

      async function getJson(url, options) {
        const response = await fetch(url, options);
        const body = await response.json().catch(() => null);
        if (!response.ok || !body?.ok) {
          const error = new Error(body?.error?.message || "REQUEST_FAILED");
          error.code = body?.error?.code;
          throw error;
        }
        return body.data;
      }

      function renderImage(job) {
        if (!viewer) return;
        viewer.classList.add("is-loading");
        const image = document.createElement("img");
        image.alt = job.lookTitle || copy.defaultLook;
        image.loading = "eager";
        image.decoding = "async";
        if (
          job.resultDisplayImage &&
          job.resultDisplayImage !== job.resultImage
        ) {
          image.addEventListener(
            "error",
            (event) => {
              if (image.dataset.fallbackApplied === "true") return;
              image.dataset.fallbackApplied = "true";
              event.stopImmediatePropagation();
              image.src = job.resultImage;
            },
            { once: true },
          );
        }
        image.addEventListener(
          "load",
          () => viewer.classList.remove("is-loading"),
          { once: true },
        );
        image.addEventListener(
          "error",
          () => viewer.classList.remove("is-loading"),
          { once: true },
        );
        image.src = job.resultDisplayImage || job.resultImage;
        viewer.replaceChildren(image);
        if (image.complete)
          requestAnimationFrame(() => viewer.classList.remove("is-loading"));
      }

      function renderJob(job) {
        currentJob = job;
        const statusText =
          job.status === "succeeded"
            ? copy.statusSucceeded
            : [
                  "created",
                  "upload_validating",
                  "diagnosis_running",
                  "image_running",
                ].includes(job.status)
              ? copy.statusRunning
              : copy.statusFailed;
        if (summary) summary.textContent = job.disclaimer || copy.disclaimer;
        if (status) status.textContent = statusText;
        if (look) look.textContent = job.lookTitle || copy.defaultLook;
        if (date) {
          date.textContent = job.createdAt
            ? new Intl.DateTimeFormat(
                document.documentElement.lang || undefined,
                {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                },
              ).format(new Date(job.createdAt))
            : "-";
        }
        if (job.status === "succeeded" && job.resultImage) {
          renderImage(job);
          if (download)
            download.href = `/api/tryon-jobs/${encodeURIComponent(job.id)}/result`;
          if (shareBtn)
            shareBtn.href = `${hrefs.shareCard}?jobId=${encodeURIComponent(job.id)}`;
          if (retry) {
            const retryUrl = new URL(hrefs.tryonFree, location.origin);
            if (job.lookSlug) retryUrl.searchParams.set("look", job.lookSlug);
            retry.href = `${retryUrl.pathname}${retryUrl.search}`;
          }
          if (actions) actions.hidden = false;
          loadSavedState();
          return;
        }
        showEmpty();
      }

      function showEmpty() {
        if (viewer) {
          const box = document.createElement("div");
          box.className = "result-loading";
          box.textContent = copy.missingTitle;
          viewer.replaceChildren(box);
        }
        if (actions) actions.hidden = true;
        if (empty) empty.hidden = false;
      }

      async function loadSavedState() {
        if (!saveBtn) return;
        try {
          const data = await getJson("/api/saved-looks");
          const items = Array.isArray(data?.items) ? data.items : [];
          const saved = items.some((item) => item.jobId === jobId);
          saveBtn.dataset.saved = saved ? "true" : "false";
          saveBtn.textContent = saved ? copy.saved : copy.save;
          saveBtn.setAttribute("aria-pressed", String(saved));
        } catch {
          /* keep default save state */
        }
      }

      saveBtn?.addEventListener("click", async () => {
        if (!currentJob) return;
        saveBtn.disabled = true;
        const saved = saveBtn.dataset.saved === "true";
        try {
          if (saved) {
            await getJson(`/api/saved-looks/${encodeURIComponent(jobId)}`, {
              method: "DELETE",
            });
            saveBtn.dataset.saved = "false";
            saveBtn.textContent = copy.save;
            saveBtn.setAttribute("aria-pressed", "false");
          } else {
            await getJson("/api/saved-looks", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                jobId,
                lookSlug: currentJob.lookSlug || "commute",
              }),
            });
            saveBtn.dataset.saved = "true";
            saveBtn.textContent = copy.saved;
            saveBtn.setAttribute("aria-pressed", "true");
          }
        } catch (error) {
          showFeedback(
            error.code === "SAVED_LOOK_LIMIT_REACHED"
              ? copy.savedLimitReached
              : copy.saveFailed,
          );
        } finally {
          saveBtn.disabled = false;
        }
      });

      if (!jobId) {
        showEmpty();
        return;
      }

      getJson(`/api/tryon-jobs/${encodeURIComponent(jobId)}`)
        .then(renderJob)
        .catch(showEmpty);
    })();
  </script>

  <style>
    :global(.result-body) {
      max-width: 100%;
      overflow-x: hidden;
      overscroll-behavior-x: none;
    }

    .result-main {
      width: 100%;
      max-width: 100%;
      min-height: calc(100dvh - 64px);
      overflow-x: hidden;
      padding: 24px;
      background: var(--page-surface);
      touch-action: pan-y;
    }

    .result-shell {
      display: grid;
      grid-template-columns: minmax(0, 1.12fr) minmax(320px, 0.88fr);
      gap: 22px;
      width: min(100%, 1120px);
      max-width: 100%;
      min-width: 0;
      overflow-x: hidden;
      margin: 0 auto;
      padding: 18px;
    }

    .result-viewer {
