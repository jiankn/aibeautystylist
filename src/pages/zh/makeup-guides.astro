---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = true;

const featuredGuides = [
  { label: 'AI 试妆', href: '/zh/try-on/', detail: '上传自拍前先了解 AI 会如何判断肤色、五官和妆容方向。' },
  { label: '口红和粉底色号测试', href: '/zh/tools/shade-finder/', detail: '从冷暖调、肤色深浅和妆容目标开始缩小色号范围。' },
  { label: '冷暖皮判断', href: '/zh/tools/undertone-quiz/', detail: '用 5 个问题判断你更接近冷调、暖调还是中性调。' },
  { label: '按肤色冷暖调找粉底', href: '/zh/tools/foundation-shade-finder-by-undertone/', detail: '理解黄调、粉调、中性调、橄榄调和深肤色底妆方向。' },
  { label: '口红色号指南', href: '/zh/lipstick-shades/', detail: '从暖皮、冷皮、橄榄皮、深肤色和亚洲肤色选择口红色系。' },
];

const styleGuides = [
  { label: '单眼皮妆容', href: '/zh/styles/monolid-makeup/', detail: '睁眼也看得到的眼影画法，不用伪造双眼皮褶皱。' },
  { label: '橄榄皮妆容', href: '/zh/styles/olive-skin-makeup/', detail: '顺着绿金底色选色，避开显灰和发橘。' },
  { label: '深肤色妆容', href: '/zh/styles/deep-skin-makeup/', detail: '有深度、不发灰的底妆、腮红和裸唇。' },
  { label: '韩系水光妆', href: '/zh/styles/korean-dewy-makeup/', detail: '清透不油腻的底妆和渐变唇。' },
];

const scenarioGuides = [
  { label: '肿眼泡眼妆', href: '/zh/scenarios/hooded-eyes-makeup/', detail: '睁眼也有轮廓、不显肿的眼影位置。' },
  { label: '成熟肌妆容', href: '/zh/scenarios/mature-skin-makeup/', detail: '薄层、提拉和不卡纹的画法。' },
  { label: '婚礼宾客妆', href: '/zh/scenarios/wedding-guest-makeup/', detail: '上镜、耐久又不抢新娘风头。' },
  { label: '日常裸妆', href: '/zh/scenarios/everyday-natural-makeup/', detail: '清透、好上手、可重复的日常妆。' },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'AI Beauty Stylist 中文美妆指南',
  description: '中文美妆指南，覆盖 AI 试妆、冷暖皮判断、口红色号、粉底色号和场景妆容。',
  url: 'https://aibeautystylist.com/zh/makeup-guides/',
};
---

<BaseLayout
  locale="zh-CN"
  title="美妆指南｜AI 试妆、冷暖皮、口红和粉底色号"
  description="AI Beauty Stylist 中文美妆指南。按问题查找 AI 试妆、冷暖皮判断、口红色号、粉底色号和适合不同场景的妆容建议。"
  structuredData={structuredData}
>
  <section class="section">
    <div class="container section-copy narrow">
      <span class="eyebrow">美妆指南</span>
      <h1>从你真正关心的问题开始，而不是从复杂教程开始。</h1>
      <p>这里整理中文用户最常见的美妆问题：适合我的妆容、冷暖皮判断、口红显白、粉底不发灰、日常和重要场景妆容。</p>
    </div>

    <div class="container grid-cards grid-cards-3 top-gap">
      {featuredGuides.map((guide) => (
        <a class="card guide-hub-card" href={guide.href}>
          <span class="pill">中文 P0 指南</span>
          <h2>{guide.label}</h2>
          <p>{guide.detail}</p>
        </a>
      ))}
    </div>

    <div class="container section-copy narrow top-gap">
      <h2>按妆容风格选择</h2>
      <p>这些是适合中文用户的高频妆容专题，每个都有完整的步骤、技巧和产品建议。</p>
    </div>

    <div class="container grid-cards grid-cards-2 top-gap">
      {styleGuides.map((guide) => (
        <a class="card guide-hub-card" href={guide.href}>
          <span class="pill">妆容风格</span>
          <h2>{guide.label}</h2>
          <p>{guide.detail}</p>
        </a>
      ))}
    </div>

    <div class="container section-copy narrow top-gap">
      <h2>按场景和眼型选择</h2>
      <p>针对具体场景和需求的妆容方案，从日常到重要场合。</p>
    </div>

    <div class="container grid-cards grid-cards-2 top-gap">
      {scenarioGuides.map((guide) => (
        <a class="card guide-hub-card" href={guide.href}>
          <span class="pill">场景妆容</span>
          <h2>{guide.label}</h2>
          <p>{guide.detail}</p>
        </a>
      ))}
    </div>

    <div class="container section-copy narrow top-gap">
      <h2>后续会扩展的中文专题</h2>
      <p>下一批适合继续做成独立中文 SEO 页的主题包括：通勤妆、约会妆、面试妆、玻璃肌妆容和成熟肌通勤妆。</p>
    </div>
  </section>
</BaseLayout>
