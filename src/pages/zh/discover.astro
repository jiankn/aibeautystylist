---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildLookTryOnHref, lookCatalogItems, lookFilters } from '../../data/lookCatalog';
import { styleNavigationItems } from '../../data/stylePages';

export const prerender = true;

const lookItems = lookCatalogItems.map((look, index) => ({
  ...look,
  position: index + 1,
  tryOnHref: `${buildLookTryOnHref(look)}&source=zh-discover-look-library&position=${index + 1}`,
}));

const styleItems = styleNavigationItems.map((style, index) => ({
  ...style,
  position: index + 1,
  tryOnHref: `/try-on?scenario=${style.tryOnScenario}&style=${style.slug}&look=${style.lookSlug}&source=zh-discover-style-nav&position=${index + 1}`,
}));

const styleFilters = [
  { label: '全部', value: 'all' },
  { label: '日常', value: 'office' },
  { label: '约会', value: 'date' },
  { label: '拍照', value: 'photo' },
];

// 过滤标签中文化
const zhLookFilters = lookFilters.map((f) => {
  const labelMap: Record<string, string> = {
    All: '全部', Daily: '日常', Glam: '光感', Glow: '水光',
    Editorial: '创意', Beginner: '新手', Camera: '拍照',
  };
  return { ...f, label: labelMap[f.label] ?? f.label };
});

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: '发现妆容',
    description: '浏览 AI Beauty Stylist 全部妆容和风格方向，选择后进入 AI 试妆。',
    url: 'https://aibeautystylist.com/zh/discover/',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'AI 妆容图库',
    numberOfItems: lookItems.length,
    itemListElement: lookItems.map((look) => ({
      '@type': 'ListItem',
      position: look.position,
      name: look.title,
      url: `https://aibeautystylist.com${look.tryOnHref}`,
    })),
  },
];
---

<BaseLayout
  locale="zh-CN"
  title="发现妆容｜AI Beauty Stylist 中文版"
  description={`浏览 ${lookItems.length} 个妆容和 ${styleItems.length} 个风格方向，然后用 AI 试妆在自己脸上看效果。`}
  structuredData={structuredData}
>
  <section class="section discover-hero">
    <div class="container discover-hero-grid">
      <div class="section-copy discover-hero-copy">
        <span class="eyebrow">发现妆容</span>
        <h1>浏览完整妆容图库，不用挤在首页找灵感。</h1>
        <p>想要视觉灵感时浏览具体妆容，已经知道想要什么风格时直接选风格方向。</p>
        <div class="discover-hero-actions">
          <a class="btn" href="#look-library">浏览妆容</a>
          <a class="btn btn-secondary" href="#style-directions">试试风格</a>
        </div>
      </div>

      <div class="discover-stats" aria-label="图库数量">
        <article>
          <strong>{lookItems.length}</strong>
          <span>妆容</span>
          <small>完整灵感图库</small>
        </article>
        <article>
          <strong>{styleItems.length}</strong>
          <span>风格方向</span>
          <small>完整风格地图</small>
        </article>
        <article>
          <strong>8</strong>
          <span>过滤分组</span>
          <small>快速筛选</small>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-soft discover-library" id="look-library">
    <div class="container discover-section-head">
      <div class="section-copy">
        <span class="eyebrow">完整图库</span>
        <h2>{lookItems.length} 个妆容，覆盖不同场景、心情和五官特征。</h2>
        <p>这些是具体的妆容：以视觉为主、场景明确，可以直接传入 AI 试妆作为灵感参考。</p>
      </div>
      <div class="discover-filter-tabs" aria-label="过滤妆容">
        {zhLookFilters.map((filter, index) => (
          <button
            class:list={['discover-filter-chip', { 'is-active': index === 0 }]}
            type="button"
            data-discover-filter="look"
            data-filter-value={filter.value}
          >
            {filter.label}
          </button>
        ))}
      </div>
    </div>

    <div class="container discover-look-grid">
      {lookItems.map((look) => (
        <a
          class="discover-look-card"
          href={look.tryOnHref}
          style={`--look-focus:${look.focus};`}
          data-discover-look
          data-filter-group={look.category}
          data-analytics-look
          data-analytics-source="zh-discover-look-library"
          data-analytics-look-slug={look.slug}
          data-analytics-position={look.position}
        >
          <span class="discover-look-image">
            <img src={look.image} alt={look.imageAlt} loading={look.position <= 8 ? 'eager' : 'lazy'} />
          </span>
          <span class="discover-look-copy">
            <span>{look.tone}</span>
            <strong>{look.title}</strong>
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="section discover-styles" id="style-directions">
    <div class="container discover-section-head">
      <div class="section-copy">
        <span class="eyebrow">全部风格</span>
        <h2>{styleItems.length} 个风格方向，稳定的导航路径。</h2>
        <p>这些是更宏观的审美路线，不是一次性的图片。每个风格都指向一个代表性妆容和试妆意图。</p>
      </div>
      <div class="discover-filter-tabs" aria-label="过滤风格方向">
        {styleFilters.map((filter, index) => (
          <button
            class:list={['discover-filter-chip', { 'is-active': index === 0 }]}
            type="button"
            data-discover-filter="style"
            data-filter-value={filter.value}
          >
            {filter.label}
          </button>
        ))}
      </div>
    </div>

    <div class="container discover-style-grid">
      {styleItems.map((style) => (
        <a
          class="discover-style-card"
          href={style.tryOnHref}
          style={`--look-focus:${style.focus ?? 'center'};`}
          data-discover-style
          data-filter-group={style.tryOnScenario}
          data-analytics-look
          data-analytics-source="zh-discover-style-nav"
          data-analytics-look-slug={style.lookSlug}
          data-analytics-style-slug={style.slug}
          data-analytics-position={style.position}
        >
          <span class="discover-style-image">
            <img src={style.image} alt={style.imageAlt} loading="lazy" />
          </span>
          <span>{style.label}</span>
        </a>
      ))}
    </div>
  </section>

  <script>
    function initDiscoverFilters() {
      const filterButtons = document.querySelectorAll<HTMLButtonElement>('[data-discover-filter]');
      filterButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const filterType = button.dataset.discoverFilter;
          const filterValue = button.dataset.filterValue || 'all';
          if (!filterType) return;
          document.querySelectorAll<HTMLButtonElement>(`[data-discover-filter="${filterType}"]`).forEach((item) => {
            item.classList.toggle('is-active', item === button);
          });
          const selector = filterType === 'look' ? '[data-discover-look]' : '[data-discover-style]';
          document.querySelectorAll<HTMLElement>(selector).forEach((card) => {
            const group = card.dataset.filterGroup || '';
            card.hidden = filterValue !== 'all' && group !== filterValue;
          });
        });
      });
    }
    initDiscoverFilters();
  </script>
</BaseLayout>

<style>
  .discover-hero { padding-top: 48px; }
  .discover-hero-grid { display: grid; grid-template-columns: minmax(0, 1fr) 360px; gap: 40px; align-items: end; }
  .discover-hero-copy { max-width: 760px; margin: 0; }
  .discover-hero-actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 24px; }
  .discover-stats { display: grid; gap: 12px; }
  .discover-stats article { display: grid; gap: 4px; padding: 18px; border: 1px solid var(--border); border-radius: var(--radius-sm); background: rgba(255,255,255,0.82); box-shadow: 0 18px 44px rgba(68,42,42,0.08); }
  .discover-stats strong { font-family: 'Playfair Display', Georgia, serif; font-size: 2.15rem; line-height: 1; color: var(--text); }
  .discover-stats span { font-weight: 700; color: var(--text); }
  .discover-stats small { color: var(--muted); font-weight: 600; }
  .discover-section-head { display: flex; align-items: end; justify-content: space-between; gap: 24px; margin-bottom: 28px; }
  .discover-section-head .section-copy { max-width: 720px; margin: 0; }
  .discover-filter-tabs { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: 8px; max-width: 440px; }
  .discover-filter-chip { min-height: 40px; padding: 8px 14px; border: 1px solid var(--border); border-radius: 999px; background: rgba(255,255,255,0.82); color: var(--text-secondary); font-size: 0.84rem; font-weight: 700; cursor: pointer; }
  .discover-filter-chip.is-active { background: var(--accent); border-color: var(--accent); color: white; }
  .discover-look-grid { display: grid; grid-template-columns: repeat(6, minmax(0, 1fr)); gap: 12px; }
  .discover-look-card, .discover-style-card { color: inherit; text-decoration: none; }
  .discover-look-card { display: grid; gap: 10px; min-width: 0; }
  .discover-look-image { position: relative; display: block; overflow: hidden; aspect-ratio: 3/4; border-radius: var(--radius-sm); background: var(--accent-soft); box-shadow: 0 16px 36px rgba(68,42,42,0.08); }
  .discover-look-image img, .discover-style-image img { width: 100%; height: 100%; object-fit: cover; object-position: var(--look-focus, center); transition: transform 0.45s ease; }
  .discover-look-card:hover img, .discover-style-card:hover img { transform: scale(1.045); }
  .discover-look-copy { display: grid; gap: 3px; }
  .discover-look-copy span { color: var(--accent-deep); font-size: 0.72rem; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase; }
  .discover-look-copy strong { color: var(--text); font-size: 0.92rem; line-height: 1.25; }
  .discover-style-grid { display: grid; grid-template-columns: repeat(6, minmax(0, 1fr)); gap: 14px; }
  .discover-style-card { display: grid; gap: 8px; text-align: center; min-width: 0; }
  .discover-style-image { display: block; overflow: hidden; aspect-ratio: 3/4; border-radius: var(--radius-sm); background: var(--accent-soft); box-shadow: 0 14px 34px rgba(62,39,39,0.08); }
  .discover-style-card > span:last-child { font-size: 0.84rem; font-weight: 700; line-height: 1.25; color: var(--text); }
  @media (max-width: 1100px) { .discover-look-grid, .discover-style-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); } }
  @media (max-width: 800px) { .discover-hero-grid, .discover-section-head { grid-template-columns: 1fr; display: grid; align-items: start; } .discover-filter-tabs { justify-content: flex-start; max-width: none; } }
  @media (max-width: 640px) { .discover-look-grid, .discover-style-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; } .discover-stats { grid-template-columns: 1fr; } }
</style>
