---
import LookCard from "../components/LookCard.astro";
import MobileAppTopBar from "../components/MobileAppTopBar.astro";
import MobileBottomNav from "../components/MobileBottomNav.astro";
import SiteHeader from "../components/SiteHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { resolveLookCatalog } from "../data/makeup/resolveCatalog";
import { getCurrentLocale } from "../lib/i18n";
import { getLocalizedAppHref, resolveLocaleRoute } from "../i18n/routing";
import {
  getMarketProfileLabel,
  getMarketProfileOptions,
} from "../data/makeup/audienceProfiles";
import {
  experienceLabels as zhExperienceLabels,
  scenarioLabels as zhScenarioLabels,
  finishFilterLabels as zhFinishFilterLabels,
  uiLabels as zhUiLabels,
} from "../data/makeup/localizations/zh-CN";
import {
  experienceLabels as enExperienceLabels,
  scenarioLabels as enScenarioLabels,
  finishFilterLabels as enFinishFilterLabels,
  uiLabels as enUiLabels,
} from "../data/makeup/localizations/en";
import {
  experienceLabels as esExperienceLabels,
  scenarioLabels as esScenarioLabels,
  finishFilterLabels as esFinishFilterLabels,
  uiLabels as esUiLabels,
} from "../data/makeup/localizations/es";
import {
  experienceLabels as deExperienceLabels,
  scenarioLabels as deScenarioLabels,
  finishFilterLabels as deFinishFilterLabels,
  uiLabels as deUiLabels,
} from "../data/makeup/localizations/de";
import {
  experienceLabels as frExperienceLabels,
  scenarioLabels as frScenarioLabels,
  finishFilterLabels as frFinishFilterLabels,
  uiLabels as frUiLabels,
} from "../data/makeup/localizations/fr";
import {
  experienceLabels as jaExperienceLabels,
  scenarioLabels as jaScenarioLabels,
  finishFilterLabels as jaFinishFilterLabels,
  uiLabels as jaUiLabels,
} from "../data/makeup/localizations/ja";
import {
  experienceLabels as koExperienceLabels,
  scenarioLabels as koScenarioLabels,
  finishFilterLabels as koFinishFilterLabels,
  uiLabels as koUiLabels,
} from "../data/makeup/localizations/ko";
import {
  experienceLabels as ptBRExperienceLabels,
  scenarioLabels as ptBRScenarioLabels,
  finishFilterLabels as ptBRFinishFilterLabels,
  uiLabels as ptBRUiLabels,
} from "../data/makeup/localizations/pt-BR";
import {
  experienceLabels as zhTWExperienceLabels,
  scenarioLabels as zhTWScenarioLabels,
  finishFilterLabels as zhTWFinishFilterLabels,
  uiLabels as zhTWUiLabels,
} from "../data/makeup/localizations/zh-TW";

// 获取 Audience Context（由中间件注入）
const audienceContext = Astro.locals.audienceContext;
const locale = getCurrentLocale();
const currentPathname = Astro.originPathname || Astro.url.pathname;
const currentRoute =
  Astro.locals.localeRoute ?? resolveLocaleRoute(currentPathname);
const localizeAppHref = (href: string) =>
  getLocalizedAppHref(href, currentRoute.language.slug);
const localeValue = String(locale);
const isKo = locale.startsWith("ko");
const isDe = locale.startsWith("de");
const isFr = locale.startsWith("fr");
const isJa = locale.startsWith("ja");
const isEs = locale.startsWith("es");
const isPt = locale.startsWith("pt");
const isZhTW = localeValue === "zh-TW" || localeValue === "zh-HK";
const isZh = locale.startsWith("zh") && !isZhTW;

// 选择当前 locale 的 UI 文案
const ui = isKo
  ? koUiLabels
  : isDe
    ? deUiLabels
    : isFr
      ? frUiLabels
      : isJa
        ? jaUiLabels
        : isZhTW
          ? zhTWUiLabels
          : isZh
            ? zhUiLabels
            : isEs
              ? esUiLabels
              : isPt
                ? ptBRUiLabels
                : enUiLabels;
const scenarioL = isKo
  ? koScenarioLabels
  : isDe
    ? deScenarioLabels
    : isFr
      ? frScenarioLabels
      : isJa
        ? jaScenarioLabels
        : isZhTW
          ? zhTWScenarioLabels
          : isZh
            ? zhScenarioLabels
            : isEs
              ? esScenarioLabels
              : isPt
                ? ptBRScenarioLabels
                : enScenarioLabels;
const finishL = isKo
  ? koFinishFilterLabels
  : isDe
    ? deFinishFilterLabels
    : isFr
      ? frFinishFilterLabels
      : isJa
        ? jaFinishFilterLabels
        : isZhTW
          ? zhTWFinishFilterLabels
          : isZh
            ? zhFinishFilterLabels
            : isEs
              ? esFinishFilterLabels
              : isPt
                ? ptBRFinishFilterLabels
                : enFinishFilterLabels;
const experienceL = isKo
  ? koExperienceLabels
  : isDe
    ? deExperienceLabels
    : isFr
      ? frExperienceLabels
      : isJa
        ? jaExperienceLabels
        : isZhTW
          ? zhTWExperienceLabels
          : isZh
            ? zhExperienceLabels
            : isEs
              ? esExperienceLabels
              : isPt
                ? ptBRExperienceLabels
                : enExperienceLabels;

// 通过目录解析器获取排序后的妆容列表
const resolvedLooks = resolveLookCatalog(audienceContext);

// 当前市场画像标签
const marketLabel = getMarketProfileLabel(
  audienceContext.marketProfile,
  locale,
);
const marketOptions = getMarketProfileOptions(locale);

const copy = isKo
  ? {
      chooseInspiration: "메이크업 영감 선택",
      inspirationHint:
        "추천 순서와 참고 이미지만 바꾸며, 사용자의 정체성을 의미하지 않습니다.",
      inspirationControlLabel: "추천 기준",
      inspirationControlNote: "추천 순서와 참고 이미지만 조정합니다.",
      inspirationSwitchShort: "변경",
      close: "닫기",
      closeFilters: "필터 닫기",
      currentSelection: "현재 선택",
      applySitewide: "사이트 전체에 적용",
      lookGallery: "룩 목록",
      libraryFooter: `${resolvedLooks.length}개 룩을 선택할 수 있습니다. 하나를 고른 뒤 셀피로 시도해 보세요.`,
    }
  : isDe
    ? {
        chooseInspiration: "Make-up Inspiration wählen",
        inspirationHint:
          "Dies ändert nur die Reihenfolge der Empfehlungen und Referenzbilder, nicht deine Identität.",
        inspirationControlLabel: "Referenz-Inspiration",
        inspirationControlNote:
          "Passt Empfehlungen und Referenzbilder an, ohne alle Looks zu begrenzen.",
        inspirationSwitchShort: "Ändern",
        close: "Schließen",
        closeFilters: "Filter schließen",
        currentSelection: "Aktuelle Auswahl",
        applySitewide: "Auf der gesamten Website anwenden",
        lookGallery: "Look-Galerie",
        libraryFooter: `${resolvedLooks.length} Looks verfügbar. Wähle einen Look und teste ihn auf deinem Selfie.`,
      }
    : isFr
      ? {
          chooseInspiration: "Choisir une inspiration maquillage",
          inspirationHint:
            "Cela modifie seulement l’ordre des recommandations et les images de référence, pas votre identité.",
          inspirationControlLabel: "Inspiration de référence",
          inspirationControlNote:
            "Ajuste les recommandations et les images sans limiter tous les looks.",
          inspirationSwitchShort: "Changer",
          close: "Fermer",
          closeFilters: "Fermer les filtres",
          currentSelection: "Sélection actuelle",
          applySitewide: "Appliquer à tout le site",
          lookGallery: "Galerie de looks",
          libraryFooter: `${resolvedLooks.length} looks disponibles. Choisissez-en un puis essayez-le sur votre selfie.`,
        }
      : isJa
        ? {
            chooseInspiration: "メイクの表示基準を選ぶ",
            inspirationHint:
              "おすすめ順と参考画像だけが変わり、あなたの属性を示すものではありません。",
            inspirationControlLabel: "参考インスピレーション",
            inspirationControlNote: "おすすめ順と参考画像だけを調整します。",
            inspirationSwitchShort: "変更",
            close: "閉じる",
            closeFilters: "絞り込みを閉じる",
            currentSelection: "現在の選択",
            applySitewide: "サイト全体に適用",
            lookGallery: "メイク一覧",
            libraryFooter: `${resolvedLooks.length}件のメイクから選び、セルフィーで試着できます。`,
          }
        : isZhTW
          ? {
              chooseInspiration: "選擇妝容靈感",
              inspirationHint: "這只會影響推薦順序和參考圖，不代表你的身份。",
              inspirationControlLabel: "參考靈感",
              inspirationControlNote:
                "只調整推薦順序和參考圖，不限制全部妝容。",
              inspirationSwitchShort: "切換",
              close: "關閉",
              closeFilters: "關閉篩選",
              currentSelection: "目前選擇",
              applySitewide: "切換並套用到全站",
              lookGallery: "妝容列表",
              libraryFooter: `共 ${resolvedLooks.length} 個妝容，可選擇後上傳自拍試妝`,
            }
          : isZh
            ? {
                chooseInspiration: "选择妆容灵感",
                inspirationHint: "这只影响推荐顺序和参考图，不代表你的身份。",
                inspirationControlLabel: "参考灵感",
                inspirationControlNote:
                  "只调整推荐顺序和参考图，不限制全部妆容。",
                inspirationSwitchShort: "切换",
                close: "关闭",
                closeFilters: "关闭筛选",
                currentSelection: "当前选择",
                applySitewide: "切换并应用到全站",
                lookGallery: "妆容列表",
                libraryFooter: `共 ${resolvedLooks.length} 个妆容，可选择后上传自拍试妆`,
              }
            : isEs
              ? {
                  chooseInspiration: "Elegir inspiración de maquillaje",
                  inspirationHint:
                    "Esto solo cambia el orden de recomendaciones y las imágenes de referencia; no define tu identidad.",
                  inspirationControlLabel: "Inspiración de referencia",
                  inspirationControlNote:
                    "Ajusta recomendaciones e imágenes sin limitar todos los looks.",
                  inspirationSwitchShort: "Cambiar",
                  close: "Cerrar",
                  closeFilters: "Cerrar filtros",
                  currentSelection: "Selección actual",
                  applySitewide: "Aplicar en todo el sitio",
                  lookGallery: "Galería de looks",
                  libraryFooter: `${resolvedLooks.length} looks disponibles. Elige uno y sube una selfie para probarlo.`,
                }
              : isPt
                ? {
                    chooseInspiration: "Escolher inspiração de maquiagem",
                    inspirationHint:
                      "Isso só altera a ordem das recomendações e as imagens de referência; não define sua identidade.",
                    inspirationControlLabel: "Inspiração de referência",
                    inspirationControlNote:
                      "Ajusta recomendações e imagens sem limitar todos os looks.",
                    inspirationSwitchShort: "Trocar",
                    close: "Fechar",
                    closeFilters: "Fechar filtros",
                    currentSelection: "Seleção atual",
                    applySitewide: "Aplicar em todo o site",
                    lookGallery: "Galeria de looks",
                    libraryFooter: `${resolvedLooks.length} looks disponíveis. Escolha um e envie uma selfie para testar.`,
                  }
                : {
                    chooseInspiration: "Choose makeup inspiration",
                    inspirationHint:
                      "This changes recommendations and reference images, not your identity.",
                    inspirationControlLabel: "Reference inspiration",
                    inspirationControlNote:
                      "Adjusts recommendations and reference images without limiting all looks.",
                    inspirationSwitchShort: "Change",
                    close: "Close",
                    closeFilters: "Close filters",
                    currentSelection: "Current selection",
                    applySitewide: "Apply across the site",
                    lookGallery: "Look Gallery",
                    libraryFooter: `${resolvedLooks.length} looks available — choose one and upload a selfie to try it on`,
                  };

const allLabel = finishL.all;
const finishMatches = isKo
  ? {
      sheer: ["시어", "촉촉한", "가벼운"],
      natural: ["내추럴", "깔끔한", "빠른", "이지"],
      glow: ["광채", "부드러운", "화사한"],
      matte: ["소프트 매트", "저채도", "벨벳", "에디토리얼"],
      satin: ["윤광", "새틴", "정돈된"],
      photogenic: ["사진 준비", "소프트 포커스"],
      contour: ["웜", "윤곽", "리프팅"],
      professional: ["프로페셔널"],
    }
  : isDe
    ? {
        sheer: ["Transparent", "Dewy", "Leicht"],
        natural: ["Natürlich", "Clean", "Schnell", "Unkompliziert"],
        glow: ["Glowy", "Sanft", "Strahlend", "Aufhellend"],
        matte: ["Soft Matte", "Gedeckt", "Samtig", "Editorial"],
        satin: ["Leuchtend", "Satin", "Gepflegt"],
        photogenic: ["Kameratauglich", "Soft Focus"],
        contour: ["Warm", "Konturiert", "Geliftet"],
        professional: ["Professionell"],
      }
    : isFr
      ? {
          sheer: ["Léger", "Glowy", "Aérien"],
          natural: ["Naturel", "Net", "Rapide", "Sans effort"],
          glow: ["Éclatant", "Doux", "Radieux", "Illuminateur"],
          matte: ["Mat doux", "Sourd", "Velours", "Éditorial"],
          satin: ["Lumineux", "Satiné", "Soigné"],
          photogenic: ["Photogénique", "Flou doux"],
          contour: ["Chaud", "Sculpté", "Lifté"],
          professional: ["Professionnel"],
        }
      : isJa
        ? {
            sheer: ["シアー", "ツヤ", "軽やか"],
            natural: ["ナチュラル", "クリーン", "時短", "抜け感"],
            glow: ["グロウ", "ソフト", "明るいツヤ", "トーンアップ"],
            matte: ["ソフトマット", "低彩度", "ベルベット", "エディトリアル"],
            satin: ["ルミナス", "サテン", "上品"],
            photogenic: ["写真向け", "ソフトフォーカス"],
            contour: ["ウォーム", "立体感", "リフト"],
            professional: ["きちんと感"],
          }
        : isZhTW
          ? {
              sheer: ["清透", "水潤", "輕盈"],
              natural: ["自然", "乾淨", "快速", "輕鬆"],
              glow: ["光澤", "柔和", "光采", "提亮"],
              matte: ["柔霧", "低飽和", "絲絨", "編輯感"],
              satin: ["透亮", "緞光", "精緻"],
              photogenic: ["上鏡", "柔焦"],
              contour: ["暖調", "輪廓", "提拉"],
              professional: ["專業"],
            }
          : isZh
            ? {
                sheer: ["清透", "水润", "水光", "轻盈"],
                natural: ["自然", "松弛", "快速", "干净"],
                glow: ["显气色", "柔和", "焕亮", "提神"],
                matte: ["柔雾", "低饱和", "丝绒", "高级"],
                satin: ["光泽", "缎光", "精致"],
                photogenic: ["上镜", "柔焦"],
                contour: ["暖调", "立体", "提拉"],
                professional: ["专业"],
              }
            : isEs
              ? {
                  sheer: ["Ligero", "Luminoso"],
                  natural: ["Natural", "Limpio", "Rápido", "Sin esfuerzo"],
                  glow: ["Brillante", "Suave", "Radiante", "Iluminador"],
                  matte: ["Mate suave", "Apagado", "Terciopelo", "Editorial"],
                  satin: ["Luminoso", "Satinado", "Pulido"],
                  photogenic: ["Listo para cámara", "Soft focus"],
                  contour: ["Cálido", "Definido", "Elevado"],
                  professional: ["Profesional"],
                }
              : isPt
                ? {
                    sheer: ["Leve", "Glow"],
                    natural: ["Natural", "Limpo", "Rápido", "Descomplicado"],
                    glow: ["Viçoso", "Suave", "Radiante", "Iluminado"],
                    matte: [
                      "Matte suave",
                      "Baixa saturação",
                      "Velvet",
                      "Editorial",
                    ],
                    satin: ["Luminoso", "Satinado", "Polido"],
                    photogenic: ["Pronto para câmera", "Soft focus"],
                    contour: ["Quente", "Contornado", "Lift"],
                    professional: ["Profissional"],
                  }
                : {
                    sheer: ["Sheer", "Dewy", "Airy"],
                    natural: ["Natural", "Clean", "Quick", "Effortless"],
                    glow: ["Glowing", "Soft", "Radiant", "Brightening"],
                    matte: ["Soft Matte", "Muted", "Velvet", "Editorial"],
                    satin: ["Luminous", "Satin", "Polished"],
                    photogenic: ["Camera Ready", "Soft Focus"],
                    contour: ["Warm", "Sculpted", "Lifted"],
                    professional: ["Professional"],
                  };

const scenarioFilters = [
  { value: allLabel, label: allLabel },
  { value: scenarioL.daily, label: scenarioL.daily },
  { value: scenarioL.commute, label: scenarioL.commute },
  { value: scenarioL.interview, label: scenarioL.interview },
  { value: scenarioL.date, label: scenarioL.date },
  { value: scenarioL.photo, label: scenarioL.photo },
  { value: scenarioL.event, label: scenarioL.event },
  { value: scenarioL.evening, label: scenarioL.evening },
];

const finishFilters = [
  { value: allLabel, label: finishL.all },
  {
    value: finishMatches.sheer[0],
    label: finishL.sheer,
    match: finishMatches.sheer,
  },
  {
    value: finishMatches.natural[0],
    label: finishL.natural,
    match: finishMatches.natural,
  },
  {
    value: finishMatches.glow[0],
    label: finishL.glow,
    match: finishMatches.glow,
  },
  {
    value: finishMatches.matte[0],
    label: finishL.matte,
    match: finishMatches.matte,
  },
  {
    value: finishMatches.satin[0],
    label: finishL.satin,
    match: finishMatches.satin,
  },
  {
    value: finishMatches.photogenic[0],
    label: finishL.photogenic,
    match: finishMatches.photogenic,
  },
  {
    value: finishMatches.contour[0],
    label: finishL.contour,
    match: finishMatches.contour,
  },
  {
    value: finishMatches.professional[0],
    label: finishL.professional,
    match: finishMatches.professional,
  },
];

const experienceFilters = [
  { value: allLabel, label: allLabel },
  { value: experienceL.beginner, label: experienceL.beginner },
  { value: experienceL.advanced, label: experienceL.advanced },
];

const favoriteFilterLabel = isKo
  ? "저장"
  : isDe
    ? "Gespeichert"
    : isFr
      ? "Favoris"
      : isJa
        ? "保存済み"
        : isZhTW
          ? "收藏"
          : isZh
            ? "收藏"
            : isEs || isPt
              ? "Guardados"
              : "Saved";
const favoriteOnlyLabel = isKo
  ? "저장한 룩만"
  : isDe
    ? "Nur gespeicherte Looks"
    : isFr
      ? "Looks enregistrés"
      : isJa
        ? "保存したメイクのみ"
        : isZhTW
          ? "只看收藏"
          : isZh
            ? "只看收藏"
            : isEs
              ? "Solo guardados"
              : isPt
                ? "Somente salvos"
                : "Saved only";
const favoriteFilters = [
  { value: allLabel, label: allLabel },
  { value: "favorites", label: favoriteOnlyLabel },
];

const filterGroups = [
  { id: "scenario", label: ui.filterScenario, options: scenarioFilters },
  { id: "finish", label: ui.filterFinish, options: finishFilters },
  { id: "experience", label: ui.filterExperience, options: experienceFilters },
  { id: "favorite", label: favoriteFilterLabel, options: favoriteFilters },
] as const;

const recommendedTabLabel = isKo
  ? "추천"
  : isDe
    ? "Empfohlen"
    : isFr
      ? "Recommandés"
      : isJa
        ? "おすすめ"
        : isZhTW
          ? "推薦"
          : isZh
            ? "推荐"
            : isEs || isPt
              ? "Recomendados"
              : "Recommended";
const scenarioTabSlugs = ["recommended", "commute", "date", "photo"] as const;
type ScenarioTabSlug = (typeof scenarioTabSlugs)[number];
const requestedScenarioSlug =
  Astro.url.searchParams.get("scenario")?.toLowerCase() ?? "recommended";
const activeScenarioSlug: ScenarioTabSlug = scenarioTabSlugs.includes(
  requestedScenarioSlug as ScenarioTabSlug,
)
  ? (requestedScenarioSlug as ScenarioTabSlug)
  : "recommended";
const scenarioTabValues: Record<ScenarioTabSlug, string> = {
  recommended: allLabel,
  commute: scenarioL.commute,
  date: scenarioL.date,
  photo: scenarioL.photo,
};
const discoverPath = Astro.url.pathname;
const scenarioTabHref = (slug: ScenarioTabSlug) => {
  const params = new URLSearchParams(Astro.url.search);
  params.set("scenario", slug);
  return `${discoverPath}?${params.toString()}`;
};
const mobileTopTabs = [
  {
    label: recommendedTabLabel,
    href: scenarioTabHref("recommended"),
    active: activeScenarioSlug === "recommended",
    filterGroup: "scenario",
    filterValue: scenarioTabValues.recommended,
    queryParam: "scenario",
    queryValue: "recommended",
  },
  {
    label: scenarioL.commute,
    href: scenarioTabHref("commute"),
    active: activeScenarioSlug === "commute",
    filterGroup: "scenario",
    filterValue: scenarioTabValues.commute,
    queryParam: "scenario",
    queryValue: "commute",
  },
  {
    label: scenarioL.date,
    href: scenarioTabHref("date"),
    active: activeScenarioSlug === "date",
    filterGroup: "scenario",
    filterValue: scenarioTabValues.date,
    queryParam: "scenario",
    queryValue: "date",
  },
  {
    label: scenarioL.photo,
    href: scenarioTabHref("photo"),
    active: activeScenarioSlug === "photo",
    filterGroup: "scenario",
    filterValue: scenarioTabValues.photo,
    queryParam: "scenario",
    queryValue: "photo",
  },
];
const mobileDiscoverTitle = isKo
  ? "룩 탐색"
  : isDe
    ? "Looks entdecken"
    : isFr
      ? "Explorer les looks"
      : isJa
        ? "メイクを探す"
        : isZhTW
          ? "探索妝容"
          : isZh
            ? "探索妆容"
            : isEs
              ? "Explorar looks"
              : isPt
                ? "Explorar looks"
                : "Discover Looks";
const searchCopy = isKo
  ? {
      label: "룩 검색",
      placeholder: "룩, 상황, 효과 검색",
      clear: "검색어 지우기",
    }
  : isDe
    ? {
        label: "Looks suchen",
        placeholder: "Look, Anlass oder Effekt suchen",
        clear: "Suche leeren",
      }
    : isFr
      ? {
          label: "Rechercher des looks",
          placeholder: "Rechercher un look, une occasion ou un effet",
          clear: "Effacer la recherche",
        }
      : isJa
        ? {
            label: "メイクを検索",
            placeholder: "メイク・シーン・効果で検索",
            clear: "検索をクリア",
          }
        : isZhTW
          ? {
              label: "搜尋妝容",
              placeholder: "搜尋妝容、場景或效果",
              clear: "清除搜尋",
            }
          : isZh
            ? {
                label: "搜索妆容",
                placeholder: "搜索妆容、场景或效果",
                clear: "清除搜索",
              }
            : isEs
              ? {
                  label: "Buscar looks",
                  placeholder: "Busca por look, ocasión o efecto",
                  clear: "Borrar búsqueda",
                }
              : isPt
                ? {
                    label: "Buscar looks",
                    placeholder: "Busque por look, ocasião ou efeito",
                    clear: "Limpar busca",
                  }
                : {
                    label: "Search looks",
                    placeholder: "Search looks, scenarios, or effects",
                    clear: "Clear search",
                  };
const referenceCta = isKo
  ? {
      badge: "Premium",
      title: "원하는 메이크업을 찾지 못했나요? 참고 이미지 업로드",
      body: "참고 이미지의 메이크업을 내 셀피에 비공개로 적용하세요. 공개 메이크업 라이브러리에는 추가되지 않습니다.",
      mobileBody: "비공개이며 공개 라이브러리에 추가되지 않습니다.",
      action: "참고 이미지로 체험하기",
    }
  : isDe
    ? {
        badge: "Premium",
        title: "Nicht das passende Make-up gefunden? Referenzbild hochladen",
        body: "Übertrage einen Referenz-Look privat auf dein Selfie. Deine Referenz erscheint nicht in der öffentlichen Look-Bibliothek.",
        mobileBody: "Privat. Nicht in der öffentlichen Bibliothek.",
        action: "Referenz-Look testen",
      }
    : isFr
      ? {
          badge: "Premium",
          title:
            "Vous ne trouvez pas le bon maquillage ? Importez une référence",
          body: "Appliquez un maquillage de référence à votre selfie en toute confidentialité. Il ne sera pas ajouté à la galerie publique.",
          mobileBody: "Privé, sans ajout à la galerie publique.",
          action: "Essayer avec une référence",
        }
      : isJa
        ? {
            badge: "Premium",
            title: "好みのメイクが見つからない？参考画像をアップロード",
            body: "参考画像のメイクを自分のセルフィーに非公開で適用できます。公開メイクライブラリには追加されません。",
            mobileBody: "非公開。公開ライブラリには追加されません。",
            action: "参考画像で試す",
          }
        : isZhTW
          ? {
              badge: "Premium",
              title: "找不到喜歡的妝容？上傳參考圖",
              body: "將喜歡的參考妝容私密套用到自拍，不會進入公開妝容庫。",
              mobileBody: "私密套用到自拍，不會進入公開妝容庫。",
              action: "開始參考圖試妝",
            }
          : isZh
            ? {
                badge: "Premium",
                title: "找不到喜欢的妆容？上传参考图",
                body: "将喜欢的参考妆容私密套用到自拍，不会进入公开妆容库。",
                mobileBody: "私密套用到自拍，不会进入公开妆容库。",
                action: "开始参考图试妆",
              }
            : isEs
              ? {
                  badge: "Premium",
                  title:
                    "¿No encuentras el maquillaje ideal? Sube una referencia",
                  body: "Aplica de forma privada un maquillaje de referencia a tu selfie. No se añadirá a la galería pública.",
                  mobileBody: "Privado, sin añadirlo a la galería pública.",
                  action: "Probar con una referencia",
                }
              : isPt
                ? {
                    badge: "Premium",
                    title:
                      "Não encontrou a maquiagem ideal? Envie uma referência",
                    body: "Aplique com privacidade uma maquiagem de referência à sua selfie. Ela não será adicionada à galeria pública.",
                    mobileBody: "Privado, sem entrar na galeria pública.",
                    action: "Testar com referência",
                  }
                : {
                    badge: "Premium",
                    title: "Can’t find the right look? Upload a reference",
                    body: "Privately apply a reference makeup look to your selfie. It won’t be added to the public look library.",
                    mobileBody: "Private. Not added to the public library.",
                    action: "Try a reference look",
                  };
const referenceTryOnHref = localizeAppHref("/reference-tryon?source=discover");

function matchValues(option: { value: string; match?: string[] }) {
  return (option.match ?? [option.value]).join("|");
}

function isActiveFilterOption(groupId: string, option: { value: string }) {
  if (groupId === "scenario") {
    return option.value === scenarioTabValues[activeScenarioSlug];
  }
  return option.value === allLabel;
}
---

<BaseLayout title={ui.discoverTitle} description={ui.discoverDescription}>
  <SiteHeader active="discover" mobileHidden />
  <MobileAppTopBar
    brand
    title={mobileDiscoverTitle}
    rightAction="search"
    searchControls="discover-search-panel"
    showLanguage={false}
    showTheme={false}
    tabs={mobileTopTabs}
  />
  <main class="discover-main">
    <div class="shell">
      <div class="page-heading">
        <div>
          <h1>{ui.pageTitle}</h1>
          <p>{ui.pageSubtitle}</p>
        </div>
      </div>
      <a class="private-reference-cta" href={referenceTryOnHref}>
        <span class="private-reference-mark" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M5 7.5h14v11H5z"></path>
            <path d="m7.5 15 3-3 2.2 2.1 2.2-2.2 2.1 2.1"></path>
            <circle cx="9" cy="10" r="1.2"></circle>
            <path d="M12 3v4M10 5h4"></path>
          </svg>
        </span>
        <span class="private-reference-copy">
          <small>{referenceCta.badge}</small>
          <strong>{referenceCta.title}</strong>
          <span class="reference-body-desktop">{referenceCta.body}</span>
          <span class="reference-body-mobile">{referenceCta.mobileBody}</span>
        </span>
        <span class="private-reference-action">
          {referenceCta.action}<i aria-hidden="true">→</i>
        </span>
      </a>
      <dialog
        class="inspiration-dialog"
        data-inspiration-dialog
        aria-labelledby="inspiration-dialog-title"
      >
        <div class="inspiration-dialog-head">
          <div>
            <h2 id="inspiration-dialog-title">
              {copy.chooseInspiration}
            </h2>
            <p>{copy.inspirationHint}</p>
          </div>
          <button
            class="inspiration-dialog-close"
            type="button"
            data-inspiration-close
            aria-label={copy.close}
          >
            ×
          </button>
        </div>
        <div class="inspiration-options" role="list">
          {
            marketOptions.map((option) => (
              <button
                class:list={[
                  "inspiration-option",
                  option.value === audienceContext.marketProfile && "active",
                ]}
                type="button"
                data-inspiration-value={option.value}
                aria-pressed={
                  option.value === audienceContext.marketProfile
                    ? "true"
                    : "false"
                }
              >
                <strong>{option.label}</strong>
                <span>
                  {option.value === audienceContext.marketProfile
                    ? copy.currentSelection
                    : copy.applySitewide}
                </span>
              </button>
            ))
          }
        </div>
        <p
          class="inspiration-dialog-status"
          data-inspiration-status
          role="status"
        >
        </p>
      </dialog>
      <div
        class="discover-search-panel"
        id="discover-search-panel"
        data-discover-search-panel
        hidden
      >
        <label class="sr-only" for="discover-search-input">
          {searchCopy.label}
        </label>
        <div class="discover-search-control">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="10.8" cy="10.8" r="6.2"></circle>
            <path d="m16 16 4.2 4.2"></path>
          </svg>
          <input
            id="discover-search-input"
            type="search"
            inputmode="search"
            autocomplete="off"
            placeholder={searchCopy.placeholder}
            data-look-search
          />
          <button
            class="discover-search-clear"
            type="button"
            aria-label={searchCopy.clear}
            data-look-search-clear
            hidden
          >
            ×
          </button>
        </div>
      </div>
      <div class="mobile-filter-bar" data-mobile-filter-bar>
        <button
          class="mobile-filter-trigger"
          type="button"
          data-filter-open
          aria-controls="discover-filter-sheet"
          aria-expanded="false"
        >
          <span>{ui.filterTitle}</span>
          <strong data-filter-mobile-summary>{ui.filterTitle}</strong>
          <small data-filter-mobile-count data-looks-label={ui.looksCount}
            >{resolvedLooks.length} {ui.looksCount}</small
          >
        </button>
      </div>
      <div class="discover-layout">
        <button
          class="filter-sheet-backdrop"
          type="button"
          data-filter-backdrop
          data-filter-close
          aria-label={copy.closeFilters}
          hidden
        >
        </button>
        <aside
          class="filter-panel panel"
          id="discover-filter-sheet"
          data-filter-panel
          aria-label={ui.filterTitle}
        >
          <div class="filter-sheet-header">
            <div>
              <strong>{ui.filterTitle}</strong>
              <small data-filter-mobile-count data-looks-label={ui.looksCount}
                >{resolvedLooks.length} {ui.looksCount}</small
              >
            </div>
            <button
              class="filter-sheet-close"
              type="button"
              data-filter-close
              aria-label={copy.closeFilters}
            >
              {copy.close}
            </button>
          </div>
          <div class="filter-sheet-body">
            <div class="filter-inspiration" data-inspiration-bar>
              <div class="filter-inspiration-main">
                <div class="filter-inspiration-text">
                  <span class="filter-inspiration-label">
                    {copy.inspirationControlLabel}
                  </span>
                  <strong class="filter-inspiration-value">{marketLabel}</strong
                  >
                </div>
                <button
                  class="btn btn-sm filter-inspiration-switch"
                  type="button"
                  data-switch-inspiration
                  aria-label={`${ui.switchInspiration}: ${marketLabel}`}
                  hidden={marketOptions.length <= 1}
                >
                  {copy.inspirationSwitchShort}
                </button>
              </div>
              <p>{copy.inspirationControlNote}</p>
            </div>
            {
              filterGroups.map((group) => (
                <fieldset class="filter-group" data-filter-group={group.id}>
                  <legend class="filter-title">{group.label}</legend>
                  <div class="filter-options">
                    {group.options.map((option) => {
                      const isActive = isActiveFilterOption(group.id, option);
                      return (
                        <button
                          type="button"
                          class:list={["filter-chip", isActive && "active"]}
                          data-filter-value={option.value}
                          data-filter-match={matchValues(option)}
                          data-filter-all={
                            option.value === allLabel || undefined
                          }
                          aria-pressed={isActive ? "true" : "false"}
                        >
                          {option.label}
                        </button>
                      );
                    })}
                  </div>
                </fieldset>
              ))
            }
          </div>
          <div class="filter-sheet-actions">
            <button class="btn btn-wide" type="button" data-clear-filters
              >{ui.clearFilters}</button
            >
            <button
              class="btn btn-primary filter-sheet-apply"
              type="button"
              data-filter-apply
            >
              {ui.viewResults}
              <span data-filter-result-count>{resolvedLooks.length}</span>
              {ui.looksCount}
            </button>
          </div>
        </aside>
        <section class="look-library panel" aria-label={copy.lookGallery}>
          <h2 class="sr-only">{copy.lookGallery}</h2>
          <div class="look-grid" id="look-grid">
            {
              resolvedLooks.map((look, index) => (
                <LookCard
                  look={look}
                  variant="library"
                  source="discover_library"
                  priority={index < 3}
                  highPriority={index === 0}
                />
              ))
            }
          </div>
          <div class="empty-state" id="empty-state" hidden>
            <span class="empty-icon" aria-hidden="true"></span>
            <h3>{ui.emptyTitle}</h3>
            <p class="muted">{ui.emptyHint}</p>
            <button class="btn btn-primary" type="button" data-clear-filters
              >{ui.clearFilters}</button
            >
            <a class="btn btn-outline" href={referenceTryOnHref}>
              {referenceCta.action}
            </a>
          </div>
          <div
            class="library-footer"
            data-filter-summary
            data-filter-summary-template={`${ui.viewResults}: {count} ${ui.looksCount}`}
            id="filter-summary"
            role="status"
            aria-live="polite"
          >
            {copy.libraryFooter}
          </div>
        </section>
      </div>
    </div>
  </main>
  <MobileBottomNav active="discover" />
  <style>
    @media (max-width: 767px) {
      .discover-main {
        padding-top: 12px;
      }
      .page-heading {
        display: none;
      }
      .look-library.panel {
        padding: 0;
        border: 0;
        background: transparent;
        box-shadow: none;
      }
      .look-grid {
        gap: 10px;
      }
      .library-footer {
        margin-bottom: 8px;
      }
    }
    .private-reference-cta {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 14px;
      align-items: center;
      margin: 0 0 18px;
      padding: 16px 18px;
      border: 1px solid color-mix(in srgb, var(--gold) 48%, var(--line));
      border-radius: 12px;
      background: linear-gradient(
        135deg,
        color-mix(in srgb, var(--gold-soft) 58%, var(--bg-elevated)),
        var(--bg-elevated) 72%
      );
      color: var(--heading);
      text-decoration: none;
      box-shadow: 0 8px 20px color-mix(in srgb, var(--gold) 7%, transparent);
      transition:
        border-color 180ms ease,
        box-shadow 180ms ease,
        transform 180ms ease;
    }
    .private-reference-cta:hover {
      border-color: var(--gold-border);
      box-shadow: 0 10px 24px color-mix(in srgb, var(--gold) 13%, transparent);
      transform: translateY(-1px);
    }
    .private-reference-cta:focus-visible {
      border-color: var(--gold-border);
      outline: 3px solid var(--gold-text);
      outline-offset: 3px;
    }
    .private-reference-cta:active {
      box-shadow: 0 4px 12px color-mix(in srgb, var(--gold) 8%, transparent);
      transform: translateY(0);
    }
    .private-reference-mark {
      width: 48px;
      height: 48px;
      display: grid;
      place-items: center;
      border-radius: 10px;
      background: var(--gold-soft);
      color: var(--gold-text);
    }
    .private-reference-mark svg {
      width: 26px;
      fill: none;
      stroke: currentColor;
      stroke-width: 1.7;
      stroke-linecap: round;
      stroke-linejoin: round;
    }
    .private-reference-copy {
      min-width: 0;
      display: grid;
      gap: 3px;
    }
    .private-reference-copy small {
      width: max-content;
      padding: 3px 7px;
      border: 1px solid color-mix(in srgb, var(--gold) 42%, transparent);
      border-radius: 999px;
      background: color-mix(in srgb, var(--gold-soft) 80%, var(--bg-elevated));
      color: var(--gold-text);
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    .private-reference-copy strong {
      font-size: 1.02rem;
    }
    .private-reference-copy > span {
      color: var(--body-secondary);
      font-size: 0.88rem;
      line-height: 1.5;
    }
    .reference-body-mobile {
      display: none;
    }
    .private-reference-action {
      min-height: 36px;
      display: inline-flex;
      gap: 8px;
      align-items: center;
      justify-content: center;
      padding: 7px 12px;
      border: 1px solid color-mix(in srgb, var(--gold) 48%, var(--gold-border));
      border-radius: 999px;
      background: color-mix(in srgb, var(--gold-soft) 74%, var(--bg-elevated));
      color: var(--gold-text);
      font-size: 0.88rem;
      font-weight: 750;
      white-space: nowrap;
    }
    .private-reference-action i {
      font-style: normal;
      transition: transform 180ms ease;
    }
    .private-reference-cta:hover .private-reference-action i {
      transform: translateX(2px);
    }
    .empty-state .btn + .btn {
      margin-left: 8px;
    }
    @media (max-width: 767px) {
      .private-reference-cta {
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 4px 10px;
        margin: 0 0 12px;
        padding: 12px 14px;
      }
      .private-reference-mark {
        display: none;
      }
      .private-reference-copy {
        display: contents;
      }
      .private-reference-copy small {
        grid-column: 1;
        grid-row: 3;
        align-self: center;
        padding: 2px 6px;
        font-size: 0.64rem;
      }
      .private-reference-copy strong {
        grid-column: 1 / -1;
        grid-row: 1;
        font-size: 0.96rem;
        line-height: 1.35;
      }
      .reference-body-desktop {
        display: none;
      }
      .reference-body-mobile {
        display: inline;
        grid-column: 1 / -1;
        grid-row: 2;
      }
      .private-reference-action {
        grid-column: 2;
        grid-row: 3;
        justify-self: start;
        min-height: 32px;
        padding: 6px 10px;
        font-size: 0.8rem;
      }
    }
    @media (max-width: 340px) {
      .private-reference-action {
        grid-column: 1 / -1;
        grid-row: 4;
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .private-reference-cta,
      .private-reference-action i {
        transition: none;
      }
      .private-reference-cta:hover,
      .private-reference-cta:active,
      .private-reference-cta:hover .private-reference-action i {
        transform: none;
      }
    }
  </style>
</BaseLayout>
