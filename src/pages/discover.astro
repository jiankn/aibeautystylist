---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  buildLookTryOnHref,
  lookCatalogItems,
  lookFilters,
} from '../data/lookCatalog';
import { styleNavigationItems } from '../data/stylePages';

export const prerender = true;

const lookItems = lookCatalogItems.map((look, index) => ({
  ...look,
  position: index + 1,
  tryOnHref: `${buildLookTryOnHref(look)}&source=discover-look-library&position=${index + 1}`,
}));

const styleItems = styleNavigationItems.map((style, index) => ({
  ...style,
  position: index + 1,
  tryOnHref: `/try-on?scenario=${style.tryOnScenario}&style=${style.slug}&look=${style.lookSlug}&source=discover-style-nav&position=${index + 1}`,
}));

const styleFilters = [
  { label: 'All', value: 'all' },
  { label: 'Everyday', value: 'office' },
  { label: 'Date', value: 'date' },
  { label: 'Camera', value: 'photo' },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Discover Makeup Looks',
    description: 'Browse AI Beauty Stylist makeup looks and style directions for try-on, tutorials, and personalized recommendations.',
    url: 'https://aibeautystylist.com/discover/',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'AI makeup look library',
    numberOfItems: lookItems.length,
    itemListElement: lookItems.map((look) => ({
      '@type': 'ListItem',
      position: look.position,
      name: look.title,
      url: `https://aibeautystylist.com${look.tryOnHref}`,
    })),
  },
];
---

<BaseLayout
  title="Discover Makeup Looks | AI Beauty Stylist"
  description={`Explore ${lookItems.length} makeup looks and ${styleItems.length} style directions, then try the right one on your own face with AI Beauty Stylist.`}
  structuredData={structuredData}
>
  <section class="section discover-hero">
    <div class="container discover-hero-grid">
      <div class="section-copy discover-hero-copy">
        <span class="eyebrow">Discover</span>
        <h1>Explore the full makeup library without crowding the homepage.</h1>
        <p>
          Browse specific looks when you want visual inspiration, or use style directions when you already know the aesthetic you want to test.
        </p>
        <div class="discover-hero-actions">
          <a class="btn" href="#look-library">Browse Looks</a>
          <a class="btn btn-secondary" href="#style-directions">Try a Style</a>
        </div>
      </div>

      <div class="discover-stats" aria-label="Discover library counts">
        <article>
          <strong>{lookItems.length}</strong>
          <span>Makeup looks</span>
          <small>Full inspiration library</small>
        </article>
        <article>
          <strong>{styleItems.length}</strong>
          <span>Style directions</span>
          <small>Complete style map</small>
        </article>
        <article>
          <strong>8</strong>
          <span>Filter groups</span>
          <small>For fast scanning</small>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-soft discover-library" id="look-library">
    <div class="container discover-section-head">
      <div class="section-copy">
        <span class="eyebrow">Full Library</span>
        <h2>48 makeup looks for moments, moods, and features.</h2>
        <p>These are concrete looks: visual-first, scenario-aware, and ready to pass into AI Try-On as inspiration.</p>
      </div>
      <div class="discover-filter-tabs" aria-label="Filter makeup looks">
        {lookFilters.map((filter, index) => (
          <button
            class:list={['discover-filter-chip', { 'is-active': index === 0 }]}
            type="button"
            data-discover-filter="look"
            data-filter-value={filter.value}
          >
            {filter.label}
          </button>
        ))}
      </div>
    </div>

    <div class="container discover-look-grid">
      {lookItems.map((look) => (
        <a
          class="discover-look-card"
          href={look.tryOnHref}
          style={`--look-focus:${look.focus};`}
          data-discover-look
          data-filter-group={look.category}
          data-analytics-look
          data-analytics-source="discover-look-library"
          data-analytics-look-slug={look.slug}
          data-analytics-position={look.position}
        >
          <span class="discover-look-image">
            <img src={look.image} alt={look.imageAlt} loading={look.position <= 8 ? 'eager' : 'lazy'} />
          </span>
          <span class="discover-look-copy">
            <span>{look.tone}</span>
            <strong>{look.title}</strong>
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="section discover-styles" id="style-directions">
    <div class="container discover-section-head">
      <div class="section-copy">
        <span class="eyebrow">All Styles</span>
        <h2>{styleItems.length} style directions for stable navigation.</h2>
        <p>These are broader aesthetic routes, not one-off pictures. Each style points to a representative look and try-on intent.</p>
      </div>
      <div class="discover-filter-tabs" aria-label="Filter style directions">
        {styleFilters.map((filter, index) => (
          <button
            class:list={['discover-filter-chip', { 'is-active': index === 0 }]}
            type="button"
            data-discover-filter="style"
            data-filter-value={filter.value}
          >
            {filter.label}
          </button>
        ))}
      </div>
    </div>

    <div class="container discover-style-grid">
      {styleItems.map((style) => (
        <a
          class="discover-style-card"
          href={style.tryOnHref}
          style={`--look-focus:${style.focus ?? 'center'};`}
          data-discover-style
          data-filter-group={style.tryOnScenario}
          data-analytics-look
          data-analytics-source="discover-style-nav"
          data-analytics-look-slug={style.lookSlug}
          data-analytics-style-slug={style.slug}
          data-analytics-position={style.position}
        >
          <span class="discover-style-image">
            <img src={style.image} alt={style.imageAlt} loading="lazy" />
          </span>
          <span>{style.label}</span>
        </a>
      ))}
    </div>
  </section>

  <script>
    function initDiscoverFilters() {
      const filterButtons = document.querySelectorAll<HTMLButtonElement>('[data-discover-filter]');

      filterButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const filterType = button.dataset.discoverFilter;
          const filterValue = button.dataset.filterValue || 'all';
          if (!filterType) return;

          document.querySelectorAll<HTMLButtonElement>(`[data-discover-filter="${filterType}"]`).forEach((item) => {
            item.classList.toggle('is-active', item === button);
          });

          const selector = filterType === 'look' ? '[data-discover-look]' : '[data-discover-style]';
          document.querySelectorAll<HTMLElement>(selector).forEach((card) => {
            const group = card.dataset.filterGroup || '';
            card.hidden = filterValue !== 'all' && group !== filterValue;
          });
        });
      });
    }

    initDiscoverFilters();
  </script>
</BaseLayout>

<style>
  .discover-hero {
    padding-top: 48px;
  }

  .discover-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 40px;
    align-items: end;
  }

  .discover-hero-copy {
    max-width: 760px;
    margin: 0;
  }

  .discover-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .discover-stats {
    display: grid;
    gap: 12px;
  }

  .discover-stats article {
    display: grid;
    gap: 4px;
    padding: 18px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.82);
    box-shadow: 0 18px 44px rgba(68, 42, 42, 0.08);
  }

  .discover-stats strong {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 2.15rem;
    line-height: 1;
    color: var(--text);
  }

  .discover-stats span {
    font-weight: 700;
    color: var(--text);
  }

  .discover-stats small {
    color: var(--muted);
    font-weight: 600;
  }

  .discover-section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 28px;
  }

  .discover-section-head .section-copy {
    max-width: 720px;
    margin: 0;
  }

  .discover-filter-tabs {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 8px;
    max-width: 440px;
  }

  .discover-filter-chip {
    min-height: 40px;
    padding: 8px 14px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
    color: var(--text-secondary);
    font-size: 0.84rem;
    font-weight: 700;
    cursor: pointer;
  }

  .discover-filter-chip.is-active {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }

  .discover-look-grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 12px;
  }

  .discover-look-card,
  .discover-style-card {
    color: inherit;
    text-decoration: none;
  }

  .discover-look-card {
    display: grid;
    gap: 10px;
    min-width: 0;
  }

  .discover-look-image {
    position: relative;
    display: block;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    border-radius: var(--radius-sm);
    background: var(--accent-soft);
    box-shadow: 0 16px 36px rgba(68, 42, 42, 0.08);
  }

  .discover-look-image img,
  .discover-style-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--look-focus, center);
    transition: transform 0.45s ease;
  }

  .discover-look-card:hover img,
  .discover-look-card:focus-visible img,
  .discover-style-card:hover img,
  .discover-style-card:focus-visible img {
    transform: scale(1.045);
  }

  .discover-look-copy {
    display: grid;
    gap: 3px;
  }

  .discover-look-copy span {
    color: var(--accent-deep);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .discover-look-copy strong {
    color: var(--text);
    font-size: 0.92rem;
    line-height: 1.25;
  }

  .discover-style-grid {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 14px;
  }

  .discover-style-card {
    display: grid;
    gap: 8px;
    text-align: center;
    min-width: 0;
  }

  .discover-style-image {
    display: block;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    border-radius: var(--radius-sm);
    background: var(--accent-soft);
    box-shadow: 0 14px 34px rgba(62, 39, 39, 0.08);
  }

  .discover-style-card > span:last-child {
    font-size: 0.84rem;
    font-weight: 700;
    line-height: 1.25;
    color: var(--text);
  }

  @media (max-width: 1100px) {
    .discover-look-grid,
    .discover-style-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (max-width: 800px) {
    .discover-hero-grid,
    .discover-section-head {
      grid-template-columns: 1fr;
      display: grid;
      align-items: start;
    }

    .discover-filter-tabs {
      justify-content: flex-start;
      max-width: none;
    }
  }

  @media (max-width: 640px) {
    .discover-look-grid,
    .discover-style-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .discover-stats {
      grid-template-columns: 1fr;
    }
  }
</style>
