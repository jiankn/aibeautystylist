---
/**
 * 管理后台 — AI 成本分析
 * 按模型/天/操作维度的成本、调用量和性能分析。
 */
import AdminLayout from "../../layouts/AdminLayout.astro";
import { checkAdmin } from "../../lib/adminGuard";
import { getRuntimeBindings } from "../../lib/runtime";

const { DB } = getRuntimeBindings();
if (!DB) {
  return Astro.redirect(
    `/login?next=${encodeURIComponent(`${Astro.url.pathname}${Astro.url.search}`)}`,
  );
}
const auth = await checkAdmin(Astro.cookies, DB);
if (!auth.authorized) {
  return Astro.redirect(
    `/login?next=${encodeURIComponent(`${Astro.url.pathname}${Astro.url.search}`)}`,
  );
}
---

<AdminLayout title="AI 成本分析" activeNav="ai-costs">
  <!-- KPI -->
  <div class="kpi-grid" style="grid-template-columns:repeat(4,1fr)">
    <div class="kpi-card">
      <div class="kpi-label">AI 计量成本</div>
      <div class="kpi-value" id="acTotalCost">—</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">API 调用总数</div>
      <div class="kpi-value" id="acTotalCalls">—</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">单次平均计量</div>
      <div class="kpi-value" id="acAvgCost">—</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">成功率</div>
      <div class="kpi-value" id="acSuccessRate">—</div>
    </div>
  </div>

  <!-- 时间段选择 -->
  <div style="display:flex;gap:8px;margin-bottom:20px">
    <button class="admin-btn admin-btn-sm" data-days="7">7 天</button>
    <button class="admin-btn admin-btn-sm admin-btn-primary" data-days="30"
      >30 天</button
    >
    <button class="admin-btn admin-btn-sm" data-days="60">60 天</button>
    <button class="admin-btn admin-btn-sm" data-days="90">90 天</button>
  </div>

  <!-- 图表区域 -->
  <div class="admin-grid-2 admin-section">
    <div class="admin-card">
      <div class="admin-card-title">每日 AI 计量趋势</div>
      <div class="chart-container">
        <canvas id="costTrendChart" class="chart-canvas"></canvas>
      </div>
    </div>
    <div class="admin-card">
      <div class="admin-card-title">模型调用分布</div>
      <div id="modelDist" style="padding:16px 0">
        <div class="admin-loading">
          <div class="admin-spinner"></div>加载中...
        </div>
      </div>
    </div>
  </div>

  <!-- 效率矩阵 -->
  <div class="admin-section">
    <div class="admin-card">
      <div class="admin-card-title" style="margin-bottom:16px">
        模型效率矩阵
      </div>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>模型</th>
              <th>Provider</th>
              <th>调用次数</th>
              <th>成功率</th>
              <th>平均耗时</th>
              <th>总 Token</th>
              <th>总成本</th>
              <th>单次成本</th>
            </tr>
          </thead>
          <tbody id="modelMatrixBody">
            <tr
              ><td colspan="8" class="admin-loading"
                ><div class="admin-spinner"></div>加载中...</td
              ></tr
            >
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- 操作类型分析 -->
  <div class="admin-section">
    <div class="admin-card">
      <div class="admin-card-title" style="margin-bottom:16px">
        操作类型分析
      </div>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>操作</th>
              <th>调用次数</th>
              <th>成功率</th>
              <th>平均耗时</th>
              <th>总成本</th>
            </tr>
          </thead>
          <tbody id="opMatrixBody">
            <tr
              ><td colspan="5" class="admin-loading"
                ><div class="admin-spinner"></div>加载中...</td
              ></tr
            >
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- 最近调用日志 -->
  <div class="admin-section">
    <div class="admin-card">
      <div class="admin-card-title" style="margin-bottom:16px">
        最近 AI 调用
      </div>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>时间</th>
              <th>操作</th>
              <th>模型</th>
              <th>耗时</th>
              <th>Token</th>
              <th>成本</th>
              <th>状态</th>
            </tr>
          </thead>
          <tbody id="recentCallsBody">
            <tr
              ><td colspan="7" class="admin-loading"
                ><div class="admin-spinner"></div>加载中...</td
              ></tr
            >
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      function loadData(days) {
        // 更新按钮状态
        document.querySelectorAll("[data-days]").forEach(function (btn) {
          btn.classList.toggle(
            "admin-btn-primary",
            Number(btn.dataset.days) === days,
          );
        });

        fetch("/api/admin/ai-costs?days=" + days)
          .then(function (r) {
            return r.json();
          })
          .then(function (res) {
            if (!res.ok) return;
            var d = res.data;

            // KPI 计算
            var totalCost = 0,
              totalCalls = 0,
              totalSuccess = 0;
            (d.byModel || []).forEach(function (m) {
              totalCost += Number(m.total_cost_micros) || 0;
              totalCalls += Number(m.call_count) || 0;
              totalSuccess += Number(m.success_count) || 0;
            });
            var avgCost = totalCalls > 0 ? totalCost / totalCalls : 0;
            var successRate =
              totalCalls > 0
                ? ((totalSuccess / totalCalls) * 100).toFixed(1)
                : "100.0";

            document.getElementById("acTotalCost").textContent =
              formatUnits(totalCost);
            document.getElementById("acTotalCalls").textContent =
              formatNum(totalCalls);
            document.getElementById("acAvgCost").textContent = formatUnits(
              avgCost,
              4,
            );
            document.getElementById("acSuccessRate").textContent =
              successRate + "%";

            renderCostTrend(d.byDay || []);
            renderModelDist(d.byModel || []);
            renderModelMatrix(d.byModel || []);
            renderOpMatrix(d.byOperation || []);
            renderRecentCalls(d.recentCalls || []);
          });
      }

      // 时间段按钮
      document.querySelectorAll("[data-days]").forEach(function (btn) {
        btn.addEventListener("click", function () {
          loadData(Number(btn.dataset.days));
        });
      });

      function renderCostTrend(data) {
        var canvas = document.getElementById("costTrendChart");
        if (!canvas) return;
        var ctx = canvas.getContext("2d");
        var rect = canvas.parentElement.getBoundingClientRect();
        var dpr = window.devicePixelRatio || 1;
        canvas.width = rect.width * dpr;
        canvas.height = rect.height * dpr;
        ctx.scale(dpr, dpr);
        var w = rect.width,
          h = rect.height;

        if (!data.length) {
          ctx.fillStyle = "#64748b";
          ctx.font = "14px Inter, sans-serif";
          ctx.textAlign = "center";
          ctx.fillText("暂无数据", w / 2, h / 2);
          return;
        }

        var costs = data.map(function (d) {
          return Number(d.cost_micros) / 1000000;
        });
        var labels = data.map(function (d) {
          return d.day.slice(5);
        });
        var max = Math.max.apply(null, costs) || 0.01;

        var padL = 50,
          padR = 20,
          padT = 20,
          padB = 40;
        var chartW = w - padL - padR;
        var chartH = h - padT - padB;

        // 网格
        ctx.strokeStyle = "rgba(139,92,246,0.08)";
        for (var i = 0; i <= 4; i++) {
          var gy = padT + (chartH / 4) * i;
          ctx.beginPath();
          ctx.moveTo(padL, gy);
          ctx.lineTo(w - padR, gy);
          ctx.stroke();
        }

        // 渐变填充
        var grad = ctx.createLinearGradient(0, padT, 0, h - padB);
        grad.addColorStop(0, "rgba(236,72,153,0.25)");
        grad.addColorStop(1, "rgba(236,72,153,0.02)");

        var pts = costs.map(function (v, i) {
          return {
            x: padL + (chartW / Math.max(1, costs.length - 1)) * i,
            y: padT + chartH - (v / max) * chartH,
          };
        });

        ctx.beginPath();
        ctx.moveTo(pts[0].x, h - padB);
        pts.forEach(function (p) {
          ctx.lineTo(p.x, p.y);
        });
        ctx.lineTo(pts[pts.length - 1].x, h - padB);
        ctx.closePath();
        ctx.fillStyle = grad;
        ctx.fill();

        ctx.beginPath();
        pts.forEach(function (p, i) {
          i === 0 ? ctx.moveTo(p.x, p.y) : ctx.lineTo(p.x, p.y);
        });
        ctx.strokeStyle = "#ec4899";
        ctx.lineWidth = 2.5;
        ctx.stroke();

        pts.forEach(function (p) {
          ctx.beginPath();
          ctx.arc(p.x, p.y, 3, 0, Math.PI * 2);
          ctx.fillStyle = "#ec4899";
          ctx.fill();
        });

        ctx.fillStyle = "#64748b";
        ctx.font = "11px Inter, sans-serif";
        ctx.textAlign = "center";
        var step = Math.max(1, Math.floor(labels.length / 8));
        labels.forEach(function (l, i) {
          if (i % step === 0) ctx.fillText(l, pts[i].x, h - padB + 18);
        });

        ctx.textAlign = "right";
        for (var j = 0; j <= 4; j++) {
          var val = (max - (max / 4) * j).toFixed(2);
          ctx.fillText(val, padL - 8, padT + (chartH / 4) * j + 4);
        }
      }

      function renderModelDist(data) {
        var el = document.getElementById("modelDist");
        if (!data.length) {
          el.innerHTML = '<div class="admin-empty">暂无数据</div>';
          return;
        }

        var totalCalls =
          data.reduce(function (s, d) {
            return s + Number(d.call_count);
          }, 0) || 1;
        var colors = [
          "#8b5cf6",
          "#ec4899",
          "#14b8a6",
          "#f59e0b",
          "#3b82f6",
          "#ef4444",
        ];

        var html = '<div style="display:flex;flex-direction:column;gap:14px">';
        data.forEach(function (item, idx) {
          var pct = ((item.call_count / totalCalls) * 100).toFixed(1);
          var color = colors[idx % colors.length];
          var costUnits = formatUnits(Number(item.total_cost_micros));
          html += "<div>";
          html +=
            '<div style="display:flex;justify-content:space-between;margin-bottom:4px">';
          html +=
            '<span style="font-size:12px;font-weight:500;font-family:monospace">' +
            escapeHtml(item.model) +
            "</span>";
          html +=
            '<span style="font-size:11px;color:#94a3b8">' +
            formatNum(item.call_count) +
            " 次 · " +
            costUnits +
            "</span>";
          html += "</div>";
          html +=
            '<div class="progress-bar"><div class="progress-fill" style="width:' +
            pct +
            "%;background:" +
            color +
            '"></div></div>';
          html += "</div>";
        });
        html += "</div>";
        el.innerHTML = html;
      }

      function renderModelMatrix(data) {
        var tbody = document.getElementById("modelMatrixBody");
        if (!data.length) {
          tbody.innerHTML =
            '<tr><td colspan="8" class="admin-empty">暂无数据</td></tr>';
          return;
        }

        var html = "";
        data.forEach(function (m) {
          var successRate =
            m.call_count > 0
              ? ((m.success_count / m.call_count) * 100).toFixed(1)
              : "0.0";
          var avgCostUnits =
            m.call_count > 0
              ? formatUnits(m.total_cost_micros / m.call_count, 4)
              : formatUnits(0, 4);
          var totalCostUnits = formatUnits(m.total_cost_micros);
          var successCls =
            Number(successRate) >= 98
              ? "badge-green"
              : Number(successRate) >= 90
                ? "badge-amber"
                : "badge-red";
          var durationCls =
            Number(m.avg_duration_ms) < 3000
              ? "badge-green"
              : Number(m.avg_duration_ms) < 10000
                ? "badge-amber"
                : "badge-red";

          html += "<tr>";
          html +=
            '<td style="font-family:monospace;font-size:12px">' +
            escapeHtml(m.model) +
            "</td>";
          html +=
            '<td><span class="badge badge-purple">' +
            escapeHtml(m.provider) +
            "</span></td>";
          html += "<td>" + formatNum(m.call_count) + "</td>";
          html +=
            '<td><span class="badge ' +
            successCls +
            '">' +
            successRate +
            "%</span></td>";
          html +=
            '<td><span class="badge ' +
            durationCls +
            '">' +
            formatDuration(m.avg_duration_ms) +
            "</span></td>";
          html += "<td>" + formatNum(Number(m.total_tokens)) + "</td>";
          html += '<td style="font-weight:600">' + totalCostUnits + "</td>";
          html +=
            '<td style="font-size:12px;color:var(--admin-text-muted)">' +
            avgCostUnits +
            "</td>";
          html += "</tr>";
        });
        tbody.innerHTML = html;
      }

      function renderOpMatrix(data) {
        var tbody = document.getElementById("opMatrixBody");
        if (!data.length) {
          tbody.innerHTML =
            '<tr><td colspan="5" class="admin-empty">暂无数据</td></tr>';
          return;
        }
        var opLabels = {
          diagnosis: "🔬 妆容诊断",
          image_generation: "🖼️ 图像生成",
        };
        var html = "";
        data.forEach(function (op) {
          var sr =
            op.call_count > 0
              ? ((op.success_count / op.call_count) * 100).toFixed(1)
              : "0.0";
          var srCls =
            Number(sr) >= 98
              ? "badge-green"
              : Number(sr) >= 90
                ? "badge-amber"
                : "badge-red";
          html += "<tr>";
          html +=
            '<td style="font-size:13px">' +
            escapeHtml(opLabels[op.operation] || op.operation) +
            "</td>";
          html += "<td>" + formatNum(op.call_count) + "</td>";
          html +=
            '<td><span class="badge ' + srCls + '">' + sr + "%</span></td>";
          html += "<td>" + formatDuration(op.avg_duration_ms) + "</td>";
          html +=
            '<td style="font-weight:600">' +
            formatUnits(op.total_cost_micros) +
            "</td>";
          html += "</tr>";
        });
        tbody.innerHTML = html;
      }

      function renderRecentCalls(calls) {
        var tbody = document.getElementById("recentCallsBody");
        if (!calls.length) {
          tbody.innerHTML =
            '<tr><td colspan="7" class="admin-empty">暂无数据</td></tr>';
          return;
        }
        var opIcons = { diagnosis: "🔬", image_generation: "🖼️" };
        var html = "";
        calls.forEach(function (c) {
          var isSuccess = c.status === "succeeded";
          html += "<tr>";
          html +=
            '<td style="font-size:12px;color:var(--admin-text-muted);white-space:nowrap">' +
            formatTime(c.created_at) +
            "</td>";
          html +=
            "<td>" +
            escapeHtml(opIcons[c.operation] || "⚡") +
            " " +
            escapeHtml(c.operation) +
            "</td>";
          html +=
            '<td style="font-family:monospace;font-size:11px">' +
            escapeHtml(c.model || "—") +
            "</td>";
          html += "<td>" + formatDuration(c.duration_ms) + "</td>";
          html +=
            '<td style="font-size:12px">' +
            (c.prompt_tokens || 0) +
            " → " +
            (c.output_tokens || 0) +
            "</td>";
          html +=
            '<td style="font-weight:500">' +
            formatUnits(c.estimated_cost_micros || 0, 4) +
            "</td>";
          html +=
            '<td><span class="badge ' +
            (isSuccess ? "badge-green" : "badge-red") +
            '"><span class="badge-dot"></span>' +
            escapeHtml(isSuccess ? "成功" : c.error_code || "失败") +
            "</span></td>";
          html += "</tr>";
        });
        tbody.innerHTML = html;
      }

      function formatNum(n) {
        n = Number(n) || 0;
        if (n >= 1000000) return (n / 1000000).toFixed(1) + "M";
        if (n >= 1000) return (n / 1000).toFixed(1) + "K";
        return String(n);
      }

      function formatDuration(ms) {
        ms = Number(ms) || 0;
        if (ms < 1000) return ms + "ms";
        return (ms / 1000).toFixed(1) + "s";
      }

      function formatUnits(micros, digits) {
        var value = (Number(micros) || 0) / 1000000;
        return value.toFixed(digits === undefined ? 2 : digits) + " units";
      }

      function formatTime(iso) {
        if (!iso) return "—";
        var d = new Date(iso);
        return d.toLocaleString("zh-CN", {
          month: "2-digit",
          day: "2-digit",
          hour: "2-digit",
          minute: "2-digit",
          second: "2-digit",
        });
      }

      function escapeHtml(s) {
        var div = document.createElement("div");
        div.appendChild(document.createTextNode(s || ""));
        return div.innerHTML;
      }

      // 初始加载
      loadData(30);
    })();
  </script>
</AdminLayout>
