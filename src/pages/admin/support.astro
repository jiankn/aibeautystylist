---
/**
 * 管理后台 — 工单管理
 * 工单列表、状态筛选和状态更新。
 */
import AdminLayout from "../../layouts/AdminLayout.astro";
import { checkAdmin } from "../../lib/adminGuard";
import { getRuntimeBindings } from "../../lib/runtime";

const { DB } = getRuntimeBindings();
if (!DB) {
  return Astro.redirect(
    `/login?next=${encodeURIComponent(`${Astro.url.pathname}${Astro.url.search}`)}`,
  );
}
const auth = await checkAdmin(Astro.cookies, DB);
if (!auth.authorized) {
  return Astro.redirect(
    `/login?next=${encodeURIComponent(`${Astro.url.pathname}${Astro.url.search}`)}`,
  );
}
---

<AdminLayout title="工单管理" activeNav="support">
  <section class="admin-page-header">
    <div>
      <div class="admin-page-kicker">Support Operations</div>
      <h2 class="admin-page-title">工单管理</h2>
      <p class="admin-page-description">
        以 open 和 pending
        为优先级处理用户支持请求；状态更新会写入管理员审计日志。
      </p>
    </div>
    <button class="admin-btn" id="supportRefresh" type="button">刷新</button>
  </section>

  <div class="admin-meta-row">
    <span
      >数据口径：open 为待处理，pending 为处理中，resolved/closed 不进入待办。</span
    >
    <span
      >最后更新：<b class="admin-last-updated" id="supportUpdated">—</b></span
    >
  </div>

  <div class="admin-status-banner loading" id="supportStatus" role="status">
    <span data-status-text>正在加载工单数据...</span>
    <button
      class="admin-btn admin-btn-sm"
      id="supportRetry"
      type="button"
      hidden
    >
      重试
    </button>
  </div>

  <div
    class="kpi-grid"
    style="grid-template-columns:repeat(auto-fit,minmax(160px,1fr))"
  >
    <button class="kpi-card" type="button" data-status-filter="">
      <div class="kpi-label">全部工单</div>
      <div class="kpi-value" id="stAll">—</div>
    </button>
    <button
      class="kpi-card"
      type="button"
      style="--admin-accent-glow:rgba(245,158,11,0.15)"
      data-status-filter="open"
    >
      <div class="kpi-label">待处理</div>
      <div class="kpi-value" id="stOpen" style="color:var(--admin-amber)">
        —
      </div>
    </button>
    <button
      class="kpi-card"
      type="button"
      style="--admin-accent-glow:rgba(59,130,246,0.15)"
      data-status-filter="pending"
    >
      <div class="kpi-label">处理中</div>
      <div class="kpi-value" id="stPending" style="color:var(--admin-blue)">
        —
      </div>
    </button>
    <button
      class="kpi-card"
      type="button"
      style="--admin-accent-glow:rgba(16,185,129,0.15)"
      data-status-filter="resolved"
    >
      <div class="kpi-label">已解决</div>
      <div class="kpi-value" id="stResolved" style="color:var(--admin-green)">
        —
      </div>
    </button>
  </div>

  <div class="admin-toolbar">
    <div class="admin-toolbar-actions">
      <select id="statusFilter" class="admin-select">
        <option value="">全部状态</option>
        <option value="open">待处理</option>
        <option value="pending">处理中</option>
        <option value="resolved">已解决</option>
        <option value="closed">已关闭</option>
      </select>
      <span id="filterInfo" style="font-size:13px;color:var(--admin-text-muted)"
      ></span>
    </div>
  </div>

  <div class="admin-card admin-section">
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>工单号</th>
            <th>用户</th>
            <th>主题</th>
            <th>内容预览</th>
            <th>语言</th>
            <th>状态</th>
            <th>创建时间</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody id="ticketsBody">
          <tr
            ><td colspan="8" class="admin-loading"
              ><div class="admin-spinner"></div>加载中...</td
            ></tr
          >
        </tbody>
      </table>
    </div>
    <div class="admin-pagination" id="ticketsPagination"></div>
  </div>

  <div
    class="admin-drawer-backdrop"
    id="ticketDrawerBackdrop"
    aria-hidden="true"
  >
    <aside
      class="admin-drawer"
      role="dialog"
      aria-modal="true"
      aria-labelledby="ticketDrawerTitle"
    >
      <div class="admin-drawer-header">
        <div>
          <div class="admin-page-kicker">Ticket Detail</div>
          <h2 class="admin-drawer-title" id="ticketDrawerTitle">工单详情</h2>
        </div>
        <button
          class="admin-btn admin-btn-sm"
          id="ticketDrawerClose"
          type="button">关闭</button
        >
      </div>
      <div class="admin-drawer-body" id="ticketDrawerBody"></div>
    </aside>
  </div>

  <script is:inline>
    (function () {
      var currentPage = 1;
      var currentStatus = "";
      var hasLoadedTickets = false;
      var ticketDataById = {};
      var pendingConfirm = null;
      var refreshBtn = document.getElementById("supportRefresh");
      var retryBtn = document.getElementById("supportRetry");
      var statusEl = document.getElementById("supportStatus");
      var statusTextEl = statusEl?.querySelector("[data-status-text]");
      var updatedEl = document.getElementById("supportUpdated");
      var drawer = document.getElementById("ticketDrawerBackdrop");
      var drawerBody = document.getElementById("ticketDrawerBody");
      var drawerTitle = document.getElementById("ticketDrawerTitle");

      refreshBtn?.addEventListener("click", function () {
        refreshAll(currentPage, currentStatus);
      });
      retryBtn?.addEventListener("click", function () {
        refreshAll(currentPage, currentStatus);
      });

      document
        .querySelectorAll("[data-status-filter]")
        .forEach(function (card) {
          card.addEventListener("click", function () {
            refreshAll(1, card.dataset.statusFilter);
          });
        });

      document
        .getElementById("statusFilter")
        .addEventListener("change", function () {
          refreshAll(1, this.value);
        });

      document
        .getElementById("ticketDrawerClose")
        .addEventListener("click", closeDrawer);
      drawer.addEventListener("click", function (event) {
        if (event.target === drawer) closeDrawer();
      });
      document.addEventListener("keydown", function (event) {
        if (event.key === "Escape") closeDrawer();
      });

      window.__loadTickets = loadTickets;
      window.__showTicket = showTicket;
      refreshAll(1, "");

      function refreshAll(page, status) {
        loadCounts();
        loadTickets(page || 1, status);
      }

      function loadTickets(page, status) {
        currentPage = page || 1;
        currentStatus = status !== undefined ? status : currentStatus;
        document.getElementById("statusFilter").value = currentStatus;
        if (refreshBtn) refreshBtn.disabled = true;
        setStatus("loading", "正在加载工单数据...", false);
        setTableLoading();

        var params = new URLSearchParams();
        params.set("page", String(currentPage));
        params.set("limit", "20");
        if (currentStatus) params.set("status", currentStatus);

        fetch("/api/admin/support?" + params.toString())
          .then(function (response) {
            return response.json().then(function (body) {
              return { ok: response.ok, body: body };
            });
          })
          .then(function (payload) {
            if (!payload.ok || !payload.body?.ok) {
              throw new Error(
                payload.body?.error?.message || "工单列表加载失败。",
              );
            }
            renderTickets(payload.body.data.tickets || []);
            renderPagination(payload.body.data.pagination);
            document.getElementById("filterInfo").textContent =
              "共 " + payload.body.data.pagination.total + " 条";
            setUpdatedAt(payload.body.data.generatedAt);
            setStatus("", "", false);
            hasLoadedTickets = true;
          })
          .catch(function (err) {
            setStatus(
              "error",
              err?.message || "工单数据加载失败，请稍后重试。",
              true,
            );
            if (!hasLoadedTickets) renderTickets([]);
          })
          .finally(function () {
            if (refreshBtn) refreshBtn.disabled = false;
          });
      }

      function loadCounts() {
        ["", "open", "pending", "resolved"].forEach(function (st, idx) {
          var params = new URLSearchParams({ limit: "1" });
          if (st) params.set("status", st);
          fetch("/api/admin/support?" + params.toString())
            .then(function (r) {
              return r.json();
            })
            .then(function (res) {
              if (!res.ok) return;
              var ids = ["stAll", "stOpen", "stPending", "stResolved"];
              document.getElementById(ids[idx]).textContent =
                res.data.pagination.total;
            })
            .catch(function () {});
        });
      }

      function renderTickets(tickets) {
        var tbody = document.getElementById("ticketsBody");
        ticketDataById = {};
        if (!tickets || !tickets.length) {
          tbody.innerHTML =
            '<tr><td colspan="8" class="admin-empty"><strong>暂无工单</strong><small>当前筛选条件下没有支持请求。</small></td></tr>';
          document.getElementById("ticketsPagination").innerHTML = "";
          return;
        }
        var statusMap = getStatusMap();
        var topicLabels = getTopicLabels();
        var html = "";
        tickets.forEach(function (t) {
          ticketDataById[t.id] = t;
          var s = statusMap[t.status] || statusMap.open;
          html += "<tr>";
          html +=
            '<td><span class="admin-code">' +
            escapeHtml(t.ticket_code) +
            "</span></td>";
          html +=
            '<td><span style="font-size:13px">' +
            escapeHtml(t.name) +
            '</span><br><span style="font-size:11px;color:var(--admin-text-dim)">' +
            escapeHtml(t.email) +
            "</span></td>";
          html +=
            "<td>" + escapeHtml(topicLabels[t.topic] || t.topic) + "</td>";
          html +=
            '<td style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:12px;color:var(--admin-text-muted)">' +
            escapeHtml((t.message || "").slice(0, 72)) +
            "</td>";
          html +=
            '<td><span class="badge badge-gray">' +
            escapeHtml(t.locale || "en") +
            "</span></td>";
          html +=
            '<td><span class="badge ' +
            s.cls +
            '"><span class="badge-dot"></span>' +
            s.label +
            "</span></td>";
          html +=
            '<td style="font-size:12px;color:var(--admin-text-muted);white-space:nowrap">' +
            getTimeAgo(t.created_at) +
            "</td>";
          html +=
            '<td><button class="admin-btn admin-btn-sm" type="button" data-ticket-id="' +
            escapeHtml(t.id) +
            '">查看</button></td>';
          html += "</tr>";
        });
        tbody.innerHTML = html;
        tbody.querySelectorAll("[data-ticket-id]").forEach(function (btn) {
          btn.addEventListener("click", function () {
            showTicket(btn.getAttribute("data-ticket-id"));
          });
        });
      }

      function renderPagination(p) {
        var el = document.getElementById("ticketsPagination");
        if (!p || p.totalPages <= 1) {
          el.innerHTML = "<span>共 " + (p?.total || 0) + " 条</span>";
          return;
        }
        var html =
          "<span>第 " +
          p.page +
          " / " +
          p.totalPages +
          " 页，共 " +
          p.total +
          " 条</span>";
        html += '<div class="admin-pagination-btns">';
        if (p.page > 1) {
          html +=
            '<button class="admin-btn admin-btn-sm" onclick="window.__loadTickets(' +
            (p.page - 1) +
            ')">上一页</button>';
        }
        if (p.page < p.totalPages) {
          html +=
            '<button class="admin-btn admin-btn-sm" onclick="window.__loadTickets(' +
            (p.page + 1) +
            ')">下一页</button>';
        }
        html += "</div>";
        el.innerHTML = html;
      }

      function showTicket(id) {
        var t = ticketDataById[id];
        if (!t) return;
        pendingConfirm = null;
        drawerTitle.textContent = t.ticket_code;

        var statusMap = getStatusMap();
        var topicLabels = getTopicLabels();
        var statusOpts = ["open", "pending", "resolved", "closed"];
        var selectHtml =
          '<select id="ticketStatusSelect" class="admin-select" style="width:100%">';
        statusOpts.forEach(function (status) {
          selectHtml +=
            '<option value="' +
            status +
            '"' +
            (status === t.status ? " selected" : "") +
            ">" +
            statusMap[status].label +
            "</option>";
        });
        selectHtml += "</select>";

        drawerBody.innerHTML =
          '<dl class="admin-detail-grid">' +
          detailRow("用户", escapeHtml(t.name || "—")) +
          detailRow("邮箱", escapeHtml(t.email || "—")) +
          detailRow(
            "主题",
            escapeHtml(topicLabels[t.topic] || t.topic || "—"),
          ) +
          detailRow("语言", escapeHtml(t.locale || "en")) +
          detailRow(
            "当前状态",
            '<span class="badge ' +
              (statusMap[t.status] || statusMap.open).cls +
              '"><span class="badge-dot"></span>' +
              (statusMap[t.status] || statusMap.open).label +
              "</span>",
          ) +
          detailRow("创建时间", escapeHtml(formatDateTime(t.created_at))) +
          detailRow("更新时间", escapeHtml(formatDateTime(t.updated_at))) +
          "</dl>" +
          '<div><div class="admin-card-title">内容</div>' +
          '<div style="font-size:14px;line-height:1.7;background:var(--admin-bg);padding:14px;border-radius:8px;border:1px solid var(--admin-border);white-space:pre-wrap">' +
          escapeHtml(t.message || "") +
          "</div></div>" +
          '<div><label style="font-size:12px;color:var(--admin-text-muted);display:block;margin-bottom:8px">更新状态</label>' +
          selectHtml +
          '<p class="admin-muted" style="font-size:12px;margin-top:8px">确认后会写入 admin_audit_logs，记录旧状态、新状态和操作管理员。</p>' +
          "</div>" +
          '<button class="admin-btn admin-btn-primary" id="updateStatusBtn" type="button" style="width:100%">更新状态</button>' +
          '<div id="updateMsg" role="status" style="font-size:13px;text-align:center;min-height:20px"></div>';

        drawer.classList.add("open");
        drawer.setAttribute("aria-hidden", "false");

        document
          .getElementById("ticketStatusSelect")
          .addEventListener("change", function () {
            pendingConfirm = null;
            document.getElementById("updateStatusBtn").textContent = "更新状态";
            setUpdateMsg("", "var(--admin-text-muted)");
          });
        document
          .getElementById("updateStatusBtn")
          .addEventListener("click", function () {
            updateTicketStatus(t);
          });
      }

      function updateTicketStatus(ticket) {
        var select = document.getElementById("ticketStatusSelect");
        var btn = document.getElementById("updateStatusBtn");
        var newStatus = select.value;
        var statusMap = getStatusMap();
        if (newStatus === ticket.status) {
          setUpdateMsg("状态未变化，无需更新。", "var(--admin-text-muted)");
          return;
        }

        if (
          !pendingConfirm ||
          pendingConfirm.id !== ticket.id ||
          pendingConfirm.status !== newStatus
        ) {
          pendingConfirm = { id: ticket.id, status: newStatus };
          btn.textContent = "确认更新为 " + statusMap[newStatus].label;
          var oldStatusLabel = (statusMap[ticket.status] || statusMap.open)
            .label;
          setUpdateMsg(
            "再次点击确认，将把状态从 " +
              oldStatusLabel +
              " 改为 " +
              statusMap[newStatus].label +
              "。",
            "var(--admin-amber)",
          );
          return;
        }

        btn.disabled = true;
        setUpdateMsg("正在更新...", "var(--admin-text-muted)");
        fetch("/api/admin/support/" + ticket.id, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ status: newStatus }),
        })
          .then(function (response) {
            return response.json().then(function (body) {
              return { ok: response.ok, body: body };
            });
          })
          .then(function (payload) {
            if (!payload.ok || !payload.body?.ok) {
              throw new Error(payload.body?.error?.message || "状态更新失败。");
            }
            setUpdateMsg("状态已更新，审计日志已记录。", "var(--admin-green)");
            ticket.status = newStatus;
            ticket.updated_at = payload.body.data.updatedAt;
            loadCounts();
            setTimeout(function () {
              loadTickets(currentPage, currentStatus);
              closeDrawer();
            }, 700);
          })
          .catch(function (err) {
            btn.disabled = false;
            pendingConfirm = null;
            btn.textContent = "更新状态";
            setUpdateMsg(
              err?.message || "网络错误，状态未更新。",
              "var(--admin-red)",
            );
          });
      }

      function closeDrawer() {
        drawer.classList.remove("open");
        drawer.setAttribute("aria-hidden", "true");
      }

      function setUpdateMsg(message, color) {
        var msgEl = document.getElementById("updateMsg");
        if (!msgEl) return;
        msgEl.textContent = message;
        msgEl.style.color = color;
      }

      function setTableLoading() {
        document.getElementById("ticketsBody").innerHTML =
          '<tr><td colspan="8" class="admin-loading"><div class="admin-spinner"></div>加载中...</td></tr>';
      }

      function setStatus(type, message, retryable) {
        if (!statusEl || !statusTextEl) return;
        statusEl.className = "admin-status-banner" + (type ? " " + type : "");
        statusEl.hidden = !type;
        statusTextEl.textContent = message;
        if (retryBtn) retryBtn.hidden = !retryable;
      }

      function setUpdatedAt(iso) {
        var d = iso ? new Date(iso) : new Date();
        if (updatedEl) updatedEl.textContent = d.toLocaleString("zh-CN");
      }

      function detailRow(label, value) {
        return (
          '<div class="admin-detail-row"><dt>' +
          escapeHtml(label) +
          "</dt><dd>" +
          value +
          "</dd></div>"
        );
      }

      function getStatusMap() {
        return {
          open: { label: "待处理", cls: "badge-amber" },
          pending: { label: "处理中", cls: "badge-blue" },
          resolved: { label: "已解决", cls: "badge-green" },
          closed: { label: "已关闭", cls: "badge-gray" },
        };
      }

      function getTopicLabels() {
        return {
          billing: "账单",
          tryon: "试妆",
          diagnosis: "诊断",
          account: "账户",
          cooperation: "合作",
          other: "其他",
        };
      }

      function getTimeAgo(isoStr) {
        var d = new Date(isoStr);
        var now = new Date();
        var diff = (now - d) / 1000;
        if (diff < 60) return "刚刚";
        if (diff < 3600) return Math.floor(diff / 60) + " 分钟前";
        if (diff < 86400) return Math.floor(diff / 3600) + " 小时前";
        if (diff < 604800) return Math.floor(diff / 86400) + " 天前";
        return d.toLocaleDateString("zh-CN");
      }

      function formatDateTime(iso) {
        if (!iso) return "—";
        return new Date(iso).toLocaleString("zh-CN");
      }

      function escapeHtml(s) {
        var div = document.createElement("div");
        div.appendChild(document.createTextNode(s || ""));
        return div.innerHTML;
      }
    })();
  </script>
</AdminLayout>
