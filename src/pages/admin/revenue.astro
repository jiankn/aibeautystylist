---
/**
 * 管理后台 — 收入分析
 * MRR 趋势、订阅分布、状态分析和最近变动。
 */
import AdminLayout from "../../layouts/AdminLayout.astro";
import { checkAdmin } from "../../lib/adminGuard";
import { PLAN_DEFINITIONS } from "../../lib/plans";
import { getRuntimeBindings } from "../../lib/runtime";

const { DB } = getRuntimeBindings();
if (!DB) return Astro.redirect("/login");
const auth = await checkAdmin(Astro.cookies, DB);
if (!auth.authorized) return Astro.redirect("/login");

const monthlyPrices = {
  pro: PLAN_DEFINITIONS.pro.monthlyPriceUsd,
  premium: PLAN_DEFINITIONS.premium.monthlyPriceUsd,
};
---

<AdminLayout title="收入分析" activeNav="revenue">
  <!-- KPI -->
  <div class="kpi-grid" style="grid-template-columns:repeat(4,1fr)">
    <div class="kpi-card">
      <div class="kpi-label">活跃订阅</div>
      <div class="kpi-value" id="rvActiveSubs">—</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">Pro 订阅</div>
      <div class="kpi-value" id="rvProSubs">—</div>
      <span class="badge badge-purple" style="margin-top:4px">
        {"$" + monthlyPrices.pro.toFixed(2) + "/月"}
      </span>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">Premium 订阅</div>
      <div class="kpi-value" id="rvPremiumSubs">—</div>
      <span class="badge badge-amber" style="margin-top:4px">
        {"$" + monthlyPrices.premium.toFixed(2) + "/月"}
      </span>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">估算 MRR</div>
      <div class="kpi-value" id="rvMrr">—</div>
      <span class="kpi-change up" id="rvMrrNote">月度估算</span>
    </div>
  </div>

  <!-- 图表 -->
  <div class="admin-grid-2 admin-section">
    <div class="admin-card">
      <div class="admin-card-title">订阅分布</div>
      <div id="planDist" style="padding:16px 0">
        <div class="admin-loading">
          <div class="admin-spinner"></div>加载中...
        </div>
      </div>
    </div>
    <div class="admin-card">
      <div class="admin-card-title">订阅状态分布</div>
      <div id="statusDist" style="padding:16px 0">
        <div class="admin-loading">
          <div class="admin-spinner"></div>加载中...
        </div>
      </div>
    </div>
  </div>

  <!-- 新增订阅趋势 -->
  <div class="admin-section">
    <div class="admin-card">
      <div class="admin-card-title">新增订阅趋势（近 30 天）</div>
      <div class="chart-container">
        <canvas id="subsTrendChart" class="chart-canvas"></canvas>
      </div>
    </div>
  </div>

  <!-- 最近变动 -->
  <div class="admin-section">
    <div class="admin-card">
      <div class="admin-card-title" style="margin-bottom:16px">
        最近订阅变动
      </div>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>用户</th>
              <th>计划</th>
              <th>状态</th>
              <th>Stripe ID</th>
              <th>创建时间</th>
              <th>更新时间</th>
            </tr>
          </thead>
          <tbody id="recentSubsBody">
            <tr
              ><td colspan="6" class="admin-loading"
                ><div class="admin-spinner"></div>加载中...</td
              ></tr
            >
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ monthlyPrices }}>
    (function () {
      fetch("/api/admin/revenue")
        .then(function (r) {
          return r.json();
        })
        .then(function (res) {
          if (!res.ok) return;
          var d = res.data;

          // KPI
          var proCount = 0,
            premiumCount = 0;
          (d.planDistribution || []).forEach(function (p) {
            if (p.plan_code === "pro") proCount = p.cnt;
            if (p.plan_code === "premium") premiumCount = p.cnt;
          });
          var activeSubs = proCount + premiumCount;
          var mrr =
            proCount * monthlyPrices.pro + premiumCount * monthlyPrices.premium;

          document.getElementById("rvActiveSubs").textContent = activeSubs;
          document.getElementById("rvProSubs").textContent = proCount;
          document.getElementById("rvPremiumSubs").textContent = premiumCount;
          document.getElementById("rvMrr").textContent = "$" + mrr.toFixed(0);

          // 计划分布
          renderPlanDist(d.planDistribution || []);
          // 状态分布
          renderStatusDist(d.statusDistribution || []);
          // 趋势图
          renderSubsTrend(d.subscriptionsByDay || []);
          // 最近变动
          renderRecentSubs(d.recentSubscriptions || []);
        });

      function renderPlanDist(data) {
        var el = document.getElementById("planDist");
        if (!data.length) {
          el.innerHTML = '<div class="admin-empty">暂无订阅数据</div>';
          return;
        }
        var total =
          data.reduce(function (s, d) {
            return s + d.cnt;
          }, 0) || 1;
        var colors = { pro: "#8b5cf6", premium: "#f59e0b", free: "#64748b" };
        var html = '<div style="display:flex;flex-direction:column;gap:14px">';
        data.forEach(function (item) {
          var pct = ((item.cnt / total) * 100).toFixed(1);
          var color = colors[item.plan_code] || "#64748b";
          html += "<div>";
          html +=
            '<div style="display:flex;justify-content:space-between;margin-bottom:4px">';
          html +=
            '<span style="font-size:13px;font-weight:500;text-transform:capitalize">' +
            escapeHtml(item.plan_code) +
            "</span>";
          html +=
            '<span style="font-size:12px;color:#94a3b8">' +
            item.cnt +
            " (" +
            pct +
            "%)</span>";
          html += "</div>";
          html +=
            '<div class="progress-bar"><div class="progress-fill" style="width:' +
            pct +
            "%;background:" +
            color +
            '"></div></div>';
          html += "</div>";
        });
        html += "</div>";
        el.innerHTML = html;
      }

      function renderStatusDist(data) {
        var el = document.getElementById("statusDist");
        if (!data.length) {
          el.innerHTML = '<div class="admin-empty">暂无数据</div>';
          return;
        }
        var statusColors = {
          active: "#10b981",
          trialing: "#3b82f6",
          past_due: "#ef4444",
          canceled: "#64748b",
          incomplete: "#f59e0b",
          incomplete_expired: "#94a3b8",
        };
        var statusLabels = {
          active: "活跃",
          trialing: "试用",
          past_due: "逾期",
          canceled: "已取消",
          incomplete: "未完成",
          incomplete_expired: "过期",
        };
        var total =
          data.reduce(function (s, d) {
            return s + d.cnt;
          }, 0) || 1;
        var html = '<div style="display:flex;flex-direction:column;gap:14px">';
        data.forEach(function (item) {
          var pct = ((item.cnt / total) * 100).toFixed(1);
          var color = statusColors[item.status] || "#64748b";
          var label = statusLabels[item.status] || item.status;
          html += "<div>";
          html +=
            '<div style="display:flex;justify-content:space-between;margin-bottom:4px">';
          html +=
            '<span style="font-size:13px;font-weight:500">' +
            escapeHtml(label) +
            "</span>";
          html +=
            '<span style="font-size:12px;color:#94a3b8">' +
            item.cnt +
            " (" +
            pct +
            "%)</span>";
          html += "</div>";
          html +=
            '<div class="progress-bar"><div class="progress-fill" style="width:' +
            pct +
            "%;background:" +
            color +
            '"></div></div>';
          html += "</div>";
        });
        html += "</div>";
        el.innerHTML = html;
      }

      function renderSubsTrend(data) {
        var canvas = document.getElementById("subsTrendChart");
        if (!canvas || !data.length) return;
        var ctx = canvas.getContext("2d");
        var rect = canvas.parentElement.getBoundingClientRect();
        var dpr = window.devicePixelRatio || 1;
        canvas.width = rect.width * dpr;
        canvas.height = rect.height * dpr;
        ctx.scale(dpr, dpr);
        var w = rect.width,
          h = rect.height;

        // 按天聚合
        var byDay = {};
        data.forEach(function (d) {
          byDay[d.day] = (byDay[d.day] || 0) + d.cnt;
        });
        var days = Object.keys(byDay).sort();
        var values = days.map(function (d) {
          return byDay[d];
        });
        var labels = days.map(function (d) {
          return d.slice(5);
        });

        if (!values.length) return;
        var max = Math.max.apply(null, values) || 1;
        var padL = 40,
          padR = 20,
          padT = 20,
          padB = 40;
        var chartW = w - padL - padR;
        var chartH = h - padT - padB;

        // 网格
        ctx.strokeStyle = "rgba(139,92,246,0.08)";
        for (var i = 0; i <= 4; i++) {
          var gy = padT + (chartH / 4) * i;
          ctx.beginPath();
          ctx.moveTo(padL, gy);
          ctx.lineTo(w - padR, gy);
          ctx.stroke();
        }

        // 柱状图
        var barW = Math.max(6, (chartW / values.length) * 0.6);
        var gap = chartW / values.length;
        values.forEach(function (v, idx) {
          var barH = (v / max) * chartH;
          var x = padL + gap * idx + (gap - barW) / 2;
          var y = padT + chartH - barH;

          var grad = ctx.createLinearGradient(x, y, x, padT + chartH);
          grad.addColorStop(0, "#8b5cf6");
          grad.addColorStop(1, "rgba(139,92,246,0.2)");
          ctx.fillStyle = grad;

          // 圆角柱子
          var r = Math.min(3, barW / 2);
          ctx.beginPath();
          ctx.moveTo(x + r, y);
          ctx.lineTo(x + barW - r, y);
          ctx.quadraticCurveTo(x + barW, y, x + barW, y + r);
          ctx.lineTo(x + barW, padT + chartH);
          ctx.lineTo(x, padT + chartH);
          ctx.lineTo(x, y + r);
          ctx.quadraticCurveTo(x, y, x + r, y);
          ctx.fill();
        });

        // X 轴标签
        ctx.fillStyle = "#64748b";
        ctx.font = "11px Inter, sans-serif";
        ctx.textAlign = "center";
        labels.forEach(function (l, i) {
          if (i % Math.max(1, Math.floor(labels.length / 10)) === 0) {
            ctx.fillText(l, padL + gap * i + gap / 2, h - padB + 18);
          }
        });

        // Y 轴
        ctx.textAlign = "right";
        for (var j = 0; j <= 4; j++) {
          ctx.fillText(
            String(Math.round(max - (max / 4) * j)),
            padL - 8,
            padT + (chartH / 4) * j + 4,
          );
        }
      }

      function renderRecentSubs(subs) {
        var tbody = document.getElementById("recentSubsBody");
        if (!subs.length) {
          tbody.innerHTML =
            '<tr><td colspan="6" class="admin-empty">暂无数据</td></tr>';
          return;
        }
        var planBadges = {
          pro: '<span class="badge badge-purple"><span class="badge-dot"></span>Pro</span>',
          premium:
            '<span class="badge badge-amber"><span class="badge-dot"></span>Premium</span>',
        };
        var statusBadges = {
          active:
            '<span class="badge badge-green"><span class="badge-dot"></span>Active</span>',
          trialing:
            '<span class="badge badge-blue"><span class="badge-dot"></span>Trial</span>',
          past_due:
            '<span class="badge badge-red"><span class="badge-dot"></span>Past Due</span>',
          canceled:
            '<span class="badge badge-gray"><span class="badge-dot"></span>Canceled</span>',
        };
        var html = "";
        subs.forEach(function (s) {
          html += "<tr>";
          html += '<td style="font-size:13px">' + escapeHtml(s.email) + "</td>";
          html +=
            "<td>" +
            (planBadges[s.plan_code] || escapeHtml(s.plan_code)) +
            "</td>";
          html +=
            "<td>" +
            (statusBadges[s.status] ||
              '<span class="badge badge-gray">' +
                escapeHtml(s.status) +
                "</span>") +
            "</td>";
          html +=
            '<td style="font-family:monospace;font-size:11px;color:var(--admin-text-dim)">' +
            escapeHtml((s.stripe_subscription_id || "").slice(0, 16)) +
            "...</td>";
          html +=
            '<td style="font-size:12px;color:var(--admin-text-muted)">' +
            formatDate(s.created_at) +
            "</td>";
          html +=
            '<td style="font-size:12px;color:var(--admin-text-muted)">' +
            formatDate(s.updated_at) +
            "</td>";
          html += "</tr>";
        });
        tbody.innerHTML = html;
      }

      function formatDate(iso) {
        if (!iso) return "—";
        return new Date(iso).toLocaleDateString("zh-CN", {
          month: "2-digit",
          day: "2-digit",
          hour: "2-digit",
          minute: "2-digit",
        });
      }

      function escapeHtml(s) {
        var div = document.createElement("div");
        div.appendChild(document.createTextNode(s || ""));
        return div.innerHTML;
      }
    })();
  </script>
</AdminLayout>
