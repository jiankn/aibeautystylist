---
/**
 * 管理后台 — Overview 总览大盘
 * 展示所有核心 KPI、趋势图表和最新工单。
 */
import AdminLayout from "../../layouts/AdminLayout.astro";
import { checkAdmin } from "../../lib/adminGuard";
import { getRuntimeBindings } from "../../lib/runtime";

const { DB } = getRuntimeBindings();
if (!DB) {
  return Astro.redirect(
    `/login?next=${encodeURIComponent(`${Astro.url.pathname}${Astro.url.search}`)}`,
  );
}

const auth = await checkAdmin(Astro.cookies, DB);
if (!auth.authorized) {
  return Astro.redirect(
    `/login?next=${encodeURIComponent(`${Astro.url.pathname}${Astro.url.search}`)}`,
  );
}
---

<AdminLayout title="总览" activeNav="overview">
  <section class="admin-page-header">
    <div>
      <div class="admin-page-kicker">Operations Overview</div>
      <h2 class="admin-page-title">运营总览</h2>
      <p class="admin-page-description">
        用一屏判断今天是否需要处理工单、订阅异常、AI 成本或服务质量问题。
      </p>
    </div>
    <button class="admin-btn" id="overviewRefresh" type="button">刷新</button>
  </section>

  <div class="admin-meta-row">
    <span
      >数据口径：订阅为当前有效订阅；AI 计量成本为本月 estimated_cost_micros
      汇总。</span
    >
    <span
      >最后更新：<b class="admin-last-updated" id="overviewUpdated">—</b></span
    >
  </div>

  <div class="admin-status-banner loading" id="overviewStatus" role="status">
    <span data-status-text>正在加载总览数据...</span>
    <button
      class="admin-btn admin-btn-sm"
      id="overviewRetry"
      type="button"
      hidden
    >
      重试
    </button>
  </div>

  <div class="kpi-grid" id="kpiGrid">
    <div class="kpi-card">
      <div class="kpi-label">总用户数</div>
      <div class="kpi-value" id="kpiTotalUsers">—</div>
      <span class="kpi-change neutral" id="kpiNewToday">等待数据</span>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">活跃订阅</div>
      <div class="kpi-value" id="kpiActiveSubs">—</div>
      <span class="kpi-change neutral" id="kpiSubsDetail">等待数据</span>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">AI 计量成本</div>
      <div class="kpi-value" id="kpiAiCost">—</div>
      <span class="kpi-change neutral" id="kpiAiCalls">本月</span>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">AI 成功率</div>
      <div class="kpi-value" id="kpiSuccessRate">—</div>
      <span class="kpi-change neutral" id="kpiAvgDuration">本月</span>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">待处理工单</div>
      <div class="kpi-value" id="kpiOpenTickets">—</div>
      <a
        href="/admin/support"
        class="kpi-change neutral"
        style="text-decoration:none">查看工单</a
      >
    </div>
  </div>

  <div class="admin-section">
    <div class="admin-card">
      <div
        style="display:flex;justify-content:space-between;align-items:flex-start;gap:16px;margin-bottom:16px"
      >
        <div>
          <div class="admin-card-title" style="margin:0">今日处理队列</div>
          <p class="admin-muted" style="font-size:13px;margin-top:6px">
            按运营风险排序，优先处理影响收入、服务成功率和用户等待的问题。
          </p>
        </div>
        <span class="badge badge-gray">自动生成</span>
      </div>
      <div class="admin-action-list" id="actionQueue">
        <div class="admin-loading" style="padding:22px 0">
          <div class="admin-spinner"></div>正在评估运营风险...
        </div>
      </div>
    </div>
  </div>

  <div class="admin-grid-2 admin-section">
    <div class="admin-card">
      <div class="admin-card-title">用户增长趋势（近 14 天）</div>
      <div class="chart-container">
        <canvas id="userGrowthChart" class="chart-canvas"></canvas>
      </div>
    </div>
    <div class="admin-card">
      <div class="admin-card-title">订阅分布</div>
      <div id="subsDistribution" style="padding:24px 0">
        <div class="admin-loading">
          <div class="admin-spinner"></div>加载中...
        </div>
      </div>
    </div>
  </div>

  <div class="admin-section">
    <div class="admin-card">
      <div
        style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px"
      >
        <div class="admin-card-title" style="margin:0">最新工单</div>
        <a
          href="/admin/support"
          class="admin-btn admin-btn-sm"
          style="text-decoration:none">全部工单</a
        >
      </div>
      <div class="admin-table-wrap">
        <table class="admin-table" id="ticketsTable">
          <thead>
            <tr>
              <th>工单号</th>
              <th>用户</th>
              <th>主题</th>
              <th>状态</th>
              <th>创建时间</th>
            </tr>
          </thead>
          <tbody id="ticketsBody">
            <tr
              ><td colspan="5" class="admin-loading"
                ><div class="admin-spinner"></div>加载中...</td
              ></tr
            >
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      var refreshBtn = document.getElementById("overviewRefresh");
      var retryBtn = document.getElementById("overviewRetry");
      var statusEl = document.getElementById("overviewStatus");
      var statusTextEl = statusEl?.querySelector("[data-status-text]");
      var updatedEl = document.getElementById("overviewUpdated");
      var hasLoaded = false;

      refreshBtn?.addEventListener("click", loadOverview);
      retryBtn?.addEventListener("click", loadOverview);
      loadOverview();

      function loadOverview() {
        if (refreshBtn) refreshBtn.disabled = true;
        setStatus("loading", "正在加载总览数据...", false);

        fetch("/api/admin/stats")
          .then(function (response) {
            return response.json().then(function (body) {
              return { ok: response.ok, body: body };
            });
          })
          .then(function (payload) {
            if (!payload.ok || !payload.body?.ok) {
              var message =
                payload.body?.error?.message || "总览数据加载失败，请重试。";
              throw new Error(message);
            }

            var d = payload.body.data;
            updateKpis(d);
            renderActionQueue(d);
            renderUserChart(d.dailyNewUsers || []);
            renderSubsDistribution(d);
            renderTickets(d.recentTickets || []);
            hasLoaded = true;
            setUpdatedAt(d.generatedAt);
            setStatus("", "", false);
          })
          .catch(function (err) {
            setStatus(
              "error",
              err?.message || "总览数据加载失败，请检查网络后重试。",
              true,
            );
            if (!hasLoaded) {
              renderActionQueue(null);
              renderUserChart([]);
              renderSubsDistribution(null);
              renderTickets([]);
            }
          })
          .finally(function () {
            if (refreshBtn) refreshBtn.disabled = false;
          });
      }

      function updateKpis(d) {
        document.getElementById("kpiTotalUsers").textContent = formatNumber(
          d.totalUsers,
        );
        document.getElementById("kpiNewToday").textContent =
          "今日 +" + d.newUsersToday + " / 本周 +" + d.newUsersWeek;
        document.getElementById("kpiNewToday").className =
          d.newUsersToday > 0 ? "kpi-change up" : "kpi-change neutral";

        document.getElementById("kpiActiveSubs").textContent = formatNumber(
          d.activeSubscriptions,
        );
        document.getElementById("kpiSubsDetail").textContent =
          "Pro " + d.proSubscriptions + " / Premium " + d.premiumSubscriptions;
        document.getElementById("kpiSubsDetail").className =
          d.activeSubscriptions > 0 ? "kpi-change up" : "kpi-change neutral";

        document.getElementById("kpiAiCost").textContent =
          Number(d.monthlyAiCostUnits || 0).toLocaleString() + " units";
        document.getElementById("kpiAiCalls").textContent =
          formatNumber(d.monthlyAiCalls) + " 次调用";

        document.getElementById("kpiSuccessRate").textContent =
          d.aiSuccessRate + "%";
        document.getElementById("kpiAvgDuration").textContent =
          "平均 " + (Number(d.avgAiDurationMs || 0) / 1000).toFixed(1) + "s";
        document.getElementById("kpiAvgDuration").className =
          d.aiSuccessRate >= 95 ? "kpi-change up" : "kpi-change down";

        document.getElementById("kpiOpenTickets").textContent =
          d.openTickets || 0;
      }

      function renderActionQueue(d) {
        var el = document.getElementById("actionQueue");
        if (!d) {
          el.innerHTML =
            '<div class="admin-empty"><strong>无法生成处理队列</strong><small>总览 API 未返回数据，请重试。</small></div>';
          return;
        }

        var items = [];
        if (Number(d.openTickets) > 0) {
          items.push({
            level: Number(d.openTickets) >= 5 ? "danger" : "warning",
            title: d.openTickets + " 个待处理工单",
            copy: "优先处理 open 状态，避免用户等待过久。",
            href: "/admin/support",
            action: "处理工单",
          });
        }
        if (Number(d.aiSuccessRate) < 95) {
          items.push({
            level: "danger",
            title: "AI 成功率低于 95%",
            copy: "检查失败模型、错误码和最近调用日志。",
            href: "/admin/ai-costs",
            action: "查看成本",
          });
        } else if (Number(d.aiSuccessRate) < 98) {
          items.push({
            level: "warning",
            title: "AI 成功率需要关注",
            copy: "当前为 " + d.aiSuccessRate + "%，建议观察失败原因。",
            href: "/admin/ai-costs",
            action: "查看日志",
          });
        }
        if (Number(d.avgAiDurationMs) > 10000) {
          items.push({
            level: "warning",
            title: "AI 平均耗时超过 10 秒",
            copy: "会影响用户等待体验，建议检查慢模型和高耗时操作。",
            href: "/admin/ai-costs",
            action: "定位耗时",
          });
        }
        if (Number(d.totalUsers) >= 10 && Number(d.activeSubscriptions) === 0) {
          items.push({
            level: "warning",
            title: "暂无有效付费订阅",
            copy: "用户量已形成样本，建议检查定价页、支付链路和转化漏斗。",
            href: "/admin/revenue",
            action: "看收入",
          });
        }
        if (!items.length) {
          items.push({
            level: "",
            title: "暂无阻塞项",
            copy: "工单、AI 成功率和订阅核心指标均无明显告警。",
            href: "/admin/users",
            action: "看用户",
          });
        }

        el.innerHTML = items
          .map(function (item) {
            return (
              '<div class="admin-action-item">' +
              '<span class="admin-action-dot ' +
              escapeHtml(item.level) +
              '"></span>' +
              "<div>" +
              '<div class="admin-action-title">' +
              escapeHtml(item.title) +
              "</div>" +
              '<div class="admin-action-copy">' +
              escapeHtml(item.copy) +
              "</div>" +
              "</div>" +
              '<a class="admin-btn admin-btn-sm" style="text-decoration:none" href="' +
              escapeHtml(item.href) +
              '">' +
              escapeHtml(item.action) +
              "</a>" +
              "</div>"
            );
          })
          .join("");
      }

      function setStatus(type, message, retryable) {
        if (!statusEl || !statusTextEl) return;
        statusEl.className = "admin-status-banner" + (type ? " " + type : "");
        statusEl.hidden = !type;
        statusTextEl.textContent = message;
        if (retryBtn) retryBtn.hidden = !retryable;
      }

      function setUpdatedAt(iso) {
        var d = iso ? new Date(iso) : new Date();
        if (updatedEl) updatedEl.textContent = d.toLocaleString("zh-CN");
      }

      function formatNumber(n) {
        n = Number(n) || 0;
        if (n >= 1000000) return (n / 1000000).toFixed(1) + "M";
        if (n >= 1000) return (n / 1000).toFixed(1) + "K";
        return String(n);
      }

      function renderUserChart(data) {
        var canvas = document.getElementById("userGrowthChart");
        if (!canvas) return;
        var ctx = canvas.getContext("2d");
        var rect = canvas.parentElement.getBoundingClientRect();
        var dpr = window.devicePixelRatio || 1;
        canvas.width = Math.max(1, rect.width * dpr);
        canvas.height = Math.max(1, rect.height * dpr);
        ctx.scale(dpr, dpr);
        var w = rect.width;
        var h = rect.height;

        if (!data.length) {
          drawEmptyChart(ctx, w, h, "暂无用户增长数据");
          return;
        }

        var values = data.map(function (d) {
          return Number(d.cnt);
        });
        var labels = data.map(function (d) {
          return d.day.slice(5);
        });
        var max = Math.max.apply(null, values) || 1;
        var padL = 40,
          padR = 20,
          padT = 20,
          padB = 40;
        var chartW = w - padL - padR;
        var chartH = h - padT - padB;

        ctx.strokeStyle = "rgba(148,163,184,0.12)";
        ctx.lineWidth = 1;
        for (var i = 0; i <= 4; i++) {
          var y = padT + (chartH / 4) * i;
          ctx.beginPath();
          ctx.moveTo(padL, y);
          ctx.lineTo(w - padR, y);
          ctx.stroke();
        }

        var grad = ctx.createLinearGradient(0, padT, 0, h - padB);
        grad.addColorStop(0, "rgba(56,189,248,0.28)");
        grad.addColorStop(1, "rgba(56,189,248,0.03)");

        var pts = values.map(function (v, i) {
          return {
            x: padL + (chartW / (values.length - 1 || 1)) * i,
            y: padT + chartH - (v / max) * chartH,
          };
        });

        ctx.beginPath();
        ctx.moveTo(pts[0].x, h - padB);
        pts.forEach(function (p) {
          ctx.lineTo(p.x, p.y);
        });
        ctx.lineTo(pts[pts.length - 1].x, h - padB);
        ctx.closePath();
        ctx.fillStyle = grad;
        ctx.fill();

        ctx.beginPath();
        ctx.moveTo(pts[0].x, pts[0].y);
        pts.forEach(function (p) {
          ctx.lineTo(p.x, p.y);
        });
        ctx.strokeStyle = "#38bdf8";
        ctx.lineWidth = 2.5;
        ctx.stroke();

        pts.forEach(function (p) {
          ctx.beginPath();
          ctx.arc(p.x, p.y, 4, 0, Math.PI * 2);
          ctx.fillStyle = "#38bdf8";
          ctx.fill();
          ctx.beginPath();
          ctx.arc(p.x, p.y, 2, 0, Math.PI * 2);
          ctx.fillStyle = "#0b0f14";
          ctx.fill();
        });

        ctx.fillStyle = "#64748b";
        ctx.font = "11px Inter, sans-serif";
        ctx.textAlign = "center";
        labels.forEach(function (l, i) {
          if (i % 2 === 0 || labels.length <= 7) {
            ctx.fillText(l, pts[i].x, h - padB + 20);
          }
        });

        ctx.textAlign = "right";
        for (var j = 0; j <= 4; j++) {
          var val = Math.round(max - (max / 4) * j);
          ctx.fillText(String(val), padL - 8, padT + (chartH / 4) * j + 4);
        }
      }

      function drawEmptyChart(ctx, w, h, message) {
        ctx.fillStyle = "#64748b";
        ctx.font = "14px Inter, sans-serif";
        ctx.textAlign = "center";
        ctx.fillText(message, w / 2, h / 2);
      }

      function renderSubsDistribution(d) {
        var el = document.getElementById("subsDistribution");
        if (!d) {
          el.innerHTML =
            '<div class="admin-empty"><strong>订阅数据不可用</strong><small>请刷新后重试。</small></div>';
          return;
        }
        var total = Number(d.totalUsers) || 0;
        if (total === 0) {
          el.innerHTML =
            '<div class="admin-empty"><strong>暂无用户数据</strong><small>订阅分布会在有用户后生成。</small></div>';
          return;
        }
        var free = Math.max(
          0,
          total -
            Number(d.proSubscriptions || 0) -
            Number(d.premiumSubscriptions || 0),
        );
        var items = [
          {
            label: "Free",
            count: free,
            pct: ((free / total) * 100).toFixed(1),
            color: "#64748b",
          },
          {
            label: "Pro",
            count: Number(d.proSubscriptions || 0),
            pct: ((Number(d.proSubscriptions || 0) / total) * 100).toFixed(1),
            color: "#38bdf8",
          },
          {
            label: "Premium",
            count: Number(d.premiumSubscriptions || 0),
            pct: ((Number(d.premiumSubscriptions || 0) / total) * 100).toFixed(
              1,
            ),
            color: "#f59e0b",
          },
        ];

        var html = '<div style="display:flex;flex-direction:column;gap:16px">';
        items.forEach(function (it) {
          html += '<div style="display:flex;align-items:center;gap:12px">';
          html +=
            '<div style="width:12px;height:12px;border-radius:3px;background:' +
            it.color +
            ';flex-shrink:0"></div>';
          html += '<div style="flex:1">';
          html +=
            '<div style="display:flex;justify-content:space-between;margin-bottom:4px">';
          html +=
            '<span style="font-size:13px;font-weight:500">' +
            it.label +
            "</span>";
          html +=
            '<span style="font-size:12px;color:#94a3b8">' +
            formatNumber(it.count) +
            " (" +
            it.pct +
            "%)</span>";
          html += "</div>";
          html +=
            '<div class="progress-bar"><div class="progress-fill" style="width:' +
            it.pct +
            "%;background:" +
            it.color +
            '"></div></div>';
          html += "</div></div>";
        });
        html += "</div>";

        var convRate =
          total > 0
            ? (
                ((Number(d.proSubscriptions || 0) +
                  Number(d.premiumSubscriptions || 0)) /
                  total) *
                100
              ).toFixed(1)
            : "0.0";
        html +=
          '<div style="margin-top:20px;padding-top:16px;border-top:1px solid rgba(148,163,184,0.12);display:flex;justify-content:space-between;font-size:13px">';
        html += '<span style="color:#94a3b8">付费转化率</span>';
        html +=
          '<span style="font-weight:600;color:#10b981">' +
          convRate +
          "%</span>";
        html += "</div>";

        el.innerHTML = html;
      }

      function renderTickets(tickets) {
        var tbody = document.getElementById("ticketsBody");
        if (!tickets || !tickets.length) {
          tbody.innerHTML =
            '<tr><td colspan="5" class="admin-empty"><strong>暂无工单</strong><small>最新用户支持请求会显示在这里。</small></td></tr>';
          return;
        }
        var statusMap = {
          open: { label: "待处理", cls: "badge-amber" },
          pending: { label: "处理中", cls: "badge-blue" },
          resolved: { label: "已解决", cls: "badge-green" },
          closed: { label: "已关闭", cls: "badge-gray" },
        };
        var topicLabels = {
          billing: "账单",
          tryon: "试妆",
          diagnosis: "诊断",
          account: "账户",
          cooperation: "合作",
          other: "其他",
        };
        var html = "";
        tickets.forEach(function (t) {
          var s = statusMap[t.status] || statusMap.open;
          var topicLabel = topicLabels[t.topic] || t.topic;
          var timeAgo = getTimeAgo(t.created_at);
          html += "<tr>";
          html +=
            '<td><span class="admin-code">' +
            escapeHtml(t.ticket_code) +
            "</span></td>";
          html +=
            "<td>" +
            escapeHtml(t.name) +
            '<br><span style="font-size:11px;color:var(--admin-text-dim)">' +
            escapeHtml(t.email) +
            "</span></td>";
          html += "<td>" + escapeHtml(topicLabel) + "</td>";
          html +=
            '<td><span class="badge ' +
            s.cls +
            '"><span class="badge-dot"></span>' +
            s.label +
            "</span></td>";
          html +=
            '<td style="color:var(--admin-text-muted);font-size:12px">' +
            timeAgo +
            "</td>";
          html += "</tr>";
        });
        tbody.innerHTML = html;
      }

      function getTimeAgo(isoStr) {
        var d = new Date(isoStr);
        var now = new Date();
        var diff = (now - d) / 1000;
        if (diff < 60) return "刚刚";
        if (diff < 3600) return Math.floor(diff / 60) + " 分钟前";
        if (diff < 86400) return Math.floor(diff / 3600) + " 小时前";
        if (diff < 604800) return Math.floor(diff / 86400) + " 天前";
        return d.toLocaleDateString("zh-CN");
      }

      function escapeHtml(s) {
        var div = document.createElement("div");
        div.appendChild(document.createTextNode(s || ""));
        return div.innerHTML;
      }
    })();
  </script>
</AdminLayout>
