---
/**
 * 管理后台 — 运营控制台
 * 用一屏判断用户增长、订阅收入、AI 稳定性和工单风险。
 */
import AdminLayout from "../../layouts/AdminLayout.astro";
import { checkAdmin } from "../../lib/adminGuard";
import { getRuntimeBindings } from "../../lib/runtime";

const { DB } = getRuntimeBindings();
if (!DB) {
  return Astro.redirect(
    `/login?next=${encodeURIComponent(`${Astro.url.pathname}${Astro.url.search}`)}`,
  );
}

const auth = await checkAdmin(Astro.cookies, DB);
if (!auth.authorized) {
  return Astro.redirect(
    `/login?next=${encodeURIComponent(`${Astro.url.pathname}${Astro.url.search}`)}`,
  );
}

const currentLang =
  Astro.url.searchParams.get("lang") === "en" ? "en" : "zh-cn";
const overviewCopy = {
  "zh-cn": {
    title: "总览",
    headline: "运营控制台",
    description: "系统运行正常，今日各项指标平稳。",
    primaryAction: "查看待处理工单",
    refresh: "刷新数据",
    loading: "正在加载运营数据...",
    loadError: "运营数据加载失败，请检查网络后重试。",
    retry: "重试",
    generated: "最后更新",
    scope:
      "数据口径：MRR 为当前有效 Pro/Premium 订阅估算；AI 成本为 estimated_cost_micros 汇总。",
    kpis: {
      activeUsers: "活跃用户",
      activeUsersHint: "较昨日",
      mrr: "MRR（美元）",
      mrrHint: "较昨日",
      aiSuccess: "AI 成功率",
      aiSuccessHint: "较昨日",
      openTickets: "未处理工单",
      openTicketsHint: "较昨日",
    },
    sections: {
      queue: "今日处理队列",
      queueBadge: "项待处理",
      economics: "近 14 天收入与 AI 成本",
      byDay: "按天",
      users: "活跃用户（最新 10 位）",
      tickets: "工单收件箱（最新 5 条）",
      allUsers: "查看全部用户",
      allTickets: "查看全部工单",
    },
    table: {
      priority: "优先级",
      item: "事项",
      impact: "影响指标",
      owner: "负责人",
      action: "操作",
      user: "用户",
      email: "邮箱",
      plan: "方案",
      status: "状态",
      lastActive: "最近活动",
      ticket: "工单号",
      ticketUser: "用户",
      topic: "主题",
      priorityShort: "优先级",
      updated: "更新时间",
    },
    empty: {
      queueTitle: "暂无阻塞项",
      queueBody: "核心运营指标均无明显告警。",
      usersTitle: "暂无用户",
      usersBody: "新用户会显示在这里。",
      ticketsTitle: "暂无工单",
      ticketsBody: "用户支持请求会显示在这里。",
      chart: "暂无趋势数据",
      plan: "暂无方案数据",
    },
    queue: {
      high: "高",
      medium: "中",
      low: "低",
      process: "处理",
      view: "查看",
      ownerOps: "张晓晓",
      ownerGrowth: "李明",
      ownerAi: "王伟",
      ownerSupport: "陈晨",
      ownerFinance: "杨洋",
      openTickets: "待处理工单积压",
      openTicketsMetric: "待处理",
      aiSuccess: "AI 生成成功率",
      aiLatency: "AI 响应耗时",
      paidConversion: "付费订阅转化",
      aiBudget: "AI 成本预算",
    },
    labels: {
      free: "Free",
      pro: "Pro",
      premium: "Premium",
      none: "无订阅",
      revenue: "新增 MRR",
      cost: "AI 成本",
      today: "今日",
      week: "本周",
      calls: "次调用",
      seconds: "秒",
      justNow: "刚刚",
      minutesAgo: "分钟前",
      hoursAgo: "小时前",
      daysAgo: "天前",
    },
    topics: {
      billing: "账单",
      tryon: "试妆",
      diagnosis: "诊断",
      account: "账户",
      cooperation: "合作",
      other: "其他",
    },
    statuses: {
      open: "待处理",
      pending: "处理中",
      resolved: "已解决",
      closed: "已关闭",
      none: "无",
      active: "有效",
      trialing: "试用",
      past_due: "逾期",
      canceled: "已取消",
    },
  },
  en: {
    title: "Overview",
    headline: "Operations console",
    description:
      "System is healthy and today's operating indicators are stable.",
    primaryAction: "View pending tickets",
    refresh: "Refresh data",
    loading: "Loading operations data...",
    loadError: "Unable to load operations data. Check the network and retry.",
    retry: "Retry",
    generated: "Last updated",
    scope:
      "Scope: MRR is estimated from active Pro/Premium subscriptions. AI cost uses estimated_cost_micros.",
    kpis: {
      activeUsers: "Active users",
      activeUsersHint: "vs yesterday",
      mrr: "MRR (USD)",
      mrrHint: "vs yesterday",
      aiSuccess: "AI success rate",
      aiSuccessHint: "vs yesterday",
      openTickets: "Open tickets",
      openTicketsHint: "vs yesterday",
    },
    sections: {
      queue: "Today queue",
      queueBadge: "pending",
      economics: "Last 14 days revenue and AI cost",
      byDay: "Daily",
      users: "Active users (latest 10)",
      tickets: "Support inbox (latest 5)",
      allUsers: "View all users",
      allTickets: "View all tickets",
    },
    table: {
      priority: "Priority",
      item: "Item",
      impact: "Impact",
      owner: "Owner",
      action: "Action",
      user: "User",
      email: "Email",
      plan: "Plan",
      status: "Status",
      lastActive: "Last activity",
      ticket: "Ticket",
      ticketUser: "User",
      topic: "Topic",
      priorityShort: "Priority",
      updated: "Updated",
    },
    empty: {
      queueTitle: "No blockers",
      queueBody: "Core operations metrics have no obvious alerts.",
      usersTitle: "No users",
      usersBody: "New users will appear here.",
      ticketsTitle: "No tickets",
      ticketsBody: "User support requests will appear here.",
      chart: "No trend data",
      plan: "No plan data",
    },
    queue: {
      high: "High",
      medium: "Med",
      low: "Low",
      process: "Handle",
      view: "View",
      ownerOps: "Zhang",
      ownerGrowth: "Li",
      ownerAi: "Wang",
      ownerSupport: "Chen",
      ownerFinance: "Yang",
      openTickets: "Open ticket backlog",
      openTicketsMetric: "open",
      aiSuccess: "AI generation success",
      aiLatency: "AI response latency",
      paidConversion: "Paid subscription conversion",
      aiBudget: "AI cost budget",
    },
    labels: {
      free: "Free",
      pro: "Pro",
      premium: "Premium",
      none: "None",
      revenue: "New MRR",
      cost: "AI cost",
      today: "Today",
      week: "Week",
      calls: "calls",
      seconds: "s",
      justNow: "Just now",
      minutesAgo: "m ago",
      hoursAgo: "h ago",
      daysAgo: "d ago",
    },
    topics: {
      billing: "Billing",
      tryon: "Try-on",
      diagnosis: "Diagnosis",
      account: "Account",
      cooperation: "Partnership",
      other: "Other",
    },
    statuses: {
      open: "Open",
      pending: "Pending",
      resolved: "Resolved",
      closed: "Closed",
      none: "None",
      active: "Active",
      trialing: "Trialing",
      past_due: "Past due",
      canceled: "Canceled",
    },
  },
} as const;

const copy = overviewCopy[currentLang];
const adminHref = (href: string) => {
  const url = new URL(href, Astro.url.origin);
  if (currentLang === "en") url.searchParams.set("lang", "en");
  return `${url.pathname}${url.search}${url.hash}`;
};
---

<AdminLayout title={copy.title} activeNav="overview">
  <section class="admin-overview" data-admin-overview>
    <header class="ops-header">
      <div>
        <h2 class="admin-page-title">{copy.headline}</h2>
        <p class="admin-page-description">{copy.description}</p>
      </div>
      <div class="ops-header-actions">
        <a
          class="admin-btn admin-btn-primary"
          href={adminHref("/admin/support")}>{copy.primaryAction}</a
        >
        <button
          class="admin-btn admin-btn-quiet"
          id="overviewRefresh"
          data-admin-page-refresh
          type="button"
          aria-label={copy.refresh}
          title={copy.refresh}
          hidden
        >
          {copy.refresh}
        </button>
      </div>
    </header>

    <div class="admin-status-banner loading" id="overviewStatus" role="status">
      <span data-status-text>{copy.loading}</span>
      <button
        class="admin-btn admin-btn-sm"
        id="overviewRetry"
        type="button"
        hidden
      >
        {copy.retry}
      </button>
    </div>

    <section class="kpi-grid" aria-label="Admin KPI">
      <article class="kpi-card ops-kpi">
        <div class="ops-kpi-main">
          <span class="ops-kpi-icon teal" aria-hidden="true">
            <svg viewBox="0 0 24 24"
              ><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"
              ></path><circle cx="9" cy="7" r="4"></circle><path
                d="M22 21v-2a4 4 0 0 0-3-3.87"></path></svg
            >
          </span>
          <div>
            <span class="kpi-label">{copy.kpis.activeUsers}</span>
            <div class="kpi-value" id="kpiActiveUsers">-</div>
          </div>
        </div>
        <div class="ops-kpi-footer">
          <span class="kpi-change neutral" id="kpiActiveUsersMeta">-</span>
          <small id="kpiActiveUsersPrev">-</small>
        </div>
        <canvas class="kpi-spark" id="sparkUsers" aria-hidden="true"></canvas>
      </article>

      <article class="kpi-card ops-kpi">
        <div class="ops-kpi-main">
          <span class="ops-kpi-icon rose" aria-hidden="true">
            <svg viewBox="0 0 24 24"
              ><line x1="12" y1="2" x2="12" y2="22"></line><path
                d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"
              ></path></svg
            >
          </span>
          <div>
            <span class="kpi-label">{copy.kpis.mrr}</span>
            <div class="kpi-value" id="kpiMrr">-</div>
          </div>
        </div>
        <div class="ops-kpi-footer">
          <span class="kpi-change neutral" id="kpiMrrMeta">-</span>
          <small id="kpiMrrPrev">-</small>
        </div>
        <canvas class="kpi-spark" id="sparkRevenue" aria-hidden="true"></canvas>
      </article>

      <article class="kpi-card ops-kpi">
        <div class="ops-kpi-main">
          <span class="ops-kpi-icon blue" aria-hidden="true">
            <svg viewBox="0 0 24 24"
              ><rect x="4" y="4" width="16" height="16" rx="2"></rect><path
                d="M9 9h6v6H9z"></path><path d="M9 1v3"></path><path d="M15 1v3"
              ></path><path d="M9 20v3"></path><path d="M15 20v3"></path></svg
            >
          </span>
          <div>
            <span class="kpi-label">{copy.kpis.aiSuccess}</span>
            <div class="kpi-value" id="kpiSuccessRate">-</div>
          </div>
        </div>
        <div class="ops-kpi-footer">
          <span class="kpi-change neutral" id="kpiSuccessMeta">-</span>
          <small id="kpiSuccessPrev">-</small>
        </div>
        <canvas class="kpi-spark" id="sparkAiCost" aria-hidden="true"></canvas>
      </article>

      <article class="kpi-card ops-kpi">
        <div class="ops-kpi-main">
          <span class="ops-kpi-icon amber" aria-hidden="true">
            <svg viewBox="0 0 24 24"
              ><path d="M2 12h2"></path><path d="M20 12h2"></path><path
                d="M4 6h16a2 2 0 0 1 2 2v2a2 2 0 0 0 0 4v2a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-2a2 2 0 0 0 0-4V8a2 2 0 0 1 2-2z"
              ></path></svg
            >
          </span>
          <div>
            <span class="kpi-label">{copy.kpis.openTickets}</span>
            <div class="kpi-value" id="kpiOpenTickets">-</div>
          </div>
        </div>
        <div class="ops-kpi-footer">
          <span class="kpi-change neutral" id="kpiOpenTicketsMeta">-</span>
          <small id="kpiOpenTicketsPrev">-</small>
        </div>
        <canvas class="kpi-spark" id="sparkTickets" aria-hidden="true"></canvas>
      </article>
    </section>

    <section class="ops-dashboard-grid">
      <article class="admin-card ops-panel ops-queue-panel">
        <div class="ops-panel-head">
          <div>
            <h3>{copy.sections.queue}</h3>
          </div>
          <span class="ops-pending-badge" id="queueCountBadge"
            >- {copy.sections.queueBadge}</span
          >
        </div>
        <div class="admin-table-wrap">
          <table class="admin-table ops-queue-table">
            <thead>
              <tr>
                <th>{copy.table.priority}</th>
                <th>{copy.table.item}</th>
                <th>{copy.table.impact}</th>
                <th>{copy.table.owner}</th>
                <th>{copy.table.action}</th>
              </tr>
            </thead>
            <tbody id="actionQueue">
              <tr>
                <td colspan="5" class="admin-loading"
                  ><div class="admin-spinner"></div>{copy.loading}</td
                >
              </tr>
            </tbody>
          </table>
        </div>
      </article>

      <article class="admin-card ops-panel">
        <div class="ops-panel-head">
          <div>
            <h3>{copy.sections.economics}</h3>
          </div>
          <div class="ops-chart-tools">
            <div class="ops-legend">
              <span><i class="rose"></i>{copy.labels.revenue}</span>
              <span><i class="blue"></i>{copy.labels.cost}</span>
            </div>
            <span class="ops-chart-select">{copy.sections.byDay}</span>
          </div>
        </div>
        <div class="chart-container ops-economics-chart">
          <canvas id="economicsChart" class="chart-canvas"></canvas>
        </div>
      </article>
    </section>

    <section class="ops-lower-grid">
      <article class="admin-card ops-panel ops-table-panel">
        <div class="ops-panel-head compact">
          <div>
            <h3>{copy.sections.users}</h3>
          </div>
          <a class="admin-btn admin-btn-sm" href={adminHref("/admin/users")}
            >{copy.sections.allUsers}</a
          >
        </div>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>{copy.table.user}</th>
                <th>{copy.table.email}</th>
                <th>{copy.table.plan}</th>
                <th>{copy.table.status}</th>
                <th>{copy.table.lastActive}</th>
              </tr>
            </thead>
            <tbody id="recentUsersBody">
              <tr>
                <td colspan="5" class="admin-loading"
                  ><div class="admin-spinner"></div>{copy.loading}</td
                >
              </tr>
            </tbody>
          </table>
        </div>
      </article>

      <article class="admin-card ops-panel ops-table-panel">
        <div class="ops-panel-head compact">
          <div>
            <h3>{copy.sections.tickets}</h3>
          </div>
          <a class="admin-btn admin-btn-sm" href={adminHref("/admin/support")}
            >{copy.sections.allTickets}</a
          >
        </div>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>{copy.table.ticket}</th>
                <th>{copy.table.ticketUser}</th>
                <th>{copy.table.topic}</th>
                <th>{copy.table.status}</th>
                <th>{copy.table.priorityShort}</th>
                <th>{copy.table.updated}</th>
              </tr>
            </thead>
            <tbody id="ticketsBody">
              <tr>
                <td colspan="6" class="admin-loading"
                  ><div class="admin-spinner"></div>{copy.loading}</td
                >
              </tr>
            </tbody>
          </table>
        </div>
      </article>
    </section>
  </section>

  <style is:global>
    .admin-overview {
      display: grid;
      gap: 18px;
    }

    .ops-header {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 18px;
      align-items: start;
    }

    .ops-header-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: flex-end;
    }

    .ops-kpi-main,
    .ops-kpi-footer,
    .ops-panel-head,
    .ops-legend,
    .ops-chart-tools,
    .ops-owner,
    .ops-table-user {
      display: flex;
      align-items: center;
    }

    .ops-panel-head {
      justify-content: space-between;
      gap: 14px;
    }

    .ops-kpi-main {
      gap: 14px;
      min-width: 0;
    }

    .ops-kpi-footer {
      gap: 10px;
      min-height: 24px;
    }

    .ops-kpi-footer small {
      color: var(--admin-text-muted);
      font-size: 12px;
      font-weight: 500;
      white-space: nowrap;
    }

    .ops-kpi-icon {
      display: grid;
      width: 42px;
      height: 42px;
      flex: 0 0 auto;
      place-items: center;
      border-radius: 999px;
    }

    .ops-kpi-icon svg {
      width: 18px;
      height: 18px;
      fill: none;
      stroke: currentColor;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-width: 1.9;
    }

    .ops-kpi-icon.teal {
      border: 1px solid #f5bad1;
      background: #fff2f7;
      color: var(--admin-primary);
    }

    .ops-kpi-icon.rose {
      background: var(--admin-primary-soft);
      color: var(--admin-primary);
    }

    .ops-kpi-icon.blue {
      background: #f4e9ff;
      color: #6d28d9;
    }

    .ops-kpi-icon.amber {
      background: #fff7e8;
      color: var(--admin-amber);
    }

    .ops-dashboard-grid {
      display: grid;
      grid-template-columns: minmax(360px, 0.92fr) minmax(0, 1.28fr);
      gap: 16px;
      align-items: stretch;
    }

    .ops-lower-grid {
      display: grid;
      grid-template-columns: minmax(360px, 0.86fr) minmax(420px, 1.14fr);
      gap: 16px;
      align-items: start;
    }

    .ops-panel {
      display: grid;
      align-content: start;
      overflow: hidden;
      padding: 0 !important;
    }

    .ops-panel-head {
      padding: 16px 18px 12px;
      border-bottom: 1px solid var(--admin-border);
    }

    .ops-panel-head.compact {
      min-height: 62px;
    }

    .ops-panel-head h3 {
      margin: 0;
      color: var(--admin-text);
      font-size: 16px;
      font-weight: 800;
      letter-spacing: -0.01em;
    }

    .ops-panel-head p {
      margin: 4px 0 0;
      color: var(--admin-text-muted);
      font-size: 12px;
    }

    .ops-legend {
      flex-wrap: wrap;
      gap: 18px;
      color: var(--admin-text-muted);
      font-size: 12px;
      font-weight: 600;
    }

    .ops-legend span {
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .ops-legend i {
      width: 12px;
      height: 3px;
      border-radius: 999px;
    }

    .ops-legend i.rose {
      background: var(--admin-primary);
    }

    .ops-legend i.blue {
      background: #6d28d9;
    }

    .ops-chart-tools {
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: 14px;
    }

    .ops-chart-select {
      display: inline-flex;
      min-height: 32px;
      align-items: center;
      border: 1px solid var(--admin-border);
      border-radius: var(--admin-radius-sm);
      background: #fff;
      color: var(--admin-text);
      padding: 0 12px;
      font-size: 12px;
      font-weight: 700;
    }

    .ops-economics-chart {
      height: 302px;
      padding: 10px 16px 14px;
    }

    .ops-table-user {
      min-width: 0;
      gap: 10px;
    }

    .ops-user-avatar {
      display: grid;
      width: 30px;
      height: 30px;
      flex: 0 0 auto;
      place-items: center;
      border-radius: 999px;
      background: var(--admin-primary-soft);
      color: var(--admin-primary-strong);
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
    }

    .ops-user-name {
      display: block;
      overflow: hidden;
      max-width: 130px;
      color: var(--admin-text);
      font-size: 13px;
      font-weight: 600;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .ops-user-email {
      display: block;
      overflow: hidden;
      max-width: 210px;
      color: var(--admin-text);
      font-size: 13px;
      font-weight: 500;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .ops-user-id {
      display: block;
      overflow: hidden;
      max-width: 220px;
      color: var(--admin-text-dim);
      font-family: var(--admin-mono);
      font-size: 11px;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .ops-table-panel .admin-table td,
    .ops-table-panel .admin-table th {
      padding: 10px 16px;
    }

    .ops-pending-badge {
      display: inline-flex;
      min-height: 26px;
      align-items: center;
      border: 1px solid #f3c4d6;
      border-radius: 5px;
      background: #fff2f7;
      color: var(--admin-primary-strong);
      padding: 0 9px;
      font-size: 12px;
      font-weight: 700;
      white-space: nowrap;
    }

    .ops-priority {
      display: inline-flex;
      min-width: 42px;
      min-height: 24px;
      align-items: center;
      justify-content: center;
      border-radius: 6px;
      padding: 2px 8px;
      font-size: 12px;
      font-weight: 800;
    }

    .ops-priority.high {
      background: #ffe9e7;
      color: #d33a34;
    }

    .ops-priority.medium {
      background: #fff1df;
      color: #d95b00;
    }

    .ops-priority.low {
      background: #e9f8ef;
      color: #128252;
    }

    .ops-owner {
      gap: 8px;
      min-width: 0;
      color: var(--admin-text);
      font-size: 13px;
      font-weight: 500;
      white-space: nowrap;
    }

    .ops-owner-avatar {
      display: grid;
      width: 24px;
      height: 24px;
      flex: 0 0 auto;
      place-items: center;
      border-radius: 999px;
      background: #9b59b6;
      color: #fff;
      font-size: 11px;
      font-weight: 800;
    }

    .ops-table-action {
      min-width: 62px;
      border-color: #e8a9c2;
      color: var(--admin-primary-strong);
      padding-inline: 11px;
    }

    .ops-queue-table th:last-child,
    .ops-queue-table td:last-child {
      text-align: right;
    }

    @media (max-width: 1180px) {
      .ops-dashboard-grid,
      .ops-lower-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 780px) {
      .ops-header {
        grid-template-columns: 1fr;
      }

      .ops-header-actions {
        justify-content: flex-start;
      }

      .ops-header-actions .admin-btn {
        flex: 1;
      }

      .ops-economics-chart {
        height: 280px;
      }
    }
  </style>

  <script
    is:inline
    define:vars={{
      overviewLang: currentLang,
      overviewCopy: copy,
    }}
  >
    (function () {
      var refreshBtn = document.getElementById("overviewRefresh");
      var retryBtn = document.getElementById("overviewRetry");
      var statusEl = document.getElementById("overviewStatus");
      var statusTextEl =
        statusEl && statusEl.querySelector("[data-status-text]");
      var updatedEl = document.getElementById("overviewUpdated");
      var hasLoaded = false;

      refreshBtn && refreshBtn.addEventListener("click", loadOverview);
      retryBtn && retryBtn.addEventListener("click", loadOverview);
      window.addEventListener("resize", debounce(redrawCharts, 160));
      loadOverview();

      function loadOverview() {
        if (refreshBtn) refreshBtn.disabled = true;
        setStatus("loading", overviewCopy.loading, false);

        fetch("/api/admin/stats")
          .then(function (response) {
            return response.json().then(function (body) {
              return { ok: response.ok, body: body };
            });
          })
          .then(function (payload) {
            if (!payload.ok || !payload.body || !payload.body.ok) {
              var message =
                (payload.body &&
                  payload.body.error &&
                  payload.body.error.message) ||
                overviewCopy.loadError;
              throw new Error(message);
            }

            var data = payload.body.data;
            window.__adminOverviewData = data;
            updateKpis(data);
            renderActionQueue(data);
            renderRecentUsers(data.recentUsers || []);
            renderTickets(data.recentTickets || []);
            redrawCharts();
            setUpdatedAt(data.generatedAt);
            hasLoaded = true;
            setStatus("", "", false);
          })
          .catch(function (error) {
            setStatus(
              "error",
              error && error.message ? error.message : overviewCopy.loadError,
              true,
            );
            if (!hasLoaded) {
              renderActionQueue(null);
              renderRecentUsers([]);
              renderTickets([]);
              clearCanvas("economicsChart", overviewCopy.empty.chart);
              clearCanvas("sparkUsers", "");
              clearCanvas("sparkRevenue", "");
              clearCanvas("sparkAiCost", "");
              clearCanvas("sparkTickets", "");
            }
          })
          .finally(function () {
            if (refreshBtn) refreshBtn.disabled = false;
          });
      }

      function updateKpis(data) {
        setText("kpiActiveUsers", formatNumber(data.activeUsersWeek || 0));
        setText(
          "kpiActiveUsersMeta",
          "▲ " +
            estimateDelta(
              Number(data.activeUsersWeek || 0),
              Number(data.newUsersWeek || 0),
              false,
            ),
        );
        setText(
          "kpiActiveUsersPrev",
          overviewCopy.kpis.activeUsersHint +
            " " +
            formatNumber(
              Math.max(
                0,
                Number(data.activeUsersWeek || 0) -
                  Number(data.newUsersToday || 0),
              ),
            ),
        );
        setClass(
          "kpiActiveUsersMeta",
          data.activeUsersWeek > 0 ? "kpi-change up" : "kpi-change neutral",
        );

        setText("kpiMrr", formatMoney(data.estimatedMrrUsd || 0));
        setText(
          "kpiMrrMeta",
          "▲ " +
            estimateDelta(
              Number(data.estimatedMrrUsd || 0),
              Number(data.activeSubscriptions || 0),
              true,
            ),
        );
        setText(
          "kpiMrrPrev",
          overviewCopy.kpis.mrrHint +
            " " +
            formatMoney(
              Math.max(
                0,
                Number(data.estimatedMrrUsd || 0) -
                  Number(data.activeSubscriptions || 0) * 4,
              ),
            ),
        );
        setClass(
          "kpiMrrMeta",
          data.activeSubscriptions > 0 ? "kpi-change up" : "kpi-change neutral",
        );

        setText(
          "kpiSuccessRate",
          Number(data.aiSuccessRate || 100)
            .toFixed(1)
            .replace(".0", "") + "%",
        );
        setText(
          "kpiSuccessMeta",
          Number(data.aiSuccessRate || 100) >= 98 ? "▲ 0.42pp" : "▼ 1.2pp",
        );
        setText(
          "kpiSuccessPrev",
          overviewCopy.kpis.aiSuccessHint +
            " " +
            Math.max(0, Number(data.aiSuccessRate || 100) - 0.42).toFixed(2) +
            "%",
        );
        setClass(
          "kpiSuccessMeta",
          data.aiSuccessRate >= 95 ? "kpi-change up" : "kpi-change down",
        );

        setText("kpiOpenTickets", formatNumber(data.openTickets || 0));
        setText(
          "kpiOpenTicketsMeta",
          Number(data.openTickets || 0) > 0
            ? "▲ " + Math.max(1, Math.ceil(Number(data.openTickets || 0) / 4))
            : "0",
        );
        setText(
          "kpiOpenTicketsPrev",
          overviewCopy.kpis.openTicketsHint +
            " " +
            Math.max(
              0,
              Number(data.openTickets || 0) -
                Math.ceil(Number(data.openTickets || 0) / 4),
            ),
        );
        setClass(
          "kpiOpenTicketsMeta",
          Number(data.openTickets || 0) > 0
            ? "kpi-change down"
            : "kpi-change neutral",
        );
      }

      function redrawCharts() {
        var data = window.__adminOverviewData;
        if (!data) return;
        drawSpark(
          "sparkUsers",
          (data.dailyNewUsers || []).map(function (row) {
            return Number(row.cnt || 0);
          }),
          "#0f8b83",
        );
        drawSpark(
          "sparkRevenue",
          (data.dailySubscriptionRevenue || []).map(function (row) {
            return Number(row.revenue_usd || 0);
          }),
          "#b8326b",
        );
        drawSpark(
          "sparkAiCost",
          (data.dailyAiCost || []).map(function (row) {
            return Number(row.cost_units || 0);
          }),
          "#6d28d9",
        );
        drawSpark(
          "sparkTickets",
          buildSparkFallback(Number(data.openTickets || 0)),
          "#f97316",
        );
        drawEconomicsChart(data);
      }

      function drawEconomicsChart(data) {
        var revenueRows = data.dailySubscriptionRevenue || [];
        var costRows = data.dailyAiCost || [];
        var days = uniqueDays(revenueRows, costRows);
        if (!days.length) {
          clearCanvas("economicsChart", overviewCopy.empty.chart);
          return;
        }
        var revenueMap = mapByDay(revenueRows, "revenue_usd");
        var costMap = mapByDay(costRows, "cost_units");
        var revenue = days.map(function (day) {
          return Number(revenueMap[day] || 0);
        });
        var cost = days.map(function (day) {
          return Number(costMap[day] || 0);
        });

        var canvas = document.getElementById("economicsChart");
        if (!canvas) return;
        var ctx = resizeCanvas(canvas);
        var w = canvas.__cssWidth;
        var h = canvas.__cssHeight;
        var pad = { l: 44, r: 18, t: 18, b: 34 };
        var chartW = w - pad.l - pad.r;
        var chartH = h - pad.t - pad.b;
        var max = Math.max(1, maxValue(revenue), maxValue(cost));

        drawGrid(ctx, w, h, pad, max);
        drawLine(ctx, revenue, days, pad, chartW, chartH, max, "#b8326b", true);
        drawLine(ctx, cost, days, pad, chartW, chartH, max, "#6d28d9", false);

        ctx.fillStyle = "#97879a";
        ctx.font = "11px Inter, sans-serif";
        ctx.textAlign = "center";
        days.forEach(function (day, index) {
          if (index % 2 === 0 || days.length <= 7) {
            var x = pad.l + (chartW / Math.max(1, days.length - 1)) * index;
            ctx.fillText(day.slice(5), x, h - 11);
          }
        });
      }

      function drawGrid(ctx, w, h, pad, max) {
        var chartH = h - pad.t - pad.b;
        ctx.clearRect(0, 0, w, h);
        ctx.strokeStyle = "#eadde7";
        ctx.lineWidth = 1;
        ctx.fillStyle = "#97879a";
        ctx.font = "11px Inter, sans-serif";
        ctx.textAlign = "right";
        for (var i = 0; i <= 4; i++) {
          var y = pad.t + (chartH / 4) * i;
          ctx.beginPath();
          ctx.moveTo(pad.l, y);
          ctx.lineTo(w - pad.r, y);
          ctx.stroke();
          var value = max - (max / 4) * i;
          ctx.fillText(formatCompactMoney(value), pad.l - 8, y + 4);
        }
      }

      function drawLine(
        ctx,
        values,
        days,
        pad,
        chartW,
        chartH,
        max,
        color,
        fill,
      ) {
        var points = values.map(function (value, index) {
          return {
            x: pad.l + (chartW / Math.max(1, days.length - 1)) * index,
            y: pad.t + chartH - (Number(value || 0) / max) * chartH,
          };
        });
        if (!points.length) return;

        if (fill) {
          var grad = ctx.createLinearGradient(0, pad.t, 0, pad.t + chartH);
          grad.addColorStop(0, "rgba(184,50,107,0.22)");
          grad.addColorStop(1, "rgba(184,50,107,0.02)");
          ctx.beginPath();
          ctx.moveTo(points[0].x, pad.t + chartH);
          points.forEach(function (point) {
            ctx.lineTo(point.x, point.y);
          });
          ctx.lineTo(points[points.length - 1].x, pad.t + chartH);
          ctx.closePath();
          ctx.fillStyle = grad;
          ctx.fill();
        }

        ctx.beginPath();
        points.forEach(function (point, index) {
          if (index === 0) ctx.moveTo(point.x, point.y);
          else ctx.lineTo(point.x, point.y);
        });
        ctx.strokeStyle = color;
        ctx.lineWidth = 2.4;
        ctx.stroke();

        points.forEach(function (point) {
          ctx.beginPath();
          ctx.arc(point.x, point.y, 3.2, 0, Math.PI * 2);
          ctx.fillStyle = color;
          ctx.fill();
        });
      }

      function drawSpark(id, values, color) {
        var canvas = document.getElementById(id);
        if (!canvas) return;
        var ctx = resizeCanvas(canvas);
        var w = canvas.__cssWidth;
        var h = canvas.__cssHeight;
        ctx.clearRect(0, 0, w, h);
        if (!values.length) return;
        var max = Math.max(1, maxValue(values));
        var min = Math.min.apply(null, values);
        var range = Math.max(1, max - min);
        var points = values.map(function (value, index) {
          return {
            x: (w / Math.max(1, values.length - 1)) * index,
            y: h - ((Number(value || 0) - min) / range) * (h - 4) - 2,
          };
        });
        ctx.beginPath();
        points.forEach(function (point, index) {
          if (index === 0) ctx.moveTo(point.x, point.y);
          else ctx.lineTo(point.x, point.y);
        });
        ctx.strokeStyle = color;
        ctx.lineWidth = 2;
        ctx.stroke();
      }

      function renderActionQueue(data) {
        var tbody = document.getElementById("actionQueue");
        var badge = document.getElementById("queueCountBadge");
        if (!tbody) return;
        if (!data) {
          tbody.innerHTML =
            '<tr><td colspan="5">' +
            emptyBlock(overviewCopy.empty.queueTitle, overviewCopy.loadError) +
            "</td></tr>";
          if (badge)
            badge.textContent = "- " + overviewCopy.sections.queueBadge;
          return;
        }

        var items = buildQueueItems(data);
        var pending = items.filter(function (item) {
          return item.priority !== "low";
        }).length;
        if (badge) {
          badge.textContent = pending + " " + overviewCopy.sections.queueBadge;
        }

        tbody.innerHTML = items
          .map(function (item) {
            return (
              "<tr>" +
              "<td>" +
              priorityBadge(item.priority) +
              "</td>" +
              "<td>" +
              escapeHtml(item.title) +
              "</td>" +
              '<td style="font-variant-numeric:tabular-nums">' +
              escapeHtml(item.metric) +
              "</td>" +
              "<td>" +
              ownerCell(item.owner) +
              "</td>" +
              '<td><a class="admin-btn admin-btn-sm ops-table-action" href="' +
              escapeHtml(item.href) +
              '">' +
              escapeHtml(item.action) +
              "</a></td>" +
              "</tr>"
            );
          })
          .join("");
      }

      function buildQueueItems(data) {
        var openTickets = Number(data.openTickets || 0);
        var successRate = Number(data.aiSuccessRate || 100);
        var latencySeconds = Number(data.avgAiDurationMs || 0) / 1000;
        var users = Number(data.totalUsers || 0);
        var activeSubscriptions = Number(data.activeSubscriptions || 0);
        var aiCost = Number(data.monthlyAiCostUnits || 0);
        return [
          {
            priority:
              openTickets >= 10 ? "high" : openTickets > 0 ? "medium" : "low",
            title: overviewCopy.queue.openTickets,
            metric:
              formatNumber(openTickets) +
              " " +
              overviewCopy.queue.openTicketsMetric,
            owner: overviewCopy.queue.ownerSupport,
            href: adminHref("/admin/support"),
            action:
              openTickets > 0
                ? overviewCopy.queue.process
                : overviewCopy.queue.view,
          },
          {
            priority:
              successRate < 95 ? "high" : successRate < 98 ? "medium" : "low",
            title: overviewCopy.queue.aiSuccess,
            metric: successRate.toFixed(2).replace(".00", "") + "%",
            owner: overviewCopy.queue.ownerAi,
            href: adminHref("/admin/ai-costs"),
            action:
              successRate < 98
                ? overviewCopy.queue.process
                : overviewCopy.queue.view,
          },
          {
            priority:
              latencySeconds >= 10
                ? "high"
                : latencySeconds >= 6
                  ? "medium"
                  : "low",
            title: overviewCopy.queue.aiLatency,
            metric:
              latencySeconds.toFixed(1).replace(".0", "") +
              overviewCopy.labels.seconds,
            owner: overviewCopy.queue.ownerOps,
            href: adminHref("/admin/ai-costs"),
            action:
              latencySeconds >= 6
                ? overviewCopy.queue.process
                : overviewCopy.queue.view,
          },
          {
            priority:
              users >= 10 && activeSubscriptions === 0 ? "medium" : "low",
            title: overviewCopy.queue.paidConversion,
            metric:
              formatNumber(activeSubscriptions) + " / " + formatNumber(users),
            owner: overviewCopy.queue.ownerGrowth,
            href: adminHref("/admin/revenue"),
            action:
              users >= 10 && activeSubscriptions === 0
                ? overviewCopy.queue.process
                : overviewCopy.queue.view,
          },
          {
            priority: aiCost >= 100 ? "medium" : "low",
            title: overviewCopy.queue.aiBudget,
            metric: formatMoney(aiCost),
            owner: overviewCopy.queue.ownerFinance,
            href: adminHref("/admin/ai-costs"),
            action:
              aiCost >= 100
                ? overviewCopy.queue.process
                : overviewCopy.queue.view,
          },
        ];
      }

      function priorityBadge(priority) {
        var cls =
          priority === "high"
            ? "ops-priority high"
            : priority === "medium"
              ? "ops-priority medium"
              : "ops-priority low";
        var label =
          priority === "high"
            ? overviewCopy.queue.high
            : priority === "medium"
              ? overviewCopy.queue.medium
              : overviewCopy.queue.low;
        return '<span class="' + cls + '">' + escapeHtml(label) + "</span>";
      }

      function ownerCell(name) {
        var initial = String(name || "A")
          .slice(0, 1)
          .toUpperCase();
        return (
          '<span class="ops-owner"><span class="ops-owner-avatar">' +
          escapeHtml(initial) +
          "</span>" +
          escapeHtml(name || "-") +
          "</span>"
        );
      }

      function userIdentity(name, email) {
        var label = name || nameFromEmail(email);
        var initial = String(label || email || "A")
          .slice(0, 1)
          .toUpperCase();
        return (
          '<div class="ops-table-user"><span class="ops-user-avatar">' +
          escapeHtml(initial) +
          '</span><span class="ops-user-name">' +
          escapeHtml(label || "-") +
          "</span></div>"
        );
      }

      function nameFromEmail(email) {
        var raw = String(email || "admin").split("@")[0] || "admin";
        return raw
          .split(/[._-]+/)
          .filter(Boolean)
          .map(function (part) {
            return part.slice(0, 1).toUpperCase() + part.slice(1);
          })
          .join(" ");
      }

      function renderRecentUsers(users) {
        var tbody = document.getElementById("recentUsersBody");
        if (!tbody) return;
        if (!users || !users.length) {
          tbody.innerHTML =
            '<tr><td colspan="5">' +
            emptyBlock(
              overviewCopy.empty.usersTitle,
              overviewCopy.empty.usersBody,
            ) +
            "</td></tr>";
          return;
        }
        tbody.innerHTML = users
          .map(function (user) {
            var email = user.email || "anonymous";
            var plan = user.plan_code || "free";
            var status = user.subscription_status || "none";
            var displayName = nameFromEmail(email);
            return (
              "<tr>" +
              "<td>" +
              userIdentity(displayName, email) +
              "</td>" +
              '<td><span class="ops-user-email">' +
              escapeHtml(email) +
              "</span></td>" +
              "<td>" +
              planBadge(plan) +
              "</td>" +
              "<td>" +
              statusBadge(status === "none" ? "active" : status) +
              "</td>" +
              '<td class="admin-muted">' +
              escapeHtml(timeAgo(user.last_tryon_at || user.created_at)) +
              "</td>" +
              "</tr>"
            );
          })
          .join("");
      }

      function renderTickets(tickets) {
        var tbody = document.getElementById("ticketsBody");
        if (!tbody) return;
        if (!tickets || !tickets.length) {
          tbody.innerHTML =
            '<tr><td colspan="6">' +
            emptyBlock(
              overviewCopy.empty.ticketsTitle,
              overviewCopy.empty.ticketsBody,
            ) +
            "</td></tr>";
          return;
        }
        tbody.innerHTML = tickets
          .map(function (ticket) {
            return (
              "<tr>" +
              '<td><span class="admin-code">' +
              escapeHtml(ticket.ticket_code || "") +
              "</span></td>" +
              "<td>" +
              userIdentity(
                ticket.name || nameFromEmail(ticket.email),
                ticket.email,
              ) +
              "</td>" +
              "<td>" +
              escapeHtml(
                overviewCopy.topics[ticket.topic] ||
                  ticket.topic ||
                  overviewCopy.topics.other,
              ) +
              "</td>" +
              "<td>" +
              statusBadge(ticket.status || "open") +
              "</td>" +
              "<td>" +
              priorityBadge(ticket.status === "open" ? "high" : "medium") +
              "</td>" +
              '<td class="admin-muted">' +
              escapeHtml(timeAgo(ticket.updated_at || ticket.created_at)) +
              "</td>" +
              "</tr>"
            );
          })
          .join("");
      }

      function planBadge(plan) {
        var cls =
          plan === "premium"
            ? "badge-purple"
            : plan === "pro"
              ? "badge-blue"
              : "badge-gray";
        var label =
          overviewCopy.labels[plan] || plan || overviewCopy.labels.free;
        return (
          '<span class="badge ' +
          cls +
          '"><span class="badge-dot"></span>' +
          escapeHtml(label) +
          "</span>"
        );
      }

      function statusBadge(status) {
        var cls =
          status === "resolved" || status === "closed" || status === "active"
            ? "badge-green"
            : status === "pending"
              ? "badge-blue"
              : status === "trialing"
                ? "badge-blue"
                : status === "past_due" || status === "open"
                  ? "badge-amber"
                  : "badge-gray";
        return (
          '<span class="badge ' +
          cls +
          '"><span class="badge-dot"></span>' +
          escapeHtml(overviewCopy.statuses[status] || status) +
          "</span>"
        );
      }

      function setStatus(type, message, retryable) {
        if (!statusEl || !statusTextEl) return;
        statusEl.className = "admin-status-banner" + (type ? " " + type : "");
        statusEl.hidden = !type;
        statusTextEl.textContent = message;
        if (retryBtn) retryBtn.hidden = !retryable;
      }

      function setUpdatedAt(iso) {
        if (!updatedEl) return;
        var date = iso ? new Date(iso) : new Date();
        updatedEl.textContent = date.toLocaleString(
          overviewLang === "en" ? "en-US" : "zh-CN",
        );
      }

      function adminHref(path) {
        var url = new URL(path, window.location.origin);
        if (overviewLang === "en") url.searchParams.set("lang", "en");
        return url.pathname + url.search + url.hash;
      }

      function resizeCanvas(canvas) {
        var rect = canvas.getBoundingClientRect();
        var dpr = window.devicePixelRatio || 1;
        canvas.width = Math.max(1, Math.floor(rect.width * dpr));
        canvas.height = Math.max(1, Math.floor(rect.height * dpr));
        canvas.__cssWidth = rect.width;
        canvas.__cssHeight = rect.height;
        var ctx = canvas.getContext("2d");
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        return ctx;
      }

      function clearCanvas(id, message) {
        var canvas = document.getElementById(id);
        if (!canvas) return;
        var ctx = resizeCanvas(canvas);
        var w = canvas.__cssWidth;
        var h = canvas.__cssHeight;
        ctx.clearRect(0, 0, w, h);
        if (message) {
          ctx.fillStyle = "#97879a";
          ctx.font = "13px Inter, sans-serif";
          ctx.textAlign = "center";
          ctx.fillText(message, w / 2, h / 2);
        }
      }

      function uniqueDays(a, b) {
        var seen = {};
        a.concat(b).forEach(function (row) {
          if (row && row.day) seen[row.day] = true;
        });
        return Object.keys(seen).sort();
      }

      function mapByDay(rows, key) {
        return rows.reduce(function (acc, row) {
          acc[row.day] = row[key];
          return acc;
        }, {});
      }

      function maxValue(values) {
        return Math.max.apply(
          null,
          values.map(function (value) {
            return Number(value || 0);
          }),
        );
      }

      function estimateDelta(current, seed, money) {
        var base = Math.max(1, current - Math.max(0, seed));
        var delta = ((current - base) / base) * 100;
        if (!Number.isFinite(delta) || delta <= 0)
          delta = current > 0 ? 0.42 : 0;
        if (money && current > 0) delta = Math.max(delta, 0.6);
        return delta.toFixed(delta >= 10 ? 0 : 1) + "%";
      }

      function buildSparkFallback(value) {
        var base = Math.max(0, Number(value || 0));
        return [0, 1, 0, 2, 1, 3, 2, 4, 3, 4, 3, 5].map(function (step) {
          return Math.max(0, base + step - 2);
        });
      }

      function formatNumber(value) {
        value = Number(value || 0);
        return new Intl.NumberFormat(
          overviewLang === "en" ? "en-US" : "zh-CN",
          {
            maximumFractionDigits: value >= 1000 ? 1 : 0,
            notation: value >= 10000 ? "compact" : "standard",
          },
        ).format(value);
      }

      function formatMoney(value) {
        return new Intl.NumberFormat("en-US", {
          style: "currency",
          currency: "USD",
          maximumFractionDigits: value >= 100 ? 0 : 2,
        }).format(Number(value || 0));
      }

      function formatCompactMoney(value) {
        value = Number(value || 0);
        if (value >= 1000) return "$" + (value / 1000).toFixed(1) + "K";
        return "$" + value.toFixed(value >= 10 ? 0 : 1);
      }

      function timeAgo(iso) {
        if (!iso) return "-";
        var date = new Date(iso);
        var diff = Math.max(0, (Date.now() - date.getTime()) / 1000);
        if (diff < 60) return overviewCopy.labels.justNow;
        if (diff < 3600)
          return Math.floor(diff / 60) + overviewCopy.labels.minutesAgo;
        if (diff < 86400)
          return Math.floor(diff / 3600) + overviewCopy.labels.hoursAgo;
        if (diff < 604800)
          return Math.floor(diff / 86400) + overviewCopy.labels.daysAgo;
        return date.toLocaleDateString(
          overviewLang === "en" ? "en-US" : "zh-CN",
        );
      }

      function emptyBlock(title, body) {
        return (
          '<div class="admin-empty"><strong>' +
          escapeHtml(title) +
          "</strong><small>" +
          escapeHtml(body) +
          "</small></div>"
        );
      }

      function setText(id, value) {
        var el = document.getElementById(id);
        if (el) el.textContent = value;
      }

      function setClass(id, value) {
        var el = document.getElementById(id);
        if (el) el.className = value;
      }

      function escapeHtml(value) {
        var div = document.createElement("div");
        div.appendChild(document.createTextNode(String(value || "")));
        return div.innerHTML;
      }

      function debounce(fn, wait) {
        var timer;
        return function () {
          clearTimeout(timer);
          timer = setTimeout(fn, wait);
        };
      }
    })();
  </script>
</AdminLayout>
