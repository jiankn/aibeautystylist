---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { getLocalizedAppHref, resolveLocaleRoute } from "../i18n/routing";
import { getCurrentLocale } from "../lib/i18n";
import { getLocalizedSupportContent } from "../data/supportingPageContent";

const currentPathname = Astro.originPathname || Astro.url.pathname;
const currentRoute =
  Astro.locals.localeRoute ?? resolveLocaleRoute(currentPathname);
const localizeAppHref = (href: string) =>
  getLocalizedAppHref(href, currentRoute.language.slug);
const faqHref = localizeAppHref("/faq");
const privacyHref = localizeAppHref("/privacy");
const isEn = !getCurrentLocale().startsWith("zh");
const fallbackCopy = isEn
  ? {
      metaTitle: "Support | AI Beauty Stylist",
      title: "Support that starts with the problem",
      description:
        "Tell us what happened and what you expected. We will create a trackable support ticket.",
      eyebrow: "Support",
      intro:
        "For account, billing, diagnosis, or try-on issues, submit one clear request. No photo is required.",
      formTitle: "Create a support ticket",
      formDesc:
        "Required fields are marked. Do not include passwords or payment card details.",
      name: "Name",
      email: "Contact email",
      topic: "Issue type",
      message: "What happened?",
      namePlaceholder: "How should we address you?",
      messagePlaceholder:
        "Describe what you did, what happened, and what you expected. Include an order or job ID if relevant.",
      choose: "Choose an issue type",
      topics: [
        ["billing", "Billing and subscription"],
        ["tryon", "Try-on generation"],
        ["diagnosis", "AI diagnosis"],
        ["account", "Account access"],
        ["cooperation", "Business inquiry"],
        ["other", "Other feedback"],
      ],
      submit: "Submit ticket",
      submitting: "Submitting...",
      privacy:
        "By submitting, you agree that we may use this information to respond to your request.",
      privacyLink: "Privacy policy",
      successTitle: "Your ticket is in the support queue",
      successBody: "Keep this ticket number for follow-up:",
      another: "Submit another request",
      directTitle: "Before you submit",
      directItems: [
        [
          "Protect your account",
          "Never send passwords, verification codes, or full card details.",
        ],
        [
          "Help us reproduce it",
          "Include the page, steps, expected result, and any job or order ID.",
        ],
        [
          "Photo issues",
          "You can describe the issue without attaching or emailing a selfie.",
        ],
      ],
      emailTitle: "Prefer email?",
      emailBody:
        "Send the same details to support@aibeautystylist.com. Use your account email when possible.",
      browseFaq: "Browse common answers",
      response:
        "Requests are reviewed in order. Complex billing or technical cases may take longer.",
    }
  : {
      metaTitle: "联系支持 | AI Beauty Stylist",
      title: "提交支持工单",
      description:
        "告诉我们遇到的问题、操作步骤和期待结果，系统会创建一个可追踪的支持工单。",
      eyebrow: "支持中心",
      intro:
        "账号、账单、妆容诊断或试妆问题，请提交一条信息完整的工单。无需上传自拍。",
      formTitle: "创建支持工单",
      formDesc: "带星号为必填项。请勿填写密码、验证码或完整银行卡信息。",
      name: "如何称呼你",
      email: "联系邮箱",
      topic: "问题类型",
      message: "问题描述",
      namePlaceholder: "例如：林女士",
      messagePlaceholder:
        "说明你的操作步骤、实际结果和期待结果；如涉及订单或生成任务，可附上对应编号。",
      choose: "选择问题类型",
      topics: [
        ["billing", "账单与会员订阅"],
        ["tryon", "试妆生成问题"],
        ["diagnosis", "妆容诊断问题"],
        ["account", "账号登录与访问"],
        ["cooperation", "商务合作"],
        ["other", "其他反馈"],
      ],
      submit: "提交工单",
      submitting: "正在提交...",
      privacy: "提交即表示你同意我们使用这些信息处理并回复本次请求。",
      privacyLink: "查看隐私政策",
      successTitle: "工单已进入支持队列",
      successBody: "后续沟通请保留此工单号：",
      another: "再提交一条",
      directTitle: "提交前请确认",
      directItems: [
        ["保护账号安全", "不要发送密码、验证码或完整银行卡信息。"],
        [
          "帮助我们复现",
          "写清页面、操作步骤、期待结果，以及相关任务或订单编号。",
        ],
        ["涉及自拍的问题", "只需描述现象，不必通过工单或邮件发送自拍。"],
      ],
      emailTitle: "更习惯邮件？",
      emailBody:
        "可将同样的信息发送至 support@aibeautystylist.com，建议使用账号邮箱联系。",
      browseFaq: "先查看常见问题",
      response: "请求会按顺序处理；复杂账单或技术问题可能需要更长时间。",
    };
const copy = getLocalizedSupportContent(getCurrentLocale()) ?? fallbackCopy;
---

<BaseLayout title={copy.metaTitle} description={copy.description}>
  <SiteHeader />
  <main class="support-main">
    <header class="support-hero shell">
      <div>
        <span class="section-kicker">{copy.eyebrow}</span>
        <h1>{copy.title}</h1>
        <p>{copy.intro}</p>
      </div>
      <a class="text-link" href={faqHref}
        >{copy.browseFaq} <span aria-hidden="true">→</span></a
      >
    </header>

    <section
      class="support-workspace shell"
      aria-labelledby="support-form-title"
    >
      <div class="support-form-panel panel">
        <div class="section-heading">
          <span class="step-index">01</span>
          <div>
            <h2 id="support-form-title">{copy.formTitle}</h2>
            <p>{copy.formDesc}</p>
          </div>
        </div>

        <form id="support-form" class="support-form">
          <div class="form-row">
            <label>
              <span>{copy.name} <b aria-hidden="true">*</b></span>
              <input
                name="name"
                autocomplete="name"
                required
                minlength="2"
                maxlength="80"
                placeholder={copy.namePlaceholder}
              />
            </label>
            <label>
              <span>{copy.email} <b aria-hidden="true">*</b></span>
              <input
                name="email"
                type="email"
                autocomplete="email"
                required
                maxlength="160"
                placeholder="name@example.com"
              />
            </label>
          </div>
          <label>
            <span>{copy.topic} <b aria-hidden="true">*</b></span>
            <select name="topic" required>
              <option value="" disabled selected>{copy.choose}</option>
              {
                copy.topics.map(([value, label]) => (
                  <option value={value}>{label}</option>
                ))
              }
            </select>
          </label>
          <label>
            <span>{copy.message} <b aria-hidden="true">*</b></span>
            <textarea
              name="message"
              rows="7"
              required
              minlength="10"
              maxlength="3000"
              placeholder={copy.messagePlaceholder}></textarea>
          </label>
          <label class="honeypot" aria-hidden="true">
            Website
            <input name="website" tabindex="-1" autocomplete="off" />
          </label>
          <input type="hidden" name="locale" value={isEn ? "en" : "zh-CN"} />
          <div class="submit-row">
            <button
              class="btn btn-primary"
              type="submit"
              data-submit
              data-default={copy.submit}
              data-busy={copy.submitting}
            >
              {copy.submit}
            </button>
            <p>{copy.privacy} <a href={privacyHref}>{copy.privacyLink}</a></p>
          </div>
          <p
            class="form-status"
            role="status"
            aria-live="polite"
            data-status
            hidden
          >
          </p>
        </form>

        <div class="success-state" data-success hidden>
          <span class="success-mark" aria-hidden="true">✓</span>
          <h2>{copy.successTitle}</h2>
          <p>{copy.successBody}</p>
          <strong data-ticket></strong>
          <button class="btn" type="button" data-reset>{copy.another}</button>
        </div>
      </div>

      <aside class="support-guide" aria-label={copy.directTitle}>
        <div class="guide-heading">
          <span class="step-index">02</span>
          <h2>{copy.directTitle}</h2>
        </div>
        <ol>
          {
            copy.directItems.map(([title, detail]) => (
              <li>
                <strong>{title}</strong>
                <span>{detail}</span>
              </li>
            ))
          }
        </ol>
        <div class="email-strip">
          <strong>{copy.emailTitle}</strong>
          <p>{copy.emailBody}</p>
          <a href="mailto:support@aibeautystylist.com"
            >support@aibeautystylist.com</a
          >
        </div>
        <p class="response-note">{copy.response}</p>
      </aside>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  (() => {
    const form = document.querySelector("#support-form");
    const submit = document.querySelector("[data-submit]");
    const status = document.querySelector("[data-status]");
    const success = document.querySelector("[data-success]");
    const ticket = document.querySelector("[data-ticket]");
    const reset = document.querySelector("[data-reset]");
    if (!form || !submit || !status || !success || !ticket) return;

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      submit.disabled = true;
      submit.textContent = submit.dataset.busy;
      status.hidden = true;
      try {
        const payload = Object.fromEntries(new FormData(form).entries());
        const response = await fetch("/api/support", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload),
        });
        const result = await response.json();
        if (!response.ok || !result.ok)
          throw new Error(result.error?.message || "Submit failed");
        ticket.textContent = result.data.ticketCode;
        form.hidden = true;
        success.hidden = false;
        success.focus?.();
      } catch (error) {
        status.textContent =
          error instanceof Error ? error.message : "Submit failed";
        status.hidden = false;
      } finally {
        submit.disabled = false;
        submit.textContent = submit.dataset.default;
      }
    });

    reset?.addEventListener("click", () => {
      form.reset();
      form.hidden = false;
      success.hidden = true;
      form.querySelector("input")?.focus();
    });
  })();
</script>

<style>
  .support-main {
    padding: 54px 0 88px;
    background: var(--page-surface);
  }
  .support-hero {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 32px;
    padding-bottom: 34px;
    border-bottom: 1px solid var(--line);
  }
  .support-hero > div {
    max-width: 760px;
  }
  .section-kicker {
    display: block;
    margin-bottom: 13px;
    color: var(--rose);
    font-size: var(--content-label-size);
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }
  .support-hero h1 {
    max-width: 720px;
    margin: 0;
    color: var(--heading);
    font-family: var(--font-display);
    font-size: var(--content-hero-size);
    font-weight: 500;
    line-height: 1.08;
  }
  .support-hero p {
    max-width: 660px;
    margin: 18px 0 0;
    color: var(--body-secondary);
    font-size: var(--content-body-size);
    line-height: 1.75;
  }
  .text-link {
    flex: 0 0 auto;
    color: var(--rose);
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
  }
  .support-workspace {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(300px, 0.75fr);
    gap: 34px;
    padding-top: 38px;
    align-items: start;
  }
  .support-form-panel {
    padding: 32px;
  }
  .section-heading,
  .guide-heading {
    display: flex;
    align-items: start;
    gap: 14px;
  }
  .step-index {
    display: grid;
    width: 32px;
    height: 32px;
    flex: 0 0 32px;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 50%;
    color: var(--rose);
    font-size: var(--content-label-size);
    font-weight: 700;
  }
  .section-heading h2,
  .guide-heading h2 {
    margin: 2px 0 0;
    color: var(--heading);
    font-size: var(--content-subsection-title-size);
  }
  .section-heading p {
    margin: 7px 0 0;
    color: var(--muted);
    font-size: var(--content-supporting-size);
    line-height: 1.6;
  }
  .support-form {
    display: grid;
    gap: 18px;
    margin-top: 28px;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .support-form label {
    display: grid;
    gap: 7px;
    color: var(--heading);
    font-size: var(--content-supporting-size);
    font-weight: 700;
  }
  .support-form label b {
    color: var(--rose);
  }
  .support-form input,
  .support-form select,
  .support-form textarea {
    width: 100%;
    min-height: 48px;
    padding: 11px 13px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--bg-elevated);
    color: var(--text);
    font: inherit;
    line-height: 1.5;
  }
  .support-form textarea {
    resize: vertical;
  }
  .support-form input:focus-visible,
  .support-form select:focus-visible,
  .support-form textarea:focus-visible {
    outline: 3px solid var(--rose-soft);
    outline-offset: 2px;
    border-color: var(--rose);
  }
  .honeypot {
    position: absolute !important;
    left: -10000px;
  }
  .submit-row {
    display: flex;
    align-items: center;
    gap: 16px;
    padding-top: 2px;
  }
  .submit-row .btn {
    min-width: 132px;
  }
  .submit-row p {
    margin: 0;
    color: var(--muted);
    font-size: var(--content-label-size);
    line-height: 1.55;
  }
  .submit-row a,
  .email-strip a {
    color: var(--rose);
  }
  .form-status {
    margin: 0;
    color: var(--danger-text);
    font-size: var(--content-supporting-size);
  }
  .support-guide {
    padding: 8px 0 0;
  }
  .support-guide ol {
    list-style: none;
    margin: 24px 0 0;
    padding: 0;
    border-top: 1px solid var(--line);
  }
  .support-guide li {
    display: grid;
    gap: 5px;
    padding: 19px 0;
    border-bottom: 1px solid var(--line);
  }
  .support-guide li strong {
    color: var(--heading);
    font-size: 14px;
  }
  .support-guide li span,
  .email-strip p,
  .response-note {
    color: var(--body-secondary);
    font-size: 13px;
    line-height: 1.65;
  }
  .email-strip {
    margin-top: 26px;
    padding: 20px;
    border-left: 3px solid var(--rose);
    background: var(--surface-rose);
  }
  .email-strip strong {
    color: var(--heading);
    font-size: 14px;
  }
  .email-strip p {
    margin: 7px 0 9px;
  }
  .email-strip a {
    font-size: 13px;
    font-weight: 700;
  }
  .response-note {
    margin: 15px 0 0;
  }
  .success-state {
    min-height: 390px;
    padding: 50px 10px;
    text-align: center;
  }
  .success-mark {
    display: grid;
    width: 44px;
    height: 44px;
    margin: 0 auto 18px;
    place-items: center;
    border-radius: 50%;
    background: var(--teal-soft);
    color: var(--teal);
    font-weight: 700;
  }
  .success-state h2 {
    margin: 0;
    color: var(--heading);
    font-size: 24px;
  }
  .success-state p {
    margin: 10px 0 8px;
    color: var(--muted);
  }
  .success-state strong {
    display: block;
    margin-bottom: 24px;
    color: var(--rose);
    font-family: monospace;
    font-size: 17px;
  }
  @media (max-width: 900px) {
    .support-workspace {
      grid-template-columns: 1fr;
    }
    .support-guide {
      padding-top: 10px;
    }
  }
  @media (max-width: 700px) {
    .support-main {
      padding-top: 34px;
    }
    .support-hero {
      display: block;
      padding-bottom: 26px;
    }
    .support-hero h1 {
      font-size: var(--content-hero-size-mobile);
    }
    .text-link {
      display: inline-block;
      margin-top: 18px;
    }
    .support-workspace {
      padding-top: 24px;
    }
    .support-form-panel {
      padding: 20px 16px;
    }
    .form-row {
      grid-template-columns: 1fr;
    }
    .submit-row {
      align-items: stretch;
      flex-direction: column;
    }
    .submit-row .btn {
      width: 100%;
    }
  }
</style>
