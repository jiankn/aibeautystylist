---
import BaseLayout from '../layouts/BaseLayout.astro';

const token = Astro.url.searchParams.get('token') ?? '';
---

<BaseLayout
  title="Reset password — AI Beauty Stylist"
  description="Choose a new password for your AI Beauty Stylist account."
  robots="noindex,nofollow"
>
  <section class="auth-page-shell">
    <div class="auth-card auth-card-narrow">
      <div class="auth-copy">
        <p class="auth-eyebrow">Secure reset</p>
        <h1>Choose a new password</h1>
        <p>Your password must be at least 8 characters.</p>
      </div>

      <form class="auth-form" data-reset-form>
        <input type="hidden" name="token" value={token} />

        <label class="auth-field">
          <span>New password</span>
          <input name="password" type="password" autocomplete="new-password" placeholder="••••••••" required minlength="8" />
        </label>

        <button class="btn auth-submit" type="submit" data-reset-submit>Reset password</button>
        <p class="auth-message" data-reset-message hidden></p>
      </form>

      <p class="auth-footnote"><a href="/login">Back to sign in</a></p>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.querySelector('[data-reset-form]') as HTMLFormElement | null;
  const submit = document.querySelector('[data-reset-submit]') as HTMLButtonElement | null;
  const message = document.querySelector('[data-reset-message]') as HTMLElement | null;

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!submit || !message) return;

    const formData = new FormData(form);
    submit.disabled = true;
    submit.textContent = 'Resetting…';
    message.hidden = true;
    message.classList.remove('is-error', 'is-success');

    try {
      const resp = await fetch('/api/auth/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          token: String(formData.get('token') ?? ''),
          password: String(formData.get('password') ?? ''),
        }),
      });
      const data = (await resp.json().catch(() => ({}))) as { message?: string };
      if (!resp.ok) throw new Error(data.message ?? 'Unable to reset password.');

      message.textContent = 'Password updated. Redirecting to sign in…';
      message.classList.add('is-success');
      message.hidden = false;
      setTimeout(() => { window.location.href = '/login'; }, 900);
    } catch (error) {
      message.textContent = error instanceof Error ? error.message : 'Unable to reset password.';
      message.classList.add('is-error');
      message.hidden = false;
      submit.disabled = false;
      submit.textContent = 'Reset password';
    }
  });
</script>
