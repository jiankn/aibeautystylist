---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { getLocalizedAppHref, resolveLocaleRoute } from "../i18n/routing";
import { getCurrentLocale } from "../lib/i18n";
import {
  getLocalizedAuthResponseMessages,
  getLocalizedResetPasswordContent,
} from "../data/authContent";

const currentLocale = getCurrentLocale();
const isZh = currentLocale.startsWith("zh");
const currentPathname = Astro.originPathname || Astro.url.pathname;
const currentRoute =
  Astro.locals.localeRoute ?? resolveLocaleRoute(currentPathname);
const loginHref = getLocalizedAppHref("/login", currentRoute.language.slug);
const fallbackCopy = isZh
  ? {
      title: "重置密码 | AI Beauty Stylist",
      description: "设置新的 AI Beauty Stylist 账户密码。",
      heading: "设置新密码",
      password: "新密码",
      passwordHint: "至少 8 位，包含字母和数字",
      submit: "保存新密码",
      back: "返回登录",
      invalid: "重置链接无效，请重新从邮件打开",
      saving: "保存中…",
      success: "密码已更新，正在跳转…",
      failed: "重置失败",
    }
  : {
      title: "Reset password | AI Beauty Stylist",
      description: "Set a new password for your AI Beauty Stylist account.",
      heading: "Set a new password",
      password: "New password",
      passwordHint: "At least 8 characters with letters and numbers",
      submit: "Save new password",
      back: "Back to sign in",
      invalid: "This reset link is invalid. Open the latest email link.",
      saving: "Saving...",
      success: "Password updated. Redirecting...",
      failed: "Password reset failed",
    };
const copy = getLocalizedResetPasswordContent(currentLocale) ?? fallbackCopy;
const authResponseMessages = getLocalizedAuthResponseMessages(currentLocale);
---

<BaseLayout
  title={copy.title}
  description={copy.description}
  bodyClass="auth-body"
  robots="noindex,follow"
>
  <SiteHeader showAuth={false} />
  <main class="auth-main">
    <div class="auth-card panel" data-reset>
      <h1 class="auth-heading">{copy.heading}</h1>
      <form class="auth-form" data-reset-form>
        <label
          >{copy.password}<input
            type="password"
            name="password"
            autocomplete="new-password"
            required
          /><small>{copy.passwordHint}</small></label
        >
        <button class="btn btn-primary btn-wide" type="submit"
          >{copy.submit}</button
        >
      </form>
      <p class="auth-message" data-reset-message role="status"></p>
      <a class="auth-link" href={loginHref}>{copy.back}</a>
    </div>
  </main>

  <style>
    .auth-main {
      display: flex;
      justify-content: center;
      padding: 48px 16px;
    }
    .auth-card {
      width: 100%;
      max-width: 420px;
      padding: 28px;
    }
    .auth-heading {
      font-size: 20px;
      margin: 0 0 18px;
    }
    .auth-form {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .auth-form label {
      display: flex;
      flex-direction: column;
      gap: 6px;
      font-size: 14px;
      color: var(--text);
    }
    .auth-form input {
      padding: 11px 12px;
      border: 1px solid var(--input-border);
      background: var(--bg);
      border-radius: 8px;
      font-size: 15px;
    }
    .auth-form small {
      color: var(--muted);
      font-size: 12px;
    }
    .auth-link {
      display: inline-block;
      margin-top: 14px;
      color: var(--rose, #e8909c);
      font-size: 13px;
    }
    .auth-message {
      margin-top: 14px;
      font-size: 14px;
      min-height: 20px;
    }
    .auth-message.is-error {
      color: var(--danger-text);
    }
    .auth-message.is-success {
      color: var(--success-text);
    }
  </style>

  <script is:inline define:vars={{ copy, authResponseMessages, loginHref }}>
    (() => {
      const root = document.querySelector("[data-reset]");
      if (!root) return;
      const form = root.querySelector("[data-reset-form]");
      const message = root.querySelector("[data-reset-message]");
      const token = new URLSearchParams(window.location.search).get("token");

      function setMessage(text, kind) {
        message.textContent = text || "";
        message.className = "auth-message" + (kind ? " is-" + kind : "");
      }
      function responseMessage(body, fallback) {
        const code = body?.error?.code;
        const byCode = {
          NETWORK_ERROR: authResponseMessages.networkError,
          WEAK_PASSWORD: authResponseMessages.weakPassword,
          INVALID_TOKEN: authResponseMessages.invalidToken,
          OAUTH_REQUIRED: authResponseMessages.oauthRequired,
          AUTH_UNAVAILABLE: authResponseMessages.authUnavailable,
          RATE_LIMITED: authResponseMessages.rateLimited,
        };
        return (code && byCode[code]) || fallback;
      }
      async function postJson(url, payload) {
        try {
          const res = await fetch(url, {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify(payload),
          });
          return await res.json().catch(() => null);
        } catch {
          return { ok: false, error: { code: "NETWORK_ERROR" } };
        }
      }

      if (!token) {
        setMessage(copy.invalid, "error");
        form.querySelector("button").disabled = true;
        return;
      }

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        const password = new FormData(form).get("password");
        setMessage(copy.saving);
        const body = await postJson("/api/auth/reset-password", {
          token,
          password,
        });
        if (body?.ok) {
          setMessage(copy.success, "success");
          window.location.href = loginHref;
        } else {
          setMessage(responseMessage(body, copy.failed), "error");
        }
      });
    })();
  </script>
</BaseLayout>
