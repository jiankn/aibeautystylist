---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllLooks } from '../lib/mockTryOn';

export const prerender = true;

const looks = getAllLooks('en');
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Makeup Tutorials by AI Beauty Stylist',
  description: 'Static makeup tutorial hub with step-by-step looks for office, date, photo, and event makeup.',
  url: 'https://aibeautystylist.com/tutorial/',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: looks.map((look, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: look.name,
      url: `https://aibeautystylist.com/tutorials/${look.id}/`,
    })),
  },
};
---

<BaseLayout
  title="Makeup Tutorials | Step-by-Step AI Beauty Guides"
  description="Browse static step-by-step makeup tutorials for office, date-night, photo-ready, and beginner-friendly looks."
  structuredData={structuredData}
>
  <section class="section">
    <div class="container section-copy narrow">
      <span class="eyebrow">Tutorial Library</span>
      <h1>Pick a makeup tutorial that matches the moment, not just the trend.</h1>
      <p>
        Each guide turns one AI beauty look into a repeatable routine: what to do, what to avoid, how to self-check, and which product roles matter.
      </p>
    </div>

    <div class="container grid-cards grid-cards-3">
      {looks.map((look) => (
        <a class="card tutorial-index-card" href={`/tutorials/${look.id}`}>
          <span class="pill">{look.scenario}</span>
          <h3>{look.name}</h3>
          <p>{look.reason}</p>
          <ul class="check-list compact">
            <li>{look.minutes}</li>
            <li>{look.difficulty}</li>
            <li>{look.focus}</li>
          </ul>
          <span class="text-link">Open tutorial</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .tutorial-index-card {
    color: inherit;
    text-decoration: none;
  }
</style>
