---
import BaseLayout from '../layouts/BaseLayout.astro';
import { scenarioPages } from '../data/scenarioPages';
import { lipstickShadePages } from '../data/lipstickShadePages';
import { stylePages } from '../data/stylePages';
import { getAllLooks } from '../lib/mockTryOn';

export const prerender = true;

const tutorials = getAllLooks('en');
const featuredSeoGuides = [
  { label: 'Deep skin makeup guide', href: '/styles/deep-skin-makeup', detail: 'Pigment, nude lips, blush depth, and non-ashy glow.' },
  { label: 'Monolid makeup guide', href: '/styles/monolid-makeup', detail: 'Eyes-open mapping, lash-root definition, and visible lift.' },
  { label: 'Olive skin makeup guide', href: '/styles/olive-skin-makeup', detail: 'Muted undertone, base matching, blush, bronzer, and lipstick.' },
  { label: 'Korean dewy makeup guide', href: '/styles/korean-dewy-makeup', detail: 'Hydrated skin, sheer color, soft brows, and controlled shine.' },
  { label: 'Makeup for hooded eyes', href: '/scenarios/hooded-eyes-makeup', detail: 'Open-eye placement and liner that still shows.' },
  { label: 'Makeup for mature skin', href: '/scenarios/mature-skin-makeup', detail: 'Thin layers, lift, softened powder, and fresh color.' },
  { label: 'AI makeup try on for wedding guest', href: '/scenarios/wedding-guest-makeup', detail: 'Photo-safe wedding guest makeup you can preview first.' },
  { label: 'Lipstick shades for Asian skin', href: '/lipstick-shades/asian-skin-lipstick-shades', detail: 'Tea rose, rose-brown, berry, and undertone-safe shades.' },
  { label: 'Foundation shade finder by undertone', href: '/tools/foundation-shade-finder-by-undertone', detail: 'Warm, cool, neutral, olive, and deep foundation directions.' },
];
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'AI Beauty Stylist Makeup Guides',
  description: 'Makeup guides by scenario, lipstick undertone, and step-by-step tutorial.',
  url: 'https://aibeautystylist.com/makeup-guides/',
};
---

<BaseLayout
  title="Makeup Guides | AI Beauty Stylist"
  description="Browse static makeup guides by scenario, undertone, lipstick shade, and tutorial style."
  structuredData={structuredData}
>
  <section class="section">
    <div class="container section-copy narrow">
      <span class="eyebrow">Makeup Guides</span>
      <h1>Start with the beauty question you actually have.</h1>
      <p>
        Use the guide library for search-friendly advice, then move into AI Try-On when you want the recommendation adjusted to your face.
      </p>
    </div>

    <div class="container guide-hub-section top-gap">
      <div class="section-copy">
        <span class="eyebrow">Popular Questions</span>
        <h2>High-intent makeup guides</h2>
      </div>
      <div class="grid-cards grid-cards-3">
        {featuredSeoGuides.map((guide) => (
          <a class="card guide-hub-card" href={guide.href}>
            <span class="pill">SEO Guide</span>
            <h3>{guide.label}</h3>
            <p>{guide.detail}</p>
          </a>
        ))}
      </div>
    </div>

    <div class="container guide-hub-section">
      <div class="section-copy">
        <span class="eyebrow">By Scenario</span>
        <h2>Makeup for real-life moments</h2>
      </div>
      <div class="grid-cards grid-cards-3">
        {scenarioPages.map((page) => (
          <a class="card guide-hub-card" href={`/scenarios/${page.slug}`}>
            <span class="pill">{page.eyebrow}</span>
            <h3>{page.headline}</h3>
            <p>{page.description}</p>
          </a>
        ))}
      </div>
    </div>

    <div class="container guide-hub-section top-gap">
      <div class="section-copy">
        <span class="eyebrow">By Style</span>
        <h2>Aesthetic looks decoded step-by-step</h2>
      </div>
      <div class="grid-cards grid-cards-3">
        {stylePages.map((page) => (
          <a class="card guide-hub-card" href={`/styles/${page.slug}`}>
            <span class="pill">{page.eyebrow}</span>
            <h3>{page.headline}</h3>
            <p>{page.description}</p>
          </a>
        ))}
      </div>
    </div>

    <div class="container guide-hub-section top-gap">
      <div class="section-copy">
        <span class="eyebrow">By Lip Color</span>
        <h2>Shade families that fit your skin</h2>
      </div>
      <div class="grid-cards grid-cards-3">
        {lipstickShadePages.map((page) => (
          <a class="card guide-hub-card" href={`/lipstick-shades/${page.slug}`}>
            <span class="pill">{page.eyebrow}</span>
            <h3>{page.headline}</h3>
            <p>{page.description}</p>
          </a>
        ))}
      </div>
    </div>

    <div class="container guide-hub-section top-gap">
      <div class="section-copy">
        <span class="eyebrow">By Tutorial</span>
        <h2>Repeatable routines from the AI look library</h2>
      </div>
      <div class="grid-cards grid-cards-3">
        {tutorials.map((look) => (
          <a class="card guide-hub-card" href={`/tutorials/${look.id}`}>
            <span class="pill">{look.scenario}</span>
            <h3>{look.name}</h3>
            <p>{look.tutorialHeadline}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .guide-hub-card {
    color: inherit;
    text-decoration: none;
  }

  .guide-hub-section .section-copy {
    margin-bottom: 18px;
  }
</style>
