    label: "Error del servidor 500",
    heading: "El servidor no está disponible temporalmente",
    message: "Lo sentimos, la última solicitud no se completó correctamente.",
    details:
      "La excepción quedó registrada. Puedes intentarlo más tarde, volver al inicio, consultar ayuda o contactar con soporte.",
    home: "Volver al inicio",
    faq: "Centro de ayuda",
    support: "Contactar con soporte",
  },
  "es-419": {
    title: "Error del servidor 500",
    description:
      "El servidor no pudo completar la solicitud. Inténtalo más tarde o contacta a soporte.",
    label: "Error del servidor 500",
    heading: "El servidor no está disponible temporalmente",
    message: "Lo sentimos, la última solicitud no se completó correctamente.",
    details:
      "La excepción quedó registrada. Puedes intentarlo más tarde, volver al inicio, consultar ayuda o contactar a soporte.",
    home: "Volver al inicio",
    faq: "Centro de ayuda",
    support: "Contactar a soporte",
  },
  "pt-BR": {
    title: "Erro de servidor 500",
    description:
      "O servidor não conseguiu concluir a solicitação. Tente mais tarde ou fale com o suporte.",
    label: "Erro de servidor 500",
    heading: "O servidor está temporariamente indisponível",
    message: "Desculpe, a última solicitação não foi concluída com sucesso.",
    details:
      "A exceção foi registrada. Você pode tentar mais tarde, voltar ao início, consultar a central de ajuda ou falar com o suporte.",
    home: "Voltar ao início",
    faq: "Central de ajuda",
    support: "Falar com suporte",
  },
