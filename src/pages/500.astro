---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { getLocalizedAppHref, resolveLocaleRoute } from "../i18n/routing";
import { getCurrentLocale } from "../lib/i18n";

const currentLocale = getCurrentLocale();
const isZh = currentLocale.startsWith("zh");
const currentPathname = Astro.originPathname || Astro.url.pathname;
const currentRoute =
  Astro.locals.localeRoute ?? resolveLocaleRoute(currentPathname);
const homeHref = getLocalizedAppHref("/", currentRoute.language.slug);
const faqHref = getLocalizedAppHref("/faq", currentRoute.language.slug);
const supportHref = getLocalizedAppHref("/support", currentRoute.language.slug);
const copy = isZh
  ? {
      title: "500 服务器错误",
      description: "服务器暂时无法完成请求，请稍后重试或联系支持。",
      label: "500 SERVER ERROR",
      heading: "服务器暂时不可用",
      message: "很抱歉，刚才的请求没有成功完成。",
      details:
        "我们已记录该异常。你可以稍后刷新重试，或先返回首页、查看帮助中心、提交支持工单。",
      home: "返回首页",
      faq: "查看帮助中心",
      support: "联系客户支持",
    }
  : {
      title: "500 server error",
      description:
        "The server could not complete the request. Try again later or contact support.",
      label: "500 SERVER ERROR",
      heading: "The server is temporarily unavailable",
      message: "Sorry, the last request did not complete successfully.",
      details:
        "The exception has been recorded. You can retry later, return home, check the help center, or contact support.",
      home: "Back to home",
      faq: "Help center",
      support: "Contact support",
    };
---

<BaseLayout
  title={copy.title}
  description={copy.description}
  bodyClass="error-body"
  robots="noindex,follow"
>
  <SiteHeader showAuth={false} />
  <main class="error-main">
    <div class="error-card panel">
      <div class="error-icon" aria-hidden="true">
        <span>!</span>
      </div>
      <span class="pill pill-rose">{copy.label}</span>
      <h1 class="error-heading">{copy.heading}</h1>
      <p class="error-message">{copy.message}</p>
      <p class="error-details">{copy.details}</p>

      <div class="error-actions">
        <a class="btn btn-primary" href={homeHref}>{copy.home}</a>
        <a class="btn btn-outline-rose" href={faqHref}>{copy.faq}</a>
        <a class="btn" href={supportHref}>{copy.support}</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .error-body {
    background-color: var(--bg);
  }

  .error-main {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - 180px);
    padding: 48px 16px;
    background: linear-gradient(180deg, var(--rose-soft) 0%, var(--bg) 100%);
  }

  .error-card {
    width: 100%;
    max-width: 520px;
    padding: 48px 36px;
    text-align: center;
    border: 1px solid var(--border);
    border-radius: 24px;
    background: var(--panel-bg);
    box-shadow: 0 8px 30px var(--rose-soft);
  }

  .error-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    background: var(--rose-soft);
    border-radius: 50%;
    font-size: 36px;
    margin-bottom: 24px;
    animation: pulse 2s infinite ease-in-out;
  }

  @keyframes pulse {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.06);
    }
  }

  .error-heading {
    font-size: 24px;
    font-weight: 800;
    color: var(--text);
    margin: 16px 0 12px;
  }

  .error-message {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-light);
    line-height: 1.6;
    margin: 0 0 12px;
  }

  .error-details {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
    margin: 0 0 32px;
  }

  .error-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .error-actions a {
    display: block;
    width: 100%;
  }

  @media (min-width: 480px) {
    .error-actions {
      flex-direction: row;
      justify-content: center;
      gap: 10px;
    }
    .error-actions a {
      width: auto;
      flex: 1;
      white-space: nowrap;
    }
  }

  @media (max-width: 700px) {
    .error-card {
      padding: 32px 20px;
    }
  }
</style>
