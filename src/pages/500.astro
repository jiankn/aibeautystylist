const copy = copyByLocale[currentLocale];
---

<BaseLayout
  title={copy.title}
  description={copy.description}
  bodyClass="error-body"
  robots="noindex,follow"
>
  <SiteHeader showAuth={false} />
  <main class="error-main">
    <div class="error-card panel">
      <div class="error-icon" aria-hidden="true">
        <span>!</span>
      </div>
      <span class="pill pill-rose">{copy.label}</span>
      <h1 class="error-heading">{copy.heading}</h1>
      <p class="error-message">{copy.message}</p>
      <p class="error-details">{copy.details}</p>

      <div class="error-actions">
        <a class="btn btn-primary" href={homeHref}>{copy.home}</a>
        <a class="btn btn-outline-rose" href={faqHref}>{copy.faq}</a>
        <a class="btn" href={supportHref}>{copy.support}</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .error-body {
    background-color: var(--bg);
  }

  .error-main {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - 180px);
    padding: 48px 16px;
    background: linear-gradient(180deg, var(--rose-soft) 0%, var(--bg) 100%);
  }

  .error-card {
    width: 100%;
    max-width: 520px;
    padding: 48px 36px;
    text-align: center;
    border: 1px solid var(--border);
    border-radius: 24px;
    background: var(--panel-bg);
    box-shadow: 0 8px 30px var(--rose-soft);
  }

  .error-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    background: var(--rose-soft);
    border-radius: 50%;
    font-size: 36px;
    margin-bottom: 24px;
    animation: pulse 2s infinite ease-in-out;
  }

  @keyframes pulse {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.06);
    }
  }

  .error-heading {
    font-size: 24px;
    font-weight: 800;
    color: var(--text);
    margin: 16px 0 12px;
  }

  .error-message {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-light);
    line-height: 1.6;
    margin: 0 0 12px;
  }

  .error-details {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
    margin: 0 0 32px;
  }

  .error-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .error-actions a {
    display: block;
    width: 100%;
  }

  @media (min-width: 480px) {
    .error-actions {
      flex-direction: row;
      justify-content: center;
      gap: 10px;
    }
    .error-actions a {
      width: auto;
      flex: 1;
      white-space: nowrap;
    }
  }

  @media (max-width: 700px) {
    .error-card {
      padding: 32px 20px;
    }
  }
</style>
