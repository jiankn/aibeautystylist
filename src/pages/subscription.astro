      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 16px;
      align-items: center;
    }
    .subscription-gate h2 {
      margin: 0 0 5px;
      color: var(--heading);
      font-size: 20px;
    }
