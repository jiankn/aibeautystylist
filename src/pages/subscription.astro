      line-height: 1;
    }
    .subscription-plan-chip {
      display: inline-flex;
      min-height: 32px;
      align-items: center;
      padding: 0 12px;
      border: 1px solid color-mix(in srgb, var(--teal) 28%, var(--line));
      border-radius: 999px;
      background: var(--teal-soft);
      color: var(--teal);
      font-size: 12px;
      font-weight: 900;
    }
    .subscription-plan[data-plan="pro"] .subscription-plan-chip {
      border-color: color-mix(in srgb, var(--rose) 34%, var(--line));
      background: var(--rose-soft);
      color: var(--rose);
    }
    .subscription-plan[data-plan="premium"] .subscription-plan-chip {
      border-color: color-mix(in srgb, var(--gold) 40%, var(--line));
      background: var(--gold-soft);
      color: var(--gold-text);
    }
    .subscription-plan-note {
      margin: 0;
      color: var(--muted);
      line-height: 1.65;
    }
    .subscription-price {
      display: flex;
      align-items: baseline;
      gap: 8px;
      color: var(--heading);
    }
    .subscription-price span {
      font-size: 18px;
    }
    .subscription-price b {
