    }
    .subscription-section-head {
      display: grid;
      gap: 4px;
      margin-bottom: 16px;
    }
    .subscription-section-head h2 {
      margin: 0;
      color: var(--heading);
      font-size: 24px;
    }
    .subscription-feature-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }
    .subscription-feature-grid article {
      display: grid;
      gap: 9px;
      min-width: 0;
      padding: 14px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--bg);
    }
    .subscription-feature-grid span {
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
      line-height: 1.4;
    }
    .subscription-feature-grid b {
      color: var(--heading);
      font-size: 16px;
      line-height: 1.3;
    }
    @media (max-width: 860px) {
      .subscription-main {
        padding: 18px 12px 76px;
      }
      .subscription-hero,
      .subscription-gate,
      .subscription-grid {
        grid-template-columns: 1fr;
      }
      .subscription-hero {
        display: grid;
        padding: 22px;
      }
      .subscription-hero .btn {
        width: 100%;
      }
      .subscription-grid,
      .subscription-feature-grid {
        grid-template-columns: 1fr;
      }
      .subscription-status {
        grid-template-columns: 1fr;
      }
      .subscription-price b {
        font-size: 44px;
      }
    }
  </style>
</BaseLayout>
