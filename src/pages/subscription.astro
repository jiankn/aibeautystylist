  signInBody: string;
  signIn: string;
  currentPlan: string;
  quotaTitle: string;
  quotaDesc: string;
  remaining: string;
  nextRefresh: string;
  renewsOn: string;
  activeUntil: string;
  status: string;
  statusLabels: Record<string, string>;
  savedLimit: string;
  price: string;
  priceUnit: string;
  actionsTitle: string;
  manage: string;
  upgrade: string;
  upgradePremium: string;
  comparePlans: string;
  support: string;
  included: string;
  featureQuota: string;
  featureSaved: string;
  featureHd: string;
  featurePriority: string;
  featureHistory: string;
  featureLibrary: string;
  includedYes: string;
  includedNo: string;
  planNotes: Record<string, string>;
