        var(--page-surface);
    }
    .subscription-shell {
      display: grid;
      gap: 18px;
      width: min(1120px, 100%);
      margin: 0 auto;
    }
    .subscription-hero {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 18px;
      padding: 28px;
    }
    .subscription-hero h1 {
      margin: 0;
      color: var(--heading);
      font-family: var(--font-display);
