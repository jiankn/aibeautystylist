const copy = copyByLocale[locale] ?? enCopy;
const planMeta = Object.fromEntries(
  Object.values(PLAN_DEFINITIONS).map((plan) => [
    plan.code,
    {
      title: plan.title,
      monthlyQuota: plan.monthlyQuota,
      savedLookLimit: plan.savedLookLimit,
      monthlyPriceUsd: plan.monthlyPriceUsd,
      features: plan.features,
    },
  ]),
);
---

<BaseLayout
  title={copy.title}
  description={copy.description}
  bodyClass="subscription-body"
  robots="noindex,follow"
>
  <SiteHeader
    active="dashboard"
    mobileMenuSection={accountMobileMenu}
    mobileSmartHide
    mobileHidden
  />
  <MobileAppTopBar title={copy.mobileTitle} />
  <main class="subscription-main" data-subscription>
    <div class="subscription-shell">
      <section class="subscription-hero panel">
        <div>
          <p class="section-kicker">{copy.eyebrow}</p>
          <h1>{copy.heading}</h1>
          <p>{copy.subtitle}</p>
        </div>
        <a class="btn btn-outline" href={hrefs.dashboard}
          >{accountCopy.myData}</a
        >
      </section>

      <section class="subscription-loading panel" data-subscription-loading>
        {copy.loading}
      </section>

      <section class="subscription-gate panel" data-auth-gate hidden>
        <AppIconBadge icon="membership" tone="gold" />
        <div>
          <h2>{copy.signInTitle}</h2>
          <p>{copy.signInBody}</p>
        </div>
        <a class="btn btn-primary" href={hrefs.login}>{copy.signIn}</a>
      </section>

      <div class="subscription-content" data-subscription-content hidden>
        <section class="subscription-grid">
          <article
            class="subscription-plan panel"
            data-plan-card
            data-plan="free"
          >
            <div class="subscription-plan-head">
              <div>
                <p class="section-kicker">{copy.currentPlan}</p>
                <h2 data-plan-title>--</h2>
              </div>
              <span class="subscription-plan-chip" data-plan-chip>--</span>
            </div>
            <p class="subscription-plan-note" data-plan-note></p>
            <div class="subscription-price">
              <span>$</span><b data-plan-price>--</b><small
                >{copy.priceUnit}</small
              >
            </div>
            <div class="subscription-meter-block">
              <div>
                <span>{copy.quotaTitle}</span>
                <b data-quota-value>--</b>
              </div>
              <div class="meter"><i data-quota-meter style="width:0%"></i></div>
              <small data-quota-refresh>--</small>
            </div>
          </article>

          <article class="subscription-actions panel">
            <p class="section-kicker">{copy.actionsTitle}</p>
            <div class="subscription-action-list">
              <button
                class="btn btn-primary"
                type="button"
                data-manage-billing
                hidden
              >
                {copy.manage}
              </button>
              <a class="btn btn-primary" href={hrefs.pricing} data-upgrade-plan>
                {copy.upgrade}
              </a>
              <a class="btn btn-outline" href={hrefs.pricing}
                >{copy.comparePlans}</a
              >
              <a class="btn btn-outline" href="#credit-packs">
                {t("creditPacks", "buy")}
              </a>
              <a class="btn btn-outline-rose" href={hrefs.support}
                >{copy.support}</a
              >
            </div>
            <dl class="subscription-status">
              <div>
                <dt>{copy.status}</dt>
                <dd data-subscription-status>--</dd>
              </div>
              <div>
                <dt>{copy.savedLimit}</dt>
                <dd data-saved-limit>--</dd>
              </div>
            </dl>
            <p
              class="subscription-message"
              data-subscription-message
              role="status"
            >
            </p>
          </article>
        </section>

        <section class="subscription-benefits panel">
          <div class="subscription-section-head">
            <p class="section-kicker">{copy.included}</p>
            <h2 data-included-title>--</h2>
          </div>
          <div class="subscription-feature-grid">
            <article>
              <AppIconBadge icon="tryon" tone="teal" />
              <span>{copy.featureQuota}</span>
              <b data-feature-quota>--</b>
            </article>
            <article>
              <AppIconBadge icon="saved" tone="rose" />
              <span>{copy.featureSaved}</span>
              <b data-feature-saved>--</b>
            </article>
            <article>
              <AppIconBadge icon="billing" tone="gold" />
              <span>{copy.featureHd}</span>
              <b data-feature-hd>--</b>
            </article>
            <article>
              <AppIconBadge icon="membership" tone="gold" />
              <span>{copy.featurePriority}</span>
              <b data-feature-priority>--</b>
            </article>
            <article>
              <AppIconBadge icon="history" tone="navy" />
              <span>{copy.featureHistory}</span>
              <b data-feature-history>--</b>
            </article>
            <article>
              <AppIconBadge icon="discover" tone="teal" />
              <span>{copy.featureLibrary}</span>
              <b data-feature-library>--</b>
            </article>
          </div>
        </section>
        <CreditPackPanel returnTo={`${subscriptionHref}#credit-packs`} />
      </div>
    </div>
  </main>
  {isLoggedIn && <MobileBottomNav active="account" />}

  <script is:inline define:vars={{ copy, planMeta, hrefs }}>
    (() => {
      const root = document.querySelector("[data-subscription]");
      if (!root) return;
      const query = (selector) => root.querySelector(selector);
      const setText = (selector, value) => {
        const node = query(selector);
        if (node) node.textContent = value;
      };
      const normalizePlan = (plan) =>
        plan === "premium" ? "premium" : plan === "pro" ? "pro" : "free";
      const formatDate = (value) => {
        if (!value) return "--";
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return "--";
        return new Intl.DateTimeFormat(
          document.documentElement.lang || undefined,
          { year: "numeric", month: "short", day: "numeric" },
        ).format(date);
      };
      const formatTemplate = (template, values) =>
        Object.entries(values).reduce(
          (text, [key, value]) => text.replace(`{${key}}`, value),
          template,
        );
      const yesNo = (enabled) => (enabled ? copy.includedYes : copy.includedNo);

      function showState(kind) {
        query("[data-subscription-loading]")?.toggleAttribute(
          "hidden",
          kind !== "loading",
        );
        query("[data-auth-gate]")?.toggleAttribute("hidden", kind !== "gate");
        query("[data-subscription-content]")?.toggleAttribute(
          "hidden",
          kind !== "content",
        );
      }

      function renderSubscription(data) {
        const plan = normalizePlan(data?.plan);
        const meta = planMeta[plan] || planMeta.free;
        const quota = data?.quota || {};
        const subscription = data?.subscription;
        const remaining = Number(quota.remaining ?? 0);
        const total = Number(quota.total ?? meta.monthlyQuota ?? 0);
        const remainingPercent = total
          ? Math.max(0, Math.min(100, (remaining / total) * 100))
          : 0;
        const statusKey = subscription?.status || "none";
        const statusLabel = copy.statusLabels?.[statusKey] || statusKey;
        const planCard = query("[data-plan-card]");
        if (planCard) planCard.dataset.plan = plan;

        setText("[data-plan-title]", meta.title);
        setText("[data-plan-chip]", meta.title);
        setText("[data-plan-note]", copy.planNotes?.[plan] || "");
        setText("[data-plan-price]", String(meta.monthlyPriceUsd));
        setText(
          "[data-quota-value]",
          formatTemplate(copy.remaining, { remaining, total }),
        );
        const meter = query("[data-quota-meter]");
        if (meter) meter.style.width = `${remainingPercent}%`;
        const dateText = subscription?.currentPeriodEnd
          ? formatTemplate(
              statusKey === "canceled" ? copy.activeUntil : copy.renewsOn,
              { date: formatDate(subscription.currentPeriodEnd) },
            )
          : formatTemplate(copy.nextRefresh, {
              date: formatDate(quota.nextRefreshAt),
            });
        setText("[data-quota-refresh]", dateText);
        setText("[data-subscription-status]", statusLabel);
        setText("[data-saved-limit]", String(meta.savedLookLimit));
        setText("[data-included-title]", meta.title);
        setText("[data-feature-quota]", String(meta.monthlyQuota));
        setText("[data-feature-saved]", String(meta.savedLookLimit));
        setText("[data-feature-hd]", yesNo(meta.features?.hdDownload));
        setText("[data-feature-priority]", yesNo(meta.features?.priorityQueue));
        setText(
          "[data-feature-history]",
          yesNo(meta.features?.longTermHistory),
        );
        setText(
          "[data-feature-library]",
          yesNo(meta.features?.fullLookLibrary),
        );

        const manage = query("[data-manage-billing]");
        const upgrade = query("[data-upgrade-plan]");
        manage?.toggleAttribute("hidden", plan === "free");
        if (upgrade) {
          upgrade.toggleAttribute("hidden", plan === "premium");
          upgrade.textContent =
            plan === "pro" ? copy.upgradePremium : copy.upgrade;
        }
      }

      async function loadSubscription() {
        showState("loading");
        try {
          const res = await fetch("/api/session");
          const body = await res.json().catch(() => null);
          if (!body?.ok) throw new Error(copy.loadFailed);
          if (body.data?.user?.kind !== "account") {
            showState("gate");
            return;
          }
          renderSubscription(body.data);
          showState("content");
          if (window.location.hash === "#credit-packs") {
            window.requestAnimationFrame(() => {
              const panel = document.getElementById("credit-packs");
              panel?.scrollIntoView({ behavior: "smooth", block: "start" });
              panel?.focus({ preventScroll: true });
            });
          }
        } catch (error) {
          showState("loading");
          const loading = query("[data-subscription-loading]");
          if (loading) loading.textContent = error?.message || copy.loadFailed;
        }
      }

      query("[data-manage-billing]")?.addEventListener("click", async () => {
        const button = query("[data-manage-billing]");
        const message = query("[data-subscription-message]");
        if (button) button.disabled = true;
        if (message) message.textContent = "";
        try {
          const res = await fetch("/api/billing/portal", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ returnPath: window.location.pathname }),
          });
          const body = await res.json().catch(() => null);
          if (body?.ok && body.data?.url) {
            window.location.href = body.data.url;
            return;
          }
          throw new Error(body?.error?.message || copy.portalFailed);
        } catch (error) {
          if (message)
            message.textContent = error?.message || copy.portalFailed;
        } finally {
          if (button) button.disabled = false;
        }
      });

      loadSubscription();
    })();
  </script>

  <style>
    .subscription-main {
      min-height: calc(100vh - 64px);
      padding: 32px 16px 64px;
      background:
        linear-gradient(
          180deg,
          color-mix(in srgb, var(--rose-soft) 40%, transparent),
          transparent 340px
