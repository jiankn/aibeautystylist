{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aibeautystylist",
  "account_id": "9679290d9ad455c63c2002a90d381bf7",
  "compatibility_date": "2026-06-07",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist/client"
  },
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "SESSION",
      "id": "85c0b835a20847719af0256e50d7f726"
    }
  ],
  // Astro adapter 在构建阶段使用此文件（不含 main）。
  // 部署配置见 wrangler.jsonc。
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ai-beauty-stylist-db",
      "database_id": "b4ca2fa7-49ea-410e-b802-bb710975d01a"
    }
  ],
  "r2_buckets": [
    {
      "binding": "USER_UPLOADS",
      "bucket_name": "ai-beauty-stylist-user-uploads"
    }
  ],
  "vars": {
    "APP_ENV": "production",
    "APP_PUBLIC_URL": "https://aibeautystylist.com",
    "AI_PROVIDER": "gemini",
    "UPLOAD_PROVIDER": "r2",
    "TRYON_PROVIDER": "gemini",
    "IMAGE_PROVIDER": "gemini",
    "GEMINI_MODEL": "gemini-2.5-flash",
    "GEMINI_MODEL_FREE": "gemini-2.5-flash-lite",
    "GEMINI_IMAGE_MODEL": "gemini-2.5-flash-image",
    "GEMINI_TIMEOUT_MS": "120000",
    "GEMINI_IMAGE_TIMEOUT_MS": "75000",
    "GEMINI_THINKING_LEVEL": "none",
    "EVOLINK_IMAGE_MODEL": "wan2.5-image-to-image",
    "EVOLINK_IMAGE_SIZE": "1280x1280",
    "EVOLINK_IMAGE_QUALITY": "low",
    "EVOLINK_IMAGE_TIMEOUT_MS": "75000",
    "SUPPORT_EMAIL": "support@aibeautystylist.com"
  }
}
